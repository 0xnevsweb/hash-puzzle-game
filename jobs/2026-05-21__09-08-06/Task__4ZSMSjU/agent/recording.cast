[94.66443, "i", "cat > /app/src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { PUZZLES, PUZZLE_ORDER } from './data/puzzles.js';\nimport {\n  canonicalKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n} from './utils/hashiLogic.js';\n\nconst GRID = 40;\nconst W = 800;\nconst H = 600;\n\nfunction islandAtPixel(island) {\n  return { px: island.x * GRID, py: island.y * GRID };\n}\n\nfunction getIslandById(islands, id) {\n  return islands.find((i) => i.id === id) || null;\n}\n\nfunction getNearestIslandInDirection(islands, fromIsland, dir) {\n  // Only move to visible islands in same row/col in that direction; nearest by distance.\n  if (!fromIsland) return null;\n  let best = null;\n  let bestDist = Infinity;\n  for (const isl of islands) {\n    if (isl.id === fromIsland.id) continue;\n    if (dir === 'left' && isl.y === fromIsland.y && isl.x < fromIsland.x) {\n      const d = fromIsland.x - isl.x;\n      if (d < bestDist) { bestDist = d; best = isl; }\n    }\n    if (dir === 'right' && isl.y === from"]
[94.664574, "i", "Island.y && isl.x > fromIsland.x) {\n      const d = isl.x - fromIsland.x;\n      if (d < bestDist) { bestDist = d; best = isl; }\n    }\n    if (dir === 'up' && isl.x === fromIsland.x && isl.y < fromIsland.y) {\n      const d = fromIsland.y - isl.y;\n      if (d < bestDist) { bestDist = d; best = isl; }\n    }\n    if (dir === 'down' && isl.x === fromIsland.x && isl.y > fromIsland.y) {\n      const d = isl.y - fromIsland.y;\n      if (d < bestDist) { bestDist = d; best = isl; }\n    }\n  }\n  return best;\n}\n\nfunction bridgeLinesForPair(from, to, count) {\n  // returns array of line endpoints in pixel coords, with slight offset for double bridges\n  const { px: x1, py: y1 } = islandAtPixel(from);\n  const { px: x2, py: y2 } = islandAtPixel(to);\n\n  const isH = y1 === y2;\n  const isV = x1 === x2;\n  const offset = 6;\n\n  if (count === 1) {\n    return [{ x1, y1, x2, y2 }];\n  }\n  if (count === 2) {\n    if (isH) {\n      return [\n        { x1, y1: y1 - offset, x2, y2: y2 - offset },\n        { x1, y1: y1 + offset, x2, y2: y2 + offset"]
[94.664631, "i", " },\n      ];\n    }\n    if (isV) {\n      return [\n        { x1: x1 - offset, y1, x2: x2 - offset, y2 },\n        { x1: x1 + offset, y1, x2: x2 + offset, y2 },\n      ];\n    }\n  }\n  return [];\n}\n\nexport default function App() {\n  const [puzzleName, setPuzzleName] = useState('Easy');\n  const puzzle = PUZZLES[puzzleName];\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [error, setError] = useState(null);\n\n  // keyboard cursor: keep an island id focused; also support a \"keyboard selection\" mode.\n  const [cursorId, setCursorId] = useState(islands[0]?.id ?? 0);\n  const [kbdFromId, setKbdFromId] = useState(null);\n\n  const rootRef = useRef(null);\n\n  useEffect(() => {\n    // On puzzle change: reset everything per spec\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n    setKbdFromId(null);\n    setCursorId(PUZZLES[puzzleName].islands[0]?.id ?? 0);\n  }, [puzzleName]);\n\n  const counts = useMemo("]
[94.664681, "i", "() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function applyBridgeDelta(from, to, delta) {\n    const res = canAddBridge(islands, bridges, from, to, delta);\n    if (!res.valid) {\n      setError(res.error);\n      return false;\n    }\n    setError(null);\n\n    const key = canonicalKey(from, to);\n    const existing = bridges.get(key) ?? 0;\n    const next = Math.max(0, Math.min(2, existing + delta));\n\n    const nextMap = new Map(bridges);\n    if (next === 0) nextMap.delete(key);\n    else nextMap.set(key, next);\n    setBridges(nextMap);\n    return true;\n  }\n\n  function cycleBridge(from, to) {\n    const key = canonicalKey(from, to);\n    const existing = bridges.get(key) ?? 0;\n    const target = (existing + 1) % 3; // 0->1->2->0\n    const delta = target - existing;\n    if (delta === 0) {\n      setError(null);\n      return true;\n    }\n    return applyBridgeDelta(from, to, delta);\n  }\n\n  function toggleBridge(from, to"]
[94.664731, "i", ") {\n    const key = canonicalKey(from, to);\n    const existing = bridges.get(key) ?? 0;\n    const target = existing === 0 ? 1 : 0;\n    const delta = target - existing;\n    if (delta === 0) {\n      setError(null);\n      return true;\n    }\n    return applyBridgeDelta(from, to, delta);\n  }\n\n  function onIslandClick(island, e) {\n    // Ctrl+click treated like right-click toggle (more accessible)\n    if (e.ctrlKey) {\n      if (selectedId !== null && selectedId !== island.id) {\n        const from = getIslandById(islands, selectedId);\n        const ok = toggleBridge(from, island);\n        if (ok) setSelectedId(null);\n      } else {\n        setSelectedId(island.id);\n        setError(null);\n      }\n      return;\n    }\n\n    if (selectedId === null) {\n      setSelectedId(island.id);\n      setError(null);\n      return;\n    }\n    if (selectedId === island.id) {\n      // clicking same island just keeps selection\n      setSelectedId(island.id);\n      setError(null);\n      return;\n    }\n\n    const from = getIslandById(islan"]
[94.66497, "i", "ds, selectedId);\n    const ok = cycleBridge(from, island);\n    if (ok) setSelectedId(null);\n  }\n\n  function onIslandContextMenu(island, e) {\n    e.preventDefault();\n    if (selectedId === null) {\n      setSelectedId(island.id);\n      setError(null);\n      return;\n    }\n    if (selectedId === island.id) {\n      setSelectedId(island.id);\n      setError(null);\n      return;\n    }\n    const from = getIslandById(islands, selectedId);\n    const ok = toggleBridge(from, island);\n    if (ok) setSelectedId(null);\n  }\n\n  function reset() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setKbdFromId(null);\n    setError(null);\n  }\n\n  useEffect(() => {\n    const el = rootRef.current;\n    if (!el) return;\n    el.tabIndex = 0;\n\n    function onKeyDown(e) {\n      const key = e.key;\n      if (key === 'Escape') {\n        setSelectedId(null);\n        setKbdFromId(null);\n        setError(null);\n        return;\n      }\n\n      const cursor = getIslandById(islands, cursorId) || islands[0];\n      if (!cursor) return;\n\n      i"]
[94.665267, "i", "f (key === 'ArrowLeft' || key === 'ArrowRight' || key === 'ArrowUp' || key === 'ArrowDown') {\n        e.preventDefault();\n        const dir = key === 'ArrowLeft' ? 'left' : key === 'ArrowRight' ? 'right' : key === 'ArrowUp' ? 'up' : 'down';\n        const nxt = getNearestIslandInDirection(islands, cursor, dir);\n        if (nxt) {\n          setCursorId(nxt.id);\n          setError(null);\n        }\n        return;\n      }\n\n      if (key === 'Enter') {\n        e.preventDefault();\n        if (kbdFromId === null) {\n          setKbdFromId(cursor.id);\n          setSelectedId(cursor.id);\n          setError(null);\n          return;\n        }\n        if (kbdFromId === cursor.id) {\n          setKbdFromId(cursor.id);\n          setSelectedId(cursor.id);\n          setError(null);\n          return;\n        }\n        const from = getIslandById(islands, kbdFromId);\n        const ok = cycleBridge(from, cursor);\n        if (ok) {\n          setKbdFromId(null);\n          setSelectedId(null);\n        }\n        return;\n      }\n    }\n"]
