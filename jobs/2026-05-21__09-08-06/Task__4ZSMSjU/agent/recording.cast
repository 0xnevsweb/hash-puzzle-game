[94.666982, "i", "\n    el.addEventListener('keydown', onKeyDown);\n    return () => el.removeEventListener('keydown', onKeyDown);\n  }, [islands, cursorId, kbdFromId, bridges]);\n\n  const bridgeRender = [];\n  for (const [key, n] of bridges.entries()) {\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const from = islands.find((i) => i.x === x1 && i.y === y1);\n    const to = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!from || !to) continue;\n    const lines = bridgeLinesForPair(from, to, n);\n    for (let idx = 0; idx < lines.length; idx++) {\n      const ln = lines[idx];\n      bridgeRender.push(\n        <line\n          key={`${key}-${idx}`}\n          x1={ln.x1}\n          y1={ln.y1}\n          x2={ln.x2}\n          y2={ln.y2}\n          stroke=\"#00ff66\"\n          strokeWidth={4}\n          strokeLinecap=\"round\"\n          opacity={0.9}\n        />\n      );\n    }\n  }\n\n  const cursorIsland = getIslandById(islands, cursorId) || islands[0];\n  const cursorPx = cursorIsland ? islandAtPixel(cursorIsland) : { px: 0, py: 0 }"]
[94.667181, "i", ";\n\n  return (\n    <div className=\"app\" ref={rootRef}>\n      <div className=\"hud\">\n        <label>\n          Puzzle:{' '}\n          <select\n            value={puzzleName}\n            onChange={(e) => setPuzzleName(e.target.value)}\n          >\n            {PUZZLE_ORDER.map((name) => (\n              <option key={name} value={name}>{name}</option>\n            ))}\n          </select>\n        </label>\n        <button onClick={reset}>Reset</button>\n      </div>\n\n      {error ? <div className=\"error-message\">{error}</div> : null}\n      {solved ? <div className=\"victory-banner\">SOLVED!</div> : null}\n\n      <svg className=\"board\" width={W} height={H} viewBox={`0 0 ${W} ${H}`}>\n        {/* bridges */}\n        {bridgeRender}\n\n        {/* cursor: rect (NOT a circle) */}\n        {cursorIsland ? (\n          <rect\n            x={cursorPx.px - 18}\n            y={cursorPx.py - 18}\n            width={36}\n            height={36}\n            fill=\"none\"\n            stroke={kbdFromId !== null ? \"#ffffff\" : \"#00ff66\"}\n            s"]
[94.669306, "i", "trokeWidth={2}\n            strokeDasharray={kbdFromId !== null ? \"\" : \"4 3\"}\n            opacity={0.95}\n          />\n        ) : null}\n\n        {/* islands */}\n        {islands.map((isl) => {\n          const { px, py } = islandAtPixel(isl);\n          const selected = selectedId === isl.id;\n          const curCount = counts.get(isl.id) ?? 0;\n          const satisfied = curCount === isl.value;\n          return (\n            <g key={isl.id}>\n              <circle\n                cx={px}\n                cy={py}\n                r={16}\n                fill=\"#000\"\n                stroke={selected ? \"#ffffff\" : satisfied ? \"#00ff66\" : \"#00cc55\"}\n                strokeWidth={selected ? 3 : 2}\n                onClick={(e) => onIslandClick(isl, e)}\n                onContextMenu={(e) => onIslandContextMenu(isl, e)}\n                style={{ cursor: 'pointer' }}\n              />\n              <text\n                x={px}\n                y={py + 6}\n                textAnchor=\"middle\"\n                fontSize={16}\n          "]
