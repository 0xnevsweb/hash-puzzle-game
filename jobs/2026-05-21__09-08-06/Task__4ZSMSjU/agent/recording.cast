[94.340994, "i", "urrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) return { valid: false, error: ERR_EXCEED };\n\n  // crossing only matters if we're adding (delta>0)\n  if (delta > 0 && bridgesWouldCross(bridges, from, to)) return { valid: false, error: ERR_CROSS };\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n  const adj = new Map(islands.map((i) => [i.id, []]));\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const aId = posToId.get(`${x1},${y1}`);\n    const bId = posToId.get(`${x2},${y2}`);\n    if (aId === undefined || bId === undefined) continue;\n    adj.get(aId).push(bId);\n    adj.get(bId).push(aId);\n  }\n\n  const startId = islands[0].id;\n  const seen "]
[94.34109, "i", "= new Set([startId]);\n  const stack = [startId];\n  while (stack.length) {\n    const cur = stack.pop();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        stack.push(nxt);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // no crossings\n  for (const [keyA, nA] of bridges.entries()) {\n    if (!nA) continue;\n    const a = parseKey(keyA);\n    for (const [keyB, nB] of bridges.entries()) {\n      if (!nB || keyB === keyA) continue;\n      const b = parseKey(keyB);\n      const sharesEndpoint =\n        (a.x1 === b.x1 && a.y1 === b.y1) ||\n        (a.x1 === b.x2 && a.y1 === b.y2) ||\n        (a.x2 === b.x1 && a.y2 === b.y1) ||\n        (a.x2 === b.x2 && a.y2 === b.y2);\n      if (sharesEndpoint) continue;\n      if (segmentsCross(a, b)) return false;\n    }\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n  "]
