    const ax = x1 * GRID;
    const ay = y1 * GRID;
    const bx = x2 * GRID;
    const by = y2 * GRID;

    const isH = ay === by;
    const offset = 6;

    if (n === 1) {
      bridgeLines.push(
        <line
          key={`b-${k}-1`}
          x1={ax}
          y1={ay}
          x2={bx}
          y2={by}
          stroke="#00ff66"
          strokeWidth={4}
          strokeLinecap="round"
        />
      );
    } else if (n === 2) {
      const dx = isH ? 0 : offset;
      const dy = isH ? offset : 0;
