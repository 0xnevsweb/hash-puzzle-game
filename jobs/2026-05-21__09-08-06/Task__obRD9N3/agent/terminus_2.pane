[?2004l[?2004hroot@90933ddfea33:/app# cat > src/utils/hashiLogic.js <<'EOF'
[?2004l[?2004h> const ERR_NON_ADJ = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> const ERR_MAX_PAIR = 'Max 2 bridges per pair';
[?2004l[?2004h> const ERR_EXCEED = 'Island would exceed its number';
[?2004l[?2004h> const ERR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> function keyFor(a, b) {
[?2004l[?2004h>   const p1 = { x: a.x, y: a.y };
[?2004l[?2004h>   const p2 = { x: b.x, y: b.y };
[?2004l[?2004h>   const first = (p1.x < p2.x) || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;
[?2004l[?2004h>   const second = first === p1 ? p2 : p1;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function parseKey(k) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAxisAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(v, a, b) {
[?2004l[?2004h>   return v > Math.min(a, b) && v < Math.max(a, b);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function hasIslandBetween(islands, a, b) {
[?2004l[?2004h>   if (a.x === b.x) {
[?2004l[?2004h>     return islands.some((i) => i.id !== a.id && i.id !== b.id && i.x === a.x && between(i.y, a.y, b.y));
[?2004l[?2004h>   }
[?2004l[?2004h>   if (a.y === b.y) {
[?2004l[?2004h>     return islands.some((i) => i.id !== a.id && i.id !== b.id && i.y === a.y && between(i.x, a.x, b.x));
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(segA, segB) {
[?2004l[?2004h>   const a = segA;
[?2004l[?2004h>   const b = segB;
[?2004l[?2004h>   const aVert = a.x1 === a.x2;
[?2004l[?2004h>   const bVert = b.x1 === b.x2;
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const v = aVert ? a : b;
[?2004l[?2004h>   const h = aVert ? b : a;
[?2004l[?2004h> 
[?2004l[?2004h>   const ix = v.x1;
[?2004l[?2004h>   const iy = h.y1;
[?2004l[?2004h> 
[?2004l[?2004h>   const vMinY = Math.min(v.y1, v.y2);
[?2004l[?2004h>   const vMaxY = Math.max(v.y1, v.y2);
[?2004l[?2004h>   const hMinX = Math.min(h.x1, h.x2);
[?2004l[?2004h>   const hMaxX = Math.max(h.x1, h.x2);
[?2004l[?2004h> 
[?2004l[?2004h>   const intersects = ix > hMinX && ix < hMaxX && iy > vMinY && iy < vMaxY;
[?2004l[?2004h>   return intersects;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(k);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function anyCrossing(bridges) {
[?2004l[?2004h>   const segs = [];
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(k);
[?2004l[?2004h>     segs.push({ x1, y1, x2, y2 });
[?2004l[?2004h>   }
[?2004l[?2004h>   for (let i = 0; i < segs.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < segs.length; j++) {
[?2004l[?2004h>       const a = segs[i];
[?2004l[?2004h>       const b = segs[j];
[?2004l[?2004h>       const shareEndpoint =
[?2004l[?2004h>         (a.x1 === b.x1 && a.y1 === b.y1) ||
[?2004l[?2004h>         (a.x1 === b.x2 && a.y1 === b.y2) ||
[?2004l[?2004h>         (a.x2 === b.x1 && a.y2 === b.y1) ||
[?2004l[?2004h>         (a.x2 === b.x2 && a.y2 === b.y2);
[?2004l[?2004h>       if (shareEndpoint) continue;
[?2004l[?2004h>       if (segmentsCross(a, b)) return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   if (!isAxisAligned(from, to)) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   if (hasIslandBetween(islands, from, to)) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h> 
[?2004l[?2004h>   const k = keyFor(from, to);
[?2004l[?2004h>   const current = bridges.get(k) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h>   if (next < 0) return { valid: false, error: ERR_MAX_PAIR };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) ?? 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) ?? 0;
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const tmp = new Map(bridges);
[?2004l[?2004h>   if (next === 0) tmp.delete(k);
[?2004l[?2004h>   else tmp.set(k, next);
[?2004l[?2004h>   if (anyCrossing(tmp)) return { valid: false, error: ERR_CROSS };
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const byCoord = new Map();
[?2004l[?2004h>   for (const i of islands) byCoord.set(`${i.x},${i.y}`, i);
[?2004l[?2004h> 
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const i of islands) adj.set(i.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(k);
[?2004l[?2004h>     const a = byCoord.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byCoord.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const startId = islands[0].id;
[?2004l[?2004h>   const seen = new Set([startId]);
[?2004l[?2004h>   const stack = [startId];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     for (const nb of adj.get(cur) ?? []) {
[?2004l[?2004h>       if (!seen.has(nb)) {
[?2004l[?2004h>         seen.add(nb);
[?2004l[?2004h>         stack.push(nb);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   if (anyCrossing(bridges)) return false;
[?2004l[?2004h>   if (!checkConnectivity(islands, bridges)) return false;
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export const ERROR_TEXTS = {
[?2004l[?2004h>   ERR_NON_ADJ,
[?2004l[?2004h>   ERR_MAX_PAIR,
[?2004l[?2004h>   ERR_EXCEED,
[?2004l[?2004h>   ERR_CROSS
[?2004l[?2004h> };
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   return keyFor(from, to);
[?2004l[?2004h> }
