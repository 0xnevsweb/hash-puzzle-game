[98.482684, "i", "cat > src/styles.css <<'EOF'\n:root {\n  --bg: #000;\n  --fg: #00ff66;\n  --fg-dim: rgba(0, 255, 102, 0.7);\n  --err: #ff4d4d;\n}\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  background: var(--bg);\n  color: var(--fg);\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n}\n\n#root {\n  margin: 0;\n  padding: 0;\n}\n\n.app {\n  position: relative;\n}\n\n.hud {\n  position: absolute;\n  top: 0;\n  left: 0;\n  padding: 8px;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  z-index: 2;\n  background: rgba(0,0,0,0.75);\n  border-right: 1px solid var(--fg-dim);\n  border-bottom: 1px solid var(--fg-dim);\n}\n\nlabel {\n  display: inline-flex;\n  gap: 6px;\n  align-items: center;\n}\n\nselect, button {\n  background: #000;\n  color: var(--fg);\n  border: 1px solid var(--fg-dim);\n  font: inherit;\n  padding: 4px 8px;\n}\n\nselect:focus, button:focus {\n  outline: 2px solid var(--fg);\n  outline-offset: 2px;\n}\n\n.error-message {\n  position: absolute;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  color"]
