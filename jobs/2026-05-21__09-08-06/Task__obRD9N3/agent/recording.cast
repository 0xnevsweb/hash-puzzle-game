[98.030325, "i", "0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nfunction anyCrossing(bridges) {\n  const segs = [];\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(k);\n    segs.push({ x1, y1, x2, y2 });\n  }\n  for (let i = 0; i < segs.length; i++) {\n    for (let j = i + 1; j < segs.length; j++) {\n      const a = segs[i];\n      const b = segs[j];\n      const shareEndpoint =\n        (a.x1 === b.x1 && a.y1 === b.y1) ||\n        (a.x1 === b.x2 && a.y1 === b.y2) ||\n        (a.x2 === b.x1 && a.y2 === b.y1) ||\n        (a.x2 === b.x2 && a.y2 === b.y2);\n      if (shareEndpoint) continue;\n      if (segmentsCross(a, b)) return true;\n    }\n  }\n  return false;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to) return { valid: false, error: ERR_NON_ADJ };\n  if (from.id === to.id) return { valid: false, error: ERR_NON_ADJ };\n  if (!isAxisAligned(from, to)) return { valid: false, error: ERR_NON_ADJ };\n  if (hasIsl"]
[98.030414, "i", "andBetween(islands, from, to)) return { valid: false, error: ERR_NON_ADJ };\n\n  const k = keyFor(from, to);\n  const current = bridges.get(k) ?? 0;\n  const next = current + delta;\n  if (next < 0) return { valid: false, error: ERR_MAX_PAIR };\n  if (next > 2) return { valid: false, error: ERR_MAX_PAIR };\n\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) ?? 0;\n  const toCount = counts.get(to.id) ?? 0;\n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: ERR_EXCEED };\n  }\n\n  const tmp = new Map(bridges);\n  if (next === 0) tmp.delete(k);\n  else tmp.set(k, next);\n  if (anyCrossing(tmp)) return { valid: false, error: ERR_CROSS };\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  const byCoord = new Map();\n  for (const i of islands) byCoord.set(`${i.x},${i.y}`, i);\n\n  const adj = new Map();\n  for (const i of islands) adj.set(i.id, ["]
