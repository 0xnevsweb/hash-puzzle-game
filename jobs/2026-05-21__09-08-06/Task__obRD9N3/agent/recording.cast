[98.029443, "i", "cat > src/utils/hashiLogic.js <<'EOF'\nconst ERR_NON_ADJ = 'Cannot connect non-adjacent islands';\nconst ERR_MAX_PAIR = 'Max 2 bridges per pair';\nconst ERR_EXCEED = 'Island would exceed its number';\nconst ERR_CROSS = 'Bridges would cross';\n\nfunction keyFor(a, b) {\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const first = (p1.x < p2.x) || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\n  const second = first === p1 ? p2 : p1;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction parseKey(k) {\n  const [x1, y1, x2, y2] = k.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nfunction isAxisAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\nfunction between(v, a, b) {\n  return v > Math.min(a, b) && v < Math.max(a, b);\n}\n\nfunction hasIslandBetween(islands, a, b) {\n  if (a.x === b.x) {\n    return islands.some((i) => i.id !== a.id && i.id !== b.id && i.x === a.x && between(i.y, a.y, b.y));\n  }\n  if (a.y === b.y) {\n    return islands.some((i) => i.id !== a.id && i.id !== b.id "]
