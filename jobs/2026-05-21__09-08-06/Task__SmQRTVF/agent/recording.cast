[65.102078, "i", "cat > src/styles.css <<'EOF'\n:root {\n  --bg: #000;\n  --fg: #00ff66;\n  --fg-dim: rgba(0, 255, 102, 0.75);\n  --error: #ff4d4d;\n}\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background: var(--bg);\n  color: var(--fg);\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n}\n\n#root {\n  margin: 0;\n  padding: 0;\n}\n\na, button, select {\n  font-family: inherit;\n}\n\n.controls {\n  position: absolute;\n  left: 0;\n  top: 0;\n  padding: 8px;\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  z-index: 2;\n  background: rgba(0,0,0,0.65);\n  border: 1px solid rgba(0,255,102,0.25);\n}\n\nbutton, select {\n  background: #000;\n  color: var(--fg);\n  border: 1px solid var(--fg-dim);\n  padding: 4px 8px;\n}\n\nbutton:hover, select:hover {\n  border-color: var(--fg);\n}\n\n.error-message {\n  position: absolute;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  color: var(--error);\n  z-index: 3;\n  background: rgba(0,0,0,0.65);\n  border: 1px solid rgba(255,77,77,0.35);"]
[65.102123, "i", "\n}\n\n.victory-banner {\n  position: absolute;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  z-index: 3;\n  background: rgba(0,0,0,0.65);\n  border: 1px solid rgba(0,255,102,0.35);\n  color: var(--fg);\n}\n\n.board {\n  position: absolute;\n  left: 0;\n  top: 0;\n}\nEOF\n"]
[65.104605, "o", "cat > src/styles.css <<'EOF'"]
