[65.564082, "i", "onst onV = iy > vYmin && iy < vYmax;\n  const onH = ix > hXmin && ix < hXmax;\n  return onV && onH;\n}\n\nexport function bridgesWouldCross(bridges, from, to) {\n  const a1 = { x: from.x, y: from.y };\n  const a2 = { x: to.x, y: to.y };\n\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    // shared endpoint is allowed; crossing only counts at interior.\n    const b1 = { x: x1, y: y1 };\n    const b2 = { x: x2, y: y2 };\n\n    // Skip same segment (same endpoints)\n    const same = (a1.x === b1.x && a1.y === b1.y && a2.x === b2.x && a2.y === b2.y) ||\n                 (a1.x === b2.x && a1.y === b2.y && a2.x === b1.x && a2.y === b1.y);\n    if (same) continue;\n\n    if (segmentCrosses(a1, a2, b1, b2)) return true;\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    cons"]
[65.564094, "i", "t { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = islands.find(i => i.x === x1 && i.y === y1);\n    const b = islands.find(i => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to) return { valid: false, error: ERROR_NON_ADJ };\n  if (from.id === to.id) return { valid: false, error: ERROR_NON_ADJ };\n  if (!areAdjacent(islands, from, to)) return { valid: false, error: ERROR_NON_ADJ };\n\n  const key = canonicalBridgeKey(from, to);\n  const existing = bridges.get(key) ?? 0;\n  const next = existing + delta;\n\n  if (next < 0) return { valid: true, error: null }; // removing is always ok\n  if (next > 2) return { valid: false, error: ERROR_MAX2 };\n\n  // crossing check only if we're increasing from 0->1 (or 1->2 doesn't change geometry)\n  if (existing === 0 && next > 0) {\n    if (bridgesWouldCross(bridg"]
[65.565662, "i", "es, from, to)) return { valid: false, error: ERROR_CROSS };\n  }\n\n  // island max check\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) return { valid: false, error: ERROR_EXCEED };\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = islands.find(i => i.x === x1 && i.y === y1);\n    const b = islands.find(i => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const q = [startId];\n  while (q.length) {\n    const cur = q."]
[65.565691, "i", "shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // counts satisfied\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n  // no crossing (should already be enforced, but required)\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const from = islands.find(i => i.x === x1 && i.y === y1);\n    const to = islands.find(i => i.x === x2 && i.y === y2);\n    if (!from || !to) continue;\n    // if it would cross with any other existing, fail\n    const temp = new Map(bridges);\n    // remove itself before testing\n    temp.set(key, 0);\n    if (bridgesWouldCross(temp, from, to)) return false;\n  }\n  // connected\n  return checkConnectivity(islands, bridges);\n}\n\nexport co"]
