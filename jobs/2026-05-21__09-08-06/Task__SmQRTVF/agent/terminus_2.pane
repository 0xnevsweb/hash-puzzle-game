[?2004l[?2004h> const ERROR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;
[?2004l[?2004h>   const second = first === a ? b : a;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseBridgeKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAxisAligned(from, to) {
[?2004l[?2004h>   return from.x === to.x || from.y === to.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(a, b, c) {
[?2004l[?2004h>   // c strictly between a and b
[?2004l[?2004h>   return (c > Math.min(a, b) && c < Math.max(a, b));
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!isAxisAligned(from, to)) return false;
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const x = from.x;
[?2004l[?2004h>     const y1 = from.y;
[?2004l[?2004h>     const y2 = to.y;
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.x === x && between(y1, y2, isl.y)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   // same y
[?2004l[?2004h>   const y = from.y;
[?2004l[?2004h>   const x1 = from.x;
[?2004l[?2004h>   const x2 = to.x;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>     if (isl.y === y && between(x1, x2, isl.x)) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentCrosses(a1, a2, b1, b2) {
[?2004l[?2004h>   // a: axis-aligned, b: axis-aligned. Only crossing if one vertical and one horizontal and intersection is interior to both.
[?2004l[?2004h>   const aVert = a1.x === a2.x;
[?2004l[?2004h>   const bVert = b1.x === b2.x;
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const v1 = aVert ? a1 : b1;
[?2004l[?2004h>   const v2 = aVert ? a2 : b2;
[?2004l[?2004h>   const h1 = aVert ? b1 : a1;
[?2004l[?2004h>   const h2 = aVert ? b2 : a2;
[?2004l[?2004h> 
[?2004l[?2004h>   const ix = v1.x;
[?2004l[?2004h>   const iy = h1.y;
[?2004l[?2004h> 
[?2004l[?2004h>   const vYmin = Math.min(v1.y, v2.y);
[?2004l[?2004h>   const vYmax = Math.max(v1.y, v2.y);
[?2004l[?2004h>   const hXmin = Math.min(h1.x, h2.x);
[?2004l[?2004h>   const hXmax = Math.max(h1.x, h2.x);
[?2004l[?2004h> 
[?2004l[?2004h>   const onV = iy > vYmin && iy < vYmax;
[?2004l[?2004h>   const onH = ix > hXmin && ix < hXmax;
[?2004l[?2004h>   return onV && onH;
