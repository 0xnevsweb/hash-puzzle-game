[?2004l[?2004h>     // Skip same segment (same endpoints)
[?2004l[?2004h>     const same = (a1.x === b1.x && a1.y === b1.y && a2.x === b2.x && a2.y === b2.y) ||
[?2004l[?2004h>                  (a1.x === b2.x && a1.y === b2.y && a2.x === b1.x && a2.y === b1.y);
[?2004l[?2004h>     if (same) continue;
[?2004l[?2004h> 
