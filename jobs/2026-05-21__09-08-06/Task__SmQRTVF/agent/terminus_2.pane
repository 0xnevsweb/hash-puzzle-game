[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesWouldCross(bridges, from, to) {
[?2004l[?2004h>   const a1 = { x: from.x, y: from.y };
[?2004l[?2004h>   const a2 = { x: to.x, y: to.y };
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     // shared endpoint is allowed; crossing only counts at interior.
[?2004l[?2004h>     const b1 = { x: x1, y: y1 };
[?2004l[?2004h>     const b2 = { x: x2, y: y2 };
