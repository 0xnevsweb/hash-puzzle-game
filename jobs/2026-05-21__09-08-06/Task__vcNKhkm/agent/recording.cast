[90.48649, "i", ")\n    if (ok) {\n      setSelectedId(to.id)\n      setCursorId(to.id)\n    }\n  }\n\n  function nearestInDirection(from, dx, dy) {\n    let best = null\n    for (const isl of islands) {\n      if (isl.id === from.id) continue\n      if (dx !== 0) {\n        if (isl.y !== from.y) continue\n        const dd = (isl.x - from.x) * dx\n        if (dd <= 0) continue\n        // must be adjacent in that direction (no island between)\n        if (!areAdjacent(islands, from, isl)) continue\n        if (best == null || dd < best.dd) best = { isl, dd }\n      } else {\n        if (isl.x !== from.x) continue\n        const dd = (isl.y - from.y) * dy\n        if (dd <= 0) continue\n        if (!areAdjacent(islands, from, isl)) continue\n        if (best == null || dd < best.dd) best = { isl, dd }\n      }\n    }\n    return best?.isl ?? null\n  }\n\n  useEffect(() => {\n    function onKeyDown(e) {\n      const activeTag = document.activeElement?.tagName?.toLowerCase()\n      if (activeTag === 'select' || activeTag === 'button') return\n\n      const cur ="]
