[90.485943, "i", "tion + error, keep islands.\n    setBridges(new Map())\n    setSelectedId(null)\n    setError(null)\n    setCursorId(islands[0]?.id ?? 0)\n  }, [difficulty])\n\n  function clearOnValid(valid) {\n    if (valid) setError(null)\n  }\n\n  function applyBridgeDelta(from, to, delta) {\n    const res = canAddBridge(islands, bridges, from, to, delta)\n    if (!res.valid) {\n      setError(res.error)\n      return false\n    }\n\n    const key = canonicalBridgeKey(from, to)\n    const existing = bridges.get(key) ?? 0\n    const next = Math.max(0, Math.min(2, existing + delta))\n\n    const nextMap = new Map(bridges)\n    if (next === 0) nextMap.delete(key)\n    else nextMap.set(key, next)\n    setBridges(nextMap)\n    clearOnValid(true)\n    return true\n  }\n\n  function cycleBridge(from, to) {\n    const key = canonicalBridgeKey(from, to)\n    const existing = bridges.get(key) ?? 0\n    const target = (existing + 1) % 3 // 0->1->2->0\n    const delta = target - existing\n    return applyBridgeDelta(from, to, delta)\n  }\n\n  function toggleBridge(from, "]
