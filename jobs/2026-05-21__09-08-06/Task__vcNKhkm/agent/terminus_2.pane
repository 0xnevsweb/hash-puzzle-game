[?2004l[?2004h> const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands'
[?2004l[?2004h> const ERR_MAX_PAIR = 'Max 2 bridges per pair'
[?2004l[?2004h> const ERR_EXCEED = 'Island would exceed its number'
[?2004l[?2004h> const ERR_CROSS = 'Bridges would cross'
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y }
[?2004l[?2004h>   const b = { x: to.x, y: to.y }
[?2004l[?2004h>   if (a.x < b.x || (a.x === b.x && a.y <= b.y)) {
[?2004l[?2004h>     return `${a.x},${a.y},${b.x},${b.y}`
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${b.x},${b.y},${a.x},${a.y}`
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number)
[?2004l[?2004h>   return { x1, y1, x2, y2 }
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(v, a, b) {
[?2004l[?2004h>   return v > Math.min(a, b) && v < Math.max(a, b)
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function getIslandAt(islands, x, y) {
[?2004l[?2004h>   return islands.find((i) => i.x === x && i.y === y) || null
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!from || !to) return false
[?2004l[?2004h>   if (!isAligned(from, to)) return false
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const x = from.x
[?2004l[?2004h>     const yMin = Math.min(from.y, to.y)
[?2004l[?2004h>     const yMax = Math.max(from.y, to.y)
[?2004l[?2004h>     for (const i of islands) {
[?2004l[?2004h>       if (i.id === from.id || i.id === to.id) continue
[?2004l[?2004h>       if (i.x === x && i.y > yMin && i.y < yMax) return false
[?2004l[?2004h>     }
[?2004l[?2004h>     return true
[?2004l[?2004h>   }
[?2004l[?2004h>   const y = from.y
[?2004l[?2004h>   const xMin = Math.min(from.x, to.x)
[?2004l[?2004h>   const xMax = Math.max(from.x, to.x)
[?2004l[?2004h>   for (const i of islands) {
[?2004l[?2004h>     if (i.id === from.id || i.id === to.id) continue
[?2004l[?2004h>     if (i.y === y && i.x > xMin && i.x < xMax) return false
[?2004l[?2004h>   }
[?2004l[?2004h>   return true
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map()
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0)
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key)
[?2004l[?2004h>     const a = getIslandAt(islands, x1, y1)
[?2004l[?2004h>     const b = getIslandAt(islands, x2, y2)
[?2004l[?2004h>     if (!a || !b) continue
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n)
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n)
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(k1, k2) {
[?2004l[?2004h>   const s1 = parseKey(k1)
[?2004l[?2004h>   const s2 = parseKey(k2)
[?2004l[?2004h> 
[?2004l[?2004h>   const s1Vert = s1.x1 === s1.x2
[?2004l[?2004h>   const s2Vert = s2.x1 === s2.x2
[?2004l[?2004h>   if (s1Vert === s2Vert) return false
[?2004l[?2004h> 
[?2004l[?2004h>   const v = s1Vert ? s1 : s2
[?2004l[?2004h>   const h = s1Vert ? s2 : s1
[?2004l[?2004h> 
[?2004l[?2004h>   const ix = v.x1
[?2004l[?2004h>   const iy = h.y1
[?2004l[?2004h> 
[?2004l[?2004h>   // Proper crossing (not at endpoints)
[?2004l[?2004h>   const vYMin = Math.min(v.y1, v.y2)
[?2004l[?2004h>   const vYMax = Math.max(v.y1, v.y2)
[?2004l[?2004h>   const hXMin = Math.min(h.x1, h.x2)
[?2004l[?2004h>   const hXMax = Math.max(h.x1, h.x2)
[?2004l[?2004h> 
[?2004l[?2004h>   if (!between(iy, vYMin, vYMax)) return false
[?2004l[?2004h>   if (!between(ix, hXMin, hXMax)) return false
[?2004l[?2004h>   return true
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function wouldCrossExisting(bridges, candidateKey) {
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue
[?2004l[?2004h>     if (k === candidateKey) continue
[?2004l[?2004h>     if (segmentsCross(k, candidateKey)) return true
[?2004l[?2004h>   }
[?2004l[?2004h>   return false
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: ERR_NON_ADJACENT }
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: ERR_NON_ADJACENT }
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) return { valid: false, error: ERR_NON_ADJACENT }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to)
[?2004l[?2004h>   const existing = bridges.get(key) ?? 0
[?2004l[?2004h>   const next = existing + delta
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: true, error: null }
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PAIR }
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges)
[?2004l[?2004h>   const fromCount = counts.get(from.id) ?? 0
[?2004l[?2004h>   const toCount = counts.get(to.id) ?? 0
[?2004l[?2004h> 
[?2004l[?2004h>   // Only enforce exceed when adding
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>       return { valid: false, error: ERR_EXCEED }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Crossing only matters if we will have at least 1 bridge after change
[?2004l[?2004h>   if (delta > 0 && next > 0) {
[?2004l[?2004h>     const tmp = new Map(bridges)
[?2004l[?2004h>     tmp.set(key, next)
[?2004l[?2004h>     // candidate segment is the same regardless of single/double
[?2004l[?2004h>     if (wouldCrossExisting(bridges, key)) {
[?2004l[?2004h>       return { valid: false, error: ERR_CROSS }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null }
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true
[?2004l[?2004h>   const adj = new Map()
[?2004l[?2004h>   for (const i of islands) adj.set(i.id, [])
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key)
[?2004l[?2004h>     const a = getIslandAt(islands, x1, y1)
[?2004l[?2004h>     const b = getIslandAt(islands, x2, y2)
[?2004l[?2004h>     if (!a || !b) continue
[?2004l[?2004h>     adj.get(a.id).push(b.id)
[?2004l[?2004h>     adj.get(b.id).push(a.id)
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const startId = islands[0].id
[?2004l[?2004h>   const q = [startId]
[?2004l[?2004h>   const seen = new Set([startId])
[?2004l[?2004h>   while (q.length) {
[?2004l[?2004h>     const cur = q.shift()
[?2004l[?2004h>     for (const nxt of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt)
[?2004l[?2004h>         q.push(nxt)
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return seen.size === islands.length
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function anyCrossing(bridges) {
[?2004l[?2004h>   const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k)
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       if (segmentsCross(keys[i], keys[j])) return true
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges)
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false
[?2004l[?2004h>   }
[?2004l[?2004h>   if (anyCrossing(bridges)) return false
[?2004l[?2004h>   if (!checkConnectivity(islands, bridges)) return false
[?2004l[?2004h>   return true
[?2004l[?2004h> }
