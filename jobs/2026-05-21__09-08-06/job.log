Sending keys: ['cat > src/App.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\';\nimport { PUZZLES } from \'./data/puzzles.js\';\nimport {\n  canAddBridge,\n  canonicalBridgeKey,\n  computeCurrentCounts,\n  isVictory\n} from \'./utils/hashiLogic.js\';\n\nconst GRID = 40;\nconst W = 800;\nconst H = 600;\n\nfunction isCtrlLike(e) {\n  return e.ctrlKey || e.metaKey;\n}\n\nfunction findIslandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y) || null;\n}\n\nfunction nextIslandInDirection(islands, from, dir) {\n  const candidates = islands.filter((i) => i.id !== from.id);\n  if (dir === \'left\') {\n    const sameRow = candidates.filter((i) => i.y === from.y && i.x < from.x);\n    sameRow.sort((a, b) => b.x - a.x);\n    return sameRow[0] || null;\n  }\n  if (dir === \'right\') {\n    const sameRow = candidates.filter((i) => i.y === from.y && i.x > from.x);\n    sameRow.sort((a, b) => a.x - b.x);\n    return sameRow[0] || null;\n  }\n  if (dir === \'up\') {\n    const sameCol = candidates.filter((i) => i.x === from.x && i.y < from.y);\n    sameCol.sort((a, b) => b.y - a.y);\n    return sameCol[0] || null;\n  }\n  if (dir === \'down\') {\n    const sameCol = candidates.filter((i) => i.x === from.x && i.y > from.y);\n    sameCol.sort((a, b) => a.y - b.y);\n    return sameCol[0] || null;\n  }\n  return null;\n}\n\nfunction cycleDelta(current) {\n  // none -> single -> double -> none\n  if (current === 0) return +1;\n  if (current === 1) return +1;\n  return -2;\n}\n\nexport default function App() {\n  const [difficulty, setDifficulty] = useState(\'Easy\');\n  const puzzle = PUZZLES[difficulty];\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [cursorId, setCursorId] = useState(islands[0]?.id ?? null);\n  const [kbdFromId, setKbdFromId] = useState(null);\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  useEffect(() => {\n    // when puzzle changes: fully reset\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n    setCursorId(PUZZLES[difficulty].islands[0]?.id ?? null);\n    setKbdFromId(null);\n  }, [difficulty]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function applyBridge(from, to, delta) {\n    const res = canAddBridge(islands, bridges, from, to, delta);\n    if (!res.valid) {\n      setError(res.error);\n      return false;\n    }\n    setError(null);\n\n    const k = canonicalBridgeKey(from, to);\n    const current = bridges.get(k) ?? 0;\n    const next = current + delta;\n\n    const nb = new Map(bridges);\n    if (next === 0) nb.delete(k);\n    else nb.set(k, next);\n    setBridges(nb);\n    return true;\n  }\n\n  function toggleCycle(from, to) {\n    const k = canonicalBridgeKey(from, to);\n    const current = bridges.get(k) ?? 0;\n    const delta = cycleDelta(current);\n    applyBridge(from, to, delta);\n  }\n\n  function toggleRightClick(from, to) {\n    const k = canonicalBridgeKey(from, to);\n    const current = bridges.get(k) ?? 0;\n    const delta = current > 0 ? -1 : +1;\n    applyBridge(from, to, delta);\n  }\n\n  function onIslandClick(isl, e) {\n    e.preventDefault();\n    svgRef.current?.focus();\n\n    setCursorId(isl.id);\n\n    if (selectedId == null) {\n      setSelectedId(isl.id);\n      return;\n    }\n    if (selectedId === isl.id) return;\n\n    const from = islands.find((i) => i.id === selectedId);\n    const to = isl;\n    toggleCycle(from, to);\n    setSelectedId(null);\n  }\n\n  function onIslandContextMenu(isl, e) {\n    e.preventDefault();\n    svgRef.current?.focus();\n\n    if (selectedId == null || selectedId === isl.id) {\n      setSelectedId(isl.id);\n      return;\n    }\n    const from = islands.find((i) => i.id === selectedId);\n    toggleRightClick(from, isl);\n    setSelectedId(null);\n  }\n\n  function onIslandCtrlClick(isl, e) {\n    if (!isCtrlLike(e)) return;\n    e.preventDefault();\n    svgRef.current?.focus();\n\n    if (selectedId == null || selectedId === isl.id) {\n      setSelectedId(isl.id);\n      return;\n    }\n    const from = islands.find((i) => i.id === selectedId);\n    toggleRightClick(from, isl);\n    setSelectedId(null);\n  }\n\n  function handleKeyDown(e) {\n    if (![\'ArrowLeft\', \'ArrowRight\', \'ArrowUp\', \'ArrowDown\', \'Enter\', \'Escape\'].includes(e.key)) return;\n    e.preventDefault();\n\n    const cursor = islands.find((i) => i.id === cursorId) || islands[0];\n    if (!cursor) return;\n\n    if (e.key === \'Escape\') {\n      setKbdFromId(null);\n      setSelectedId(null);\n      setError(null);\n      return;\n    }\n\n    if (e.key.startsWith(\'Arrow\')) {\n      const dir =\n        e.key === \'ArrowLeft\' ? \'left\' :\n        e.key === \'ArrowRight\' ? \'right\' :\n        e.key === \'ArrowUp\' ? \'up\' : \'down\';\n\n      const next = nextIslandInDirection(islands, cursor, dir);\n      if (next) setCursorId(next.id);\n      return;\n    }\n\n    if (e.key === \'Enter\') {\n      if (kbdFromId == null) {\n        setKbdFromId(cursor.id);\n        setSelectedId(cursor.id);\n        return;\n      }\n\n      const from = islands.find((i) => i.id === kbdFromId);\n      const to = cursor;\n      if (!from || !to || from.id === to.id) return;\n\n      const k = canonicalBridgeKey(from, to);\n      const current = bridges.get(k) ?? 0;\n      const delta = cycleDelta(current);\n      const ok = applyBridge(from, to, delta);\n      if (ok) {\n        setKbdFromId(null);\n        setSelectedId(null);\n      }\n    }\n  }\n\n  function reset() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setKbdFromId(null);\n    setError(null);\n    svgRef.current?.focus();\n  }\n\n  const bridgeLines = [];\n  const bridgeHitAreas = [];\n\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n\n    const [x1, y1, x2, y2] = k.split(\',\').map(Number);\n    const ax = x1 * GRID;\n    const ay = y1 * GRID;\n    const bx = x2 * GRID;\n    const by = y2 * GRID;\n\n    const from = findIslandAt(islands, x1, y1);\n    const to = findIslandAt(islands, x2, y2);\n\n    // Transparent hit target so right-click / Ctrl+click on the bridge works.\n    bridgeHitAreas.push(\n      <line\n        key={`hit-${k}`}\n        x1={ax}\n        y1={ay}\n        x2={bx}\n        y2={by}\n        stroke="transparent"\n        strokeWidth={18}\n        strokeLinecap="round"\n        onContextMenu={(e) => {\n          e.preventDefault();\n          svgRef.current?.focus();\n          if (from && to) toggleRightClick(from, to);\n        }}\n        onClick={(e) => {\n          if (!isCtrlLike(e)) return;\n          e.preventDefault();\n          svgRef.current?.focus();\n          if (from && to) toggleRightClick(from, to);\n        }}\n      />\n    );\n\n    const isH = ay === by;\n    const offset = 6;\n\n    if (n === 1) {\n      bridgeLines.push(\n        <line\n          key={`b-${k}-1`}\n          x1={ax}\n          y1={ay}\n          x2={bx}\n          y2={by}\n          stroke="#00ff66"\n          strokeWidth={4}\n          strokeLinecap="round"\n        />\n      );\n    } else if (n === 2) {\n      const dx = isH ? 0 : offset;\n      const dy = isH ? offset : 0;\n      bridgeLines.push(\n        <line\n          key={`b-${k}-2a`}\n          x1={ax - dx}\n          y1={ay - dy}\n          x2={bx - dx}\n          y2={by - dy}\n          stroke="#00ff66"\n          strokeWidth={4}\n          strokeLinecap="round"\n        />\n      );\n      bridgeLines.push(\n        <line\n          key={`b-${k}-2b`}\n          x1={ax + dx}\n          y1={ay + dy}\n          x2={bx + dx}\n          y2={by + dy}\n          stroke="#00ff66"\n          strokeWidth={4}\n          strokeLinecap="round"\n        />\n      );\n    }\n  }\n\n  const cursor = islands.find((i) => i.id === cursorId) || islands[0];\n  const cursorPx = cursor ? { x: cursor.x * GRID, y: cursor.y * GRID } : { x: 0, y: 0 };\n\n  return (\n    <div className="app">\n      <div className="hud">\n        <label>\n          Puzzle\n          <select value={difficulty} onChange={(e) => setDifficulty(e.target.value)}>\n            <option value="Easy">Easy</option>\n            <option value="Medium">Medium</option>\n            <option value="Hard">Hard</option>\n          </select>\n        </label>\n        <button onClick={reset}>Reset</button>\n      </div>\n\n      {error ? <div className="error-message">{error}</div> : null}\n      {victory ? <div className="victory-banner">SOLVED!</div> : null}\n\n      <svg\n        ref={svgRef}\n        width={W}\n        height={H}\n        viewBox={`0 0 ${W} ${H}`}\n        style={{ display: \'block\', position: \'absolute\', top: 0, left: 0, background: \'#000\' }}\n        tabIndex={0}\n        onKeyDown={handleKeyDown}\n      >\n        {cursor ? (\n          <rect\n            x={cursorPx.x - 18}\n            y={cursorPx.y - 18}\n            width={36}\n            height={36}\n            fill="none"\n            stroke="#00ff66"\n            strokeWidth={3}\n            strokeDasharray="6 4"\n          />\n        ) : null}\n\n        <g>{bridgeLines}</g>\n        <g>{bridgeHitAreas}</g>\n\n        <g>\n          {islands.map((isl) => {\n            const px = isl.x * GRID;\n            const py = isl.y * GRID;\n            const isSelected = selectedId === isl.id || kbdFromId === isl.id;\n            const current = counts.get(isl.id) ?? 0;\n            const satisfied = current === isl.value;\n\n            return (\n              <g key={isl.id}>\n                <circle\n                  cx={px}\n                  cy={py}\n                  r={16}\n                  fill="#000"\n                  stroke={isSelected ? \'#00ff66\' : \'rgba(0,255,102,0.7)\'}\n                  strokeWidth={isSelected ? 4 : 2}\n                  onClick={(e) => {\n                    onIslandCtrlClick(isl, e);\n                    if (!isCtrlLike(e)) onIslandClick(isl, e);\n                  }}\n                  onContextMenu={(e) => onIslandContextMenu(isl, e)}\n                />\n                <text\n                  x={px}\n                  y={py + 6}\n                  textAnchor="middle"\n                  fontSize="16"\n                  fill={satisfied ? \'#00ff66\' : \'rgba(0,255,102,0.9)\'}\n                >\n                  {isl.value}\n                </text>\n              </g>\n            );\n          })}\n        </g>\n      </svg>\n    </div>\n  );\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
