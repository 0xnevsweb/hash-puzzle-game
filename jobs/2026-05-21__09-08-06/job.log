Sending keys: ['cat > /app/src/main.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\'\nimport { createRoot } from \'react-dom/client\'\nimport { PUZZLES, PUZZLE_OPTIONS } from \'./data/puzzles.js\'\nimport {\n  areAdjacent,\n  canAddBridge,\n  canonicalBridgeKey,\n  computeCurrentCounts,\n  getIslandAt,\n  isVictory\n} from \'./utils/hashiLogic.js\'\n\nconst GRID = 40\nconst WIDTH = 800\nconst HEIGHT = 600\n\nfunction App() {\n  const [difficulty, setDifficulty] = useState(\'Easy\')\n  const islands = useMemo(() => PUZZLES[difficulty].islands, [difficulty])\n\n  const [bridges, setBridges] = useState(() => new Map())\n  const [selectedId, setSelectedId] = useState(null)\n  const [cursorId, setCursorId] = useState(0)\n  const [error, setError] = useState(null)\n\n  const svgRef = useRef(null)\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges])\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges])\n\n  useEffect(() => {\n    // On puzzle change: reset bridges + selection + error, keep islands.\n    setBridges(new Map())\n    setSelectedId(null)\n    setError(null)\n    setCursorId(islands[0]?.id ?? 0)\n  }, [difficulty])\n\n  function clearOnValid(valid) {\n    if (valid) setError(null)\n  }\n\n  function applyBridgeDelta(from, to, delta) {\n    const res = canAddBridge(islands, bridges, from, to, delta)\n    if (!res.valid) {\n      setError(res.error)\n      return false\n    }\n\n    const key = canonicalBridgeKey(from, to)\n    const existing = bridges.get(key) ?? 0\n    const next = Math.max(0, Math.min(2, existing + delta))\n\n    const nextMap = new Map(bridges)\n    if (next === 0) nextMap.delete(key)\n    else nextMap.set(key, next)\n    setBridges(nextMap)\n    clearOnValid(true)\n    return true\n  }\n\n  function cycleBridge(from, to) {\n    const key = canonicalBridgeKey(from, to)\n    const existing = bridges.get(key) ?? 0\n    const target = (existing + 1) % 3 // 0->1->2->0\n    const delta = target - existing\n    return applyBridgeDelta(from, to, delta)\n  }\n\n  function toggleBridge(from, to) {\n    const key = canonicalBridgeKey(from, to)\n    const existing = bridges.get(key) ?? 0\n    const target = existing === 0 ? 1 : 0\n    const delta = target - existing\n    return applyBridgeDelta(from, to, delta)\n  }\n\n  function onIslandActivate(island) {\n    // First click selects.\n    if (selectedId == null || selectedId === island.id) {\n      setSelectedId(island.id)\n      setCursorId(island.id)\n      return\n    }\n    // Second click on a different island attempts toggle.\n    const from = islands.find((i) => i.id === selectedId)\n    const to = island\n    const ok = cycleBridge(from, to)\n    if (ok) {\n      setSelectedId(to.id)\n      setCursorId(to.id)\n    }\n  }\n\n  function onIslandContextToggle(island, e) {\n    e.preventDefault()\n    e.stopPropagation()\n    if (selectedId == null || selectedId === island.id) {\n      setSelectedId(island.id)\n      setCursorId(island.id)\n      return\n    }\n    const from = islands.find((i) => i.id === selectedId)\n    const to = island\n    const ok = toggleBridge(from, to)\n    if (ok) {\n      setSelectedId(to.id)\n      setCursorId(to.id)\n    }\n  }\n\n  function nearestInDirection(from, dx, dy) {\n    let best = null\n    for (const isl of islands) {\n      if (isl.id === from.id) continue\n      if (dx !== 0) {\n        if (isl.y !== from.y) continue\n        const dd = (isl.x - from.x) * dx\n        if (dd <= 0) continue\n        // must be adjacent in that direction (no island between)\n        if (!areAdjacent(islands, from, isl)) continue\n        if (best == null || dd < best.dd) best = { isl, dd }\n      } else {\n        if (isl.x !== from.x) continue\n        const dd = (isl.y - from.y) * dy\n        if (dd <= 0) continue\n        if (!areAdjacent(islands, from, isl)) continue\n        if (best == null || dd < best.dd) best = { isl, dd }\n      }\n    }\n    return best?.isl ?? null\n  }\n\n  useEffect(() => {\n    function onKeyDown(e) {\n      const activeTag = document.activeElement?.tagName?.toLowerCase()\n      if (activeTag === \'select\' || activeTag === \'button\') return\n\n      const cur = islands.find((i) => i.id === cursorId) || islands[0]\n      if (!cur) return\n\n      if (e.key === \'Escape\') {\n        setSelectedId(null)\n        setError(null)\n        return\n      }\n\n      if (e.key === \'Enter\') {\n        if (selectedId == null) {\n          setSelectedId(cur.id)\n        } else {\n          const sel = islands.find((i) => i.id === selectedId)\n          if (sel && sel.id !== cur.id) {\n            const ok = cycleBridge(sel, cur)\n            if (ok) setSelectedId(cur.id)\n          } else {\n            setSelectedId(cur.id)\n          }\n        }\n        return\n      }\n\n      let dir = null\n      if (e.key === \'ArrowLeft\') dir = [-1, 0]\n      if (e.key === \'ArrowRight\') dir = [1, 0]\n      if (e.key === \'ArrowUp\') dir = [0, -1]\n      if (e.key === \'ArrowDown\') dir = [0, 1]\n      if (!dir) return\n\n      e.preventDefault()\n      const nxt = nearestInDirection(cur, dir[0], dir[1])\n      if (nxt) setCursorId(nxt.id)\n    }\n\n    window.addEventListener(\'keydown\', onKeyDown)\n    return () => window.removeEventListener(\'keydown\', onKeyDown)\n  }, [cursorId, islands, selectedId, bridges])\n\n  function onSvgClick(e) {\n    // click empty space clears selection\n    if (e.target === svgRef.current) {\n      setSelectedId(null)\n    }\n  }\n\n  const islandById = useMemo(() => {\n    const m = new Map()\n    for (const i of islands) m.set(i.id, i)\n    return m\n  }, [islands])\n\n  const lines = useMemo(() => {\n    const arr = []\n    for (const [key, n] of bridges.entries()) {\n      if (!n) continue\n      const [x1, y1, x2, y2] = key.split(\',\').map(Number)\n      arr.push({ x1, y1, x2, y2, n, key })\n    }\n    return arr\n  }, [bridges])\n\n  return (\n    <div\n      style={{\n        margin: 0,\n        padding: 0,\n        background: \'#000\',\n        color: \'#00ff66\',\n        fontFamily: \'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace\',\n        minHeight: \'100vh\',\n        overflow: \'hidden\'\n      }}\n    >\n      <div style={{ position: \'absolute\', left: 0, top: 0, padding: 8 }}>\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={difficulty}\n            onChange={(e) => setDifficulty(e.target.value)}\n            style={{\n              background: \'#000\',\n              color: \'#00ff66\',\n              border: \'1px solid #00ff66\',\n              fontFamily: \'inherit\'\n            }}\n          >\n            {PUZZLE_OPTIONS.map((opt) => (\n              <option key={opt} value={opt}>\n                {opt}\n              </option>\n            ))}\n          </select>\n        </label>\n        <button\n          onClick={() => {\n            setBridges(new Map())\n            setSelectedId(null)\n            setError(null)\n          }}\n          style={{\n            marginLeft: 8,\n            background: \'#000\',\n            color: \'#00ff66\',\n            border: \'1px solid #00ff66\',\n            fontFamily: \'inherit\',\n            padding: \'2px 6px\',\n            cursor: \'pointer\'\n          }}\n        >\n          Reset\n        </button>\n        {error ? <div className="error-message" style={{ marginTop: 6, color: \'#00ff66\' }}>{error}</div> : null}\n        {victory ? <div className="victory-banner" style={{ marginTop: 6, color: \'#00ff66\', border: \'1px solid #00ff66\', display: \'inline-block\', padding: \'2px 6px\' }}>SOLVED!</div> : null}\n      </div>\n\n      <svg\n        ref={svgRef}\n        width={WIDTH}\n        height={HEIGHT}\n        onClick={onSvgClick}\n        style={{\n          position: \'absolute\',\n          left: 0,\n          top: 0,\n          display: \'block\',\n          background: \'#000\'\n        }}\n      >\n        {/* Bridges */}\n        {lines.map(({ x1, y1, x2, y2, n, key }) => {\n          const px1 = x1 * GRID\n          const py1 = y1 * GRID\n          const px2 = x2 * GRID\n          const py2 = y2 * GRID\n\n          const isHoriz = py1 === py2\n          const offset = 4\n          const stroke = \'#00ff66\'\n          const common = {\n            stroke,\n            strokeWidth: 3,\n            strokeLinecap: \'round\'\n          }\n\n          const handleContext = (e) => {\n            e.preventDefault()\n            e.stopPropagation()\n            // Ctrl+click on bridge toggles too\n            const a = getIslandAt(islands, x1, y1)\n            const b = getIslandAt(islands, x2, y2)\n            if (a && b) {\n              const ok = toggleBridge(a, b)\n              if (ok) {\n                setSelectedId(b.id)\n                setCursorId(b.id)\n              }\n            }\n          }\n\n          const handleClick = (e) => {\n            if (e.ctrlKey) {\n              handleContext(e)\n            }\n          }\n\n          if (n === 1) {\n            return (\n              <line\n                key={key}\n                x1={px1}\n                y1={py1}\n                x2={px2}\n                y2={py2}\n                {...common}\n                onContextMenu={handleContext}\n                onClick={handleClick}\n              />\n            )\n          }\n\n          // double bridge: two parallel lines\n          const dx = isHoriz ? 0 : offset\n          const dy = isHoriz ? offset : 0\n          return (\n            <g key={key} onContextMenu={handleContext} onClick={handleClick}>\n              <line x1={px1 - dx} y1={py1 - dy} x2={px2 - dx} y2={py2 - dy} {...common} />\n              <line x1={px1 + dx} y1={py1 + dy} x2={px2 + dx} y2={py2 + dy} {...common} />\n            </g>\n          )\n        })}\n\n        {/* Cursor (must not be a circle) */}\n        {(() => {\n          const cur = islandById.get(cursorId)\n          if (!cur) return null\n          const px = cur.x * GRID\n          const py = cur.y * GRID\n          return (\n            <rect\n              x={px - 18}\n              y={py - 18}\n              width={36}\n              height={36}\n              fill="none"\n              stroke={selectedId === cursorId ? \'#00ff66\' : \'#00aa44\'}\n              strokeWidth={2}\n              strokeDasharray={selectedId === cursorId ? \'0\' : \'4 3\'}\n            />\n          )\n        })()}\n\n        {/* Islands */}\n        {islands.map((isl) => {\n          const px = isl.x * GRID\n          const py = isl.y * GRID\n          const isSelected = selectedId === isl.id\n          const curCount = counts.get(isl.id) ?? 0\n\n          return (\n            <g\n              key={isl.id}\n              transform={`translate(${px},${py})`}\n              style={{ cursor: \'pointer\' }}\n              onClick={(e) => {\n                e.stopPropagation()\n                onIslandActivate(isl)\n              }}\n              onContextMenu={(e) => onIslandContextToggle(isl, e)}\n            >\n              <circle\n                cx={0}\n                cy={0}\n                r={14}\n                fill="#000"\n                stroke={isSelected ? \'#00ff66\' : \'#00aa44\'}\n                strokeWidth={2}\n              />\n              <text\n                x={0}\n                y={5}\n                textAnchor="middle"\n                fontSize={14}\n                fill="#00ff66"\n              >\n                {isl.value}\n              </text>\n              <text\n                x={0}\n                y={26}\n                textAnchor="middle"\n                fontSize={10}\n                fill="#00aa44"\n              >\n                {curCount}/{isl.value}\n              </text>\n            </g>\n          )\n        })}\n      </svg>\n    </div>\n  )\n}\n\ncreateRoot(do