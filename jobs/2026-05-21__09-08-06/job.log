segA, segB) {\n  // Axis-aligned segments. A cross is a strict interior intersection (not endpoints).\n  const aVert = segA.x1 === segA.x2;\n  const bVert = segB.x1 === segB.x2;\n  if (aVert === bVert) return false;\n\n  const v = aVert ? segA : segB;\n  const h = aVert ? segB : segA;\n\n  const vx = v.x1;\n  const vyMin = Math.min(v.y1, v.y2);\n  const vyMax = Math.max(v.y1, v.y2);\n\n  const hy = h.y1;\n  const hxMin = Math.min(h.x1, h.x2);\n  const hxMax = Math.max(h.x1, h.x2);\n\n  const ix = vx;\n  const iy = hy;\n\n  const vInterior = iy > vyMin && iy < vyMax;\n  const hInterior = ix > hxMin && ix < hxMax;\n  return vInterior && hInterior;\n}\n\nexport function bridgesWouldCross(bridges, from, to) {\n  const candidate = { x1: from.x, y1: from.y, x2: to.x, y2: to.y };\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const seg = parseKey(key);\n\n    // same segment doesn't count as crossing\n    const same =\n      (seg.x1 === candidate.x1 && seg.y1 === candidate.y1 && seg.x2 === candidate.x2 && seg.y2 === candidate.y2) ||\n      (seg.x1 === candidate.x2 && seg.y1 === candidate.y2 && seg.x2 === candidate.x1 && seg.y2 === candidate.y1);\n    if (same) continue;\n\n    // sharing an endpoint is allowed\n    const sharesEndpoint =\n      (seg.x1 === candidate.x1 && seg.y1 === candidate.y1) ||\n      (seg.x2 === candidate.x1 && seg.y2 === candidate.y1) ||\n      (seg.x1 === candidate.x2 && seg.y1 === candidate.y2) ||\n      (seg.x2 === candidate.x2 && seg.y2 === candidate.y2);\n    if (sharesEndpoint) continue;\n\n    if (segmentsCross(seg, candidate)) return true;\n  }\n  return false;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: false, error: ERR_NON_ADJ };\n  if (!isStraight(from, to)) return { valid: false, error: ERR_NON_ADJ };\n  if (hasIslandBetween(islands, from, to)) return { valid: false, error: ERR_NON_ADJ };\n\n  const key = canonicalKey(from, to);\n  const existing = bridges.get(key) ?? 0;\n  const next = existing + delta;\n\n  if (next > 2) return { valid: false, error: ERR_MAX2 };\n  if (next < 0) return { valid: true, error: null };\n\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) return { valid: false, error: ERR_EXCEED };\n\n  if (delta > 0 && bridgesWouldCross(bridges, from, to)) return { valid: false, error: ERR_CROSS };\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n  const adj = new Map(islands.map((i) => [i.id, []]));\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const aId = posToId.get(`${x1},${y1}`);\n    const bId = posToId.get(`${x2},${y2}`);\n    if (aId === undefined || bId === undefined) continue;\n    adj.get(aId).push(bId);\n    adj.get(bId).push(aId);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const stack = [startId];\n  while (stack.length) {\n    const cur = stack.pop();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        stack.push(nxt);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // Ensure no crossings\n  const segs = [];\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    segs.push(parseKey(key));\n  }\n  for (let i = 0; i < segs.length; i++) {\n    for (let j = i + 1; j < segs.length; j++) {\n      const a = segs[i];\n      const b = segs[j];\n      const sharesEndpoint =\n        (a.x1 === b.x1 && a.y1 === b.y1) ||\n        (a.x1 === b.x2 && a.y1 === b.y2) ||\n        (a.x2 === b.x1 && a.y2 === b.y1) ||\n        (a.x2 === b.x2 && a.y2 === b.y2);\n      if (sharesEndpoint) continue;\n      if (segmentsCross(a, b)) return false;\n    }\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
