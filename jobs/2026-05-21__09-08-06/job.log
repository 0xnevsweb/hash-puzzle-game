Sending keys: ['cat > src/App.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\';\nimport { PUZZLES } from \'./data/puzzles.js\';\nimport {\n  areAdjacent,\n  canAddBridge,\n  canonicalBridgeKey,\n  computeCurrentCounts,\n  isVictory,\n  parseBridgeKey,\n} from \'./utils/hashiLogic.js\';\n\nconst GRID = 40;\nconst WIDTH = 800;\nconst HEIGHT = 600;\n\nfunction islandPx(isl) {\n  return { cx: isl.x * GRID, cy: isl.y * GRID };\n}\n\nfunction getIslandById(islands, id) {\n  return islands.find((i) => i.id === id) || null;\n}\n\nfunction nearestInDirection(islands, from, dir) {\n  if (!from) return null;\n  const candidates = islands.filter((i) => i.id !== from.id);\n\n  if (dir === \'left\') {\n    const sameRow = candidates.filter((i) => i.y === from.y && i.x < from.x);\n    if (!sameRow.length) return null;\n    return sameRow.reduce((best, cur) => (cur.x > best.x ? cur : best));\n  }\n  if (dir === \'right\') {\n    const sameRow = candidates.filter((i) => i.y === from.y && i.x > from.x);\n    if (!sameRow.length) return null;\n    return sameRow.reduce((best, cur) => (cur.x < best.x ? cur : best));\n  }\n  if (dir === \'up\') {\n    const sameCol = candidates.filter((i) => i.x === from.x && i.y < from.y);\n    if (!sameCol.length) return null;\n    return sameCol.reduce((best, cur) => (cur.y > best.y ? cur : best));\n  }\n  if (dir === \'down\') {\n    const sameCol = candidates.filter((i) => i.x === from.x && i.y > from.y);\n    if (!sameCol.length) return null;\n    return sameCol.reduce((best, cur) => (cur.y < best.y ? cur : best));\n  }\n  return null;\n}\n\nfunction keyForPair(from, to) {\n  return canonicalBridgeKey(from, to);\n}\n\nfunction bridgeCountBetween(bridges, from, to) {\n  const key = keyForPair(from, to);\n  return bridges.get(key) ?? 0;\n}\n\nfunction cycleCount(count) {\n  if (count === 0) return 1;\n  if (count === 1) return 2;\n  return 0;\n}\n\nfunction getBridgeSegments(islands, bridges) {\n  // Returns drawable segments with count and endpoints in px\n  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n  const segs = [];\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    const p1 = islandPx(a);\n    const p2 = islandPx(b);\n    segs.push({\n      key,\n      count: n,\n      a,\n      b,\n      x1: p1.cx,\n      y1: p1.cy,\n      x2: p2.cx,\n      y2: p2.cy,\n      horizontal: a.y === b.y,\n    });\n  }\n\n  return segs;\n}\n\nexport default function App() {\n  const puzzleNames = useMemo(() => [\'Easy\', \'Medium\', \'Hard\'], []);\n  const [puzzleName, setPuzzleName] = useState(\'Easy\');\n  const islands = useMemo(() => PUZZLES[puzzleName].islands, [puzzleName]);\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null); // for mouse selection\n  const [cursorId, setCursorId] = useState(0);\n  const [kbdMode, setKbdMode] = useState({ selectingFrom: null, direction: null });\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  useEffect(() => {\n    // When puzzle changes, fully reset bridges + selections\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n    setCursorId(PUZZLES[puzzleName].islands[0]?.id ?? 0);\n    setKbdMode({ selectingFrom: null, direction: null });\n  }, [puzzleName]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function clearErrorOnValid(valid) {\n    if (valid) setError(null);\n  }\n\n  function applyBridgeChange(from, to, newCount) {\n    const key = keyForPair(from, to);\n    setBridges((prev) => {\n      const next = new Map(prev);\n      if (newCount === 0) next.delete(key);\n      else next.set(key, newCount);\n      return next;\n    });\n  }\n\n  function trySetBridgeCount(from, to, targetCount) {\n    const existing = bridgeCountBetween(bridges, from, to);\n    if (targetCount === existing) {\n      clearErrorOnValid(true);\n      return;\n    }\n\n    const delta = targetCount > existing ? 1 : -1;\n    let cur = existing;\n    while (cur !== targetCount) {\n      const attempt = canAddBridge(islands, bridges, from, to, delta);\n      if (!attempt.valid) {\n        setError(attempt.error);\n        return;\n      }\n      // update local bridges snapshot incrementally for multi-step (0->2)\n      const key = keyForPair(from, to);\n      const temp = new Map(bridges);\n      temp.set(key, (temp.get(key) ?? 0) + delta);\n      if (temp.get(key) === 0) temp.delete(key);\n      bridges = temp; // mutate closure variable snapshot intentionally\n      cur += delta;\n    }\n\n    // Commit final map from mutated snapshot\n    setBridges(new Map(bridges));\n    clearErrorOnValid(true);\n  }\n\n  function toggleBridgeCycle(from, to) {\n    if (!from || !to) return;\n    const existing = bridgeCountBetween(bridges, from, to);\n    const target = cycleCount(existing);\n    // compute delta path\n    if (!areAdjacent(islands, from, to)) {\n      setError(\'Cannot connect non-adjacent islands\');\n      return;\n    }\n    // Attempt stepwise via canAddBridge\n    if (target === 0) {\n      applyBridgeChange(from, to, 0);\n      clearErrorOnValid(true);\n      return;\n    }\n\n    // target 1 or 2: try to reach target\n    const key = keyForPair(from, to);\n    let tempBridges = new Map(bridges);\n    let cur = existing;\n    while (cur < target) {\n      const attempt = canAddBridge(islands, tempBridges, from, to, +1);\n      if (!attempt.valid) {\n        setError(attempt.error);\n        return;\n      }\n      tempBridges.set(key, (tempBridges.get(key) ?? 0) + 1);\n      cur += 1;\n    }\n    setBridges(tempBridges);\n    clearErrorOnValid(true);\n  }\n\n  function toggleBridgeDecrement(from, to) {\n    const existing = bridgeCountBetween(bridges, from, to);\n    const next = existing === 0 ? 2 : existing - 1;\n    // right-click toggles: none<->double, single->none\n    if (!areAdjacent(islands, from, to)) {\n      setError(\'Cannot connect non-adjacent islands\');\n      return;\n    }\n\n    if (next < existing) {\n      // removing is always ok\n      applyBridgeChange(from, to, next);\n      clearErrorOnValid(true);\n      return;\n    }\n\n    // adding to reach double\n    const key = keyForPair(from, to);\n    let tempBridges = new Map(bridges);\n    let cur = existing;\n    while (cur < next) {\n      const attempt = canAddBridge(islands, tempBridges, from, to, +1);\n      if (!attempt.valid) {\n        setError(attempt.error);\n        return;\n      }\n      tempBridges.set(key, (tempBridges.get(key) ?? 0) + 1);\n      cur += 1;\n    }\n    setBridges(tempBridges);\n    clearErrorOnValid(true);\n  }\n\n  function onIslandClick(isl, evt) {\n    evt.preventDefault();\n\n    // ctrl+click toggles like right-click\n    const isCtrlToggle = evt.ctrlKey;\n    if (isCtrlToggle && selectedId !== null && selectedId !== isl.id) {\n      const from = getIslandById(islands, selectedId);\n      const to = isl;\n      toggleBridgeDecrement(from, to);\n      setSelectedId(null);\n      return;\n    }\n\n    if (selectedId === null) {\n      setSelectedId(isl.id);\n      setCursorId(isl.id);\n      return;\n    }\n\n    if (selectedId === isl.id) {\n      // reselect same island does nothing\n      return;\n    }\n\n    const from = getIslandById(islands, selectedId);\n    const to = isl;\n    toggleBridgeCycle(from, to);\n    setSelectedId(null);\n  }\n\n  function onIslandContextMenu(isl, evt) {\n    evt.preventDefault();\n    if (selectedId !== null && selectedId !== isl.id) {\n      const from = getIslandById(islands, selectedId);\n      toggleBridgeDecrement(from, isl);\n      setSelectedId(null);\n    } else {\n      setSelectedId(isl.id);\n      setCursorId(isl.id);\n    }\n  }\n\n  useEffect(() => {\n    function onKeyDown(e) {\n      const cur = getIslandById(islands, cursorId) ?? islands[0];\n      if (!cur) return;\n\n      const key = e.key;\n      if (key === \'Escape\') {\n        setKbdMode({ selectingFrom: null, direction: null });\n        setSelectedId(null);\n        setError(null);\n        return;\n      }\n\n      if (key === \'Enter\') {\n        e.preventDefault();\n        if (kbdMode.selectingFrom === null) {\n          setKbdMode({ selectingFrom: cursorId, direction: null });\n          setSelectedId(cursorId);\n        } else {\n          const from = getIslandById(islands, kbdMode.selectingFrom);\n          const to = getIslandById(islands, cursorId);\n          if (from && to && from.id !== to.id) {\n            toggleBridgeCycle(from, to);\n          }\n          setKbdMode({ selectingFrom: null, direction: null });\n          setSelectedId(null);\n        }\n        return;\n      }\n\n      const dir =\n        key === \'ArrowLeft\' ? \'left\' :\n        key === \'ArrowRight\' ? \'right\' :\n        key === \'ArrowUp\' ? \'up\' :\n        key === \'ArrowDown\' ? \'down\' : null;\n\n      if (!dir) return;\n      e.preventDefault();\n\n      const next = nearestInDirection(islands, cur, dir);\n      if (next) {\n        setCursorId(next.id);\n        // In keyboard mode after selecting-from, arrows move toward another island (cursor moves)\n        setKbdMode((m) => (m.selectingFrom !== null ? { ...m, direction: dir } : m));\n      }\n    }\n\n    window.addEventListener(\'keydown\', onKeyDown);\n    return () => window.removeEventListener(\'keydown\', onKeyDown);\n  }, [cursorId, islands, kbdMode, selectedId, bridges]);\n\n  const segs = useMemo(() => getBridgeSegments(islands, bridges), [islands, bridges]);\n\n  const cursorIsland = getIslandById(islands, cursorId) ?? islands[0];\n  const cursorPx = cursorIsland ? islandPx(cursorIsland) : { cx: 0, cy: 0 };\n\n  return (\n    <div>\n      <div className="controls">\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={puzzleName}\n            onChange={(e) => setPuzzleName(e.target.value)}\n            aria-label="Puzzle selector"\n          >\n            {puzzleNames.map((name) => (\n              <option key={name} value={name}>\n                {name}\n              </option>\n            ))}\n          </select>\n        </label>\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedId(null);\n            setKbdMode({ selectingFrom: null, direction: null });\n            setError(null);\n          }}\n        >\n          Reset\n        </button>\n      </div>\n\n      {error ? <div className="error-message">{error}</div> : null}\n      {solved ? <div className="victory-banner">SOLVED!</div> : null}\n\n      <svg\n        ref={svgRef}\n        className="board"\n        width={WIDTH}\n        height={HEIGHT}\n        viewBox={`0 0 ${WIDTH} ${HEIGHT}`}\n      >\n        <defs>\n          <filter id="glow">\n            <feGaussianBlur stdDeviation="1.5" result="coloredBlur" />\n            <feMerge>\n              <feMergeNode in="coloredBlur" />\n              <feMergeNode in="SourceGraphic" />\n            </feMerge>\n          </filter>\n        </defs>\n\n        {/* Bridges */}\n        {segs.map((s) => {\n          const stroke = \'rgba(0,255,102,0.85)\';\n          const strokeWidth = 4;\n          const offset = 6;\n\n          if (s.count === 1) {\n            return (\n              <line\n                key={s.key}\n                x1={s.x1}\n                y1={s.y1}\n                x2={s.x2}\n                y2={s.y2}\n                stroke={stroke}\n                strokeWidth={strokeWidth}\n                filter="url(#glow)"\n              />\n            );\n          }\n\n          // double: two parallel lines\n          if (s.horizontal) {\n            return (\n              <g key={s.key}>\n                <line\n                  x1={s.x1}\n                  y1={s.y1 - offset}\n                  x2={s.x2}\n                  y2={s.y2 - offset}\n                  stroke={stroke}\n                  strokeWidth={strokeWidth}\n                  filter="url(#glow)"\n                />\n                <line\n                  x1={s.x1}\n                  y1={s.y1 + offset}\n                  x2={s.x2}\n                  y2={s.y2 + offset}\n                  stroke={stroke}\n                  strokeWidth={strokeWidth}\n                  filter="url(#glow)"\n                />\n              </g>\n            );\n          }\n\n          return (\n            <g key={s.key}>\n              <line\n                x1={s.x1 - offset}\n                y1={s.y1}\n                x2={s.x2 - offset}\n                y2={s.y2}\n                stroke={stroke}\n                strokeWidth={strokeWidth}\n                filter="url(#glow)"\n              />\n              <line\n                x1={s.x1 + offset}\n                y1={s.y1}\n                x2={s.x2 + offset}\n                y2={s.y2}\n                stroke={stroke}\n                strokeWidth={strokeWidth}\n                filter="url(#glow)"\n              />\n            </g>\n          );\n        })}\n\n        {/* Cursor (must not be a circle) */}\n        {cursorIsland ? (\n          <rect\n            x={cursorPx.cx - 18}\n            y={cursorPx.cy - 18}\n            width={36}\n            height={36}\n            fill="none"\n            stroke={selectedId === cursorId ? \'rgba(255,255,0,0.95)\' : \'rgba(0,255,102,0.9)\'}\n            strokeWidth={2}\n            filter="url(#glow)"\n          />\n        ) : null}\n\n        {/* Islands */}\n        {islands.map((isl) => {\n          const { cx, cy } = islandPx(isl);\n          const isSelected = selectedId === isl.id;\n          const curCount = counts.get(isl.id) ?? 0;\n          const ok = cu