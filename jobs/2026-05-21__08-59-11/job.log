Sending keys: ["cat > src/utils/hashiLogic.js <<'EOF'\nconst ERR_NON_ADJ = 'Cannot connect non-adjacent islands';\nconst ERR_MAX2 = 'Max 2 bridges per pair';\nconst ERR_EXCEED = 'Island would exceed its number';\nconst ERR_CROSS = 'Bridges would cross';\n\nexport function canonicalBridgeKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;\n  const second = first === a ? b : a;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nexport function isAxisAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\nexport function islandsByCoord(islands) {\n  const m = new Map();\n  for (const isl of islands) m.set(`${isl.x},${isl.y}`, isl);\n  return m;\n}\n\nexport function areAdjacent(islands, from, to) {\n  if (!isAxisAligned(from, to)) return false;\n  if (from.x === to.x) {\n    const x = from.x;\n    const yMin = Math.min(from.y, to.y);\n    const yMax = Math.max(from.y, to.y);\n    for (const isl of islands) {\n      if (isl.x === x && isl.y > yMin && isl.y < yMax) return false;\n    }\n    return true;\n  }\n  const y = from.y;\n  const xMin = Math.min(from.x, to.x);\n  const xMax = Math.max(from.x, to.x);\n  for (const isl of islands) {\n    if (isl.y === y && isl.x > xMin && isl.x < xMax) return false;\n  }\n  return true;\n}\n\nfunction segmentForBridge(key) {\n  const { x1, y1, x2, y2 } = parseBridgeKey(key);\n  if (x1 === x2) {\n    return { orient: 'V', x: x1, y1: Math.min(y1, y2), y2: Math.max(y1, y2) };\n  }\n  return { orient: 'H', y: y1, x1: Math.min(x1, x2), x2: Math.max(x1, x2) };\n}\n\nexport function bridgesWouldCross(bridges) {\n  const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);\n  for (let i = 0; i < keys.length; i++) {\n    const a = segmentForBridge(keys[i]);\n    for (let j = i + 1; j < keys.length; j++) {\n      const b = segmentForBridge(keys[j]);\n      if (a.orient === b.orient) continue;\n      const h = a.orient === 'H' ? a : b;\n      const v = a.orient === 'V' ? a : b;\n      // Proper crossing only at interior (not at endpoints)\n      const crosses = v.x > h.x1 && v.x < h.x2 && h.y > v.y1 && h.y < v.y2;\n      if (crosses) return true;\n    }\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map(islands.map((i) => [i.id, 0]));\n  const byCoord = islandsByCoord(islands);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) || 0) + n);\n    counts.set(b.id, (counts.get(b.id) || 0) + n);\n  }\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: false, error: ERR_NON_ADJ };\n  if (!areAdjacent(islands, from, to)) return { valid: false, error: ERR_NON_ADJ };\n\n  const key = canonicalBridgeKey(from, to);\n  const cur = bridges.get(key) || 0;\n  const next = cur + delta;\n\n  if (next < 0) return { valid: true, error: null };\n  if (next > 2) return { valid: false, error: ERR_MAX2 };\n\n  // capacity check per-island\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n\n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: ERR_EXCEED };\n  }\n\n  // crossing check: simulate\n  const test = new Map(bridges);\n  if (next === 0) test.delete(key);\n  else test.set(key, next);\n\n  if (bridgesWouldCross(test)) return { valid: false, error: ERR_CROSS };\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n  const byCoord = islandsByCoord(islands);\n  const adj = new Map(islands.map((i) => [i.id, new Set()]));\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a.id).add(b.id);\n    adj.get(b.id).add(a.id);\n  }\n\n  const start = islands[0].id;\n  const q = [start];\n  const seen = new Set([start]);\n  while (q.length) {\n    const id = q.shift();\n    for (const nb of adj.get(id) || []) {\n      if (!seen.has(nb)) {\n        seen.add(nb);\n        q.push(nb);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  if (bridgesWouldCross(bridges)) return false;\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) || 0) !== isl.value) return false;\n  }\n  return checkConnectivity(islands, bridges);\n}\n\nexport const ERROR_TEXTS = {\n  ERR_NON_ADJ,\n  ERR_MAX2,\n  ERR_EXCEED,\n  ERR_CROSS\n};\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
