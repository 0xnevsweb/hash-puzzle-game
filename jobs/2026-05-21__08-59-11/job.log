islands, selectedIslandId, bridges]);\n\n  function reset() {\n    setBridges(new Map());\n    setSelectedIslandId(null);\n    setMode(\'idle\');\n    setError(null);\n  }\n\n  // Render bridges\n  const bridgeLines = [];\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = { x: px(x1), y: px(y1) };\n    const b = { x: px(x2), y: px(y2) };\n\n    const isH = a.y === b.y;\n    const off = 5;\n    const stroke = \'#00ff66\';\n    const width = 3;\n\n    if (count === 1) {\n      bridgeLines.push(\n        <line\n          key={key}\n          x1={a.x}\n          y1={a.y}\n          x2={b.x}\n          y2={b.y}\n          stroke={stroke}\n          strokeWidth={width}\n          shapeRendering="crispEdges"\n        />\n      );\n    } else if (count === 2) {\n      if (isH) {\n        bridgeLines.push(\n          <g key={key}>\n            <line x1={a.x} y1={a.y - off} x2={b.x} y2={b.y - off} stroke={stroke} strokeWidth={width} shapeRendering="crispEdges" />\n            <line x1={a.x} y1={a.y + off} x2={b.x} y2={b.y + off} stroke={stroke} strokeWidth={width} shapeRendering="crispEdges" />\n          </g>\n        );\n      } else {\n        bridgeLines.push(\n          <g key={key}>\n            <line x1={a.x - off} y1={a.y} x2={b.x - off} y2={b.y} stroke={stroke} strokeWidth={width} shapeRendering="crispEdges" />\n            <line x1={a.x + off} y1={a.y} x2={b.x + off} y2={b.y} stroke={stroke} strokeWidth={width} shapeRendering="crispEdges" />\n          </g>\n        );\n      }\n    }\n  }\n\n  // Cursor marker (non-circle)\n  const cursorMarker = cursorIsland ? (\n    <rect\n      x={px(cursorIsland.x) - 18}\n      y={px(cursorIsland.y) - 18}\n      width={36}\n      height={36}\n      fill="none"\n      stroke={mode === \'choosingTarget\' || selectedIslandId ? \'#7CFFAA\' : \'#00aa44\'}\n      strokeWidth={3}\n      vectorEffect="non-scaling-stroke"\n    />\n  ) : null;\n\n  return (\n    <>\n      <div className="controls">\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={puzzleIndex}\n            onChange={(e) => setPuzzleIndex(Number(e.target.value))}\n          >\n            {puzzles.map((p, idx) => (\n              <option key={p.label} value={idx}>{p.label}</option>\n            ))}\n          </select>\n        </label>\n        <button onClick={reset}>Reset</button>\n        <div style={{ color: \'#00aa44\' }}>\n          Click: select island then another. Right-click/Ctrl+click on a bridge toggles it. Arrow keys + Enter.\n        </div>\n      </div>\n\n      {victory ? <div className="victory-banner">SOLVED!</div> : null}\n      {!victory && error ? <div className="error-message">{error}</div> : null}\n\n      <svg\n        ref={svgRef}\n        width={W}\n        height={H}\n        style={{ position: \'fixed\', left: 0, top: 0 }}\n        onContextMenu={handleContextOrCtrlClickBridge}\n        onMouseDown={(e) => {\n          if (e.ctrlKey) handleContextOrCtrlClickBridge(e);\n        }}\n      >\n        <rect x={0} y={0} width={W} height={H} fill="#000" />\n\n        {bridgeLines}\n        {cursorMarker}\n\n        {islands.map((isl) => {\n          const c = counts.get(isl.id) || 0;\n          const satisfied = c === isl.value;\n          const over = c > isl.value;\n          const stroke = over ? \'#ff4466\' : (satisfied ? \'#7CFFAA\' : \'#00ff66\');\n          const fill = \'#000\';\n          const r = 16;\n\n          return (\n            <g\n              key={isl.id}\n              transform={`translate(${px(isl.x)},${px(isl.y)})`}\n              onMouseDown={(e) => {\n                e.preventDefault();\n                handleIslandClick(isl);\n              }}\n              style={{ cursor: \'pointer\' }}\n            >\n              <circle cx={0} cy={0} r={r} fill={fill} stroke={stroke} strokeWidth={3} />\n              <text\n                x={0}\n                y={5}\n    