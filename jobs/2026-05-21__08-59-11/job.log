ll={satisfied ? \'#00ff66\' : \'#00cc55\'}\n+                >\n+                  {i.value}\n+                </text>\n+              </g>\n+            );\n+          })}\n+        </g>\n+      </svg>\n+    </>\n+  );\n+}\n+\n*** End Patch\nPATCH\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
