sSamePoint(p, v.from) || isSamePoint(p, v.to)) {\n    return false;\n  }\n  return true;\n}\n\nfunction crossesAny(existingBridges, candidateSeg, ignoreKey = null) {\n  const segs = getSegments(null, existingBridges);\n  for (const s of segs) {\n    if (ignoreKey && s.key === ignoreKey) continue;\n    if (segmentsCross(s, candidateSeg)) return true;\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const i1 = byCoord.get(`${x1},${y1}`);\n    const i2 = byCoord.get(`${x2},${y2}`);\n    if (!i1 || !i2) continue;\n    counts.set(i1.id, (counts.get(i1.id) || 0) + count);\n    counts.set(i2.id, (counts.get(i2.id) || 0) + count);\n  }\n  return counts;\n}\n\nfunction nearestIslandInDirection(islandsByCoord, from, dir) {\n  const { x, y } = from;\n  if (dir === 'left') {\n    for (let xx = x - 1; xx >= 0; xx--) {\n      const hit = islandsByCoord.get(`${xx},${y}`);\n      if (hit) return hit;\n    }\n  }\n  if (dir === 'right') {\n    for (let xx = x + 1; xx <= 100; xx++) {\n      const hit = islandsByCoord.get(`${xx},${y}`);\n      if (hit) return hit;\n    }\n  }\n  if (dir === 'up') {\n    for (let yy = y - 1; yy >= 0; yy--) {\n      const hit = islandsByCoord.get(`${x},${yy}`);\n      if (hit) return hit;\n    }\n  }\n  if (dir === 'down') {\n    for (let yy = y + 1; yy <= 100; yy++) {\n      const hit = islandsByCoord.get(`${x},${yy}`);\n      if (hit) return hit;\n    }\n  }\n  return null;\n}\n\nexport function areAdjacent(islands, from, to) {\n  if (!from || !to) return false;\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n\n  const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));\n  if (from.x === to.x) {\n    const step = Math.sign(to.y - from.y);\n    for (let yy = from.y + step; yy !== to.y; yy += step) {\n      if (byCoord.has(`${from.x},${yy}`)) return false;\n    }\n    return true;\n  }\n  const step = Math.sign(to.x - from.x);\n  for (let xx = from.x + step; xx !== to.x; xx += step) {\n    if (byCoord.has(`${xx},${from.y}`)) return false;\n  }\n  return true;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // delta: +1 to increase, -1 to decrease\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: ERR_NON_ADJ };\n  }\n\n  const key = canonicalBridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const next = current + delta;\n\n  if (next < 0) return { valid: true, error: null };\n  if (next > 2) return { valid: false, error: ERR_MAX2 };\n\n  // island counts must not exceed value\n  const counts = computeCurrentCounts(islands, bridges);\n  const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));\n  const i1 = byCoord.get(`${from.x},${from.y}`);\n  const i2 = byCoord.get(`${to.x},${to.y}`);\n  const after1 = (counts.get(i1.id) || 0) + delta;\n  const after2 = (counts.get(i2.id) || 0) + delta;\n\n  if (after1 > i1.value || after2 > i2.value) {\n    return { valid: false, error: ERR_EXCEED };\n  }\n\n  // crossing check (only relevant when adding)\n  if (delta > 0) {\n    const candidateSeg = {\n      from: { x: Math.min(from.x, to.x), y: Math.min(from.y, to.y) },\n      to: { x: Math.max(from.x, to.x), y: Math.max(from.y, to.y) },\n      key,\n    };\n    if (crossesAny(bridges, candidateSeg, null)) {\n      return { valid: false, error: ERR_CROSS };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n  const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));\n  const adj = new Map(islands.map(i => [i.id, new Set()]));\n\n  for (const [key