[101.678614, "i", "y)\n    const from = { x: x1, y: y1 }\n    const to = { x: x2, y: y2 }\n    if (delta === 0) {\n      clearErrorOnValidMove()\n      return\n    }\n    applyBridgeDelta(from, to, delta)\n  }\n\n  useEffect(() => {\n    const el = svgRef.current\n    if (!el) return\n\n    function onKeyDown(e) {\n      const cur = findIslandById(islands, cursorIslandId) || islands[0]\n      if (!cur) return\n\n      if (e.key === 'Escape') {\n        setSelectedIslandId(null)\n        clearErrorOnValidMove()\n        return\n      }\n\n      const dir =\n        e.key === 'ArrowLeft' ? [-1, 0] :\n        e.key === 'ArrowRight' ? [1, 0] :\n        e.key === 'ArrowUp' ? [0, -1] :\n        e.key === 'ArrowDown' ? [0, 1] :\n        null\n\n      if (dir) {\n        e.preventDefault()\n        const [dx, dy] = dir\n        const nxt = findNearestInDirection(islands, cur, dx, dy)\n        if (nxt) setCursorIslandId(nxt.id)\n        return\n      }\n\n      if (e.key === 'Enter') {\n        e.preventDefault()\n        const cursorIsland = findIslandById(islands, cursorIsla"]
[101.678667, "i", "ndId)\n        if (!cursorIsland) return\n\n        if (!selectedIslandId) {\n          setSelectedIslandId(cursorIsland.id)\n          clearErrorOnValidMove()\n          return\n        }\n\n        if (selectedIslandId === cursorIsland.id) {\n          // Do nothing\n          clearErrorOnValidMove()\n          return\n        }\n\n        const from = findIslandById(islands, selectedIslandId)\n        const to = cursorIsland\n        cycleBridge(from, to)\n        setSelectedIslandId(null)\n      }\n    }\n\n    window.addEventListener('keydown', onKeyDown)\n    return () => window.removeEventListener('keydown', onKeyDown)\n  }, [cursorIslandId, islands, selectedIslandId, bridges, error])\n\n  const cursorIsland = findIslandById(islands, cursorIslandId)\n  const selectedIsland = findIslandById(islands, selectedIslandId)\n\n  return (\n    <div className=\"app\">\n      <div className=\"hud\">\n        <label>\n          Puzzle:{' '}\n          <select\n            value={puzzleIndex}\n            onChange={(e) => setPuzzleIndex(Number(e.target.v"]
[101.678688, "o", "> "]
