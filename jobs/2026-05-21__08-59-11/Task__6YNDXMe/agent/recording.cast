[101.679004, "i", "a(0,255,102,0.9)'\n          const common = {\n            stroke,\n            strokeWidth: 3,\n            strokeLinecap: 'round',\n          }\n\n          const lines = []\n          if (num === 1) {\n            lines.push(\n              <line\n                key={`${key}-1`}\n                x1={p1.x}\n                y1={p1.y}\n                x2={p2.x}\n                y2={p2.y}\n                {...common}\n              />\n            )\n          } else {\n            if (isVert) {\n              lines.push(\n                <line key={`${key}-a`} x1={p1.x - offset} y1={p1.y} x2={p2.x - offset} y2={p2.y} {...common} />,\n                <line key={`${key}-b`} x1={p1.x + offset} y1={p1.y} x2={p2.x + offset} y2={p2.y} {...common} />\n              )\n            } else {\n              lines.push(\n                <line key={`${key}-a`} x1={p1.x} y1={p1.y - offset} x2={p2.x} y2={p2.y - offset} {...common} />,\n                <line key={`${key}-b`} x1={p1.x} y1={p1.y + offset} x2={p2.x} y2={p2.y + offset} {...common} />\n    "]
[101.679082, "i", "          )\n            }\n          }\n\n          // Invisible, fat hit target for right-click / ctrl-click toggling.\n          const { cx, cy } = bridgeCenterPixels(key)\n\n          return (\n            <g key={key}>\n              {lines}\n              <line\n                x1={p1.x}\n                y1={p1.y}\n                x2={p2.x}\n                y2={p2.y}\n                stroke=\"transparent\"\n                strokeWidth={18}\n                onMouseDown={(e) => {\n                  if (e.button === 2 || e.ctrlKey) toggleBridgeAtKey(key, e)\n                }}\n                onContextMenu={(e) => toggleBridgeAtKey(key, e)}\n              />\n              <text x={cx + 8} y={cy - 8} fill=\"rgba(0,255,102,0.35)\" fontSize=\"10\">{num}</text>\n            </g>\n          )\n        })}\n\n        {/* Cursor (must not be circle) */}\n        {cursorIsland && (() => {\n          const { px, py } = islandPixel(cursorIsland)\n          return (\n            <rect\n              x={px - 18}\n              y={py - 18}\n              w"]
[101.679125, "i", "idth={36}\n              height={36}\n              fill=\"none\"\n              stroke=\"rgba(0,255,102,0.95)\"\n              strokeWidth={2}\n              strokeDasharray=\"4 3\"\n            />\n          )\n        })()}\n\n        {/* Islands */}\n        {islands.map((isl) => {\n          const { px, py } = islandPixel(isl)\n          const curCount = counts.get(isl.id) || 0\n          const isSelected = isl.id === selectedIslandId\n          const satisfied = curCount === isl.value\n\n          return (\n            <g key={isl.id} onMouseDown={(e) => onIslandClick(isl, e)} style={{ cursor: 'pointer' }}>\n              <circle\n                cx={px}\n                cy={py}\n                r={14}\n                fill=\"#000\"\n                stroke={isSelected ? '#00ff66' : satisfied ? 'rgba(0,255,102,0.8)' : 'rgba(0,255,102,0.5)'}\n                strokeWidth={isSelected ? 3 : 2}\n              />\n              <text\n                x={px}\n                y={py + 5}\n                textAnchor=\"middle\"\n                fontSize=\""]
