[?2004l[?2004hroot@e3febcf25c5d:/app# cat > src/utils/hashiLogic.js <<'EOF'
[?2004l[?2004h> const ERR_NON_ADJ = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> const ERR_MAX2 = 'Max 2 bridges per pair';
[?2004l[?2004h> const ERR_EXCEED = 'Island would exceed its number';
[?2004l[?2004h> const ERR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;
[?2004l[?2004h>   const second = first === a ? b : a;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseBridgeKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isAxisAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function islandsByCoord(islands) {
[?2004l[?2004h>   const m = new Map();
[?2004l[?2004h>   for (const isl of islands) m.set(`${isl.x},${isl.y}`, isl);
[?2004l[?2004h>   return m;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!isAxisAligned(from, to)) return false;
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const x = from.x;
[?2004l[?2004h>     const yMin = Math.min(from.y, to.y);
[?2004l[?2004h>     const yMax = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.x === x && isl.y > yMin && isl.y < yMax) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   const y = from.y;
[?2004l[?2004h>   const xMin = Math.min(from.x, to.x);
[?2004l[?2004h>   const xMax = Math.max(from.x, to.x);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.y === y && isl.x > xMin && isl.x < xMax) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentForBridge(key) {
[?2004l[?2004h>   const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>   if (x1 === x2) {
[?2004l[?2004h>     return { orient: 'V', x: x1, y1: Math.min(y1, y2), y2: Math.max(y1, y2) };
[?2004l[?2004h>   }
[?2004l[?2004h>   return { orient: 'H', y: y1, x1: Math.min(x1, x2), x2: Math.max(x1, x2) };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesWouldCross(bridges) {
[?2004l[?2004h>   const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     const a = segmentForBridge(keys[i]);
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       const b = segmentForBridge(keys[j]);
[?2004l[?2004h>       if (a.orient === b.orient) continue;
[?2004l[?2004h>       const h = a.orient === 'H' ? a : b;
[?2004l[?2004h>       const v = a.orient === 'V' ? a : b;
[?2004l[?2004h>       // Proper crossing only at interior (not at endpoints)
[?2004l[?2004h>       const crosses = v.x > h.x1 && v.x < h.x2 && h.y > v.y1 && h.y < v.y2;
[?2004l[?2004h>       if (crosses) return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map(islands.map((i) => [i.id, 0]));
[?2004l[?2004h>   const byCoord = islandsByCoord(islands);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const a = byCoord.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byCoord.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) || 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) || 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to || from.id === to.id) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const cur = bridges.get(key) || 0;
[?2004l[?2004h>   const next = cur + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: true, error: null };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX2 };
[?2004l[?2004h> 
[?2004l[?2004h>   // capacity check per-island
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // crossing check: simulate
[?2004l[?2004h>   const test = new Map(bridges);
[?2004l[?2004h>   if (next === 0) test.delete(key);
[?2004l[?2004h>   else test.set(key, next);
[?2004l[?2004h> 
[?2004l[?2004h>   if (bridgesWouldCross(test)) return { valid: false, error: ERR_CROSS };
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length <= 1) return true;
[?2004l[?2004h>   const byCoord = islandsByCoord(islands);
[?2004l[?2004h>   const adj = new Map(islands.map((i) => [i.id, new Set()]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const a = byCoord.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byCoord.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).add(b.id);
[?2004l[?2004h>     adj.get(b.id).add(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const q = [start];
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   while (q.length) {
[?2004l[?2004h>     const id = q.shift();
[?2004l[?2004h>     for (const nb of adj.get(id) || []) {
[?2004l[?2004h>       if (!seen.has(nb)) {
[?2004l[?2004h>         seen.add(nb);
[?2004l[?2004h>         q.push(nb);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   if (bridgesWouldCross(bridges)) return false;
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) || 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
