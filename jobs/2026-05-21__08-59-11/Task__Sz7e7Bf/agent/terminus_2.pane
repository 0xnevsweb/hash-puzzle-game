[?2004l[?2004hroot@e3febcf25c5d:/app# cat > src/App.jsx <<'EOF'
[?2004l[?2004h> import React, { useEffect, useMemo, useRef, useState } from 'react';
[?2004l[?2004h> import { PUZZLES, getPuzzleByLabel } from './data/puzzles.js';
[?2004l[?2004h> import {
[?2004l[?2004h>   areAdjacent,
[?2004l[?2004h>   canonicalBridgeKey,
[?2004l[?2004h>   canAddBridge,
[?2004l[?2004h>   computeCurrentCounts,
[?2004l[?2004h>   isVictory,
[?2004l[?2004h>   parseBridgeKey
[?2004l[?2004h> } from './utils/hashiLogic.js';
[?2004l[?2004h> 
[?2004l[?2004h> const UNIT = 40;
[?2004l[?2004h> const W = 800;
[?2004l[?2004h> const H = 600;
[?2004l[?2004h> 
[?2004l[?2004h> function px(n) {
[?2004l[?2004h>   return n * UNIT;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function bridgeLinesPixels(from, to, count) {
[?2004l[?2004h>   const x1 = px(from.x);
[?2004l[?2004h>   const y1 = px(from.y);
[?2004l[?2004h>   const x2 = px(to.x);
[?2004l[?2004h>   const y2 = px(to.y);
[?2004l[?2004h> 
[?2004l[?2004h>   if (count === 1) return [{ x1, y1, x2, y2 }];
[?2004l[?2004h>   // double: 2 parallel lines offset 4px perpendicular
[?2004l[?2004h>   const offset = 4;
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     return [
[?2004l[?2004h>       { x1: x1 - offset, y1, x2: x2 - offset, y2 },
[?2004l[?2004h>       { x1: x1 + offset, y1, x2: x2 + offset, y2 }
[?2004l[?2004h>     ];
[?2004l[?2004h>   }
[?2004l[?2004h>   return [
[?2004l[?2004h>     { x1, y1: y1 - offset, x2, y2: y2 - offset },
[?2004l[?2004h>     { x1, y1: y1 + offset, x2, y2: y2 + offset }
[?2004l[?2004h>   ];
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function getNeighbors(islands, from, dir) {
[?2004l[?2004h>   // return nearest island in direction if aligned
[?2004l[?2004h>   let best = null;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h>     if (dir === 'left' && isl.y === from.y && isl.x < from.x) {
[?2004l[?2004h>       if (!best || isl.x > best.x) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'right' && isl.y === from.y && isl.x > from.x) {
[?2004l[?2004h>       if (!best || isl.x < best.x) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'up' && isl.x === from.x && isl.y < from.y) {
[?2004l[?2004h>       if (!best || isl.y > best.y) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'down' && isl.x === from.x && isl.y > from.y) {
[?2004l[?2004h>       if (!best || isl.y < best.y) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return best;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleLabel, setPuzzleLabel] = useState(PUZZLES[0].label);
[?2004l[?2004h>   const puzzle = useMemo(() => getPuzzleByLabel(puzzleLabel), [puzzleLabel]);
[?2004l[?2004h> 
[?2004l[?2004h>   const [bridges, setBridges] = useState(() => new Map());
[?2004l[?2004h>   const [selectedId, setSelectedId] = useState(null);
[?2004l[?2004h>   const [cursorId, setCursorId] = useState(puzzle.islands[0]?.id || null);
[?2004l[?2004h>   const [error, setError] = useState(null);
[?2004l[?2004h> 
