[176.62022, "i", "cat > src/data/puzzles.js <<'EOF'\n// Grid units; each unit is rendered at 40px.\n// Islands: { id, x, y, value } value is required total bridges (1-8)\n\nexport const PUZZLES = [\n  {\n    label: 'Easy',\n    islands: [\n      { id: 'e1', x: 4, y: 3, value: 2 },\n      { id: 'e2', x: 10, y: 3, value: 2 },\n      { id: 'e3', x: 4, y: 9, value: 2 },\n      { id: 'e4', x: 10, y: 9, value: 2 }\n    ]\n  },\n  {\n    label: 'Medium',\n    islands: [\n      { id: 'm1', x: 3, y: 2, value: 3 },\n      { id: 'm2', x: 9, y: 2, value: 3 },\n      { id: 'm3', x: 12, y: 2, value: 2 },\n\n      { id: 'm4', x: 3, y: 6, value: 2 },\n      { id: 'm5', x: 9, y: 6, value: 4 },\n      { id: 'm6', x: 12, y: 6, value: 2 },\n\n      { id: 'm7', x: 3, y: 10, value: 3 },\n      { id: 'm8', x: 9, y: 10, value: 3 },\n      { id: 'm9', x: 12, y: 10, value: 2 }\n    ]\n  },\n  {\n    label: 'Hard',\n    islands: [\n      { id: 'h1', x: 2, y: 2, value: 2 },\n      { id: 'h2', x: 6, y: 2, value: 4 },\n      { id: 'h3', x: 10, y: 2, value: 3 },\n      { id: 'h4', x: 14, y: 2"]
[176.620269, "i", ", value: 2 },\n\n      { id: 'h5', x: 2, y: 6, value: 3 },\n      { id: 'h6', x: 6, y: 6, value: 5 },\n      { id: 'h7', x: 10, y: 6, value: 5 },\n      { id: 'h8', x: 14, y: 6, value: 3 },\n\n      { id: 'h9', x: 2, y: 10, value: 2 },\n      { id: 'h10', x: 6, y: 10, value: 4 },\n      { id: 'h11', x: 10, y: 10, value: 3 },\n      { id: 'h12', x: 14, y: 10, value: 2 }\n    ]\n  }\n];\n\nexport function getPuzzleByLabel(label) {\n  return PUZZLES.find((p) => p.label === label) || PUZZLES[0];\n}\nEOF\n"]
