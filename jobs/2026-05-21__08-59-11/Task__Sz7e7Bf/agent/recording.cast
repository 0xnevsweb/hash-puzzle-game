[177.929068, "i", "cat > src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { PUZZLES, getPuzzleByLabel } from './data/puzzles.js';\nimport {\n  areAdjacent,\n  canonicalBridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n  parseBridgeKey\n} from './utils/hashiLogic.js';\n\nconst UNIT = 40;\nconst W = 800;\nconst H = 600;\n\nfunction px(n) {\n  return n * UNIT;\n}\n\nfunction bridgeLinesPixels(from, to, count) {\n  const x1 = px(from.x);\n  const y1 = px(from.y);\n  const x2 = px(to.x);\n  const y2 = px(to.y);\n\n  if (count === 1) return [{ x1, y1, x2, y2 }];\n  // double: 2 parallel lines offset 4px perpendicular\n  const offset = 4;\n  if (from.x === to.x) {\n    return [\n      { x1: x1 - offset, y1, x2: x2 - offset, y2 },\n      { x1: x1 + offset, y1, x2: x2 + offset, y2 }\n    ];\n  }\n  return [\n    { x1, y1: y1 - offset, x2, y2: y2 - offset },\n    { x1, y1: y1 + offset, x2, y2: y2 + offset }\n  ];\n}\n\nfunction getNeighbors(islands, from, dir) {\n  // return nearest island in direction if aligned"]
[177.929138, "i", "\n  let best = null;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\n      if (!best || isl.x > best.x) best = isl;\n    }\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\n      if (!best || isl.x < best.x) best = isl;\n    }\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\n      if (!best || isl.y > best.y) best = isl;\n    }\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\n      if (!best || isl.y < best.y) best = isl;\n    }\n  }\n  return best;\n}\n\nexport default function App() {\n  const [puzzleLabel, setPuzzleLabel] = useState(PUZZLES[0].label);\n  const puzzle = useMemo(() => getPuzzleByLabel(puzzleLabel), [puzzleLabel]);\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [cursorId, setCursorId] = useState(puzzle.islands[0]?.id || null);\n  const [error, setError] = useState(null);\n\n  const counts = useMemo(() => com"]
[177.929178, "i", "puteCurrentCounts(puzzle.islands, bridges), [puzzle.islands, bridges]);\n  const victory = useMemo(() => isVictory(puzzle.islands, bridges), [puzzle.islands, bridges]);\n\n  const islandsById = useMemo(() => {\n    const m = new Map();\n    for (const isl of puzzle.islands) m.set(isl.id, isl);\n    return m;\n  }, [puzzle.islands]);\n\n  const svgRef = useRef(null);\n\n  useEffect(() => {\n    // On puzzle change: fully reset bridges & selection/cursor\n    setBridges(new Map());\n    setSelectedId(null);\n    setCursorId(puzzle.islands[0]?.id || null);\n    setError(null);\n  }, [puzzleLabel]);\n\n  function applyDelta(from, to, delta) {\n    const res = canAddBridge(puzzle.islands, bridges, from, to, delta);\n    if (!res.valid) {\n      setError(res.error);\n      return;\n    }\n    setError(null);\n\n    const key = canonicalBridgeKey(from, to);\n    const cur = bridges.get(key) || 0;\n    const next = cur + delta;\n    const nb = new Map(bridges);\n    if (next <= 0) nb.delete(key);\n    else nb.set(key, next);\n    setBridges(nb);\n  }"]
[177.929209, "i", "\n\n  function cycleBridge(from, to) {\n    if (!areAdjacent(puzzle.islands, from, to)) {\n      setError('Cannot connect non-adjacent islands');\n      return;\n    }\n    const key = canonicalBridgeKey(from, to);\n    const cur = bridges.get(key) || 0;\n    const next = (cur + 1) % 3; // 0->1->2->0\n\n    const delta = next - cur;\n    if (delta === 0) {\n      setError(null);\n      return;\n    }\n\n    // apply in steps so validation uses correct delta (could be -2 when cycling 2->0)\n    if (delta === -2) {\n      applyDelta(from, to, -1);\n      applyDelta(from, to, -1);\n    } else if (delta === 2) {\n      applyDelta(from, to, 1);\n      applyDelta(from, to, 1);\n    } else {\n      applyDelta(from, to, delta);\n    }\n  }\n\n  function onIslandClick(id) {\n    const isl = islandsById.get(id);\n    if (!isl) return;\n\n    if (!selectedId) {\n      setSelectedId(id);\n      setCursorId(id);\n      return;\n    }\n    if (selectedId === id) {\n      // reselect; no toggle\n      setSelectedId(id);\n      return;\n    }\n    const from = island"]
[177.929229, "i", "sById.get(selectedId);\n    const to = isl;\n    cycleBridge(from, to);\n    setSelectedId(null);\n  }\n\n  function onBridgeToggle(key) {\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const from = puzzle.islands.find((i) => i.x === x1 && i.y === y1);\n    const to = puzzle.islands.find((i) => i.x === x2 && i.y === y2);\n    if (!from || !to) return;\n    cycleBridge(from, to);\n  }\n\n  function resetPuzzle() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n  }\n\n  useEffect(() => {\n    function onKeyDown(e) {\n      if (!puzzle.islands.length) return;\n\n      const cur = islandsById.get(cursorId) || puzzle.islands[0];\n\n      if (e.key === 'Escape') {\n        setSelectedId(null);\n        return;\n      }\n\n      const dirMap = {\n        ArrowLeft: 'left',\n        ArrowRight: 'right',\n        ArrowUp: 'up',\n        ArrowDown: 'down'\n      };\n\n      if (e.key in dirMap) {\n        e.preventDefault();\n        const next = getNeighbors(puzzle.islands, cur, dirMap[e.key]);\n        if (next) setCu"]
[177.929289, "i", "rsorId(next.id);\n        return;\n      }\n\n      if (e.key === 'Enter') {\n        e.preventDefault();\n        if (!selectedId) {\n          setSelectedId(cur.id);\n        } else {\n          const from = islandsById.get(selectedId);\n          const to = cur;\n          if (from && to && from.id !== to.id) {\n            cycleBridge(from, to);\n          }\n          setSelectedId(null);\n        }\n      }\n    }\n\n    window.addEventListener('keydown', onKeyDown);\n    return () => window.removeEventListener('keydown', onKeyDown);\n  }, [cursorId, islandsById, puzzle.islands, selectedId, bridges]);\n\n  const bridgeEntries = useMemo(() => {\n    const arr = [...bridges.entries()].filter(([, n]) => n > 0);\n    arr.sort((a, b) => a[0].localeCompare(b[0]));\n    return arr;\n  }, [bridges]);\n\n  return (\n    <>\n      <div className=\"controls\">\n        <label>\n          Puzzle:{' '}\n          <select\n            value={puzzleLabel}\n            onChange={(e) => setPuzzleLabel(e.target.value)}\n          >\n            {PUZZLES.map((p"]
[177.929518, "i", ") => (\n              <option key={p.label} value={p.label}>\n                {p.label}\n              </option>\n            ))}\n          </select>\n        </label>\n        <button onClick={resetPuzzle}>Reset</button>\n\n        {error ? <div className=\"error-message\">{error}</div> : null}\n        {victory ? <div className=\"victory-banner\">SOLVED!</div> : null}\n      </div>\n\n      <svg\n        ref={svgRef}\n        className=\"board\"\n        width={W}\n        height={H}\n        viewBox={`0 0 ${W} ${H}`}\n      >\n        {/* Bridges */}\n        <g stroke=\"#00ff66\" strokeWidth=\"3\" strokeLinecap=\"round\">\n          {bridgeEntries.map(([key, n]) => {\n            const { x1, y1, x2, y2 } = parseBridgeKey(key);\n            const a = puzzle.islands.find((i) => i.x === x1 && i.y === y1);\n            const b = puzzle.islands.find((i) => i.x === x2 && i.y === y2);\n            if (!a || !b) return null;\n            const lines = bridgeLinesPixels(a, b, n);\n\n            return (\n              <g\n                key={key}\n       "]
[177.930605, "i", "         onContextMenu={(e) => {\n                  e.preventDefault();\n                  onBridgeToggle(key);\n                }}\n                onClick={(e) => {\n                  if (e.ctrlKey) onBridgeToggle(key);\n                }}\n                style={{ cursor: 'pointer' }}\n              >\n                {lines.map((ln, idx) => (\n                  <line\n                    key={idx}\n                    x1={ln.x1}\n                    y1={ln.y1}\n                    x2={ln.x2}\n                    y2={ln.y2}\n                  />\n                ))}\n                {/* Hit area */}\n                <line\n                  x1={px(a.x)}\n                  y1={px(a.y)}\n                  x2={px(b.x)}\n                  y2={px(b.y)}\n                  stroke=\"transparent\"\n                  strokeWidth=\"14\"\n                />\n              </g>\n            );\n          })}\n        </g>\n\n        {/* Cursor (not a circle) */}\n        {cursorId ? (() => {\n          const c = islandsById.get(cursorId);\n          if (!c)"]
[177.930872, "i", " return null;\n          const size = 26;\n          return (\n            <rect\n              x={px(c.x) - size / 2}\n              y={px(c.y) - size / 2}\n              width={size}\n              height={size}\n              fill=\"none\"\n              stroke={selectedId ? '#ffcc00' : '#00ff66'}\n              strokeWidth=\"2\"\n            />\n          );\n        })() : null}\n\n        {/* Islands */}\n        <g>\n          {puzzle.islands.map((isl) => {\n            const isSelected = selectedId === isl.id;\n            const curCount = counts.get(isl.id) || 0;\n            const satisfied = curCount === isl.value;\n\n            return (\n              <g\n                key={isl.id}\n                transform={`translate(${px(isl.x)}, ${px(isl.y)})`}\n                onClick={() => onIslandClick(isl.id)}\n                style={{ cursor: 'pointer' }}\n              >\n                <circle\n                  r={14}\n                  fill=\"#000\"\n                  stroke={isSelected ? '#ffcc00' : satisfied ? '#00ff66' : '#00aa44"]
[177.931027, "i", "'}\n                  strokeWidth={2}\n                />\n                <text\n                  x={0}\n                  y={5}\n                  textAnchor=\"middle\"\n                  fontSize=\"14\"\n                  fill=\"#00ff66\"\n                >\n                  {isl.value}\n                </text>\n              </g>\n            );\n          })}\n        </g>\n      </svg>\n    </>\n  );\n}\nEOF\n"]
