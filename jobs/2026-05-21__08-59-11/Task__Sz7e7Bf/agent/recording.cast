[177.675804, "i", "cat > src/styles.css <<'EOF'\n:root{\n  --bg:#000;\n  --fg:#00ff66;\n  --dim:#00aa44;\n  --warn:#ffcc00;\n}\nhtml, body {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background: var(--bg);\n  color: var(--fg);\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n}\n#root{\n  width: 100%;\n  height: 100%;\n}\n\n.controls{\n  position: fixed;\n  left: 0;\n  top: 0;\n  z-index: 5;\n  padding: 8px;\n  background: rgba(0,0,0,0.85);\n  border-right: 1px solid var(--dim);\n  border-bottom: 1px solid var(--dim);\n}\n\nselect, button{\n  background: #000;\n  color: var(--fg);\n  border: 1px solid var(--dim);\n  padding: 6px 8px;\n  margin-right: 8px;\n}\nbutton:hover, select:hover{ border-color: var(--fg); }\n\n.error-message{\n  margin-top: 8px;\n  color: var(--warn);\n}\n\n.victory-banner{\n  margin-top: 8px;\n  padding: 6px 8px;\n  border: 1px solid var(--fg);\n  display: inline-block;\n}\n\nsvg.board{\n  position: fixed;\n  left: 0;\n  top: 0;\n}\nEOF\n"]
