[120.522166, "i", "j < segs.length; j++) {\n+      const a = segs[i];\n+      const b = segs[j];\n+      if (a.vertical === b.vertical) continue;\n+      const v = a.vertical ? a : b;\n+      const h = a.vertical ? b : a;\n+      const vx = v.x1;\n+      const vyMin = Math.min(v.y1, v.y2);\n+      const vyMax = Math.max(v.y1, v.y2);\n+      const hy = h.y1;\n+      const hxMin = Math.min(h.x1, h.x2);\n+      const hxMax = Math.max(h.x1, h.x2);\n+      const withinV = hy > vyMin && hy < vyMax;\n+      const withinH = vx > hxMin && vx < hxMax;\n+      if (withinV && withinH) return true;\n+    }\n+  }\n+  return false;\n+}\n+\n+export function isVictory(islands, bridges) {\n+  const counts = computeCurrentCounts(islands, bridges);\n+  for (const i of islands) {\n+    if ((counts.get(i.id) || 0) !== i.value) return false;\n+  }\n+  if (bridgesCross(bridges)) return false;\n+  if (!checkConnectivity(islands, bridges)) return false;\n+  return true;\n+}\n+\n+export const ERROR_TEXTS = {\n+  ERR_NON_ADJ,\n+  ERR_MAX2,\n+  ERR_EXCEED,\n+  ERR_CROSS\n+};\n+\n*** End Patch"]
