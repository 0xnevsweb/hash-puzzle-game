[203.446969, "i", "cat > src/styles.css <<'EOF'\n:root {\n  color-scheme: dark;\n}\n\nhtml,\nbody {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background: #000;\n  color: #00ff66;\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\",\n    \"Courier New\", monospace;\n}\n\n#root {\n  margin: 0;\n  padding: 0;\n}\n\n.hud {\n  position: absolute;\n  top: 0;\n  left: 0;\n  padding: 8px;\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  z-index: 2;\n}\n\nselect,\nbutton {\n  background: #000;\n  color: #00ff66;\n  border: 1px solid #00ff66;\n  padding: 6px 8px;\n  font: inherit;\n}\n\nbutton:active {\n  transform: translateY(1px);\n}\n\n.error-message {\n  position: absolute;\n  left: 8px;\n  top: 44px;\n  color: #00ff66;\n  border: 1px dashed #00ff66;\n  padding: 6px 8px;\n  background: rgba(0, 0, 0, 0.75);\n  z-index: 2;\n  max-width: 780px;\n}\n\n.victory-banner {\n  position: absolute;\n  left: 8px;\n  top: 44px;\n  border: 2px solid #00ff66;\n  padding: 8px 10px;\n  background: rgba(0, 0, 0, 0.85);\n  font-weight: 700;\n  letter-"]
[203.447488, "i", "spacing: 1px;\n  z-index: 3;\n}\n\n.board {\n  position: absolute;\n  top: 0;\n  left: 0;\n}\nEOF\n"]
