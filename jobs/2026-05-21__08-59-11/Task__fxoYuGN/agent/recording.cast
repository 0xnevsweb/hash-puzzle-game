[120.520847, "i", "apply_patch<<'PATCH'\n*** Begin Patch\n*** Add File: src/utils/hashiLogic.js\n+const ERR_NON_ADJ = 'Cannot connect non-adjacent islands';\n+const ERR_MAX2 = 'Max 2 bridges per pair';\n+const ERR_EXCEED = 'Island would exceed its number';\n+const ERR_CROSS = 'Bridges would cross';\n+\n+export function canonicalKey(from, to) {\n+  const a = { x: from.x, y: from.y };\n+  const b = { x: to.x, y: to.y };\n+  const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;\n+  const second = first === a ? b : a;\n+  return `${first.x},${first.y},${second.x},${second.y}`;\n+}\n+\n+export function parseKey(key) {\n+  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));\n+  return { x1, y1, x2, y2 };\n+}\n+\n+function islandAt(islands, x, y) {\n+  return islands.find((i) => i.x === x && i.y === y) || null;\n+}\n+\n+export function areAdjacent(islands, a, b) {\n+  if (!a || !b) return false;\n+  if (a.x !== b.x && a.y !== b.y) return false;\n+\n+  if (a.x === b.x) {\n+    const yMin = Math.min(a.y, b.y);\n+    const yMax = Math.max(a.y, b.y"]
[120.521125, "i", ");\n+    for (let y = yMin + 1; y <= yMax - 1; y++) {\n+      if (islandAt(islands, a.x, y)) return false;\n+    }\n+    return true;\n+  }\n+\n+  const xMin = Math.min(a.x, b.x);\n+  const xMax = Math.max(a.x, b.x);\n+  for (let x = xMin + 1; x <= xMax - 1; x++) {\n+    if (islandAt(islands, x, a.y)) return false;\n+  }\n+  return true;\n+}\n+\n+function segmentsFromBridges(bridges) {\n+  const segs = [];\n+  for (const [key, count] of bridges.entries()) {\n+    if (!count) continue;\n+    const { x1, y1, x2, y2 } = parseKey(key);\n+    const vertical = x1 === x2;\n+    segs.push({ x1, y1, x2, y2, vertical, key });\n+  }\n+  return segs;\n+}\n+\n+function wouldCrossExisting(bridges, from, to) {\n+  // Crossing only occurs when one is horizontal and the other is vertical,\n+  // and their interiors intersect (not at endpoints).\n+  const newVertical = from.x === to.x;\n+  const segs = segmentsFromBridges(bridges);\n+  const nx1 = from.x;\n+  const ny1 = from.y;\n+  const nx2 = to.x;\n+  const ny2 = to.y;\n+  const nMinX = Math.min(nx1, nx2);\n+"]
[120.521929, "o", "apply_patch<<'PATCH'"]
[120.522015, "i", "  const nMaxX = Math.max(nx1, nx2);\n+  const nMinY = Math.min(ny1, ny2);\n+  const nMaxY = Math.max(ny1, ny2);\n+\n+  for (const s of segs) {\n+    if (s.vertical === newVertical) continue;\n+\n+    if (newVertical) {\n+      // new is vertical, existing is horizontal\n+      const vx = nx1;\n+      const vyMin = nMinY;\n+      const vyMax = nMaxY;\n+      const hy = s.y1;\n+      const hxMin = Math.min(s.x1, s.x2);\n+      const hxMax = Math.max(s.x1, s.x2);\n+\n+      const crossX = vx;\n+      const crossY = hy;\n+\n+      const withinV = crossY > vyMin && crossY < vyMax;\n+      const withinH = crossX > hxMin && crossX < hxMax;\n+      if (withinV && withinH) return true;\n+    } else {\n+      // new is horizontal, existing is vertical\n+      const hy = ny1;\n+      const hxMin = nMinX;\n+      const hxMax = nMaxX;\n+      const vx = s.x1;\n+      const vyMin = Math.min(s.y1, s.y2);\n+      const vyMax = Math.max(s.y1, s.y2);\n+\n+      const crossX = vx;\n+      const crossY = hy;\n+\n+      const withinH = crossX > hxMin && crossX < "]
[120.52204, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> *** Begin Patch"]
[120.522068, "i", "hxMax;\n+      const withinV = crossY > vyMin && crossY < vyMax;\n+      if (withinH && withinV) return true;\n+    }\n+  }\n+  return false;\n+}\n+\n+export function computeCurrentCounts(islands, bridges) {\n+  const counts = new Map();\n+  for (const i of islands) counts.set(i.id, 0);\n+\n+  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n+  for (const [key, n] of bridges.entries()) {\n+    if (!n) continue;\n+    const { x1, y1, x2, y2 } = parseKey(key);\n+    const i1 = byCoord.get(`${x1},${y1}`);\n+    const i2 = byCoord.get(`${x2},${y2}`);\n+    if (!i1 || !i2) continue;\n+    counts.set(i1.id, (counts.get(i1.id) || 0) + n);\n+    counts.set(i2.id, (counts.get(i2.id) || 0) + n);\n+  }\n+  return counts;\n+}\n+\n+export function canAddBridge(islands, bridges, from, to, delta) {\n+  if (!areAdjacent(islands, from, to)) {\n+    return { valid: false, error: ERR_NON_ADJ };\n+  }\n+\n+  const key = canonicalKey(from, to);\n+  const existing = bridges.get(key) || 0;\n+  const next = existing + delta;\n+  if (next < 0) ret"]
[120.522094, "i", "urn { valid: true, error: null };\n+  if (next > 2) return { valid: false, error: ERR_MAX2 };\n+\n+  // crossing check only when adding (> existing)\n+  if (delta > 0) {\n+    // Temporarily consider the segment exists (even if it already exists, crossing would\n+    // already be present, but we still prevent adding into crossing situations).\n+    if (wouldCrossExisting(bridges, from, to)) {\n+      return { valid: false, error: ERR_CROSS };\n+    }\n+  }\n+\n+  // Island count exceed check\n+  const counts = computeCurrentCounts(islands, bridges);\n+  const fromIsland = islands.find((i) => i.x === from.x && i.y === from.y) || from;\n+  const toIsland = islands.find((i) => i.x === to.x && i.y === to.y) || to;\n+\n+  const fromCount = counts.get(fromIsland.id) || 0;\n+  const toCount = counts.get(toIsland.id) || 0;\n+\n+  if (delta > 0) {\n+    if (fromCount + delta > fromIsland.value || toCount + delta > toIsland.value) {\n+      return { valid: false, error: ERR_EXCEED };\n+    }\n+  }\n+\n+  return { valid: true, error: null };\n+}"]
[120.522127, "i", "\n+\n+export function checkConnectivity(islands, bridges) {\n+  if (islands.length <= 1) return true;\n+  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n+\n+  const adj = new Map(islands.map((i) => [i.id, new Set()]));\n+  for (const [key, n] of bridges.entries()) {\n+    if (!n) continue;\n+    const { x1, y1, x2, y2 } = parseKey(key);\n+    const a = byCoord.get(`${x1},${y1}`);\n+    const b = byCoord.get(`${x2},${y2}`);\n+    if (!a || !b) continue;\n+    adj.get(a.id).add(b.id);\n+    adj.get(b.id).add(a.id);\n+  }\n+\n+  const start = islands[0].id;\n+  const seen = new Set([start]);\n+  const queue = [start];\n+  while (queue.length) {\n+    const cur = queue.shift();\n+    for (const nb of adj.get(cur) || []) {\n+      if (!seen.has(nb)) {\n+        seen.add(nb);\n+        queue.push(nb);\n+      }\n+    }\n+  }\n+  return seen.size === islands.length;\n+}\n+\n+export function bridgesCross(bridges) {\n+  const segs = segmentsFromBridges(bridges);\n+  for (let i = 0; i < segs.length; i++) {\n+    for (let j = i + 1; "]
