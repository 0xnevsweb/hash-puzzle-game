[?2004l[?2004h>   const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>   const i1 = byCoord.get(`${from.x},${from.y}`);
[?2004l[?2004h>   const i2 = byCoord.get(`${to.x},${to.y}`);
[?2004l[?2004h>   const after1 = (counts.get(i1.id) || 0) + delta;
[?2004l[?2004h>   const after2 = (counts.get(i2.id) || 0) + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (after1 > i1.value || after2 > i2.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
