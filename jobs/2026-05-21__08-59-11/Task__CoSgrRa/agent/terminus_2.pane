[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!from || !to) return false;
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const step = Math.sign(to.y - from.y);
[?2004l[?2004h>     for (let yy = from.y + step; yy !== to.y; yy += step) {
[?2004l[?2004h>       if (byCoord.has(`${from.x},${yy}`)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   const step = Math.sign(to.x - from.x);
[?2004l[?2004h>   for (let xx = from.x + step; xx !== to.x; xx += step) {
[?2004l[?2004h>     if (byCoord.has(`${xx},${from.y}`)) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
