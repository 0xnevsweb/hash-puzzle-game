[?2004l[?2004h>       from: { x: Math.min(from.x, to.x), y: Math.min(from.y, to.y) },
[?2004l[?2004h>       to: { x: Math.max(from.x, to.x), y: Math.max(from.y, to.y) },
[?2004l[?2004h>       key,
[?2004l[?2004h>     };
[?2004l[?2004h>     if (crossesAny(bridges, candidateSeg, null)) {
