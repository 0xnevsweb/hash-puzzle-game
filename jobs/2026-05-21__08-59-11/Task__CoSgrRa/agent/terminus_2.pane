[?2004l[?2004hroot@4835e4e0af8a:/app# cat > /app/src/utils/hashiLogic.js <<'EOF'
[?2004l[?2004h> const ERR_NON_ADJ = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> const ERR_MAX2 = 'Max 2 bridges per pair';
[?2004l[?2004h> const ERR_EXCEED = 'Island would exceed its number';
[?2004l[?2004h> const ERR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   if (a.x < b.x || (a.x === b.x && a.y <= b.y)) {
[?2004l[?2004h>     return `${a.x},${a.y},${b.x},${b.y}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${b.x},${b.y},${a.x},${a.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isSamePoint(p, q) {
[?2004l[?2004h>   return p.x === q.x && p.y === q.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function getSegments(islands, bridges) {
[?2004l[?2004h>   // return list of segments in grid units: { from:{x,y}, to:{x,y}, key }
[?2004l[?2004h>   const segs = [];
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     segs.push({ from: { x: x1, y: y1 }, to: { x: x2, y: y2 }, key, count });
[?2004l[?2004h>   }
[?2004l[?2004h>   return segs;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(v, a, b) {
[?2004l[?2004h>   const lo = Math.min(a, b);
[?2004l[?2004h>   const hi = Math.max(a, b);
[?2004l[?2004h>   return v > lo && v < hi;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(s1, s2) {
[?2004l[?2004h>   // Only consider proper crossings (interior intersection). Shared endpoints are allowed.
[?2004l[?2004h>   const a = s1.from, b = s1.to;
[?2004l[?2004h>   const c = s2.from, d = s2.to;
[?2004l[?2004h>   const s1H = a.y === b.y;
[?2004l[?2004h>   const s2H = c.y === d.y;
[?2004l[?2004h>   const s1V = a.x === b.x;
[?2004l[?2004h>   const s2V = c.x === d.x;
[?2004l[?2004h> 
[?2004l[?2004h>   if ((s1H && s2H) || (s1V && s2V)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   let h, v;
[?2004l[?2004h>   if (s1H && s2V) {
[?2004l[?2004h>     h = s1; v = s2;
[?2004l[?2004h>   } else if (s1V && s2H) {
[?2004l[?2004h>     h = s2; v = s1;
[?2004l[?2004h>   } else {
[?2004l[?2004h>     return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const hy = h.from.y;
[?2004l[?2004h>   const vx = v.from.x;
[?2004l[?2004h> 
[?2004l[?2004h>   // Check intersection point is strictly inside both segments
[?2004l[?2004h>   if (!between(vx, h.from.x, h.to.x)) return false;
[?2004l[?2004h>   if (!between(hy, v.from.y, v.to.y)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // Exclude if intersection is at an endpoint (should already be excluded by between)
[?2004l[?2004h>   const p = { x: vx, y: hy };
