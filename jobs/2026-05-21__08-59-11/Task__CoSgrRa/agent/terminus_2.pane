[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length <= 1) return true;
[?2004l[?2004h>   const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>   const adj = new Map(islands.map(i => [i.id, new Set()]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const a = byCoord.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byCoord.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).add(b.id);
[?2004l[?2004h>     adj.get(b.id).add(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   const stack = [start];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     for (const nxt of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt);
[?2004l[?2004h>         stack.push(nxt);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function hasAnyCrossing(bridges) {
[?2004l[?2004h>   const segs = getSegments(null, bridges);
[?2004l[?2004h>   for (let i = 0; i < segs.length; i++) {
