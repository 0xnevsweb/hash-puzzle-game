[?2004l[?2004h> export function nextIslandByArrow(islands, currentIsland, key) {
[?2004l[?2004h>   const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>   const dir =
[?2004l[?2004h>     key === 'ArrowLeft' ? 'left' :
[?2004l[?2004h>     key === 'ArrowRight' ? 'right' :
[?2004l[?2004h>     key === 'ArrowUp' ? 'up' :
[?2004l[?2004h>     key === 'ArrowDown' ? 'down' : null;
[?2004l[?2004h>   if (!dir) return null;
