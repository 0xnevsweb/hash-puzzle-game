[?2004l[?2004h>   }
[?2004l[?2004h>   if (dir === 'right') {
[?2004l[?2004h>     for (let xx = x + 1; xx <= 100; xx++) {
[?2004l[?2004h>       const hit = islandsByCoord.get(`${xx},${y}`);
[?2004l[?2004h>       if (hit) return hit;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   if (dir === 'up') {
[?2004l[?2004h>     for (let yy = y - 1; yy >= 0; yy--) {
