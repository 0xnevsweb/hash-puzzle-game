[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function bridgeUnderPointer(islands, bridges, svgPoint, tolerancePx = 8) {
[?2004l[?2004h>   // svgPoint in px coords.
[?2004l[?2004h>   // For each bridge segment, compute distance to segment (axis-aligned).
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = { x: px(x1), y: px(y1) };
[?2004l[?2004h>     const b = { x: px(x2), y: px(y2) };
[?2004l[?2004h> 
[?2004l[?2004h>     if (a.x === b.x) {
[?2004l[?2004h>       const x = a.x;
[?2004l[?2004h>       const yMin = Math.min(a.y, b.y);
[?2004l[?2004h>       const yMax = Math.max(a.y, b.y);
[?2004l[?2004h>       if (Math.abs(svgPoint.x - x) <= tolerancePx && svgPoint.y >= yMin && svgPoint.y <= yMax) {
[?2004l[?2004h>         return { key, count };
[?2004l[?2004h>       }
[?2004l[?2004h>     } else if (a.y === b.y) {
[?2004l[?2004h>       const y = a.y;
[?2004l[?2004h>       const xMin = Math.min(a.x, b.x);
[?2004l[?2004h>       const xMax = Math.max(a.x, b.x);
[?2004l[?2004h>       if (Math.abs(svgPoint.y - y) <= tolerancePx && svgPoint.x >= xMin && svgPoint.x <= xMax) {
[?2004l[?2004h>         return { key, count };
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return null;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleIndex, setPuzzleIndex] = useState(0);
[?2004l[?2004h>   const puzzle = puzzles[puzzleIndex];
[?2004l[?2004h>   const islands = puzzle.islands;
[?2004l[?2004h> 
[?2004l[?2004h>   const [bridges, setBridges] = useState(() => new Map());
[?2004l[?2004h>   const [selectedIslandId, setSelectedIslandId] = useState(null);
[?2004l[?2004h>   const [cursorIslandId, setCursorIslandId] = useState(islands[0]?.id ?? null);
[?2004l[?2004h>   const [mode, setMode] = useState('idle'); // idle | choosingTarget
[?2004l[?2004h>   const [error, setError] = useState(null);
[?2004l[?2004h> 
[?2004l[?2004h>   const svgRef = useRef(null);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     // puzzle change: fully reset
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedIslandId(null);
[?2004l[?2004h>     setCursorIslandId(puzzles[puzzleIndex].islands[0]?.id ?? null);
[?2004l[?2004h>     setMode('idle');
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>   }, [puzzleIndex]);
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);
[?2004l[?2004h>   const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);
[?2004l[?2004h> 
[?2004l[?2004h>   const selectedIsland = useMemo(
[?2004l[?2004h>     () => islands.find(i => i.id === selectedIslandId) || null,
[?2004l[?2004h>     [islands, selectedIslandId]
[?2004l[?2004h>   );
[?2004l[?2004h> 
[?2004l[?2004h>   const cursorIsland = useMemo(
[?2004l[?2004h>     () => islands.find(i => i.id === cursorIslandId) || islands[0] || null,
[?2004l[?2004h>     [islands, cursorIslandId]
[?2004l[?2004h>   );
[?2004l[?2004h> 
[?2004l[?2004h>   function clearErrorOnValidMove(valid) {
[?2004l[?2004h>     if (valid) setError(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function applyToggleBridge(from, to, direction = +1) {
[?2004l[?2004h>     // direction +1 cycles upward; -1 cycles downward
[?2004l[?2004h>     const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>     const current = bridges.get(key) || 0;
[?2004l[?2004h>     const delta = direction;
[?2004l[?2004h>     const { valid, error: err } = canAddBridge(islands, bridges, from, to, delta);
[?2004lror([?2004h>     if (!valid) {
[?2004l[?2004h>       setError(err);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const next = current + delta;
[?2004l[?2004h>     const nextClamped = ((next % 3) + 3) % 3; // handles -1 case
[?2004l[?2004h> 
[?2004l[?2004h>     // If we were allowed to decrement below 0, normalize here
[?2004l[?2004h>     const newMap = new Map(bridges);
[?2004l[?2004h>     if (nextClamped === 0) newMap.delete(key);
[?2004l[?2004h>     else newMap.set(key, nextClamped);
[?2004l[?2004h>     setBridges(newMap);
[?2004l[?2004h>     clearErrorOnValidMove(true);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function cycleBridge(from, to) {
[?2004l[?2004h>     const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>     const current = bridges.get(key) || 0;
[?2004l[?2004h>     const target = (current + 1) % 3;
[?2004l[?2004h> 
[?2004l[?2004h>     // Determine intended delta (+1, +1, or -2 in terms of cycling 2->0)
[?2004l[?2004h>     // We'll apply step-by-step to validate constraints properly.
[?2004l[?2004h>     if (target === current) return;
[?2004l[?2004h> 
[?2004l[?2004h>     if (current === 0 && target === 1) {
[?2004l[?2004h>       const res = canAddBridge(islands, bridges, from, to, +1);
[?2004l[?2004h>       if (!res.valid) return setError(res.error);
[?2004l[?2004h>       const m = new Map(bridges);
[?2004l[?2004h>       m.set(key, 1);
[?2004l[?2004h>       setBridges(m);
[?2004l[?2004h>       return clearErrorOnValidMove(true);
[?2004l[?2004h>     }
[?2004l[?2004h>     if (current === 1 && target === 2) {
[?2004l[?2004h>       const res = canAddBridge(islands, bridges, from, to, +1);
[?2004l[?2004h>       if (!res.valid) return setError(res.error);
[?2004l[?2004h>       const m = new Map(bridges);
[?2004l[?2004h>       m.set(key, 2);
[?2004l[?2004h>       setBridges(m);
[?2004l[?2004h>       return clearErrorOnValidMove(true);
[?2004l[?2004h>     }
[?2004l[?2004h>     if (current === 2 && target === 0) {
[?2004l[?2004h>       const m = new Map(bridges);
[?2004l[?2004h>       m.delete(key);
[?2004l[?2004h>       setBridges(m);
[?2004l[?2004h>       return clearErrorOnValidMove(true);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function handleIslandClick(isl) {
[?2004l[?2004h>     if (!selectedIslandId) {
[?2004l[?2004h>       setSelectedIslandId(isl.id);
[?2004l[?2004h>       setCursorIslandId(isl.id);
[?2004l[?2004h>       setMode('idle');
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (selectedIslandId === isl.id) {
[?2004l[?2004h>       // reselect same island
[?2004l[?2004h>       setCursorIslandId(isl.id);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h>     const from = islands.find(i => i.id === selectedIslandId);
[?2004l[?2004h>     const to = isl;
[?2004l[?2004h>     // second click toggles
[?2004l[?2004h>     const resAdj = areAdjacent(islands, from, to);
[?2004l[?2004h>     if (!resAdj) {
[?2004l[?2004h>       setError('Cannot connect non-adjacent islands');
[?2004l[?2004h>       setSelectedIslandId(null);
