[?2004l[?2004h>   if (dir === 'down') {
[?2004l[?2004h>     for (let yy = y + 1; yy <= 100; yy++) {
[?2004l[?2004h>       const hit = islandsByCoord.get(`${x},${yy}`);
[?2004l[?2004h>       if (hit) return hit;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return null;
[?2004l[?2004h> }
