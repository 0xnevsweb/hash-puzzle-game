[112.668782, "i", "cat > /app/src/utils/hashiLogic.js <<'EOF'\nconst ERR_NON_ADJ = 'Cannot connect non-adjacent islands';\nconst ERR_MAX2 = 'Max 2 bridges per pair';\nconst ERR_EXCEED = 'Island would exceed its number';\nconst ERR_CROSS = 'Bridges would cross';\n\nexport function canonicalBridgeKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  if (a.x < b.x || (a.x === b.x && a.y <= b.y)) {\n    return `${a.x},${a.y},${b.x},${b.y}`;\n  }\n  return `${b.x},${b.y},${a.x},${a.y}`;\n}\n\nfunction isSamePoint(p, q) {\n  return p.x === q.x && p.y === q.y;\n}\n\nfunction getSegments(islands, bridges) {\n  // return list of segments in grid units: { from:{x,y}, to:{x,y}, key }\n  const segs = [];\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    segs.push({ from: { x: x1, y: y1 }, to: { x: x2, y: y2 }, key, count });\n  }\n  return segs;\n}\n\nfunction between(v, a, b) {\n  const lo = Math.min(a, b);\n  const hi = Math.max(a, b);\n  ret"]
[112.668824, "i", "urn v > lo && v < hi;\n}\n\nfunction segmentsCross(s1, s2) {\n  // Only consider proper crossings (interior intersection). Shared endpoints are allowed.\n  const a = s1.from, b = s1.to;\n  const c = s2.from, d = s2.to;\n  const s1H = a.y === b.y;\n  const s2H = c.y === d.y;\n  const s1V = a.x === b.x;\n  const s2V = c.x === d.x;\n\n  if ((s1H && s2H) || (s1V && s2V)) return false;\n\n  let h, v;\n  if (s1H && s2V) {\n    h = s1; v = s2;\n  } else if (s1V && s2H) {\n    h = s2; v = s1;\n  } else {\n    return false;\n  }\n\n  const hy = h.from.y;\n  const vx = v.from.x;\n\n  // Check intersection point is strictly inside both segments\n  if (!between(vx, h.from.x, h.to.x)) return false;\n  if (!between(hy, v.from.y, v.to.y)) return false;\n\n  // Exclude if intersection is at an endpoint (should already be excluded by between)\n  const p = { x: vx, y: hy };\n  if (isSamePoint(p, h.from) || isSamePoint(p, h.to) || isSamePoint(p, v.from) || isSamePoint(p, v.to)) {\n    return false;\n  }\n  return true;\n}\n\nfunction crossesAny(existingBridges, can"]
