[112.669619, "i", "},${y}`);\n      if (hit) return hit;\n    }\n  }\n  if (dir === 'right') {\n    for (let xx = x + 1; xx <= 100; xx++) {\n      const hit = islandsByCoord.get(`${xx},${y}`);\n      if (hit) return hit;\n    }\n  }\n  if (dir === 'up') {\n    for (let yy = y - 1; yy >= 0; yy--) {\n      const hit = islandsByCoord.get(`${x},${yy}`);\n      if (hit) return hit;\n    }\n  }\n  if (dir === 'down') {\n    for (let yy = y + 1; yy <= 100; yy++) {\n      const hit = islandsByCoord.get(`${x},${yy}`);\n      if (hit) return hit;\n    }\n  }\n  return null;\n}\n\nexport function areAdjacent(islands, from, to) {\n  if (!from || !to) return false;\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n\n  const byCoord = new Map(islands.map(i => [`${i.x},${i.y}`, i]));\n  if (from.x === to.x) {\n    const step = Math.sign(to.y - from.y);\n    for (let yy = from.y + step; yy !== to.y; yy += step) {\n      if (byCoord.has(`${from.x},${yy}`)) return false;\n    }\n    return true;\n  }\n  const step = M"]
