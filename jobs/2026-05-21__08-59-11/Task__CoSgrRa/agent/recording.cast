[113.049057, "i", "   if (count === 1) {\n      bridgeLines.push(\n        <line\n          key={key}\n          x1={a.x}\n          y1={a.y}\n          x2={b.x}\n          y2={b.y}\n          stroke={stroke}\n          strokeWidth={width}\n          shapeRendering=\"crispEdges\"\n        />\n      );\n    } else if (count === 2) {\n      if (isH) {\n        bridgeLines.push(\n          <g key={key}>\n            <line x1={a.x} y1={a.y - off} x2={b.x} y2={b.y - off} stroke={stroke} strokeWidth={width} shapeRendering=\"crispEdges\" />\n            <line x1={a.x} y1={a.y + off} x2={b.x} y2={b.y + off} stroke={stroke} strokeWidth={width} shapeRendering=\"crispEdges\" />\n          </g>\n        );\n      } else {\n        bridgeLines.push(\n          <g key={key}>\n            <line x1={a.x - off} y1={a.y} x2={b.x - off} y2={b.y} stroke={stroke} strokeWidth={width} shapeRendering=\"crispEdges\" />\n            <line x1={a.x + off} y1={a.y} x2={b.x + off} y2={b.y} stroke={stroke} strokeWidth={width} shapeRendering=\"crispEdges\" />\n          </g>\n        );\n      }\n"]
