[112.005912, "i", "cat > /app/src/index.css <<'EOF'\n:root{\n  --bg:#000;\n  --fg:#00ff66;\n  --fg-dim:#00aa44;\n  --danger:#ff4466;\n}\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background: var(--bg);\n  color: var(--fg);\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n}\n\n#root {\n  width: 100%;\n  height: 100%;\n}\n\nbutton, select {\n  background: #000;\n  color: var(--fg);\n  border: 1px solid var(--fg);\n  padding: 6px 10px;\n  font: inherit;\n}\n\nbutton:hover, select:hover { border-color: #7CFFAA; }\n\n.controls {\n  position: fixed;\n  left: 0;\n  top: 0;\n  padding: 8px;\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  z-index: 10;\n  background: rgba(0,0,0,0.6);\n}\n\n.error-message {\n  position: fixed;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  color: var(--danger);\n  z-index: 10;\n  background: rgba(0,0,0,0.6);\n}\n\n.victory-banner {\n  position: fixed;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  color: #000;\n  background: var(--fg);\n  z-index: 11;\n  "]
