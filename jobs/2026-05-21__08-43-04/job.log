Sending keys: ['cat > src/utils/hashiLogic.js <<\'EOF\'\n// Hashi (Bridges) logic utilities.\n// Bridges are stored as Map<string, number> where key is "x1,y1,x2,y2" in grid units,\n// canonicalized so the smaller endpoint (x then y) comes first.\n\nexport const ERRORS = {\n  NON_ADJ: \'Cannot connect non-adjacent islands\',\n  MAX_PAIR: \'Max 2 bridges per pair\',\n  EXCEED: \'Island would exceed its number\',\n  CROSS: \'Bridges would cross\'\n};\n\nexport function canonicalKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const first = (a.x < b.x) || (a.x === b.x && a.y < b.y) ? a : b;\n  const second = first === a ? b : a;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nexport function parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nexport function isAligned(from, to) {\n  return from.x === to.x || from.y === to.y;\n}\n\nexport function islandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y) || null;\n}\n\nexport function areAdjacent(islands, from, to) {\n  if (!isAligned(from, to)) return false;\n  const dx = Math.sign(to.x - from.x);\n  const dy = Math.sign(to.y - from.y);\n  let x = from.x + dx;\n  let y = from.y + dy;\n  while (x !== to.x || y !== to.y) {\n    if (islandAt(islands, x, y)) return false;\n    x += dx;\n    y += dy;\n  }\n  return true;\n}\n\nfunction segmentsCross(segA, segB) {\n  // seg: {x1,y1,x2,y2} aligned axis.\n  const aVert = segA.x1 === segA.x2;\n  const bVert = segB.x1 === segB.x2;\n\n  // Parallel segments cannot "cross" in Hashi sense (overlap). We only treat perpendicular intersections.\n  if (aVert === bVert) return false;\n\n  const v = aVert ? segA : segB;\n  const h = aVert ? segB : segA;\n\n  const vx = v.x1;\n  const vyMin = Math.min(v.y1, v.y2);\n  const vyMax = Math.max(v.y1, v.y2);\n\n  const hy = h.y1;\n  const hxMin = Math.min(h.x1, h.x2);\n  const hxMax = Math.max(h.x1, h.x2);\n\n  const intersects = (vx > hxMin && vx < hxMax && hy > vyMin && hy < vyMax);\n  return intersects;\n}\n\nexport function bridgesWouldCross(bridges, newSegKey) {\n  const newSeg = parseKey(newSegKey);\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    if (key === newSegKey) continue;\n    const seg = parseKey(key);\n    if (segmentsCross(newSeg, seg)) return true;\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map(islands.map((i) => [i.id, 0]));\n  // index by coordinate to island id\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n\n  for (const [key, num] of bridges.entries()) {\n    if (!num) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const id1 = posToId.get(`${x1},${y1}`);\n    const id2 = posToId.get(`${x2},${y2}`);\n    if (!id1 || !id2) continue;\n    counts.set(id1, (counts.get(id1) || 0) + num);\n    counts.set(id2, (counts.get(id2) || 0) + num);\n  }\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // delta is +1 (add) or -1 (remove). For UI we mostly validate +1.\n  if (!from || !to) return { valid: false, error: ERRORS.NON_ADJ };\n  if (from.id === to.id) return { valid: false, error: ERRORS.NON_ADJ };\n  if (!areAdjacent(islands, from, to)) return { valid: false, error: ERRORS.NON_ADJ };\n\n  const key = canonicalKey(from, to);\n  const cur = bridges.get(key) || 0;\n  const next = cur + delta;\n\n  if (next > 2) return { valid: false, error: ERRORS.MAX_PAIR };\n  if (next < 0) return { valid: false, error: null };\n\n  if (delta > 0) {\n    const counts = computeCurrentCounts(islands, bridges);\n    const fromCount = counts.get(from.id) || 0;\n    const toCount = counts.get(to.id) || 0;\n    if (fromCount + 1 > from.value || toCount + 1 > to.value) {\n      return { valid: false, error: ERRORS.EXCEED };\n    }\n\n    // crossing check only for actual segment existence (next>0)\n    const test = new Map(bridges);\n    test.set(key, next);\n    if (bridgesWouldCross(test, key)) {\n      return { valid: false, error: ERRORS.CROSS };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n  const adj = new Map(islands.map((i) => [i.id, new Set()]));\n\n  for (const [key, num] of bridges.entries()) {\n    if (!num) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = posToId.get(`${x1},${y1}`);\n    const b = posToId.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a).add(b);\n    adj.get(b).add(a);\n  }\n\n  const start = islands[0].id;\n  const seen = new Set([start]);\n  const q = [start];\n  while (q.length) {\n    const u = q.shift();\n    for (const v of adj.get(u) || []) {\n      if (!seen.has(v)) {\n        seen.add(v);\n        q.push(v);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // no crossing\n  for (const [key, num] of bridges.entries()) {\n    if (!num) continue;\n    if (bridgesWouldCross(bridges, key)) return false;\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const i of islands) {\n    if ((counts.get(i.id) || 0) !== i.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > src/App.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\';\nimport { PUZZLES } from \'./data/puzzles.js\';\nimport {\n  canonicalKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n  parseKey,\n  ERRORS\n} from \'./utils/hashiLogic.js\';\n\nconst GRID = 40;\nconst W = 800;\nconst H = 600;\n\nfunction px(n) {\n  return n * GRID;\n}\n\nfunction getNeighborInDirection(islands, from, dir) {\n  // dir: \'left\'|\'right\'|\'up\'|\'down\'\n  const candidates = islands.filter((i) => i.id !== from.id);\n  let best = null;\n  let bestDist = Infinity;\n\n  for (const t of candidates) {\n    if (dir === \'left\' && t.y === from.y && t.x < from.x) {\n      const d = from.x - t.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = t;\n      }\n    }\n    if (dir === \'right\' && t.y === from.y && t.x > from.x) {\n      const d = t.x - from.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = t;\n      }\n    }\n    if (dir === \'up\' && t.x === from.x && t.y < from.y) {\n      const d = from.y - t.y;\n      if (d < bestDist) {\n        bestDist = d;\n        best = t;\n      }\n    }\n    if (dir === \'down\' && t.x === from.x && t.y > from.y) {\n      const d = t.y - from.y;\n      if (d < bestDist) {\n        bestDist = d;\n        best = t;\n      }\n    }\n  }\n  return best;\n}\n\nfunction lineMidpoint(from, to) {\n  return { x: (from.x + to.x) / 2, y: (from.y + to.y) / 2 };\n}\n\nexport default function App() {\n  const [puzzleId, setPuzzleId] = useState(PUZZLES[0].id);\n  const puzzle = useMemo(() => PUZZLES.find((p) => p.id === puzzleId) || PUZZLES[0], [puzzleId]);\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedIslandId, setSelectedIslandId] = useState(null);\n  const [cursorIslandId, setCursorIslandId] = useState(() => puzzle.islands[0]?.id ?? null);\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  useEffect(() => {\n    // On puzzle change: fully reset state.\n    setBridges(new Map());\n    setSelectedIslandId(null);\n    setCursorIslandId(puzzle.islands[0]?.id ?? null);\n    setError(null);\n  }, [puzzleId]);\n\n  const islands = puzzle.islands;\n  const islandById = useMemo(() => new Map(islands.map((i) => [i.id, i])), [islands]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function clearErrorOnValid(valid) {\n    if (valid) setError(null);\n  }\n\n  function applyCycleBridge(from, to) {\n    // cycle: 0 -> 1 -> 2 -> 0\n    const key = canonicalKey(from, to);\n    const cur = bridges.get(key) || 0;\n    const target = (cur + 1) % 3;\n\n    if (target > cur) {\n      // validate +1 step(s)\n      let temp = new Map(bridges);\n      let c = cur;\n      while (c < target) {\n        const check = canAddBridge(islands, temp, from, to, +1);\n        if (!check.valid) {\n          setError(check.error);\n          return;\n        }\n        c += 1;\n        temp.set(key, c);\n      }\n      setBridges(temp);\n      clearErrorOnValid(true);\n      return;\n    }\n\n    // going to 0: always allowed\n    const next = new Map(bridges);\n    if (target === 0) next.delete(key);\n    else next.set(key, target);\n    setBridges(next);\n    clearErrorOnValid(true);\n  }\n\n  function toggleBridge(from, to) {\n    // toggle for right-click/ctrl-click: 0 <-> 1\n    const key = canonicalKey(from, to);\n    const cur = bridges.get(key) || 0;\n    if (cur === 0) {\n      const check = canAddBridge(islands, bridges, from, to, +1);\n      if (!check.valid) {\n        setError(check.error);\n        return;\n      }\n      const next = new Map(bridges);\n      next.set(key, 1);\n      setBridges(next);\n      clearErrorOnValid(true);\n    } else {\n      const next = new Map(bridges);\n      next.delete(key);\n      setBridges(next);\n      clearErrorOnValid(true);\n    }\n  }\n\n  function onIslandClick(island, evt) {\n    evt.preventDefault();\n    setCursorIslandId(island.id);\n\n    if (!selectedIslandId) {\n      setSelectedIslandId(island.id);\n      return;\n    }\n\n    if (selectedIslandId === island.id) {\n      // clicking same island: keep it selected\n      return;\n    }\n\n    const from = islandById.get(selectedIslandId);\n    const to = island;\n    applyCycleBridge(from, to);\n    setSelectedIslandId(to.id); // second click becomes new selection anchor\n  }\n\n  function onBackgroundClick() {\n    setSelectedIslandId(null);\n  }\n\n  function onBridgeContextMenu(from, to, evt) {\n    evt.preventDefault();\n    toggleBridge(from, to);\n  }\n\n  function onBridgeClick(from, to, evt) {\n    if (evt.ctrlKey) {\n      evt.preventDefault();\n      toggleBridge(from, to);\n    }\n  }\n\n  useEffect(() => {\n    function handleKeyDown(e) {\n      const cursor = cursorIslandId ? islandById.get(cursorIslandId) : null;\n      if (!cursor) return;\n\n      if (e.key === \'Escape\') {\n        setSelectedIslandId(null);\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        if (!selectedIslandId) {\n          setSelectedIslandId(cursor.id);\n        } else {\n          const from = islandById.get(selectedIslandId);\n          const to = cursor;\n          if (from && to && from.id !== to.id) {\n            applyCycleBridge(from, to);\n            setSelectedIslandId(to.id);\n          }\n        }\n        return;\n      }\n\n      const dirMap = {\n        ArrowLeft: \'left\',\n        ArrowRight: \'right\',\n        ArrowUp: \'up\',\n        ArrowDown: \'down\'\n      };\n      const dir = dirMap[e.key];\n      if (!dir) return;\n      e.preventDefault();\n\n      const n = getNeighborInDirection(islands, cursor, dir);\n      if (n) setCursorIslandId(n.id);\n    }\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [cursorIslandId, islandById, islands, selectedIslandId, bridges]);\n\n  const bridgeSegments = useMemo(() => {\n    const segs = [];\n    for (const [key, num] of bridges.entries()) {\n      if (!num) continue;\n      const { x1, y1, x2, y2 } = parseKey(key);\n      const from = islands.find((i) => i.x === x1 && i.y === y1);\n      const to = islands.find((i) => i.x === x2 && i.y === y2);\n      if (!from || !to) continue;\n      segs.push({ key, from, to, num });\n    }\n    return segs;\n  }, [bridges, islands]);\n\n  return (\n    <div className="app">\n      <div className="ui-bar">\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={puzzleId}\n            onChange={(e) => setPuzzleId(e.target.value)}\n            aria-label="Puzzle selector"\n          >\n            {PUZZLES.map((p) => (\n              <option key={p.id} value={p.id}>{p.label}</option>\n            ))}\n          </select>\n        </label>\n\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedIslandId(null);\n            setError(null);\n          }}\n        >\n          Reset\n        </button>\n\n        <div style={{ opacity: 0.85 }}>\n          Use mouse or keyboard (arrows/Enter/Esc). Ctrl+click/right-click bridge toggles.\n        </div>\n      </div>\n\n      {error ? <div className="error-message">{error}</div> : null}\n      {victory ? <div className="victory-banner">SOLVED!</div> : null}\n\n      <svg\n        ref={svgRef}\n        className="board"\n        width={W}\n        height={H}\n        viewBox={`0 0 ${W} ${H}`}\n        onMouseDown={(e) => {\n          // if clicking on empty SVG\n          if (e.target === svgRef.current) onBackgroundClick();\n        }}\n      >\n        {/* Bridges */}\n        <g stroke="#00ff66" strokeLinecap="round">\n          {bridgeSegments.map(({ key, from, to, num }) => {\n            const x1 = px(from.x);\n            const y1 = px(from.y);\n            const x2 = px(to.x);\n            const y2 = px(to.y);\n            const isH = y1 === y2;\n            const offset = 6;\n\n            const lines = [];\n            const commonProps = {\n              key: key,\n              onContextMenu: (evt) => onBridgeContextMenu(from, to, evt),\n              onClick: (evt) => onBridgeClick(from, to, evt),\n              style: { cursor: \'pointer\' }\n            };\n\n            if (num === 1) {\n              lines.push(\n                <line\n                  {...commonProps}\n                  key={`${key}-1`}\n                  x1={x1}\n                  y1={y1}\n                  x2={x2}\n                  y2={y2}\n                  strokeWidth={4}\n                />\n              );\n            } else if (num === 2) {\n              if (isH) {\n                lines.push(\n                  <line\n                    {...commonProps}\n                    key={`${key}-a`}\n                    x1={x1}\n                    y1={y1 - offset}\n                    x2={x2}\n                    y2={y2 - offset}\n                    strokeWidth={4}\n                  />,\n                  <line\n                    {...commonProps}\n                    key={`${key}-b`}\n                    x1={x1}\n                    y1={y1 + offset}\n                    x2={x2}\n                    y2={y2 + offset}\n                    strokeWidth={4}\n                  />\n                );\n              } else {\n                lines.push(\n                  <line\n                    {...commonProps}\n                    key={`${key}-a`}\n                    x1={x1 - offset}\n                    y1={y1}\n                    x2={x2 - offset}\n                    y2={y2}\n                    strokeWidth={4}\n                  />,\n                  <line\n                    {...commonProps}\n                    key={`${key}-b`}\n                    x1={x1 + offset}\n                    y1={y1}\n                    x2={x2 + offset}\n                    y2={y2}\n                    strokeWidth={4}\n                  />\n                );\n              }\n            }\n\n            return <g key={key}>{lines}</g>;\n          })}\n        </g>\n\n        {/* Keyboard cursor (not a circle) */}\n        {cursorIslandId && islandById.get(cursorIslandId) ? (() => {\n          const c = islandById.get(cursorIslandId);\n          const cx = px(c.x);\n          const cy = px(c.y);\n          const size = 34;\n          return (\n            <g>\n              <rect\n                x={cx - size / 2}\n                y={cy - size / 2}\n                width={size}\n                height={size}\n                fill="none"\n                stroke="#00ff66"\n                strokeWidth={2}\n                strokeDasharray="6 4"\n                opacity={0.9}\n              />\n            </g>\n          );\n        })() : null}\n\n        {/* Islands */}\n        <g>\n          {islands.map((i) => {\n            const cx = px(i.x);\n            const cy = px(i.y);\n            const isSelected = selectedIslandId === i.id;\n            const curCount = counts.get(i.id) || 0;\n            const satisfied = curCount === i.value;\n            const over = curCount > i.value;\n\n            return (\n              <g key={i.id} onClick={(evt) => onIslandClick(i, evt)} style={{ cursor: \'pointer\' }}>\n                <circle\n                  cx={cx}\n                  cy={cy}\n                  r={16}\n                  fill="#000"\n                  stroke={over ? \'#ff3355\' : (isSelected ? \'#00ff66\' : \'rgba(0,255,102,0.7)\')}\n                  strokeWidth={isSelected ? 3 : 2}\n                />\n                <text\n                  x={cx}\n                  y={cy + 5}\n                  textAnchor="middle"\n                  fontSize="16"\n                  fill={satisfied ? \'#00ff66\' : \'rgba(0,255,102,0.9)\'}\n                >\n                  {i.value}\n                </text>\n              </g>\n            );\n          })}\n        </g>\n      </svg>\n    </div>\n  );\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
