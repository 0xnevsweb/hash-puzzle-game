[98.4305, "i", "cat > src/utils/hashiLogic.js <<'EOF'\n// Hashi (Bridges) logic utilities.\n// Bridges are stored as Map<string, number> where key is \"x1,y1,x2,y2\" in grid units,\n// canonicalized so the smaller endpoint (x then y) comes first.\n\nexport const ERRORS = {\n  NON_ADJ: 'Cannot connect non-adjacent islands',\n  MAX_PAIR: 'Max 2 bridges per pair',\n  EXCEED: 'Island would exceed its number',\n  CROSS: 'Bridges would cross'\n};\n\nexport function canonicalKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const first = (a.x < b.x) || (a.x === b.x && a.y < b.y) ? a : b;\n  const second = first === a ? b : a;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nexport function parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nexport function isAligned(from, to) {\n  return from.x === to.x || from.y === to.y;\n}\n\nexport function islandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y) || null;\n}\n\nexport function"]
[98.430583, "i", " areAdjacent(islands, from, to) {\n  if (!isAligned(from, to)) return false;\n  const dx = Math.sign(to.x - from.x);\n  const dy = Math.sign(to.y - from.y);\n  let x = from.x + dx;\n  let y = from.y + dy;\n  while (x !== to.x || y !== to.y) {\n    if (islandAt(islands, x, y)) return false;\n    x += dx;\n    y += dy;\n  }\n  return true;\n}\n\nfunction segmentsCross(segA, segB) {\n  // seg: {x1,y1,x2,y2} aligned axis.\n  const aVert = segA.x1 === segA.x2;\n  const bVert = segB.x1 === segB.x2;\n\n  // Parallel segments cannot \"cross\" in Hashi sense (overlap). We only treat perpendicular intersections.\n  if (aVert === bVert) return false;\n\n  const v = aVert ? segA : segB;\n  const h = aVert ? segB : segA;\n\n  const vx = v.x1;\n  const vyMin = Math.min(v.y1, v.y2);\n  const vyMax = Math.max(v.y1, v.y2);\n\n  const hy = h.y1;\n  const hxMin = Math.min(h.x1, h.x2);\n  const hxMax = Math.max(h.x1, h.x2);\n\n  const intersects = (vx > hxMin && vx < hxMax && hy > vyMin && hy < vyMax);\n  return intersects;\n}\n\nexport function bridgesWouldCross(bri"]
[98.431516, "i", "dges, newSegKey) {\n  const newSeg = parseKey(newSegKey);\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    if (key === newSegKey) continue;\n    const seg = parseKey(key);\n    if (segmentsCross(newSeg, seg)) return true;\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map(islands.map((i) => [i.id, 0]));\n  // index by coordinate to island id\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n\n  for (const [key, num] of bridges.entries()) {\n    if (!num) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const id1 = posToId.get(`${x1},${y1}`);\n    const id2 = posToId.get(`${x2},${y2}`);\n    if (!id1 || !id2) continue;\n    counts.set(id1, (counts.get(id1) || 0) + num);\n    counts.set(id2, (counts.get(id2) || 0) + num);\n  }\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // delta is +1 (add) or -1 (remove). For UI we mostly validate +1.\n  if (!from || !to) return "]
