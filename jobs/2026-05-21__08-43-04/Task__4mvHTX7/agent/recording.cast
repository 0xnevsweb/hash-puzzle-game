[98.701305, "i", "cat > src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { PUZZLES } from './data/puzzles.js';\nimport {\n  canonicalKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n  parseKey,\n  ERRORS\n} from './utils/hashiLogic.js';\n\nconst GRID = 40;\nconst W = 800;\nconst H = 600;\n\nfunction px(n) {\n  return n * GRID;\n}\n\nfunction getNeighborInDirection(islands, from, dir) {\n  // dir: 'left'|'right'|'up'|'down'\n  const candidates = islands.filter((i) => i.id !== from.id);\n  let best = null;\n  let bestDist = Infinity;\n\n  for (const t of candidates) {\n    if (dir === 'left' && t.y === from.y && t.x < from.x) {\n      const d = from.x - t.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = t;\n      }\n    }\n    if (dir === 'right' && t.y === from.y && t.x > from.x) {\n      const d = t.x - from.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = t;\n      }\n    }\n    if (dir === 'up' && t.x === from.x && t.y < from.y) {\n      const d = from.y - t.y;\n    "]
