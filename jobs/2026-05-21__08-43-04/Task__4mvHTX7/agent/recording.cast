[98.705245, "i", " to 0: always allowed\n    const next = new Map(bridges);\n    if (target === 0) next.delete(key);\n    else next.set(key, target);\n    setBridges(next);\n    clearErrorOnValid(true);\n  }\n\n  function toggleBridge(from, to) {\n    // toggle for right-click/ctrl-click: 0 <-> 1\n    const key = canonicalKey(from, to);\n    const cur = bridges.get(key) || 0;\n    if (cur === 0) {\n      const check = canAddBridge(islands, bridges, from, to, +1);\n      if (!check.valid) {\n        setError(check.error);\n        return;\n      }\n      const next = new Map(bridges);\n      next.set(key, 1);\n      setBridges(next);\n      clearErrorOnValid(true);\n    } else {\n      const next = new Map(bridges);\n      next.delete(key);\n      setBridges(next);\n      clearErrorOnValid(true);\n    }\n  }\n\n  function onIslandClick(island, evt) {\n    evt.preventDefault();\n    setCursorIslandId(island.id);\n\n    if (!selectedIslandId) {\n      setSelectedIslandId(island.id);\n      return;\n    }\n\n    if (selectedIslandId === island.id) {\n      // clicking s"]
[98.705269, "i", "ame island: keep it selected\n      return;\n    }\n\n    const from = islandById.get(selectedIslandId);\n    const to = island;\n    applyCycleBridge(from, to);\n    setSelectedIslandId(to.id); // second click becomes new selection anchor\n  }\n\n  function onBackgroundClick() {\n    setSelectedIslandId(null);\n  }\n\n  function onBridgeContextMenu(from, to, evt) {\n    evt.preventDefault();\n    toggleBridge(from, to);\n  }\n\n  function onBridgeClick(from, to, evt) {\n    if (evt.ctrlKey) {\n      evt.preventDefault();\n      toggleBridge(from, to);\n    }\n  }\n\n  useEffect(() => {\n    function handleKeyDown(e) {\n      const cursor = cursorIslandId ? islandById.get(cursorIslandId) : null;\n      if (!cursor) return;\n\n      if (e.key === 'Escape') {\n        setSelectedIslandId(null);\n        return;\n      }\n\n      if (e.key === 'Enter') {\n        if (!selectedIslandId) {\n          setSelectedIslandId(cursor.id);\n        } else {\n          const from = islandById.get(selectedIslandId);\n          const to = cursor;\n          if (from"]
[98.705304, "i", " && to && from.id !== to.id) {\n            applyCycleBridge(from, to);\n            setSelectedIslandId(to.id);\n          }\n        }\n        return;\n      }\n\n      const dirMap = {\n        ArrowLeft: 'left',\n        ArrowRight: 'right',\n        ArrowUp: 'up',\n        ArrowDown: 'down'\n      };\n      const dir = dirMap[e.key];\n      if (!dir) return;\n      e.preventDefault();\n\n      const n = getNeighborInDirection(islands, cursor, dir);\n      if (n) setCursorIslandId(n.id);\n    }\n\n    window.addEventListener('keydown', handleKeyDown);\n    return () => window.removeEventListener('keydown', handleKeyDown);\n  }, [cursorIslandId, islandById, islands, selectedIslandId, bridges]);\n\n  const bridgeSegments = useMemo(() => {\n    const segs = [];\n    for (const [key, num] of bridges.entries()) {\n      if (!num) continue;\n      const { x1, y1, x2, y2 } = parseKey(key);\n      const from = islands.find((i) => i.x === x1 && i.y === y1);\n      const to = islands.find((i) => i.x === x2 && i.y === y2);\n      if (!from || !to)"]
[98.705338, "i", " continue;\n      segs.push({ key, from, to, num });\n    }\n    return segs;\n  }, [bridges, islands]);\n\n  return (\n    <div className=\"app\">\n      <div className=\"ui-bar\">\n        <label>\n          Puzzle:{' '}\n          <select\n            value={puzzleId}\n            onChange={(e) => setPuzzleId(e.target.value)}\n            aria-label=\"Puzzle selector\"\n          >\n            {PUZZLES.map((p) => (\n              <option key={p.id} value={p.id}>{p.label}</option>\n            ))}\n          </select>\n        </label>\n\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedIslandId(null);\n            setError(null);\n          }}\n        >\n          Reset\n        </button>\n\n        <div style={{ opacity: 0.85 }}>\n          Use mouse or keyboard (arrows/Enter/Esc). Ctrl+click/right-click bridge toggles.\n        </div>\n      </div>\n\n      {error ? <div className=\"error-message\">{error}</div> : null}\n      {victory ? <div className=\"victory-banner\">SOLVED!</div> : null}\n\n "]
