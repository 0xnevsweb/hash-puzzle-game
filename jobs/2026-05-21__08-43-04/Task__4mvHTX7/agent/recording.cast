[98.205243, "i", "cat > src/data/puzzles.js <<'EOF'\n// Grid units are 40px each. Island positions are in grid coordinates.\n// id must be unique per puzzle.\n\nexport const PUZZLES = [\n  {\n    id: 'easy',\n    label: 'Easy',\n    // Simple rectangle loop\n    islands: [\n      { id: 'A', x: 4, y: 3, value: 2 },\n      { id: 'B', x: 12, y: 3, value: 2 },\n      { id: 'C', x: 4, y: 10, value: 2 },\n      { id: 'D', x: 12, y: 10, value: 2 }\n    ]\n  },\n  {\n    id: 'medium',\n    label: 'Medium',\n    // 3x3 layout with a center hub\n    islands: [\n      { id: 'A', x: 4, y: 3, value: 2 },\n      { id: 'B', x: 10, y: 3, value: 3 },\n      { id: 'C', x: 16, y: 3, value: 2 },\n\n      { id: 'D', x: 4, y: 8, value: 3 },\n      { id: 'E', x: 10, y: 8, value: 4 },\n      { id: 'F', x: 16, y: 8, value: 3 },\n\n      { id: 'G', x: 4, y: 13, value: 2 },\n      { id: 'H', x: 10, y: 13, value: 3 },\n      { id: 'I', x: 16, y: 13, value: 2 }\n    ]\n  },\n  {\n    id: 'hard',\n    label: 'Hard',\n    // Denser set intended to allow many interactions; still within 800x600."]
