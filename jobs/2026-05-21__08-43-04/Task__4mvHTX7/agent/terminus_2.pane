[?2004l[?2004hroot@72bd201bd497:/app# cat > src/utils/hashiLogic.js <<'EOF'
[?2004l[?2004h> // Hashi (Bridges) logic utilities.
[?2004l[?2004h> // Bridges are stored as Map<string, number> where key is "x1,y1,x2,y2" in grid units,
[?2004l[?2004h> // canonicalized so the smaller endpoint (x then y) comes first.
[?2004l[?2004h> 
[?2004l[?2004h> export const ERRORS = {
[?2004l[?2004h>   NON_ADJ: 'Cannot connect non-adjacent islands',
[?2004l[?2004h>   MAX_PAIR: 'Max 2 bridges per pair',
[?2004l[?2004h>   EXCEED: 'Island would exceed its number',
[?2004l[?2004h>   CROSS: 'Bridges would cross'
[?2004l[?2004h> };
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const first = (a.x < b.x) || (a.x === b.x && a.y < b.y) ? a : b;
[?2004l[?2004h>   const second = first === a ? b : a;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isAligned(from, to) {
[?2004l[?2004h>   return from.x === to.x || from.y === to.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function islandAt(islands, x, y) {
[?2004l[?2004h>   return islands.find((i) => i.x === x && i.y === y) || null;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!isAligned(from, to)) return false;
[?2004l[?2004h>   const dx = Math.sign(to.x - from.x);
[?2004l[?2004h>   const dy = Math.sign(to.y - from.y);
[?2004l[?2004h>   let x = from.x + dx;
[?2004l[?2004h>   let y = from.y + dy;
[?2004l[?2004h>   while (x !== to.x || y !== to.y) {
[?2004l[?2004h>     if (islandAt(islands, x, y)) return false;
[?2004l[?2004h>     x += dx;
[?2004l[?2004h>     y += dy;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(segA, segB) {
[?2004l[?2004h>   // seg: {x1,y1,x2,y2} aligned axis.
[?2004l[?2004h>   const aVert = segA.x1 === segA.x2;
[?2004l[?2004h>   const bVert = segB.x1 === segB.x2;
[?2004l[?2004h> 
[?2004l[?2004h>   // Parallel segments cannot "cross" in Hashi sense (overlap). We only treat perpendicular intersections.
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const v = aVert ? segA : segB;
[?2004l[?2004h>   const h = aVert ? segB : segA;
[?2004l[?2004h> 
[?2004l[?2004h>   const vx = v.x1;
[?2004l[?2004h>   const vyMin = Math.min(v.y1, v.y2);
[?2004l[?2004h>   const vyMax = Math.max(v.y1, v.y2);
[?2004l[?2004h> 
[?2004l[?2004h>   const hy = h.y1;
[?2004l[?2004h>   const hxMin = Math.min(h.x1, h.x2);
[?2004l[?2004h>   const hxMax = Math.max(h.x1, h.x2);
[?2004l[?2004h> 
[?2004l[?2004h>   const intersects = (vx > hxMin && vx < hxMax && hy > vyMin && hy < vyMax);
[?2004l[?2004h>   return intersects;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesWouldCross(bridges, newSegKey) {
[?2004l[?2004h>   const newSeg = parseKey(newSegKey);
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     if (key === newSegKey) continue;
[?2004l[?2004h>     const seg = parseKey(key);
[?2004l[?2004h>     if (segmentsCross(newSeg, seg)) return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map(islands.map((i) => [i.id, 0]));
[?2004l[?2004h>   // index by coordinate to island id
[?2004l[?2004h>   const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, num] of bridges.entries()) {
[?2004l[?2004h>     if (!num) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const id1 = posToId.get(`${x1},${y1}`);
[?2004l[?2004h>     const id2 = posToId.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!id1 || !id2) continue;
[?2004l[?2004h>     counts.set(id1, (counts.get(id1) || 0) + num);
[?2004l[?2004h>     counts.set(id2, (counts.get(id2) || 0) + num);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // delta is +1 (add) or -1 (remove). For UI we mostly validate +1.
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: ERRORS.NON_ADJ };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: ERRORS.NON_ADJ };
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) return { valid: false, error: ERRORS.NON_ADJ };
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
[?2004l[?2004h>   const cur = bridges.get(key) || 0;
[?2004l[?2004h>   const next = cur + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERRORS.MAX_PAIR };
[?2004l[?2004h>   if (next < 0) return { valid: false, error: null };
[?2004l[?2004h> 
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>     const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>     const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>     if (fromCount + 1 > from.value || toCount + 1 > to.value) {
[?2004l[?2004h>       return { valid: false, error: ERRORS.EXCEED };
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     // crossing check only for actual segment existence (next>0)
[?2004l[?2004h>     const test = new Map(bridges);
[?2004l[?2004h>     test.set(key, next);
[?2004l[?2004h>     if (bridgesWouldCross(test, key)) {
[?2004l[?2004h>       return { valid: false, error: ERRORS.CROSS };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length <= 1) return true;
[?2004l[?2004h>   const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));
[?2004l[?2004h>   const adj = new Map(islands.map((i) => [i.id, new Set()]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, num] of bridges.entries()) {
[?2004l[?2004h>     if (!num) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = posToId.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = posToId.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a).add(b);
[?2004l[?2004h>     adj.get(b).add(a);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
