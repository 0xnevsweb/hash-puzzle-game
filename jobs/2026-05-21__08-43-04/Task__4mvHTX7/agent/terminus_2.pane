[?2004l[?2004h>       if (d < bestDist) {
[?2004l[?2004h>         bestDist = d;
[?2004l[?2004h>         best = t;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'right' && t.y === from.y && t.x > from.x) {
[?2004l[?2004h>       const d = t.x - from.x;
[?2004l[?2004h>       if (d < bestDist) {
