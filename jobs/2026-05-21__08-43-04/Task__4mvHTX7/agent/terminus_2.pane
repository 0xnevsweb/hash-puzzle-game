[?2004l[?2004h> 
[?2004l[?2004h>   function clearErrorOnValid(valid) {
[?2004l[?2004h>     if (valid) setError(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function applyCycleBridge(from, to) {
[?2004l[?2004h>     // cycle: 0 -> 1 -> 2 -> 0
[?2004l[?2004h>     const key = canonicalKey(from, to);
[?2004l[?2004h>     const cur = bridges.get(key) || 0;
[?2004l[?2004h>     const target = (cur + 1) % 3;
[?2004l[?2004h> 
