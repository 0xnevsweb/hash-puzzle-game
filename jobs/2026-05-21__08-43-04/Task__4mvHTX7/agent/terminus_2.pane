[?2004l[?2004h>     setBridges(next);
[?2004l[?2004h>     clearErrorOnValid(true);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function toggleBridge(from, to) {
[?2004l[?2004h>     // toggle for right-click/ctrl-click: 0 <-> 1
[?2004l[?2004h>     const key = canonicalKey(from, to);
[?2004l[?2004h>     const cur = bridges.get(key) || 0;
[?2004l[?2004h>     if (cur === 0) {
[?2004l[?2004h>       const check = canAddBridge(islands, bridges, from, to, +1);
[?2004l[?2004h>       if (!check.valid) {
[?2004l[?2004h>         setError(check.error);
