[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function onIslandClick(island, evt) {
[?2004l[?2004h>     evt.preventDefault();
[?2004l[?2004h>     setCursorIslandId(island.id);
[?2004l[?2004h> 
[?2004l[?2004h>     if (!selectedIslandId) {
