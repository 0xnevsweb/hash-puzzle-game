[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function getNeighborInDirection(islands, from, dir) {
[?2004l[?2004h>   // returns nearest island in that direction (ignores bridges)
[?2004l[?2004h>   let best = null;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h>     if (dir === 'left' && isl.y === from.y && isl.x < from.x) {
[?2004l[?2004h>       if (!best || isl.x > best.x) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'right' && isl.y === from.y && isl.x > from.x) {
[?2004l[?2004h>       if (!best || isl.x < best.x) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'up' && isl.x === from.x && isl.y < from.y) {
[?2004l[?2004h>       if (!best || isl.y > best.y) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'down' && isl.x === from.x && isl.y > from.y) {
[?2004l[?2004h>       if (!best || isl.y < best.y) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return best;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function bridgeLinesForKey(key, count) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   const a = { x: x1, y: y1 };
[?2004l[?2004h>   const b = { x: x2, y: y2 };
[?2004l[?2004h>   const x1p = px(a.x);
[?2004l[?2004h>   const y1p = px(a.y);
[?2004l[?2004h>   const x2p = px(b.x);
[?2004l[?2004h>   const y2p = px(b.y);
[?2004l[?2004h> 
[?2004l[?2004h>   const isH = a.y === b.y;
[?2004l[?2004h>   const offset = 6; // pixel offset for double bridges
[?2004l[?2004h> 
[?2004l[?2004h>   if (count === 1) {
[?2004l[?2004h>     return [
[?2004l[?2004h>       {
[?2004l[?2004h>         x1: x1p,
[?2004l[?2004h>         y1: y1p,
[?2004l[?2004h>         x2: x2p,
[?2004l[?2004h>         y2: y2p,
[?2004l[?2004h>       },
[?2004l[?2004h>     ];
[?2004l[?2004h>   }
[?2004l[?2004h>   if (count === 2) {
[?2004l[?2004h>     if (isH) {
[?2004l[?2004h>       return [
[?2004l[?2004h>         { x1: x1p, y1: y1p - offset, x2: x2p, y2: y2p - offset },
[?2004l[?2004h>         { x1: x1p, y1: y1p + offset, x2: x2p, y2: y2p + offset },
[?2004l[?2004h>       ];
[?2004l[?2004h>     }
[?2004l[?2004h>     return [
[?2004l[?2004h>       { x1: x1p - offset, y1: y1p, x2: x2p - offset, y2: y2p },
[?2004l[?2004h>       { x1: x1p + offset, y1: y1p, x2: x2p + offset, y2: y2p },
[?2004l[?2004h>     ];
[?2004l[?2004h>   }
[?2004l[?2004h>   return [];
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleName, setPuzzleName] = useState('Easy');
[?2004l[?2004h>   const puzzle = useMemo(() => puzzles.find((p) => p.name === puzzleName) ?? puzzles[0], [puzzleName]);
[?2004l[?2004h>   const islands = puzzle.islands;
[?2004l[?2004h> 
[?2004l[?2004h>   const [bridges, setBridges] = useState(() => new Map());
[?2004l[?2004h>   const [selectedId, setSelectedId] = useState(null);
[?2004l[?2004h>   const [cursorId, setCursorId] = useState(islands[0]?.id ?? 0);
[?2004l[?2004h>   const [pendingFromId, setPendingFromId] = useState(null); // keyboard selection
[?2004l[?2004h>   const [pendingDir, setPendingDir] = useState(null); // last arrow dir while pending
[?2004l[?2004h>   const [error, setError] = useState(null);
[?2004l[?2004h> 
[?2004l[?2004h>   const svgRef = useRef(null);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     // puzzle change: reset everything
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>     setPendingFromId(null);
[?2004l[?2004h>     setPendingDir(null);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setCursorId(puzzle.islands[0]?.id ?? 0);
[?2004l[?2004h>   }, [puzzleName]);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     // keep cursor valid if puzzle changes
[?2004l[?2004h>     if (!islandById(islands, cursorId)) {
[?2004l[?2004h>       setCursorId(islands[0]?.id ?? 0);
[?2004l[?2004h>     }
[?2004l[?2004h>   }, [islands, cursorId]);
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);
[?2004l[?2004h>   const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);
[?2004l[?2004h> 
[?2004l[?2004h>   function clearErrorOnValid(result) {
[?2004l[?2004h>     if (result?.valid) setError(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function setErrorIfAny(result) {
[?2004l[?2004h>     if (!result?.valid && result?.error) setError(result.error);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function cycleBridge(from, to) {
[?2004l[?2004h>     const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>     const current = bridges.get(key) ?? 0;
[?2004l[?2004h>     const next = (current + 1) % 3; // 0->1->2->0
[?2004l[?2004h> 
[?2004l[?2004h>     if (next === 0) {
[?2004l[?2004h>       const nb = new Map(bridges);
[?2004l[?2004h>       nb.delete(key);
[?2004l[?2004h>       setBridges(nb);
[?2004l[?2004h>       setError(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const delta = next - current;
[?2004l[?2004h>     const check = canAddBridge(islands, bridges, from, to, delta);
[?2004l[?2004h>     if (!check.valid) {
[?2004l[?2004h>       setErrorIfAny(check);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const nb = new Map(bridges);
[?2004l[?2004h>     nb.set(key, next);
[?2004l[?2004h>     setBridges(nb);
[?2004l[?2004h>     clearErrorOnValid(check);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function removeBridge(from, to) {
[?2004l[?2004h>     const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>     if (!(bridges.get(key) > 0)) return;
[?2004l[?2004h>     const nb = new Map(bridges);
[?2004l[?2004h>     nb.delete(key);
[?2004l[?2004h>     setBridges(nb);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function onIslandClick(isl, e) {
[?2004l[?2004h>     // ctrl+click removes a bridge if selection exists and this island is the other endpoint
[?2004l[?2004h>     if ((e.ctrlKey || e.metaKey) && selectedId !== null && selectedId !== isl.id) {
[?2004l[?2004h>       const from = islandById(islands, selectedId);
[?2004l[?2004h>       if (from && areAdjacent(islands, from, isl, bridges)) {
[?2004l[?2004h>         removeBridge(from, isl);
[?2004l[?2004h>       }
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (selectedId === null) {
[?2004l[?2004h>       setSelectedId(isl.id);
[?2004l[?2004h>       setCursorId(isl.id);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (selectedId === isl.id) {
[?2004l[?2004h>       // clicking same island keeps selection
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const from = islandById(islands, selectedId);
[?2004l[?2004h>     const to = isl;
[?2004l[?2004h>     if (!from) {
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (!areAdjacent(islands, from, to, bridges)) {
[?2004l[?2004h>       setError(ERROR_NON_ADJACENT);
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     cycleBridge(from, to);
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function onIslandContextMenu(isl, e) {
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h>     if (selectedId === null || selectedId === isl.id) return;
[?2004l[?2004h>     const from = islandById(islands, selectedId);
[?2004l[?2004h>     if (!from) return;
[?2004l[?2004h>     if (!areAdjacent(islands, from, isl, bridges)) return;
[?2004l[?2004h>     removeBridge(from, isl);
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function handleKeyDown(e) {
[?2004l[?2004h>     const cur = islandById(islands, cursorId) ?? islands[0];
[?2004l[?2004h>     if (!cur) return;
[?2004l[?2004h> 
[?2004l[?2004h>     if (e.key === 'Escape') {
[?2004l[?2004h>       setPendingFromId(null);
[?2004l[?2004h>       setPendingDir(null);
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       setError(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const dirFromKey =
[?2004l[?2004h>       e.key === 'ArrowLeft'
[?2004l[?2004h>         ? 'left'
[?2004l[?2004h>         : e.key === 'ArrowRight'
[?2004l[?2004h>           ? 'right'
[?2004l[?2004h>           : e.key === 'ArrowUp'
[?2004l[?2004h>             ? 'up'
[?2004l[?2004h>             : e.key === 'ArrowDown'
[?2004l[?2004h>               ? 'down'
[?2004l[?2004h>               : null;
[?2004l[?2004h> 
[?2004l[?2004h>     if (dirFromKey) {
[?2004l[?2004h>       e.preventDefault();
[?2004l[?2004h>       const nxt = getNeighborInDirection(islands, cur, dirFromKey);
[?2004l[?2004h>       if (nxt) {
[?2004l[?2004h>         setCursorId(nxt.id);
[?2004l[?2004h>         if (pendingFromId !== null) setPendingDir(dirFromKey);
[?2004l[?2004h>       }
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (e.key === 'Enter') {
[?2004l[?2004h>       e.preventDefault();
[?2004l[?2004h> 
[?2004l[?2004h>       if (pendingFromId === null) {
[?2004l[?2004h>         setPendingFromId(cur.id);
[?2004l[?2004h>         setSelectedId(cur.id);
[?2004l[?2004h>         setPendingDir(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       // second enter: toggle bridge from pendingFromId to current cursor target
[?2004l[?2004h>       const from = islandById(islands, pendingFromId);
[?2004l[?2004h>       const to = cur;
[?2004l[?2004h> 
[?2004l[?2004h>       if (!from || !to || from.id === to.id) {
[?2004l[?2004h>         setPendingFromId(null);
[?2004l[?2004h>         setPendingDir(null);
[?2004l[?2004h>         setSelectedId(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       if (!areAdjacent(islands, from, to, bridges)) {
[?2004l[?2004h>         setError(ERROR_NON_ADJACENT);
[?2004l[?2004h>         setPendingFromId(null);
[?2004l[?2004h>         setPendingDir(null);
[?2004l[?2004h>         setSelectedId(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       cycleBridge(from, to);
[?2004l[?2004h>       setPendingFromId(null);
[?2004l[?2004h>       setPendingDir(null);
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     // Backspace/Delete removes existing bridge between pending and current
[?2004l[?2004h>     if (e.key === 'Backspace' || e.key === 'Delete') {
[?2004l[?2004h>       if (pendingFromId === null) return;
[?2004l[?2004h>       const from = islandById(islands, pendingFromId);
[?2004l[?2004h>       const to = cur;
[?2004l[?2004h>       if (from && to && from.id !== to.id && areAdjacent(islands, from, to, bridges)) {
[?2004l[?2004h>         removeBridge(from, to);
[?2004l[?2004h>       }
[?2004l[?2004h>       setPendingFromId(null);
[?2004l[?2004h>       setPendingDir(null);
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const bridgeLineEls = [];
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (n <= 0) continue;
[?2004l[?2004h>     const segments = bridgeLinesForKey(k, n);
[?2004l[?2004h>     for (let i = 0; i < segments.length; i++) {
[?2004l[?2004h>       const s = segments[i];
[?2004l[?2004h>       bridgeLineEls.push(
[?2004l[?2004h>         <line
[?2004l[?2004h>           key={`${k}:${i}`}
[?2004l[?2004h>           x1={s.x1}
[?2004l[?2004h>           y1={s.y1}
[?2004l[?2004h>           x2={s.x2}
[?2004l[?2004h>           y2={s.y2}
[?2004l[?2004h>           stroke="#0f0"
[?2004l[?2004h>           strokeWidth={4}
[?2004l[?2004h>           strokeLinecap="round"
[?2004l[?2004h>         />
[?2004l[?2004h>       );
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return (
[?2004l[?2004h>     <div className="app-root" tabIndex={0} onKeyDown={handleKeyDown}>
[?2004l[?2004h>       <div className="ui-bar">
[?2004l[?2004h>         <label>
[?2004l[?2004h>           Puzzle:{' '}
[?2004l[?2004h>           <select
[?2004l[?2004h>             value={puzzleName}
[?2004l[?2004h>             onChange={(e) => setPuzzleName(e.target.value)}
[?2004l[?2004h>             aria-label="Puzzle"
[?2004l[?2004h>           >
[?2004l[?2004h>             <option value="Easy">Easy</option>
[?2004l[?2004h>             <option value="Medium">Medium</option>
[?2004l[?2004h>             <option value="Hard">Hard</option>
[?2004l[?2004h>           </select>
[?2004l[?2004h>         </label>
[?2004l[?2004h>         <button
[?2004l[?2004h>           onClick={() => {
[?2004l[?2004h>             setBridges(new Map());
[?2004l[?2004h>             setSelectedId(null);
[?2004l[?2004h>             setPendingFromId(null);
[?2004l[?2004h>             setPendingDir(null);
[?2004l[?2004h>             setError(null);
[?2004l[?2004h>           }}
[?2004l[?2004h>         >
[?2004l[?2004h>           Reset
[?2004l[?2004h>         </button>
[?2004l[?2004h>         <span className="counts-readout">
[?2004l[?2004h>           {islands.map((i) => `${i.id}:${counts.get(i.id) ?? 0}/${i.value}`).join('  ')}
[?2004l[?2004h>         </span>
[?2004l[?2004h>       </div>
[?2004l[?2004h> 
[?2004l[?2004h>       {error ? <div className="error-message">{error}</div> : null}
[?2004l[?2004h>       {victory ? <div className="victory-banner">SOLVED!</div> : null}
[?2004l[?2004h> 
[?2004l[?2004h>       <svg
[?2004l[?2004h>         ref={svgRef}
[?2004l[?2004h>         width={SVG_W}
[?2004l[?2004h>         height={SVG_H}
[?2004l[?2004h>         className="board"
[?2004l[?2004h>         viewBox={`0 0 ${SVG_W} ${SVG_H}`}
[?2004l[?2004h>       >
[?2004l[?2004h>         {bridgeLineEls}
[?2004l[?2004h> 
[?2004l[?2004h>         {/* cursor (must not be a circle) */}
[?2004l[?2004h>         {(() => {
[?2004l[?2004h>           const cur = islandById(islands, cursorId);
[?2004l[?2004h>           if (!cur) return null;
[?2004l[?2004h>           const size = 26;
[?2004l[?2004h>           return (
[?2004l[?2004h>             <rect
[?2004l[?2004h>               className="cursor"
[?2004l[?2004h>               x={px(cur.x) - size / 2}
[?2004l[?2004h>               y={px(cur.y) - size / 2}
[?2004l[?2004h>               width={size}
[?2004l[?2004h>               height={size}
[?2004l[?2004h>               fill="none"
[?2004l[?2004h>               stroke={pendingFromId !== null ? '#0ff' : '#0f0'}
[?2004l[?2004h>               strokeWidth={2}
[?2004l[?2004h>             />
[?2004l[?2004h>           );
[?2004l[?2004h>         })()}
[?2004l[?2004h> 
[?2004l[?2004h>         {islands.map((isl) => {
[?2004l[?2004h>           const r = 16;
[?2004l[?2004h>           const isSelected = selectedId === isl.id;
[?2004l[?2004h>           return (
[?2004l[?2004h>             <g
[?2004l[?2004h>               key={isl.id}
[?2004l[?2004h>               onClick={(e) => onIslandClick(isl, e)}
[?2004l[?2004h>               onContextMenu={(e) => onIslandContextMenu(isl, e)}
[?2004l[?2004h>               style={{ cursor: 'pointer' }}
[?2004l[?2004h>             >
[?2004l[?2004h>               <circle
[?2004l[?2004h>                 cx={px(isl.x)}
[?2004l[?2004h>                 cy={px(isl.y)}
[?2004l[?2004h>                 r={r}
[?2004l[?2004h>                 fill={isSelected ? '#0f0' : 'black'}
[?2004l[?2004h>                 stroke="#0f0"
[?2004l[?2004h>                 strokeWidth={3}
[?2004l[?2004h>               />
[?2004l[?2004h>               <text
[?2004l[?2004h>                 x={px(isl.x)}
[?2004l[?2004h>                 y={px(isl.y) + 6}
[?2004l[?2004h>                 textAnchor="middle"
[?2004l[?2004h>                 fontFamily="monospace"
[?2004l[?2004h>                 fontSize={18}
[?2004l[?2004h>                 fill={isSelected ? 'black' : '#0f0'}
[?2004l[?2004h>               >
[?2004l[?2004h>                 {isl.value}
[?2004l[?2004h>               </text>
[?2004l[?2004h>             </g>
[?2004l[?2004h>           );
[?2004l[?2004h>         })}
[?2004l[?2004h>       </svg>
[?2004l[?2004h> 
[?2004l[?2004h>       <div className="help">
[?2004l[?2004h>         Mouse: click two adjacent islands to cycle none→single→double→none. Right-click or Ctrl+click removes.
[?2004l[?2004h>         Keyboard: arrows move cursor, Enter selects then Enter toggles, Esc cancels.
[?2004l[?2004h>       </div>
[?2004l[?2004h>     </div>
[?2004l[?2004h>   );
[?2004l[?2004h> }
[?2004l[?2004h> EOF
[?2004l[?2004hroot@a1a7c85476d8:/app# cat > src/index.css <<'EOF'
[?2004l[?2004h> :root {
[?2004l[?2004h>   color-scheme: dark;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> html,
[?2004l[?2004h> body {
[?2004l[?2004h>   margin: 0;
[?2004l[?2004h>   padding: 0;
[?2004l[?2004h>   width: 100%;
[?2004l[?2004h>   height: 100%;
[?2004l[?2004h>   background: #000;
[?2004l[?2004h>   color: #0f0;
[?2004l[?2004h>   font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> #root {
[?2004l[?2004h>   width: 100%;
[?2004l[?2004h>   height: 100%;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> .app-root {
[?2004l[?2004h>   position: relative;
[?2004l[?2004h>   width: 100%;
[?2004l[?2004h>   height: 100%;
[?2004l[?2004h>   outline: none;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> .ui-bar {
[?2004l[?2004h>   position: absolute;
[?2004l[?2004h>   top: 0;
[?2004l[?2004h>   left: 0;
[?2004l[?2004h>   display: flex;
[?2004l[?2004h>   gap: 12px;
[?2004l[?2004h>   align-items: center;
[?2004l[?2004h>   padding: 8px 10px;
[?2004l[?2004h>   background: rgba(0, 0, 0, 0.85);
[?2004l[?2004h>   border-bottom: 1px solid #0f0;
[?2004l[?2004h>   z-index: 2;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> select,
[?2004l[?2004h> button {
[?2004l[?2004h>   background: #000;
[?2004l[?2004h>   color: #0f0;
[?2004l[?2004h>   border: 1px solid #0f0;
[?2004l[?2004h>   font-family: inherit;
[?2004l[?2004h>   padding: 4px 8px;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> button {
[?2004l[?2004h>   cursor: pointer;
[?2004l[?2004h> }
[?2004l[?2004h> 
