[?2004l[?2004h>   ERROR_EXCEED_NUMBER,
[?2004l[?2004h>   ERROR_MAX_PER_PAIR,
[?2004l[?2004h>   ERROR_NON_ADJACENT,
[?2004l[?2004h>   areAdjacent,
