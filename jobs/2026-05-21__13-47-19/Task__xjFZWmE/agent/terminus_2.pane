[?2004l[?2004h> export const ERROR_NON_ADJACENT = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> export const ERROR_MAX_PER_PAIR = 'Max 2 bridges per pair';
[?2004l[?2004h> export const ERROR_EXCEED_NUMBER = 'Island would exceed its number';
[?2004l[?2004h> export const ERROR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(a, b) {
[?2004l[?2004h>   const p1 = { x: a.x, y: a.y };
[?2004l[?2004h>   const p2 = { x: b.x, y: b.y };
[?2004l[?2004h>   const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;
[?2004l[?2004h>   const second = first === p1 ? p2 : p1;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isHorizontal(a, b) {
[?2004l[?2004h>   return a.y === b.y && a.x !== b.x;
[?2004l[?2004h> }
[?2004l[?2004h> function isVertical(a, b) {
[?2004l[?2004h>   return a.x === b.x && a.y !== b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to, bridges) {
[?2004l[?2004h>   if (!from || !to) return false;
[?2004l[?2004h>   if (!(isHorizontal(from, to) || isVertical(from, to))) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // must have clear path: no island between
[?2004l[?2004h>   if (isHorizontal(from, to)) {
[?2004l[?2004h>     const y = from.y;
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === y && i.x > minX && i.x < maxX);
[?2004l[?2004h>     if (between) return false;
[?2004l[?2004h>   } else {
[?2004l[?2004h>     const x = from.x;
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === x && i.y > minY && i.y < maxY);
[?2004l[?2004h>     if (between) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // cannot pass through existing bridge segment (collinear overlap is fine only if it's the same pair)
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   for (const [k, count] of bridges.entries()) {
[?2004l[?2004h>     if (count <= 0) continue;
[?2004l[?2004h>     if (k === key) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>     const A = { x: x1, y: y1 };
[?2004l[?2004h>     const B = { x: x2, y: y2 };
[?2004l[?2004h> 
[?2004l[?2004h>     // if candidate is horizontal, disallow any vertical bridge crossing its path
[?2004l[?2004h>     if (isHorizontal(from, to) && A.x === B.x) {
[?2004l[?2004h>       const cxMin = Math.min(from.x, to.x);
[?2004l[?2004h>       const cxMax = Math.max(from.x, to.x);
[?2004l[?2004h>       const byMin = Math.min(A.y, B.y);
[?2004l[?2004h>       const byMax = Math.max(A.y, B.y);
[?2004l[?2004h>       if (A.x > cxMin && A.x < cxMax && from.y > byMin && from.y < byMax) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     // if candidate is vertical, disallow any horizontal bridge crossing its path
[?2004l[?2004h>     if (isVertical(from, to) && A.y === B.y) {
[?2004l[?2004h>       const cyMin = Math.min(from.y, to.y);
[?2004l[?2004h>       const cyMax = Math.max(from.y, to.y);
[?2004l[?2004h>       const bxMin = Math.min(A.x, B.x);
[?2004l[?2004h>       const bxMax = Math.max(A.x, B.x);
[?2004l[?2004h>       if (from.x > bxMin && from.x < bxMax && A.y > cyMin && A.y < cyMax) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(k1, k2) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = k1.split(',').map(Number);
[?2004l[?2004h>   const [x3, y3, x4, y4] = k2.split(',').map(Number);
[?2004l[?2004h> 
[?2004l[?2004h>   // ignore if share endpoints
[?2004l[?2004h>   const endpoints1 = [
[?2004l[?2004h>     `${x1},${y1}`,
[?2004l[?2004h>     `${x2},${y2}`,
[?2004l[?2004h>   ];
[?2004l[?2004h>   const endpoints2 = [
[?2004l[?2004h>     `${x3},${y3}`,
[?2004l[?2004h>     `${x4},${y4}`,
[?2004l[?2004h>   ];
[?2004l[?2004h>   if (endpoints1.some((e) => endpoints2.includes(e))) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const h1 = y1 === y2;
[?2004l[?2004h>   const v1 = x1 === x2;
[?2004l[?2004h>   const h2 = y3 === y4;
[?2004l[?2004h>   const v2 = x3 === x4;
[?2004l[?2004h>   if (!(h1 || v1) || !(h2 || v2)) return false;
[?2004l[?2004h>   if ((h1 && h2) || (v1 && v2)) return false; // collinear cannot cross in this puzzle definition
[?2004l[?2004h> 
[?2004l[?2004h>   const hx1 = h1 ? [Math.min(x1, x2), Math.max(x1, x2), y1] : [Math.min(x3, x4), Math.max(x3, x4), y3];
[?2004l[?2004h>   const vy1 = v1 ? [Math.min(y1, y2), Math.max(y1, y2), x1] : [Math.min(y3, y4), Math.max(y3, y4), x3];
[?2004l[?2004h> 
[?2004l[?2004h>   const [hMinX, hMaxX, hy] = hx1;
[?2004l[?2004h>   const [vMinY, vMaxY, vx] = vy1;
[?2004l[?2004h> 
[?2004l[?2004h>   return vx > hMinX && vx < hMaxX && hy > vMinY && hy < vMaxY;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesCross(bridges) {
[?2004l[?2004h>   const keys = [];
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) if (n > 0) keys.push(k);
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       if (segmentsCross(keys[i], keys[j])) return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to || from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h> 
[?2004l[?2004h>   // adjacency in straight line with no islands between
[?2004l[?2004h>   if (!(isHorizontal(from, to) || isVertical(from, to))) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h>   // also must be nearest visible in that direction (no islands between) and no crossing path
[?2004l[?2004h>   if (!areAdjacent(islands, from, to, bridges)) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h>   if (next < 0) return { valid: false, error: ERROR_MAX_PER_PAIR };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERROR_MAX_PER_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   // check exceed counts
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) return { valid: false, error: ERROR_EXCEED_NUMBER };
[?2004l[?2004h> 
[?2004l[?2004h>   // check crossing if we're adding (delta>0)
[?2004l[?2004h>   if (delta > 0 && current === 0) {
[?2004l[?2004h>     const tmp = new Map(bridges);
[?2004l[?2004h>     tmp.set(key, 1);
[?2004l[?2004h>     if (bridgesCross(tmp)) return { valid: false, error: ERROR_CROSS };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length <= 1) return true;
[?2004l[?2004h>   const coordToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));
[?2004l[?2004h>   const adj = new Map(islands.map((i) => [i.id, []]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (n <= 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>     const a = coordToId.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = coordToId.get(`${x2},${y2}`);
[?2004l[?2004h>     if (a === undefined || b === undefined) continue;
[?2004l[?2004h>     adj.get(a).push(b);
[?2004l[?2004h>     adj.get(b).push(a);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const startId = islands[0].id;
[?2004l[?2004h>   const seen = new Set([startId]);
[?2004l[?2004h>   const q = [startId];
[?2004l[?2004h>   while (q.length) {
[?2004l[?2004h>     const cur = q.shift();
[?2004l[?2004h>     for (const nxt of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt);
[?2004l[?2004h>         q.push(nxt);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   if (bridgesCross(bridges)) return false;
[?2004l[?2004h>   if (!checkConnectivity(islands, bridges)) return false;
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
