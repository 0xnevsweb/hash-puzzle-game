[195.686305, "i", "cat > src/utils/hashiLogic.js <<'EOF'\nexport const ERROR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\nexport const ERROR_MAX_PER_PAIR = 'Max 2 bridges per pair';\nexport const ERROR_EXCEED_NUMBER = 'Island would exceed its number';\nexport const ERROR_CROSS = 'Bridges would cross';\n\nexport function canonicalBridgeKey(a, b) {\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\n  const second = first === p1 ? p2 : p1;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction isHorizontal(a, b) {\n  return a.y === b.y && a.x !== b.x;\n}\nfunction isVertical(a, b) {\n  return a.x === b.x && a.y !== b.y;\n}\n\n// Adjacent in Hashi = straight line with no islands between.\nexport function areAdjacent(islands, from, to) {\n  if (!from || !to) return false;\n  if (!(isHorizontal(from, to) || isVertical(from, to))) return false;\n\n  if (isHorizontal(from, to)) {\n    const y = from.y;\n    const minX = Math.min(from.x, to.x);"]
[195.686369, "i", "\n    const maxX = Math.max(from.x, to.x);\n    const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === y && i.x > minX && i.x < maxX);\n    return !between;\n  }\n\n  const x = from.x;\n  const minY = Math.min(from.y, to.y);\n  const maxY = Math.max(from.y, to.y);\n  const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === x && i.y > minY && i.y < maxY);\n  return !between;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nfunction segmentsCross(k1, k2) {\n  const [x1, y1, x2, y2] = k1.split"]
[195.686397, "i", "(',').map(Number);\n  const [x3, y3, x4, y4] = k2.split(',').map(Number);\n\n  // ignore if share endpoints\n  const endpoints1 = [`${x1},${y1}`, `${x2},${y2}`];\n  const endpoints2 = [`${x3},${y3}`, `${x4},${y4}`];\n  if (endpoints1.some((e) => endpoints2.includes(e))) return false;\n\n  const h1 = y1 === y2;\n  const v1 = x1 === x2;\n  const h2 = y3 === y4;\n  const v2 = x3 === x4;\n  if (!(h1 || v1) || !(h2 || v2)) return false;\n  if ((h1 && h2) || (v1 && v2)) return false;\n\n  const hx = h1 ? [Math.min(x1, x2), Math.max(x1, x2), y1] : [Math.min(x3, x4), Math.max(x3, x4), y3];\n  const vy = v1 ? [Math.min(y1, y2), Math.max(y1, y2), x1] : [Math.min(y3, y4), Math.max(y3, y4), x3];\n  const [hMinX, hMaxX, hy] = hx;\n  const [vMinY, vMaxY, vx] = vy;\n  return vx > hMinX && vx < hMaxX && hy > vMinY && hy < vMaxY;\n}\n\nexport function bridgesCross(bridges) {\n  const keys = [];\n  for (const [k, n] of bridges.entries()) if (n > 0) keys.push(k);\n  for (let i = 0; i < keys.length; i++) {\n    for (let j = i + 1; j < keys.length; j++) {"]
[195.686429, "i", "\n      if (segmentsCross(keys[i], keys[j])) return true;\n    }\n  }\n  return false;\n}\n\nfunction wouldCrossCandidate(bridges, candidateKey) {\n  for (const [k, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    if (k === candidateKey) continue;\n    if (segmentsCross(candidateKey, k)) return true;\n  }\n  return false;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  if (!(isHorizontal(from, to) || isVertical(from, to))) return { valid: false, error: ERROR_NON_ADJACENT };\n  if (!areAdjacent(islands, from, to)) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  const key = canonicalBridgeKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = current + delta;\n  if (next > 2 || next < 0) return { valid: false, error: ERROR_MAX_PER_PAIR };\n\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.ge"]
[195.686446, "i", "t(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) return { valid: false, error: ERROR_EXCEED_NUMBER };\n\n  // crossing check only when adding a new segment (0->1)\n  if (delta > 0 && current === 0) {\n    if (wouldCrossCandidate(bridges, key)) return { valid: false, error: ERROR_CROSS };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n  const coordToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n  const adj = new Map(islands.map((i) => [i.id, []]));\n\n  for (const [k, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const a = coordToId.get(`${x1},${y1}`);\n    const b = coordToId.get(`${x2},${y2}`);\n    if (a === undefined || b === undefined) continue;\n    adj.get(a).push(b);\n    adj.get(b).push(a);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const q = [startId];\n  while (q.length) {\n    const"]
[195.686462, "i", " cur = q.shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n  if (bridgesCross(bridges)) return false;\n  if (!checkConnectivity(islands, bridges)) return false;\n  return true;\n}\nEOF\n"]
