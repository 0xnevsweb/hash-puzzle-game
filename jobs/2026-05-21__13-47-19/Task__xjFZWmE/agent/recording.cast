[155.585296, "i", "cat > src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { puzzles } from './data/puzzles';\nimport {\n  ERROR_CROSS,\n  ERROR_EXCEED_NUMBER,\n  ERROR_MAX_PER_PAIR,\n  ERROR_NON_ADJACENT,\n  areAdjacent,\n  canonicalBridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n} from './utils/hashiLogic';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction px(n) {\n  return n * GRID;\n}\n\nfunction findIslandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y);\n}\n\nfunction islandById(islands, id) {\n  return islands.find((i) => i.id === id);\n}\n\nfunction getNeighborInDirection(islands, from, dir) {\n  // returns nearest island in that direction (ignores bridges)\n  let best = null;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\n      if (!best || isl.x > best.x) best = isl;\n    }\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\n      if (!best "]
[155.585481, "i", "|| isl.x < best.x) best = isl;\n    }\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\n      if (!best || isl.y > best.y) best = isl;\n    }\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\n      if (!best || isl.y < best.y) best = isl;\n    }\n  }\n  return best;\n}\n\nfunction bridgeLinesForKey(key, count) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  const a = { x: x1, y: y1 };\n  const b = { x: x2, y: y2 };\n  const x1p = px(a.x);\n  const y1p = px(a.y);\n  const x2p = px(b.x);\n  const y2p = px(b.y);\n\n  const isH = a.y === b.y;\n  const offset = 6; // pixel offset for double bridges\n\n  if (count === 1) {\n    return [\n      {\n        x1: x1p,\n        y1: y1p,\n        x2: x2p,\n        y2: y2p,\n      },\n    ];\n  }\n  if (count === 2) {\n    if (isH) {\n      return [\n        { x1: x1p, y1: y1p - offset, x2: x2p, y2: y2p - offset },\n        { x1: x1p, y1: y1p + offset, x2: x2p, y2: y2p + offset },\n      ];\n    }\n    return [\n      { x1: x1p - offset, y1: y1p, x2: x2p - offset, y2: y2p"]
[155.585556, "i", " },\n      { x1: x1p + offset, y1: y1p, x2: x2p + offset, y2: y2p },\n    ];\n  }\n  return [];\n}\n\nexport default function App() {\n  const [puzzleName, setPuzzleName] = useState('Easy');\n  const puzzle = useMemo(() => puzzles.find((p) => p.name === puzzleName) ?? puzzles[0], [puzzleName]);\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [cursorId, setCursorId] = useState(islands[0]?.id ?? 0);\n  const [pendingFromId, setPendingFromId] = useState(null); // keyboard selection\n  const [pendingDir, setPendingDir] = useState(null); // last arrow dir while pending\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  useEffect(() => {\n    // puzzle change: reset everything\n    setBridges(new Map());\n    setSelectedId(null);\n    setPendingFromId(null);\n    setPendingDir(null);\n    setError(null);\n    setCursorId(puzzle.islands[0]?.id ?? 0);\n  }, [puzzleName]);\n\n  useEffect(() => {\n    // ke"]
[155.585592, "i", "ep cursor valid if puzzle changes\n    if (!islandById(islands, cursorId)) {\n      setCursorId(islands[0]?.id ?? 0);\n    }\n  }, [islands, cursorId]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function clearErrorOnValid(result) {\n    if (result?.valid) setError(null);\n  }\n\n  function setErrorIfAny(result) {\n    if (!result?.valid && result?.error) setError(result.error);\n  }\n\n  function cycleBridge(from, to) {\n    const key = canonicalBridgeKey(from, to);\n    const current = bridges.get(key) ?? 0;\n    const next = (current + 1) % 3; // 0->1->2->0\n\n    if (next === 0) {\n      const nb = new Map(bridges);\n      nb.delete(key);\n      setBridges(nb);\n      setError(null);\n      return;\n    }\n\n    const delta = next - current;\n    const check = canAddBridge(islands, bridges, from, to, delta);\n    if (!check.valid) {\n      setErrorIfAny(check);\n      return;\n    }\n\n    const nb = new"]
[155.586962, "i", " Map(bridges);\n    nb.set(key, next);\n    setBridges(nb);\n    clearErrorOnValid(check);\n  }\n\n  function removeBridge(from, to) {\n    const key = canonicalBridgeKey(from, to);\n    if (!(bridges.get(key) > 0)) return;\n    const nb = new Map(bridges);\n    nb.delete(key);\n    setBridges(nb);\n    setError(null);\n  }\n\n  function onIslandClick(isl, e) {\n    // ctrl+click removes a bridge if selection exists and this island is the other endpoint\n    if ((e.ctrlKey || e.metaKey) && selectedId !== null && selectedId !== isl.id) {\n      const from = islandById(islands, selectedId);\n      if (from && areAdjacent(islands, from, isl, bridges)) {\n        removeBridge(from, isl);\n      }\n      setSelectedId(null);\n      return;\n    }\n\n    if (selectedId === null) {\n      setSelectedId(isl.id);\n      setCursorId(isl.id);\n      return;\n    }\n\n    if (selectedId === isl.id) {\n      // clicking same island keeps selection\n      return;\n    }\n\n    const from = islandById(islands, selectedId);\n    const to = isl;\n    if (!from) {\n"]
[155.586996, "i", "      setSelectedId(null);\n      return;\n    }\n\n    if (!areAdjacent(islands, from, to, bridges)) {\n      setError(ERROR_NON_ADJACENT);\n      setSelectedId(null);\n      return;\n    }\n\n    cycleBridge(from, to);\n    setSelectedId(null);\n  }\n\n  function onIslandContextMenu(isl, e) {\n    e.preventDefault();\n    if (selectedId === null || selectedId === isl.id) return;\n    const from = islandById(islands, selectedId);\n    if (!from) return;\n    if (!areAdjacent(islands, from, isl, bridges)) return;\n    removeBridge(from, isl);\n    setSelectedId(null);\n  }\n\n  function handleKeyDown(e) {\n    const cur = islandById(islands, cursorId) ?? islands[0];\n    if (!cur) return;\n\n    if (e.key === 'Escape') {\n      setPendingFromId(null);\n      setPendingDir(null);\n      setSelectedId(null);\n      setError(null);\n      return;\n    }\n\n    const dirFromKey =\n      e.key === 'ArrowLeft'\n        ? 'left'\n        : e.key === 'ArrowRight'\n          ? 'right'\n          : e.key === 'ArrowUp'\n            ? 'up'\n            : e.key =="]
[155.587039, "i", "= 'ArrowDown'\n              ? 'down'\n              : null;\n\n    if (dirFromKey) {\n      e.preventDefault();\n      const nxt = getNeighborInDirection(islands, cur, dirFromKey);\n      if (nxt) {\n        setCursorId(nxt.id);\n        if (pendingFromId !== null) setPendingDir(dirFromKey);\n      }\n      return;\n    }\n\n    if (e.key === 'Enter') {\n      e.preventDefault();\n\n      if (pendingFromId === null) {\n        setPendingFromId(cur.id);\n        setSelectedId(cur.id);\n        setPendingDir(null);\n        return;\n      }\n\n      // second enter: toggle bridge from pendingFromId to current cursor target\n      const from = islandById(islands, pendingFromId);\n      const to = cur;\n\n      if (!from || !to || from.id === to.id) {\n        setPendingFromId(null);\n        setPendingDir(null);\n        setSelectedId(null);\n        return;\n      }\n\n      if (!areAdjacent(islands, from, to, bridges)) {\n        setError(ERROR_NON_ADJACENT);\n        setPendingFromId(null);\n        setPendingDir(null);\n        setSelectedId(nul"]
[155.587079, "i", "l);\n        return;\n      }\n\n      cycleBridge(from, to);\n      setPendingFromId(null);\n      setPendingDir(null);\n      setSelectedId(null);\n      return;\n    }\n\n    // Backspace/Delete removes existing bridge between pending and current\n    if (e.key === 'Backspace' || e.key === 'Delete') {\n      if (pendingFromId === null) return;\n      const from = islandById(islands, pendingFromId);\n      const to = cur;\n      if (from && to && from.id !== to.id && areAdjacent(islands, from, to, bridges)) {\n        removeBridge(from, to);\n      }\n      setPendingFromId(null);\n      setPendingDir(null);\n      setSelectedId(null);\n    }\n  }\n\n  const bridgeLineEls = [];\n  for (const [k, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    const segments = bridgeLinesForKey(k, n);\n    for (let i = 0; i < segments.length; i++) {\n      const s = segments[i];\n      bridgeLineEls.push(\n        <line\n          key={`${k}:${i}`}\n          x1={s.x1}\n          y1={s.y1}\n          x2={s.x2}\n          y2={s.y2}\n          stroke=\"#"]
[155.587117, "i", "0f0\"\n          strokeWidth={4}\n          strokeLinecap=\"round\"\n        />\n      );\n    }\n  }\n\n  return (\n    <div className=\"app-root\" tabIndex={0} onKeyDown={handleKeyDown}>\n      <div className=\"ui-bar\">\n        <label>\n          Puzzle:{' '}\n          <select\n            value={puzzleName}\n            onChange={(e) => setPuzzleName(e.target.value)}\n            aria-label=\"Puzzle\"\n          >\n            <option value=\"Easy\">Easy</option>\n            <option value=\"Medium\">Medium</option>\n            <option value=\"Hard\">Hard</option>\n          </select>\n        </label>\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedId(null);\n            setPendingFromId(null);\n            setPendingDir(null);\n            setError(null);\n          }}\n        >\n          Reset\n        </button>\n        <span className=\"counts-readout\">\n          {islands.map((i) => `${i.id}:${counts.get(i.id) ?? 0}/${i.value}`).join('  ')}\n        </span>\n      </div>\n\n      {error ? <di"]
[155.587157, "i", "v className=\"error-message\">{error}</div> : null}\n      {victory ? <div className=\"victory-banner\">SOLVED!</div> : null}\n\n      <svg\n        ref={svgRef}\n        width={SVG_W}\n        height={SVG_H}\n        className=\"board\"\n        viewBox={`0 0 ${SVG_W} ${SVG_H}`}\n      >\n        {bridgeLineEls}\n\n        {/* cursor (must not be a circle) */}\n        {(() => {\n          const cur = islandById(islands, cursorId);\n          if (!cur) return null;\n          const size = 26;\n          return (\n            <rec"]
[155.587251, "i", "t\n              className=\"cursor\"\n              x={px(cur.x) - size / 2}\n              y={px(cur.y) - size / 2}\n              width={size}\n              height={size}\n              fill=\"none\"\n              stroke={pendingFromId !== null ? '#0ff' : '#0f0'}\n              strokeWidth={2}\n            />\n          );\n        })()}\n\n        {islands.map((isl) => {\n          const r = 16;\n          const isSelected = selectedId === isl.id;\n          return (\n            <g\n              key={isl.id}\n              onClick={(e) => onIslandClick(isl, e)}\n              onContextMenu={(e) => onIslandContextMenu(isl, e)}\n              style={{ cursor: 'pointer' }}\n            >\n              <circle\n                cx={px(isl.x)}\n                cy={px(isl.y)}\n                r={r}\n                fill={isSelected ? '#0f0' : 'black'}\n                stroke=\"#0f0\"\n                strokeWidth={3}\n              />\n              <text\n                x={px(isl.x)}\n                y={px(isl.y) + 6}\n                textAnchor"]
[155.587293, "i", "=\"middle\"\n                fontFamily=\"monospace\"\n                fontSize={18}\n                fill={isSelected ? 'black' : '#0f0'}\n              >\n                {isl.value}\n              </text>\n            </g>\n          );\n        })}\n      </svg>\n\n      <div className=\"help\">\n        Mouse: click two adjacent islands to cycle none→single→double→none. Right-click or Ctrl+click removes.\n        Keyboard: arrows move cursor, Enter selects then Enter toggles, Esc cancels.\n      </div>\n    </div>\n  );\n}\nEOF\n"]
