[155.071494, "i", "st maxX = Math.max(from.x, to.x);\n    const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === y && i.x > minX && i.x < maxX);\n    if (between) return false;\n  } else {\n    const x = from.x;\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === x && i.y > minY && i.y < maxY);\n    if (between) return false;\n  }\n\n  // cannot pass through existing bridge segment (collinear overlap is fine only if it's the same pair)\n  const key = canonicalBridgeKey(from, to);\n  for (const [k, count] of bridges.entries()) {\n    if (count <= 0) continue;\n    if (k === key) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const A = { x: x1, y: y1 };\n    const B = { x: x2, y: y2 };\n\n    // if candidate is horizontal, disallow any vertical bridge crossing its path\n    if (isHorizontal(from, to) && A.x === B.x) {\n      const cxMin = Math.min(from.x, to.x);\n      const cxMax = Ma"]
[155.071578, "i", "th.max(from.x, to.x);\n      const byMin = Math.min(A.y, B.y);\n      const byMax = Math.max(A.y, B.y);\n      if (A.x > cxMin && A.x < cxMax && from.y > byMin && from.y < byMax) return false;\n    }\n    // if candidate is vertical, disallow any horizontal bridge crossing its path\n    if (isVertical(from, to) && A.y === B.y) {\n      const cyMin = Math.min(from.y, to.y);\n      const cyMax = Math.max(from.y, to.y);\n      const bxMin = Math.min(A.x, B.x);\n      const bxMax = Math.max(A.x, B.x);\n      if (from.x > bxMin && from.x < bxMax && A.y > cyMin && A.y < cyMax) return false;\n    }\n  }\n\n  return true;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    co"]
[155.07162, "i", "unts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nfunction segmentsCross(k1, k2) {\n  const [x1, y1, x2, y2] = k1.split(',').map(Number);\n  const [x3, y3, x4, y4] = k2.split(',').map(Number);\n\n  // ignore if share endpoints\n  const endpoints1 = [\n    `${x1},${y1}`,\n    `${x2},${y2}`,\n  ];\n  const endpoints2 = [\n    `${x3},${y3}`,\n    `${x4},${y4}`,\n  ];\n  if (endpoints1.some((e) => endpoints2.includes(e))) return false;\n\n  const h1 = y1 === y2;\n  const v1 = x1 === x2;\n  const h2 = y3 === y4;\n  const v2 = x3 === x4;\n  if (!(h1 || v1) || !(h2 || v2)) return false;\n  if ((h1 && h2) || (v1 && v2)) return false; // collinear cannot cross in this puzzle definition\n\n  const hx1 = h1 ? [Math.min(x1, x2), Math.max(x1, x2), y1] : [Math.min(x3, x4), Math.max(x3, x4), y3];\n  const vy1 = v1 ? [Math.min(y1, y2), Math.max(y1, y2), x1] : [Math.min(y3, y4), Math.max(y3, y4), x3];\n\n  const [hMinX, hMaxX, hy] = hx1;\n  const [vMinY, vMaxY, vx] = vy1;\n\n  return "]
[155.071671, "i", "vx > hMinX && vx < hMaxX && hy > vMinY && hy < vMaxY;\n}\n\nexport function bridgesCross(bridges) {\n  const keys = [];\n  for (const [k, n] of bridges.entries()) if (n > 0) keys.push(k);\n  for (let i = 0; i < keys.length; i++) {\n    for (let j = i + 1; j < keys.length; j++) {\n      if (segmentsCross(keys[i], keys[j])) return true;\n    }\n  }\n  return false;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  // adjacency in straight line with no islands between\n  if (!(isHorizontal(from, to) || isVertical(from, to))) return { valid: false, error: ERROR_NON_ADJACENT };\n  // also must be nearest visible in that direction (no islands between) and no crossing path\n  if (!areAdjacent(islands, from, to, bridges)) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  const key = canonicalBridgeKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = current + delta;\n  if (next < 0) return { vali"]
[155.071768, "i", "d: false, error: ERROR_MAX_PER_PAIR };\n  if (next > 2) return { valid: false, error: ERROR_MAX_PER_PAIR };\n\n  // check exceed counts\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) return { valid: false, error: ERROR_EXCEED_NUMBER };\n\n  // check crossing if we're adding (delta>0)\n  if (delta > 0 && current === 0) {\n    const tmp = new Map(bridges);\n    tmp.set(key, 1);\n    if (bridgesCross(tmp)) return { valid: false, error: ERROR_CROSS };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n  const coordToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n  const adj = new Map(islands.map((i) => [i.id, []]));\n\n  for (const [k, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const a = c"]
[155.071803, "i", "oordToId.get(`${x1},${y1}`);\n    const b = coordToId.get(`${x2},${y2}`);\n    if (a === undefined || b === undefined) continue;\n    adj.get(a).push(b);\n    adj.get(b).push(a);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const q = [startId];\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n  if (bridgesCross(bridges)) return false;\n  if (!checkConnectivity(islands, bridges)) return false;\n  return true;\n}\nEOF\n"]
