[91.569477, "i", "ight', 'ArrowUp', 'ArrowDown'].includes(e.key)) {\n        e.preventDefault();\n        moveCursor(e.key);\n        return;\n      }\n\n      if (e.key === 'Escape') {\n        e.preventDefault();\n        setKeyboardFromId(null);\n        setSelectedId(null);\n        clearErrorOnValidMove();\n        return;\n      }\n\n      if (e.key === 'Enter') {\n        e.preventDefault();\n        if (cursorId === null) return;\n        const cur = islands.find((i) => i.id === cursorId);\n        if (!cur) return;\n\n        if (keyboardFromId === null) {\n          setKeyboardFromId(cur.id);\n          return;\n        }\n\n        if (keyboardFromId === cur.id) {\n          // keep selection\n          return;\n        }\n\n        const from = islands.find((i) => i.id === keyboardFromId);\n        handleToggle(from, cur);\n        setKeyboardFromId(null);\n        return;\n      }\n    }\n\n    window.addEventListener('keydown', onKeyDown);\n    return () => window.removeEventListener('keydown', onKeyDown);\n  }, [cursorId, islands, keyboardFromId, bri"]
[91.570176, "i", "dges, error]);\n\n  function reset() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setKeyboardFromId(null);\n    setError(null);\n  }\n\n  const bridgeLines = useMemo(() => {\n    const lines = [];\n    for (const [key, n] of bridges.entries()) {\n      if (!n) continue;\n      const [x1, y1, x2, y2] = key.split(',').map(Number);\n      const a = { x: x1, y: y1 };\n      const b = { x: x2, y: y2 };\n      const px1 = a.x * GRID;\n      const py1 = a.y * GRID;\n      const px2 = b.x * GRID;\n      const py2 = b.y * GRID;\n\n      const horizontal = py1 === py2;\n      const offset = 6; // px\n      const dx = horizontal ? 0 : offset;\n      const dy = horizontal ? offset : 0;\n\n      const mkLine = (idx, ox, oy) => (\n        <line\n          key={`${key}:${idx}`}\n          x1={px1 + ox}\n          y1={py1 + oy}\n          x2={px2 + ox}\n          y2={py2 + oy}\n          stroke=\"#0f0\"\n          strokeWidth={3}\n        />\n      );\n\n      if (n === 1) {\n        lines.push(mkLine(0, 0, 0));\n      } else if (n === 2) {\n        l"]
