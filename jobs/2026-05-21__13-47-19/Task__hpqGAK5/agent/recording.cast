[211.994821, "o", "  const bridgeLines = useMemo(() => {\r\n"]
[211.994829, "o", "    const lines = [];\r\n"]
[211.995181, "o", "    for (const [key, n] of bridges.entries()) {\r\n      if (!n) continue;\r\n      const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n      const a = { x: x1, y: y1 };\r\n      const b = { x: x2, y: y2 };\r\n      const px1 = a.x * GRID;\r\n      const py1 = a.y * GRID;\r\n      const px2 = b.x * GRID;\r\n      const py2 = b.y * GRID;\r\n\r\n      const horizontal = py1 === py2;\r\n      const offset = 6; // px\r\n      const dx = horizontal ? 0 : offset;\r\n      const dy = horizontal ? offset : 0;\r\n\r\n      const mkLine = (idx, ox, oy) => ("]
[211.995881, "o", "\r\n        <line\r\n"]
[211.996004, "o", "          key={`${key}:${idx}`}\r\n          x1={px1 + ox}\r\n          y1={py1 + oy}\r\n          x2={px2 + ox}\r\n          y2={py2 + oy}\r\n          stroke=\"#0f0\"\r\n          strokeWidth={3}\r\n        />\r\n      );\r\n\r\n      if (n === 1) {\r\n        lines.push(mkLine(0, 0, 0));\r\n      } else if (n === 2) {\r\n        lines.push(mkLine(0, dx, dy));\r\n        lines.push(mkLine(1, -dx, -dy));\r\n      }\r\n"]
[211.996167, "o", "    }\r\n    return lines;\r\n  }, [bridges]);\r\n\r\n  const cursorRect = useMemo(() => {\r\n    if (cursorId === null) return null;\r\n    const isl = islands.find((i) => i.id === cursorId);\r\n    if (!isl) return null;\r\n    const { cx, cy } = islandCenterPx(isl);\r\n    const size = 34;\r\n    const x = cx - size / 2;\r\n    const y = cy - size / 2;\r\n    const active = keyboardFromId === isl.id || selectedId === isl.id;\r\n"]
