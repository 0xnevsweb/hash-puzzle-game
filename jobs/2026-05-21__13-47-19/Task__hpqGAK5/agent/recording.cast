[211.993636, "o", "    if (error) setError(null);\r\n"]
[211.993647, "o", "  }\r\n\r\n"]
[211.993682, "o", "  function updateBridge(from, to, nextValue) {\r\n    const key = getCanonicalBridgeKey(from, to);\r\n    setBridges((prev) => {\r\n      const m = new Map(prev);"]
[211.993691, "o", "\r\n      if (!nextValue) m.delete(key);"]
[211.993702, "o", "\r\n      else m.set(key, nextValue);\r\n"]
[211.993717, "o", "      return m;\r\n    });\r\n"]
[211.993726, "o", "  }\r\n"]
[211.993734, "o", "\r\n  function handleToggle(from, to) {"]
[211.993743, "o", "\r\n    const key = getCanonicalBridgeKey(from, to);"]
[211.993764, "o", "\r\n    const current = bridges.get(key) ?? 0;"]
