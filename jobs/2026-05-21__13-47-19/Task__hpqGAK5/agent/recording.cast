[211.993581, "o", "  computeCurrentCounts,\r\n  getAdjacentIslands,\r\n  getCanonicalBridgeKey,\r\n  isVictory\r\n} from './utils/hashiLogic';\r\n\r\nconst GRID = 40;\r\nconst W = 800;\r\nconst H = 600;\r\n\r\nfunction islandCenterPx(isl) {\r\n  return { cx: isl.x * GRID, cy: isl.y * GRID };\r\n}\r\n\r\nfunction isCtrlClick(e) {\r\n  return e.ctrlKey || e.metaKey;\r\n}\r\n\r\nfunction App() {\r\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\r\n  const puzzle = puzzles[puzzleIndex];\r\n\r\n  const [bridges, setBridges] = useState(() => new Map());\r\n  const [selectedId, setSelectedId] = useState(null);\r\n  const [cursorId, setCursorId] = useState(puzzle.islands[0]?.id ?? null);\r\n  const [keyboardFromId, setKeyboardFromId] = useState(null);\r\n  const [error, setError] = useState(null);\r\n\r\n  const svgRef = useRef(null);\r\n\r\n  useEffect(() => {\r\n    // puzzle change resets bridges + selection/cursor\r\n    setBridges(new Map());\r\n    setSelectedId(null);\r\n    setKeyboardFromId(null);\r\n    setError(null);\r\n    setCursorId(puzzles[puzzleIndex]?.islands?.[0]?.id ?? null);\r\n  }"]
[211.993594, "o", ", [puzzleIndex]);\r\n\r\n  const islands = puzzle.islands;\r\n"]
