[211.994719, "o", "\r\n"]
[211.994726, "o", "    }\r\n"]
[211.994735, "o", "\r\n    window.addEventListener('keydown', onKeyDown);"]
[211.994742, "o", "\r\n    return () => window.removeEventListener('keydown', onKeyDown);"]
