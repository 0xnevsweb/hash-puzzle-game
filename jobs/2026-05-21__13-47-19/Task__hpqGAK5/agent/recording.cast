[95.932141, "i", "cat > src/index.css <<'EOF'\n:root {\n  color-scheme: dark;\n}\n\nhtml,\nbody {\n  margin: 0;\n  padding: 0;\n  background: #000;\n  color: #0f0;\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\",\n    \"Courier New\", monospace;\n}\n\n.app-root {\n  position: relative;\n}\n\n.ui-bar {\n  position: absolute;\n  top: 0;\n  left: 0;\n  padding: 8px;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  z-index: 2;\n  background: rgba(0, 0, 0, 0.65);\n}\n\nselect,\nbutton {\n  background: #000;\n  color: #0f0;\n  border: 1px solid #0f0;\n  padding: 4px 8px;\n  font-family: inherit;\n}\n\nbutton {\n  cursor: pointer;\n}\n\n.error-message {\n  position: absolute;\n  top: 44px;\n  left: 8px;\n  z-index: 3;\n  padding: 6px 10px;\n  border: 1px solid #0f0;\n  background: rgba(0, 0, 0, 0.85);\n  max-width: 520px;\n}\n\n.victory-banner {\n  position: absolute;\n  top: 44px;\n  right: 8px;\n  z-index: 3;\n  padding: 6px 12px;\n  border: 2px solid #0f0;\n  background: rgba(0, 0, 0, 0.85);\n  font-weight: 700;\n}\n\n.board {\n  display: block;\n  "]
