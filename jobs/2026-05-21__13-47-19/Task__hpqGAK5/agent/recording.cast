[91.569311, "i", " const { valid, error: err } = canAddBridge(islands, bridges, from, to, delta);\n    if (!valid) {\n      setError(err);\n      return;\n    }\n\n    updateBridge(from, to, next);\n    clearErrorOnValidMove();\n  }\n\n  function handleRemoveBridge(from, to) {\n    const key = getCanonicalBridgeKey(from, to);\n    if ((bridges.get(key) ?? 0) === 0) return;\n    updateBridge(from, to, 0);\n    clearErrorOnValidMove();\n  }\n\n  function onIslandLeftClick(isl) {\n    if (selectedId === null) {\n      setSelectedId(isl.id);\n      return;\n    }\n\n    if (selectedId === isl.id) {\n      // keep selected; no toggle\n      return;\n    }\n\n    const from = islands.find((i) => i.id === selectedId);\n    const to = isl;\n    handleToggle(from, to);\n    setSelectedId(null);\n  }\n\n  function onIslandRightOrCtrlClick(e, isl) {\n    e.preventDefault();\n    if (selectedId !== null && selectedId !== isl.id) {\n      const from = islands.find((i) => i.id === selectedId);\n      handleRemoveBridge(from, isl);\n      setSelectedId(null);\n      return;\n    }\n"]
