[226.742939, "o", "    const active = keyboardFromId === isl.id || selectedId === isl.id;\r\n    return (\r\n      <rect\r\n        x={x}\r\n        y={y}\r\n        width={size}\r\n        height={size}\r\n        fill=\"none\"\r\n        stroke={active ? '#7CFF7C' : '#0f0'}\r\n        strokeWidth={2}\r\n        strokeDasharray={active ? '0' : '5 4'}\r\n      />\r\n    );\r\n  }, [cursorId, islands, keyboardFromId, selectedId]);\r\n\r\n  return (\r\n    <div className=\"app-root\">\r\n      <div className=\"ui-bar\">\r\n        <label>\r\n          Puzzle:{' '}\r\n          <select\r\n            value={puzzleIndex}\r\n            onChange={(e) => setPuzzleIndex(Number(e.target.value))}\r\n          >\r\n            <option value={0}>Easy</option>\r\n            <option value={1}>Medium</option>\r\n            <option value={2}>Hard</option>\r\n          </select>\r\n        </label>\r\n        <button onClick={reset}>Reset</button>\r\n        <div className=\"status\">\r\n          Connected: {checkConnectivity(islands, bridges) ? 'yes' : 'no'}\r\n        </div>\r\n      </div>\r\n\r\n      {error ? <d"]
[226.743241, "o", "iv className=\"error-message\">{error}</div> : null}\r\n      {victory ? <div className=\"victory-banner\">SOLVED!</div> : null}\r\n\r\n      <svg\r\n        ref={svgRef}\r\n        className=\"board\"\r\n        width={W}\r\n        height={H}\r\n        viewBox={`0 0 ${W} ${H}`}\r\n        onContextMenu={(e) => e.preventDefault()}\r\n      >\r\n        {bridgeLines}\r\n        {cursorRect}\r\n\r\n        {islands.map((isl) => {\r\n          const { cx, cy } = islandCenterPx(isl);\r\n          const isSelected = selectedId === isl.id;\r\n          const isKbFrom = keyboardFromId === isl.id;\r\n          const ring = isSelected || isKbFrom;\r\n          return (\r\n            <g\r\n              key={isl.id}\r\n              transform={`translate(${cx},${cy})`}\r\n              onClick={(e) => {\r\n                if (isCtrlClick(e)) {\r\n                  onIslandRightOrCtrlClick(e, isl);\r\n                  return;\r\n                }\r\n                onIslandLeftClick(isl);\r\n                setCursorId(isl.id);\r\n              }}\r\n              onContextMenu={(e)"]
[226.743266, "o", " => onIslandRightOrCtrlClick(e, isl)}\r\n            >\r\n              <circle r={16} fill=\"black\" stroke={ring ? '#7CFF7C' : '#0f0'} strokeWidth={2} />\r\n              <text\r\n                x={0}\r\n                y={5}\r\n                textAnchor=\"middle\"\r\n                fontSize={16}\r\n                fill=\"#0f0\"\r\n              >\r\n                {isl.value}\r\n              </text>\r\n              <text\r\n                x={0}\r\n                y={28}\r\n                textAnchor=\"middle\"\r\n                fontSize={10}\r\n                fill=\"#0f0\"\r\n              >\r\n                {counts.get(isl.id) ?? 0}\r\n              </text>\r\n            </g>\r\n          );\r\n        })}\r\n      </svg>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default App;\r\n\u001b[?2004hroot@bd2a90a13cb7:/app# "]
