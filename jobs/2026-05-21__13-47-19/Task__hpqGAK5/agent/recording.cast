[211.994603, "o", "    }\r\n"]
[211.994632, "o", "\r\n    const delta = next - current;\r\n    const { valid, error: err } = canAddBridge(islands, bridges, from, to, delta);\r\n    if (!valid) {\r\n      setError(err);\r\n      return;\r\n    }\r\n\r\n    updateBridge(from, to, next);\r\n    clearErrorOnValidMove();\r\n  }\r\n\r\n  function handleRemoveBridge(from, to) {\r\n    const key = getCanonicalBridgeKey(from, to);\r\n    if ((bridges.get(key) ?? 0) === 0) return;\r\n    updateBridge(from, to, 0);\r\n    clearErrorOnValidMove();\r\n  }\r\n\r\n  function onIslandLeftClick(isl) {\r\n    if (selectedId === null) {\r\n      setSelectedId(isl.id);\r\n      return;\r\n    }\r\n\r\n    if (selectedId === isl.id) {\r\n      // keep selected; no toggle\r\n      return;\r\n    }\r\n\r\n    const from = islands.find((i) => i.id === selectedId);\r\n    const to = isl;\r\n    handleToggle(from, to);\r\n    setSelectedId(null);\r\n  }\r\n\r\n  function onIslandRightOrCtrlClick(e, isl) {\r\n    e.preventDefault();\r\n    if (selectedId !== null && selectedId !== isl.id) {\r\n      const from = islands.find((i) => i.id === selectedId);\r\n      "]
[211.994644, "o", "handleRemoveBridge(from, isl);\r\n      setSelectedId(null);\r\n      return;\r\n    }\r\n\r\n    // if no selection, remove bridge from keyboardFrom if set, otherwise do nothing\r\n    if (keyboardFromId !== null && keyboardFromId !== isl.id) {\r\n      const from = islands.find((i) => i.id === keyboardFromId);\r\n      handleRemoveBridge(from, isl);\r\n      setKeyboardFromId(null);\r\n    }\r\n  }\r\n\r\n  function moveCursor(dir) {\r\n    if (cursorId === null) return;\r\n    const cur = islands.find((i) => i.id === cursorId);\r\n    if (!cur) return;\r\n\r\n    const candidates = getAdjacentIslands(islands, cur);\r\n    // choose based on direction by comparing coordinates\r\n    let next = null;\r\n    for (const c of candidates) {\r\n      if (dir === 'ArrowLeft' && c.y === cur.y && c.x < cur.x) next = c;\r\n      if (dir === 'ArrowRight' && c.y === cur.y && c.x > cur.x) next = c;\r\n      if (dir === 'ArrowUp' && c.x === cur.x && c.y < cur.y) next = c;\r\n      if (dir === 'ArrowDown' && c.x === cur.x && c.y > cur.y) next = c;\r\n    }\r\n    if (next) s"]
[211.994663, "o", "etCursorId(next.id);\r\n  }\r\n\r\n  useEffect(() => {\r\n    function onKeyDown(e) {\r\n      if (['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(e.key)) {\r\n        e.preventDefault();\r\n        moveCursor(e.key);\r\n        return;\r\n      }\r\n\r\n      if (e.key === 'Escape') {\r\n        e.preventDefault();\r\n        setKeyboardFromId(null);\r\n        setSelectedId(null);\r\n        clearErrorOnValidMove();\r\n        return;\r\n      }\r\n\r\n      if (e.key === 'Enter') {\r\n        e.preventDefault();\r\n        if (cursorId === null) return;\r\n        const cur = islands.find((i) => i.id === cursorId);\r\n        if (!cur) return;\r\n\r\n        if (keyboardFromId === null) {\r\n          setKeyboardFromId(cur.id);\r\n          return;\r\n        }\r\n\r\n        if (keyboardFromId === cur.id) {\r\n          // keep selection\r\n          return;\r\n        }\r\n\r\n"]
[211.994672, "o", "        const from = islands.find((i) => i.id === keyboardFromId);\r\n"]
