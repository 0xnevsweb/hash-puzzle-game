[?2004l[?2004h> export function getAdjacentIslands(islands, from) {
[?2004l[?2004h>   // nearest visible island in each cardinal direction
[?2004l[?2004h>   const result = [];
[?2004l[?2004h>   const dirs = [
[?2004l[?2004h>     { dx: 1, dy: 0 },
[?2004l[?2004h>     { dx: -1, dy: 0 },
[?2004l[?2004h>     { dx: 0, dy: 1 },
[?2004l[?2004h>     { dx: 0, dy: -1 }
[?2004l[?2004h>   ];
