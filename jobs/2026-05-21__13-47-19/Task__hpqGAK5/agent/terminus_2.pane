[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!isAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERROR_NON_ADJ };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
