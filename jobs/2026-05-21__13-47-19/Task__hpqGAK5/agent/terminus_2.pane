[?2004l[?2004h>   for (const { dx, dy } of dirs) {
[?2004l[?2004h>     let cx = from.x + dx;
[?2004l[?2004h>     let cy = from.y + dy;
[?2004l[?2004h>     while (cx >= 0 && cy >= 0 && cx <= 100 && cy <= 100) {
[?2004l[?2004h>       const hit = islandAt(islands, cx, cy);
