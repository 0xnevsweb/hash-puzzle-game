[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERROR_MAX2 };
[?2004l[?2004h>   if (next < 0) return { valid: false, error: null };
[?2004l[?2004h> 
[?2004l[?2004h>   if (delta > 0 && wouldCrossExisting(bridges, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERROR_CROSS };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // island counts cannot exceed value
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERROR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = islandAt(islands, x1, y1);
[?2004l[?2004h>     const b = islandAt(islands, x2, y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   const stack = [start];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     for (const nxt of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt);
[?2004l[?2004h>         stack.push(nxt);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // no crossings
[?2004l[?2004h>   const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       const a = parseKey(keys[i]);
[?2004l[?2004h>       const b = parseKey(keys[j]);
[?2004l[?2004h>       const sharesEndpoint =
[?2004l[?2004h>         (a.x1 === b.x1 && a.y1 === b.y1) ||
[?2004l[?2004h>         (a.x1 === b.x2 && a.y1 === b.y2) ||
[?2004l[?2004h>         (a.x2 === b.x1 && a.y2 === b.y1) ||
[?2004l[?2004h>         (a.x2 === b.x2 && a.y2 === b.y2);
[?2004l[?2004h>       if (sharesEndpoint) continue;
[?2004l[?2004h>       if (segmentsCross(a, b)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
