[138.863168, "o", "export const ERROR_NON_ADJACENT = \"Cannot connect non-adjacent islands\";"]
[138.86445, "o", "\r\nexport const ERROR_MAX_PAIR = \"Max 2 bridges per pair\";\r\nexport const ERROR_EXCEED = \"Island would exceed its number\";\r\nexport const ERROR_CROSS = \"Bridges would cross\";\r\n\r\nexport function keyForBridge(a, b) {\r\n  // a,b are {x,y} in grid units\r\n  const ax = a.x;\r\n  const ay = a.y;\r\n  const bx = b.x;\r\n  const by = b.y;\r\n  if (ax < bx || (ax === bx && ay <= by)) return `${ax},${ay},${bx},${by}`;\r\n  return `${bx},${by},${ax},${ay}`;\r\n}\r\n\r\nfunction parseKey(key) {\r\n  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));\r\n  return { x1, y1, x2, y2 };\r\n}\r\n\r\nfunction isHorizontal(seg) {\r\n  return seg.y1 === seg.y2;\r\n}\r\n\r\nfunction isVertical(seg) {\r\n  return seg.x1 === seg.x2;\r\n}\r\n\r\nfunction normalizedSeg(seg) {\r\n  let { x1, y1, x2, y2 } = seg;\r\n  if (x1 === x2) {\r\n    if (y1 > y2) [y1, y2] = [y2, y1];\r\n  } else if (y1 === y2) {\r\n    if (x1 > x2) [x1, x2] = [x2, x1];\r\n  }\r\n  return { x1, y1, x2, y2 };\r\n}\r\n\r\nfunction segmentsCross(a, b) {\r\n  // Only consider perpendicular crossing at an interior point.\r\n  c"]
[138.864492, "o", "onst A = normalizedSeg(a);\r\n  const B = normalizedSeg(b);\r\n  if (isHorizontal(A) && isVertical(B)) {\r\n    const y = A.y1;\r\n    const x = B.x1;\r\n    const aMinX = Math.min(A.x1, A.x2);\r\n    const aMaxX = Math.max(A.x1, A.x2);\r\n    const bMinY = Math.min(B.y1, B.y2);\r\n    const bMaxY = Math.max(B.y1, B.y2);\r\n    const inA = x > aMinX && x < aMaxX;\r\n    const inB = y > bMinY && y < bMaxY;\r\n    return inA && inB;\r\n  }\r\n  if (isVertical(A) && isHorizontal(B)) return segmentsCross(B, A);\r\n  return false;\r\n}\r\n\r\nexport function computeCurrentCounts(islands, bridges) {\r\n  const counts = new Map();\r\n  for (const isl of islands) counts.set(isl.id, 0);\r\n\r\n  for (const [k, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    const { x1, y1, x2, y2 } = parseKey(k);\r\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\r\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\r\n    if (!a || !b) continue;\r\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\r\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\r\n  "]
[138.864503, "o", "}\r\n\r\n  return counts;\r\n}\r\n\r\nfunction isAdjacentVisible(islands, from, to) {\r\n  if (from.id === to.id) return false;\r\n  if (from.x !== to.x && from.y !== to.y) return false;\r\n\r\n  const sameRow = from.y === to.y;\r\n  const sameCol = from.x === to.x;\r\n\r\n  if (sameRow) {\r\n    const y = from.y;\r\n    const minX = Math.min(from.x, to.x);\r\n    const maxX = Math.max(from.x, to.x);\r\n    for (const isl of islands) {\r\n      if (isl.id === from.id || isl.id === to.id) continue;\r\n      if (isl.y === y && isl.x > minX && isl.x < maxX) return false;\r\n    }\r\n    return true;\r\n  }\r\n\r\n  if (sameCol) {\r\n    const x = from.x;\r\n    const minY = Math.min(from.y, to.y);\r\n    const maxY = Math.max(from.y, to.y);\r\n    for (const isl of islands) {\r\n      if (isl.id === from.id || isl.id === to.id) continue;\r\n      if (isl.x === x && isl.y > minY && isl.y < maxY) return false;\r\n    }\r\n    return true;\r\n  }\r\n\r\n  return false;\r\n}\r\n\r\nfunction wouldCrossExisting(bridges, from, to, ignoreKey) {\r\n  const candidate = normalizedSeg({ x1: from.x,"]
[138.864514, "o", " y1: from.y, x2: to.x, y2: to.y });\r\n  for (const [k, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    if (k === ignoreKey) continue;\r\n    const seg = normalizedSeg(parseKey(k));\r\n    if (segmentsCross(candidate, seg)) return true;\r\n  }\r\n  return false;\r\n}\r\n\r\nexport function canAddBridge(islands, bridges, from, to, delta) {\r\n  if (!isAdjacentVisible(islands, from, to)) {\r\n    return { valid: false, error: ERROR_NON_ADJACENT };\r\n  }\r\n\r\n  const k = keyForBridge(from, to);\r\n  const current = bridges.get(k) ?? 0;\r\n  const next = current + delta;\r\n\r\n  if (next < 0) return { valid: true, error: null };\r\n  if (next > 2) return { valid: false, error: ERROR_MAX_PAIR };\r\n\r\n  const counts = computeCurrentCounts(islands, bridges);\r\n  const fromCount = counts.get(from.id) ?? 0;\r\n  const toCount = counts.get(to.id) ?? 0;\r\n\r\n  if (fromCount + delta > from.value || toCount + delta > to.value) {\r\n    return { valid: false, error: ERROR_EXCEED };\r\n  }\r\n\r\n  if (wouldCrossExisting(bridges, from, to, k) && next > 0) {\r\n   "]
[138.868982, "o", " return { valid: false, error: ERROR_CROSS };\r\n  }\r\n\r\n  return { valid: true, error: null };\r\n}\r\n\r\nexport function checkConnectivity(islands, bridges) {\r\n  if (islands.length <= 1) return true;\r\n\r\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\r\n  const adj = new Map();\r\n  for (const isl of islands) adj.set(isl.id, []);\r\n\r\n  for (const [k, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    const { x1, y1, x2, y2 } = parseKey(k);\r\n    const aId = posToId.get(`${x1},${y1}`);\r\n    const bId = posToId.get(`${x2},${y2}`);\r\n    if (aId === undefined || bId === undefined) continue;\r\n    adj.get(aId).push(bId);\r\n    adj.get(bId).push(aId);\r\n  }\r\n\r\n  const start = islands[0].id;\r\n  const seen = new Set([start]);\r\n  const q = [start];\r\n  while (q.length) {\r\n    const cur = q.shift();\r\n    for (const nxt of adj.get(cur) || []) {\r\n      if (!seen.has(nxt)) {\r\n        seen.add(nxt);\r\n        q.push(nxt);\r\n      }\r\n    }\r\n  }\r\n\r\n  return seen.size === islands.length;\r\n}\r\n\r\nfunction noCrossings(b"]
[138.869025, "o", "ridges) {\r\n  const segs = [];\r\n  for (const [k, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    segs.push(normalizedSeg(parseKey(k)));\r\n  }\r\n  for (let i = 0; i < segs.length; i++) {\r\n    for (let j = i + 1; j < segs.length; j++) {\r\n      if (segmentsCross(segs[i], segs[j])) return false;\r\n    }\r\n  }\r\n  return true;\r\n}\r\n\r\nexport function isVictory(islands, bridges) {\r\n  const counts = computeCurrentCounts(islands, bridges);\r\n  for (const isl of islands) {\r\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n  }\r\n  if (!noCrossings(bridges)) return false;\r\n  if (!checkConnectivity(islands, bridges)) return false;\r\n  return true;\r\n}\r\n\u001b[?2004hroot@1d44877febc0:/app# npm run build\r\n\u001b[?2004l\r"]
