[?2004l[?2004hroot@4bf7c83d9c7d:/app# cat > /app/src/App.jsx <<'EOF'
[?2004l[?2004h> import React, { useEffect, useMemo, useRef, useState } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles';
[?2004l[?2004h> import {
[?2004l[?2004h>   bridgeKey,
[?2004l[?2004h>   canAddBridge,
[?2004l[?2004h>   computeCurrentCounts,
[?2004l[?2004h>   isVictory,
[?2004l[?2004h> } from './utils/hashiLogic';
[?2004l[?2004h> 
[?2004l[?2004h> const GRID = 40;
[?2004l[?2004h> const SVG_W = 800;
[?2004l[?2004h> const SVG_H = 600;
[?2004l[?2004h> 
[?2004l[?2004h> function islandPx(isl) {
[?2004l[?2004h>   return { cx: isl.x * GRID, cy: isl.y * GRID };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function pickInitialCursor(islands) {
[?2004l[?2004h>   return islands.length ? islands[0].id : null;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function findIslandById(islands, id) {
[?2004l[?2004h>   return islands.find((i) => i.id === id) ?? null;
[?2004l[?2004h> }
[?2004let[?2004h> 
[?2004l[?2004h> function findNextIslandInDirection(islands, from, dir) {
[?2004l[?2004h>   let best = null;
[?2004l[?2004h>   let bestDist = Infinity;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h>     if (dir === 'left' && isl.y === from.y && isl.x < from.x) {
[?2004l[?2004h>       const d = from.x - isl.x;
[?2004l[?2004h>       if (d < bestDist) {
[?2004l[?2004h>         bestDist = d;
[?2004l[?2004h>         best = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'right' && isl.y === from.y && isl.x > from.x) {
[?2004l[?2004h>       const d = isl.x - from.x;
[?2004l[?2004h>       if (d < bestDist) {
[?2004l[?2004h>         bestDist = d;
[?2004l[?2004h>         best = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'up' && isl.x === from.x && isl.y < from.y) {
[?2004l[?2004h>       const d = from.y - isl.y;
[?2004l[?2004h>       if (d < bestDist) {
[?2004l[?2004h>         bestDist = d;
[?2004l[?2004h>         best = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'down' && isl.x === from.x && isl.y > from.y) {
[?2004l[?2004h>       const d = isl.y - from.y;
[?2004l[?2004h>       if (d < bestDist) {
[?2004l[?2004h>         bestDist = d;
[?2004l[?2004h>         best = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return best;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function computeBridgeLines(islands, bridges) {
[?2004l[?2004h>   const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>   const lines = [];
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map((v) => Number(v));
[?2004l[?2004h>     const a = byCoord.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byCoord.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     const p1 = islandPx(a);
[?2004l[?2004h>     const p2 = islandPx(b);
[?2004l[?2004h> 
[?2004l[?2004h>     if (n === 1) {
[?2004l[?2004h>       lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy, x2: p2.cx, y2: p2.cy });
[?2004l[?2004h>     } else {
[?2004l[?2004h>       const off = 4;
[?2004l[?2004h>       const horizontal = a.y === b.y;
[?2004l[?2004h>       if (horizontal) {
[?2004l[?2004h>         lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy - off, x2: p2.cx, y2: p2.cy - off });
[?2004l[?2004h>         lines.push({ key: k, idx: 1, x1: p1.cx, y1: p1.cy + off, x2: p2.cx, y2: p2.cy + off });
[?2004l[?2004h>       } else {
[?2004l[?2004h>         lines.push({ key: k, idx: 0, x1: p1.cx - off, y1: p1.cy, x2: p2.cx - off, y2: p2.cy });
[?2004l[?2004h>         lines.push({ key: k, idx: 1, x1: p1.cx + off, y1: p1.cy, x2: p2.cx + off, y2: p2.cy });
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return lines;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleName, setPuzzleName] = useState('Easy');
[?2004l[?2004h>   const puzzle = useMemo(() => puzzles.find((p) => p.name === puzzleName) ?? puzzles[0], [puzzleName]);
[?2004l[?2004h>   const islands = puzzle.islands;
[?2004l[?2004h> 
[?2004l[?2004h>   const [bridges, setBridges] = useState(() => new Map());
[?2004l[?2004h>   const [selectedId, setSelectedId] = useState(null); // mouse selection
[?2004l[?2004h>   const [cursorId, setCursorId] = useState(() => pickInitialCursor(islands));
[?2004l[?2004h>   const [kbFromId, setKbFromId] = useState(null); // keyboard selection start
[?2004l[?2004h>   const [error, setError] = useState(null);
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);
[?2004l[?2004h>   const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);
[?2004l[?2004h>   const bridgeLines = useMemo(() => computeBridgeLines(islands, bridges), [islands, bridges]);
[?2004l[?2004h> 
[?2004l[?2004h>   const rootRef = useRef(null);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>     setKbFromId(null);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setCursorId(pickInitialCursor(islands));
[?2004l[?2004h>   }, [puzzleName]);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     rootRef.current?.focus();
[?2004l[?2004h>   }, []);
[?2004l[?2004h> 
[?2004l[?2004h>   function applyBridgeDelta(from, to, delta) {
[?2004l[?2004h>     const res = canAddBridge(islands, bridges, from, to, delta);
[?2004l[?2004h>     if (!res.valid) {
[?2004l[?2004h>       setError(res.error);
[?2004l[?2004h>       return false;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     setBridges((prev) => {
[?2004l[?2004h>       const next = new Map(prev);
[?2004l[?2004h>       const k = bridgeKey(from, to);
[?2004l[?2004h>       const existing = next.get(k) ?? 0;
[?2004l[?2004h>       const v = existing + delta;
[?2004l[?2004h>       if (v <= 0) next.delete(k);
[?2004l[?2004h>       else next.set(k, v);
[?2004l[?2004h>       return next;
[?2004l[?2004h>     });
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function cycleBridge(from, to) {
[?2004l[?2004h>     const k = bridgeKey(from, to);
[?2004l[?2004h>     const existing = bridges.get(k) ?? 0;
[?2004l[?2004h>     if (existing === 0) return applyBridgeDelta(from, to, +1);
[?2004l[?2004h>     if (existing === 1) return applyBridgeDelta(from, to, +1);
[?2004l[?2004h>     return applyBridgeDelta(from, to, -2);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function removeBridgeEntirely(from, to) {
[?2004l[?2004h>     const k = bridgeKey(from, to);
[?2004l[?2004h>     const existing = bridges.get(k) ?? 0;
[?2004l[?2004h>     if (existing <= 0) return false;
[?2004l[?2004h>     setBridges((prev) => {
[?2004l[?2004h>       const next = new Map(prev);
[?2004l[?2004h>       next.delete(k);
[?2004l[?2004h>       return next;
[?2004l[?2004h>     });
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function onIslandClick(e, isl) {
[?2004l[?2004h>     if (e.ctrlKey && selectedId != null && selectedId !== isl.id) {
[?2004l[?2004h>       const from = findIslandById(islands, selectedId);
[?2004l[?2004h>       if (from) {
[?2004l[?2004h>         removeBridgeEntirely(from, isl);
[?2004l[?2004h>         setSelectedId(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (selectedId == null) {
[?2004l[?2004h>       setSelectedId(isl.id);
[?2004l[?2004h>       setCursorId(isl.id);
[?2004l[?2004h>       setKbFromId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (selectedId === isl.id) return;
[?2004l[?2004h> 
[?2004l[?2004h>     const from = findIslandById(islands, selectedId);
[?2004l[?2004h>     if (!from) {
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     cycleBridge(from, isl);
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function onIslandContextMenu(e, isl) {
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h>     if (selectedId != null && selectedId !== isl.id) {
[?2004l[?2004h>       const from = findIslandById(islands, selectedId);
[?2004l[?2004h>       if (from) removeBridgeEntirely(from, isl);
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function onKeyDown(e) {
[?2004l[?2004h>     const cur = cursorId == null ? null : findIslandById(islands, cursorId);
[?2004l[?2004h>     if (!cur) return;
[?2004l[?2004h> 
[?2004l[?2004h>     if (e.key === 'Escape') {
[?2004l[?2004h>       setKbFromId(null);
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       setError(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const dirMap = {
[?2004l[?2004h>       ArrowLeft: 'left',
[?2004l[?2004h>       ArrowRight: 'right',
[?2004l[?2004h>       ArrowUp: 'up',
[?2004l[?2004h>       ArrowDown: 'down',
[?2004l[?2004h>     };
[?2004l[?2004h>     const dir = dirMap[e.key];
[?2004l[?2004h>     if (dir) {
[?2004l[?2004h>       e.preventDefault();
[?2004l[?2004h>       const next = findNextIslandInDirection(islands, cur, dir);
[?2004l[?2004h>       if (next) setCursorId(next.id);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     if (e.key === 'Enter') {
[?2004l[?2004h>       e.preventDefault();
[?2004l[?2004h>       if (kbFromId == null) {
[?2004l[?2004h>         setKbFromId(cur.id);
[?2004l[?2004h>         setSelectedId(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h>       if (kbFromId === cur.id) return;
[?2004l[?2004h>       const from = findIslandById(islands, kbFromId);
[?2004l[?2004h>       if (!from) {
[?2004l[?2004h>         setKbFromId(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h>       cycleBridge(from, cur);
[?2004l[?2004h>       setKbFromId(null);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const cursorIsland = cursorId == null ? null : findIslandById(islands, cursorId);
[?2004l[?2004h> 
[?2004l[?2004h>   return (
[?2004l[?2004h>     <div ref={rootRef} tabIndex={0} onKeyDown={onKeyDown} style={{ outline: 'none' }}>
[?2004l[?2004h>       <div style={{ padding: 8 }}>
[?2004l[?2004h>         <label>
[?2004l[?2004h>           Puzzle:{' '}
[?2004l[?2004h>           <select
[?2004l[?2004h>             value={puzzleName}
[?2004l[?2004h>             onChange={(e) => setPuzzleName(e.target.value)}
[?2004l[?2004h>             style={{
[?2004l[?2004h>               background: 'black',
[?2004l[?2004h>               color: '#0f0',
[?2004l[?2004h>               border: '1px solid #0f0',
[?2004l[?2004h>               fontFamily: 'monospace',
[?2004l[?2004h>             }}
[?2004l[?2004h>           >
[?2004l[?2004h>             <option value="Easy">Easy</option>
[?2004l[?2004h>             <option value="Medium">Medium</option>
[?2004l[?2004h>             <option value="Hard">Hard</option>
[?2004l[?2004h>           </select>
[?2004l[?2004h>         </label>
[?2004l[?2004h>         <button
[?2004l[?2004h>           onClick={() => {
[?2004l[?2004h>             setBridges(new Map());
[?2004l[?2004h>             setSelectedId(null);
[?2004l[?2004h>             setKbFromId(null);
[?2004l[?2004h>             setError(null);
[?2004l[?2004h>           }}
[?2004l[?2004h>           style={{
[?2004l[?2004h>             marginLeft: 12,
[?2004l[?2004h>             background: 'black',
[?2004l[?2004h>             color: '#0f0',
[?2004l[?2004h>             border: '1px solid #0f0',
[?2004l[?2004h>             fontFamily: 'monospace',
[?2004l[?2004h>             cursor: 'pointer',
[?2004l[?2004h>           }}
[?2004l[?2004h>         >
[?2004l[?2004h>           Reset
[?2004l[?2004h>         </button>
[?2004l[?2004h> 
[?2004l[?2004h>         {error ? (
[?2004l[?2004h>           <div className="error-message" style={{ marginTop: 8 }}>
[?2004l[?2004h>             {error}
[?2004l[?2004h>           </div>
[?2004l[?2004h>         ) : null}
[?2004l[?2004h>         {solved ? (
[?2004l[?2004h>           <div className="victory-banner" style={{ marginTop: 8 }}>
[?2004l[?2004h>             SOLVED!
[?2004l[?2004h>           </div>
[?2004l[?2004h>         ) : null}
[?2004l[?2004h>       </div>
[?2004l[?2004h> 
[?2004l[?2004h>       <svg width={SVG_W} height={SVG_H} viewBox={`0 0 ${SVG_W} ${SVG_H}`} style={{ display: 'block' }}>
[?2004l[?2004h>         {/* Bridges */}
[?2004l[?2004h>         <g stroke="#0f0" strokeWidth={3} strokeLinecap="round">
[?2004l[?2004h>           {bridgeLines.map((ln) => (
[?2004l[?2004h>             <line key={`${ln.key}:${ln.idx}`} x1={ln.x1} y1={ln.y1} x2={ln.x2} y2={ln.y2} />
[?2004l[?2004h>           ))}
[?2004l[?2004h>         </g>
[?2004l[?2004h> 
[?2004l[?2004h>         {/* Keyboard cursor (must not be a circle) */}
[?2004l[?2004h>         {cursorIsland
[?2004l[?2004h>           ? (() => {
[?2004l[?2004h>               const p = islandPx(cursorIsland);
[?2004l[?2004h>               const size = 26;
[?2004l[?2004h>               return (
[?2004l[?2004h>                 <rect
[?2004l[?2004h>                   x={p.cx - size / 2}
[?2004l[?2004h>                   y={p.cy - size / 2}
[?2004l[?2004h>                   width={size}
[?2004l[?2004h>                   height={size}
[?2004l[?2004h>                   fill="none"
[?2004l[?2004h>                   stroke="#0f0"
[?2004l[?2004h>                   strokeWidth={2}
[?2004l[?2004h>                   strokeDasharray="4 3"
[?2004l[?2004h>                 />
[?2004l[?2004h>               );
[?2004l[?2004h>             })()
[?2004l[?2004h>           : null}
[?2004l[?2004h> 
[?2004l[?2004h>         {/* Islands */}
[?2004l[?2004h>         <g>
[?2004l[?2004h>           {islands.map((isl) => {
