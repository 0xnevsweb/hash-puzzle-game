[?2004l[?2004h>                   stroke={isSelected || isKbFrom ? '#0f0' : '#0a0'}
[?2004l[?2004h>                   strokeWidth={isSelected || isKbFrom ? 3 : 2}
[?2004l[?2004h>                   onClick={(e) => onIslandClick(e, isl)}
[?2004l[?2004h>                   onContextMenu={(e) => onIslandContextMenu(e, isl)}
[?2004l[?2004h>                   style={{ cursor: 'pointer' }}
[?2004l[?2004h>                 />
[?2004l[?2004h>                 <text
