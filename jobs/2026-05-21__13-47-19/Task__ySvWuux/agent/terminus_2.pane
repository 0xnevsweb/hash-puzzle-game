[?2004l[?2004h> 
[?2004l[?2004h> // Two segments cross if one is vertical and the other horizontal and their interiors intersect.
[?2004l[?2004h> function segmentsCross(segA, segB) {
[?2004l[?2004h>   const aVertical = segA.x1 === segA.x2;
