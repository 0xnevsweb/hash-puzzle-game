[?2004l[?2004h> export const ERR_CROSSING = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> function cmpPoint(a, b) {
[?2004l[?2004h>   if (a.x !== b.x) return a.x - b.x;
[?2004l[?2004h>   return a.y - b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const [p1, p2] = cmpPoint(a, b) <= 0 ? [a, b] : [b, a];
[?2004l[?2004h>   return `${p1.x},${p1.y},${p2.x},${p2.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseBridgeKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAxisAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(v, a, b) {
[?2004l[?2004h>   const min = Math.min(a, b);
