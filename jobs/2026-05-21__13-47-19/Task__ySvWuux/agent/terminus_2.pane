[?2004l[?2004h> +// Core Hashi (Bridges) puzzle logic.
[?2004l[?2004h> +// Bridges are stored as Map<string, number> keyed by canonical "x1,y1,x2,y2" (grid units),
[?2004l[?2004h> +// where (x1,y1) is lexicographically <= (x2,y2). Value is 1 or 2.
[?2004l[?2004h> +
[?2004l[?2004h> +export const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> +export const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';
[?2004l[?2004h> +export const ERR_EXCEED_ISLAND = 'Island would exceed its number';
[?2004l[?2004h> +export const ERR_CROSSING = 'Bridges would cross';
[?2004l[?2004h> +
[?2004l[?2004h> +function cmpPoint(a, b) {
[?2004l[?2004h> +  if (a.x !== b.x) return a.x - b.x;
[?2004l[?2004h> +  return a.y - b.y;
[?2004l[?2004h> +}
[?2004l[?2004h> +
[?2004l[?2004h> +export function bridgeKey(from, to) {
[?2004l[?2004h> +  const a = { x: from.x, y: from.y };
