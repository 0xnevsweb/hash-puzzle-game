[?2004l[?2004h>                   fontSize={14}
[?2004l[?2004h>                   fill="#0f0"
[?2004l[?2004h>                   style={{ userSelect: 'none' }}
[?2004l[?2004h>                 >
[?2004l[?2004h>                   {isl.value}
[?2004l[?2004h>                 </text>
[?2004l[?2004h>               </g>
[?2004l[?2004h>             );
[?2004l[?2004h>           })}
[?2004l[?2004h>         </g>
[?2004l[?2004h>       </svg>
[?2004l[?2004h>     </div>
[?2004l[?2004h>   );
[?2004l[?2004h> }
