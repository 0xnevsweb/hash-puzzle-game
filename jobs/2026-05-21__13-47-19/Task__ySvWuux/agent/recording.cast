[474.499531, "i", "ion cycleBridge(from, to) {\n    const k = bridgeKey(from, to);\n    const existing = bridges.get(k) ?? 0;\n    if (existing === 0) return applyBridgeDelta(from, to, +1);\n    if (existing === 1) return applyBridgeDelta(from, to, +1);\n    return applyBridgeDelta(from, to, -2);\n  }\n\n  function removeBridgeEntirely(from, to) {\n    const k = bridgeKey(from, to);\n    const existing = bridges.get(k) ?? 0;\n    if (existing <= 0) return false;\n\n    setBridges((prev) => {\n      const next = new Map(prev);\n      next.delete(k);\n      return next;\n    });\n    setError(null);\n    return true;\n  }\n\n  function onIslandClick(e, isl) {\n    if (e.ctrlKey && selectedId != null && selectedId !== isl.id) {\n      const from = findIslandById(islands, selectedId);\n      if (from) {\n        removeBridgeEntirely(from, isl);\n        setSelectedId(null);\n        return;\n      }\n    }\n\n    if (selectedId == null) {\n      setSelectedId(isl.id);\n      setCursorId(isl.id);\n      setKbFromId(null);\n      return;\n    }\n\n    if (selectedId === i"]
[474.499552, "o", "> import React, { useEffect, useMemo, useRef, useState } from 'react';"]
[474.499569, "i", "sl.id) return;\n\n    const from = findIslandById(islands, selectedId);\n    if (!from) {\n      setSelectedId(null);\n      return;\n    }\n\n    cycleBridge(from, isl);\n    setSelectedId(null);\n  }\n\n  function onIslandContextMenu(e, isl) {\n    e.preventDefault();\n    if (selectedId != null && selectedId !== isl.id) {\n      const from = findIslandById(islands, selectedId);\n      if (from) removeBridgeEntirely(from, isl);\n      setSelectedId(null);\n    }\n  }\n\n  function onKeyDown(e) {\n    const cur = cursorId == null ? null : findIslandById(islands, cursorId);\n    if (!cur) return;\n\n    if (e.key === 'Escape') {\n      setKbFromId(null);\n      setSelectedId(null);\n      setError(null);\n      return;\n    }\n\n    const dirMap = {\n      ArrowLeft: 'left',\n      ArrowRight: 'right',\n      ArrowUp: 'up',\n      ArrowDown: 'down',\n    };\n\n    const dir = dirMap[e.key];\n    if (dir) {\n      e.preventDefault();\n      const next = findNextIslandInDirection(islands, cur, dir);\n      if (next) setCursorId(next.id);\n      return;\n "]
[474.499589, "i", "   }\n\n    if (e.key === 'Enter') {\n      e.preventDefault();\n      if (kbFromId == null) {\n        setKbFromId(cur.id);\n        setSelectedId(null);\n        return;\n      }\n      if (kbFromId === cur.id) return;\n      const from = findIslandById(islands, kbFromId);\n      if (!from) {\n        setKbFromId(null);\n        return;\n      }\n      cycleBridge(from, cur);\n      setKbFromId(null);\n    }\n  }\n\n  const cursorIsland = cursorId == null ? null : findIslandById(islands, cursorId);\n\n  return (\n    <div\n      ref={rootRef}\n      tabIndex={0}\n      onKeyDown={onKeyDown}\n      style={{ outline: 'none', position: 'relative', width: SVG_W, height: SVG_H }}\n    >\n      <svg\n        width={SVG_W}\n        height={SVG_H}\n        viewBox={`0 0 ${SVG_W} ${SVG_H}`}\n        style={{ display: 'block', position: 'absolute', left: 0, top: 0 }}\n      >\n        <g stroke=\"#0f0\" strokeWidth={3} strokeLinecap=\"round\">\n          {bridgeLines.map((ln) => (\n            <line key={`${ln.key}:${ln.idx}`} x1={ln.x1} y1={ln.y1} x2={ln.x"]
[474.499605, "i", "2} y2={ln.y2} />\n          ))}\n        </g>\n\n        {cursorIsland\n          ? (() => {\n              const p = islandPx(cursorIsland);\n              const size = 26;\n              return (\n                <rect\n                  x={p.cx - size / 2}\n                  y={p.cy - size / 2}\n                  width={size}\n                  height={size}\n                  fill=\"none\"\n                  stroke=\"#0f0\"\n                  strokeWidth={2}\n                  strokeDasharray=\"4 3\"\n                />\n              );\n            })()\n          : null}\n\n        <g>\n          {islands.map((isl) => {\n            const { cx, cy } = islandPx(isl);\n            const isSel = selectedId === isl.id;\n            const isKbFrom = kbFromId === isl.id;\n            const current = counts.get(isl.id) ?? 0;\n            const satisfied = current === isl.value;\n\n            return (\n              <g key={isl.id}>\n                <circle\n                  cx={cx}\n                  cy={cy}\n                  r={14}\n              "]
[474.499623, "i", "    fill=\"black\"\n                  stroke={isSel || isKbFrom ? '#0f0' : '#0a0'}\n                  strokeWidth={isSel || isKbFrom ? 3 : 2}\n                  onClick={(e) => onIslandClick(e, isl)}\n                  onContextMenu={(e) => onIslandContextMenu(e, isl)}\n                  style={{ cursor: 'pointer' }}\n                />\n                <text\n                  x={cx}\n                  y={cy + 5}\n                  textAnchor=\"middle\"\n                  fontFamily=\"monospace\"\n                  fontSize={14}\n                  fill=\"#0f0\"\n                  style={{ userSelect: 'none' }}\n                >\n                  {isl.value}\n                </text>\n                <text\n                  x={cx}\n                  y={cy + 28}\n                  textAnchor=\"middle\"\n                  fontFamily=\"monospace\"\n                  fontSize={10}\n                  fill={satisfied ? '#0f0' : '#0a0'}\n                  style={{ userSelect: 'none' }}\n                >\n                  {current}/{isl.value}\n       "]
