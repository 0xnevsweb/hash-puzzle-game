[115.629981, "i", " a.x === b.x || a.y === b.y;\n+}\n+\n+function between(v, a, b) {\n+  const min = Math.min(a, b);\n+  const max = Math.max(a, b);\n+  return v > min && v < max;\n+}\n+\n+function buildIslandLookup(islands) {\n+  const byId = new Map();\n+  const byCoord = new Map();\n+  for (const isl of islands) {\n+    byId.set(isl.id, isl);\n+    byCoord.set(`${isl.x},${isl.y}`, isl);\n+  }\n+  return { byId, byCoord };\n+}\n+\n+// Two segments cross if one is vertical and the other horizontal and their interiors intersect.\n+function segmentsCross(segA, segB) {\n+  // seg: {x1,y1,x2,y2}\n+  const aVertical = segA.x1 === segA.x2;\n+  const bVertical = segB.x1 === segB.x2;\n+  if (aVertical === bVertical) return false; // parallel\n+\n+  const v = aVertical ? segA : segB;\n+  const h = aVertical ? segB : segA;\n+\n+  // Proper crossing must be strictly inside both segments (not at endpoints).\n+  const x = v.x1;\n+  const y = h.y1;\n+  const inV = between(y, v.y1, v.y2);\n+  const inH = between(x, h.x1, h.x2);\n+  return inV && inH;\n+}\n+\n+export function wo"]
