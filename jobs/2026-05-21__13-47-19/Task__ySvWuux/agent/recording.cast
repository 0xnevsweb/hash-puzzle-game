[474.495766, "i", "cat > /app/src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { puzzles } from './data/puzzles';\nimport { bridgeKey, canAddBridge, computeCurrentCounts, isVictory } from './utils/hashiLogic';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction islandPx(isl) {\n  return { cx: isl.x * GRID, cy: isl.y * GRID };\n}\n\nfunction pickInitialCursor(islands) {\n  return islands.length ? islands[0].id : null;\n}\n\nfunction findIslandById(islands, id) {\n  return islands.find((i) => i.id === id) ?? null;\n}\n\nfunction findNextIslandInDirection(islands, from, dir) {\n  let best = null;\n  let bestDist = Infinity;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\n      const d = from.x - isl.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\n      const d = isl.x - from.x;\n      if (d < bestDist) "]
[474.496203, "o", "cat > /app/src/App.jsx <<'EOF'"]
[474.496272, "i", "{\n        bestDist = d;\n        best = isl;\n      }\n    }\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\n      const d = from.y - isl.y;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\n      const d = isl.y - from.y;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n  }\n  return best;\n}\n\nfunction computeBridgeLines(islands, bridges) {\n  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n  const lines = [];\n\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = k.split(',').map((v) => Number(v));\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n\n    const p1 = islandPx(a);\n    const p2 = islandPx(b);\n\n    if (n === 1) {\n      lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy, x2: p2.cx, y2: p2.cy });\n    } else {\n      const off = 4;\n      const hori"]
[474.49859, "i", "zontal = a.y === b.y;\n      if (horizontal) {\n        lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy - off, x2: p2.cx, y2: p2.cy - off });\n        lines.push({ key: k, idx: 1, x1: p1.cx, y1: p1.cy + off, x2: p2.cx, y2: p2.cy + off });\n      } else {\n        lines.push({ key: k, idx: 0, x1: p1.cx - off, y1: p1.cy, x2: p2.cx - off, y2: p2.cy });\n        lines.push({ key: k, idx: 1, x1: p1.cx + off, y1: p1.cy, x2: p2.cx + off, y2: p2.cy });\n      }\n    }\n  }\n\n  return lines;\n}\n\nexport default function App() {\n  const [puzzleName, setPuzzleName] = useState('Easy');\n  const puzzle = useMemo(() => puzzles.find((p) => p.name === puzzleName) ?? puzzles[0], [puzzleName]);\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [cursorId, setCursorId] = useState(() => pickInitialCursor(islands));\n  const [kbFromId, setKbFromId] = useState(null);\n  const [error, setError] = useState(null);\n\n  const counts = useMemo(() "]
[474.499067, "o", "\r\n"]
[474.499115, "i", "=> computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n  const bridgeLines = useMemo(() => computeBridgeLines(islands, bridges), [islands, bridges]);\n\n  const rootRef = useRef(null);\n\n  useEffect(() => {\n    setBridges(new Map());\n    setSelectedId(null);\n    setKbFromId(null);\n    setError(null);\n    setCursorId(pickInitialCursor(islands));\n  }, [puzzleName, islands]);\n\n  useEffect(() => {\n    rootRef.current?.focus();\n  }, []);\n\n  function applyBridgeDelta(from, to, delta) {\n    const res = canAddBridge(islands, bridges, from, to, delta);\n    if (!res.valid) {\n      setError(res.error);\n      return false;\n    }\n\n    setBridges((prev) => {\n      const next = new Map(prev);\n      const k = bridgeKey(from, to);\n      const existing = next.get(k) ?? 0;\n      const v = existing + delta;\n      if (v <= 0) next.delete(k);\n      else next.set(k, v);\n      return next;\n    });\n\n    setError(null);\n    return true;\n  }\n\n  funct"]
