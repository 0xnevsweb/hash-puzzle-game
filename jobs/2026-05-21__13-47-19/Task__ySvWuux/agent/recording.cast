[338.017415, "i", "cat > /app/src/utils/hashiLogic.js <<'EOF'\n// Core Hashi (Bridges) puzzle logic.\n// Bridges are stored as Map<string, number> keyed by canonical \"x1,y1,x2,y2\" (grid units),\n// where (x1,y1) is lexicographically <= (x2,y2). Value is 1 or 2.\n\nexport const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\nexport const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';\nexport const ERR_EXCEED_ISLAND = 'Island would exceed its number';\nexport const ERR_CROSSING = 'Bridges would cross';\n\nfunction cmpPoint(a, b) {\n  if (a.x !== b.x) return a.x - b.x;\n  return a.y - b.y;\n}\n\nexport function bridgeKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const [p1, p2] = cmpPoint(a, b) <= 0 ? [a, b] : [b, a];\n  return `${p1.x},${p1.y},${p2.x},${p2.y}`;\n}\n\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));\n  return { x1, y1, x2, y2 };\n}\n\nfunction isAxisAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\nfunction between(v, a, b) {\n"]
[338.017608, "i", "  const min = Math.min(a, b);\n  const max = Math.max(a, b);\n  return v > min && v < max;\n}\n\nfunction buildIslandLookup(islands) {\n  const byCoord = new Map();\n  for (const isl of islands) byCoord.set(`${isl.x},${isl.y}`, isl);\n  return { byCoord };\n}\n\n// Two segments cross if one is vertical and the other horizontal and their interiors intersect.\nfunction segmentsCross(segA, segB) {\n  const aVertical = segA.x1 === segA.x2;\n  const bVertical = segB.x1 === segB.x2;\n  if (aVertical === bVertical) return false;\n\n  const v = aVertical ? segA : segB;\n  const h = aVertical ? segB : segA;\n\n  const x = v.x1;\n  const y = h.y1;\n  return between(y, v.y1, v.y2) && between(x, h.x1, h.x2);\n}\n\nexport function wouldCross(bridges, from, to) {\n  const candidate = { x1: from.x, y1: from.y, x2: to.x, y2: to.y };\n  for (const [k, count] of bridges.entries()) {\n    if (!count) continue;\n    const existing = parseBridgeKey(k);\n    if (segmentsCross(candidate, existing)) return true;\n  }\n  return false;\n}\n\n// Adjacent means: axis-ali"]
[338.017625, "i", "gned and no island lies between; equivalently, `to` is the nearest island\n// from `from` in that direction.\nexport function areAdjacent(islands, from, to) {\n  if (from.id === to.id) return false;\n  if (!isAxisAligned(from, to)) return false;\n\n  if (from.x === to.x) {\n    const x = from.x;\n    const dir = Math.sign(to.y - from.y);\n    if (dir === 0) return false;\n    let best = null;\n    let bestDist = Infinity;\n    for (const isl of islands) {\n      if (isl.id === from.id) continue;\n      if (isl.x !== x) continue;\n      const d = isl.y - from.y;\n      if (Math.sign(d) !== dir) continue;\n      const ad = Math.abs(d);\n      if (ad < bestDist) {\n        bestDist = ad;\n        best = isl;\n      }\n    }\n    return best?.id === to.id;\n  }\n\n  const y = from.y;\n  const dir = Math.sign(to.x - from.x);\n  if (dir === 0) return false;\n  let best = null;\n  let bestDist = Infinity;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (isl.y !== y) continue;\n    const d = isl.x - from.x;\n    if (Math"]
[338.017638, "i", ".sign(d) !== dir) continue;\n    const ad = Math.abs(d);\n    if (ad < bestDist) {\n      bestDist = ad;\n      best = isl;\n    }\n  }\n  return best?.id === to.id;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  const { byCoord } = buildIslandLookup(islands);\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(k);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: ERR_NON_ADJACENT };\n  }\n\n  const key = bridgeKey(from, to);\n  const existing = bridges.get(key) ?? 0;\n  const next = existing + delta;\n\n  if (next > 2) return { valid: false, e"]
