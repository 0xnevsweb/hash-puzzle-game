[331.99055, "o", "import React, { useEffect, useMemo, useRef, useState } from 'react';"]
[331.99379, "o", "\r\nimport { puzzles } from './data/puzzles';\r\nimport {\r\n  bridgeKey,\r\n  canAddBridge,\r\n  computeCurrentCounts,\r\n  isVictory,\r\n} from './utils/hashiLogic';\r\n\r\nconst GRID = 40;\r\nconst SVG_W = 800;\r\nconst SVG_H = 600;\r\n\r\nfunction islandPx(isl) {\r\n  return { cx: isl.x * GRID, cy: isl.y * GRID };\r\n}\r\n\r\nfunction pickInitialCursor(islands) {\r\n  return islands.length ? islands[0].id : null;\r\n}\r\n\r\nfunction findIslandById(islands, id) {\r\n  return islands.find((i) => i.id === id) ?? null;\r\n}\r\n\r\nfunction findNextIslandInDirection(islands, from, dir) {\r\n  let best = null;\r\n  let bestDist = Infinity;\r\n  for (const isl of islands) {\r\n    if (isl.id === from.id) continue;\r\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\r\n      const d = from.x - isl.x;\r\n      if (d < bestDist) {\r\n        bestDist = d;\r\n        best = isl;\r\n      }\r\n    }\r\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\r\n      const d = isl.x - from.x;\r\n      if (d < bestDist) {\r\n        bestDist = d;\r\n        best = isl;\r\n    "]
[331.993835, "o", "  }\r\n    }\r\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\r\n      const d = from.y - isl.y;\r\n      if (d < bestDist) {\r\n        bestDist = d;\r\n        best = isl;\r\n      }\r\n    }\r\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\r\n      const d = isl.y - from.y;\r\n      if (d < bestDist) {\r\n        bestDist = d;\r\n        best = isl;\r\n      }\r\n    }\r\n  }\r\n  return best;\r\n}\r\n\r\nfunction computeBridgeLines(islands, bridges) {\r\n  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\r\n  const lines = [];\r\n\r\n  for (const [k, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    const [x1, y1, x2, y2] = k.split(',').map((v) => Number(v));\r\n    const a = byCoord.get(`${x1},${y1}`);\r\n    const b = byCoord.get(`${x2},${y2}`);\r\n    if (!a || !b) continue;\r\n\r\n    const p1 = islandPx(a);\r\n    const p2 = islandPx(b);\r\n\r\n    if (n === 1) {\r\n      lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy, x2: p2.cx, y2: p2.cy });\r\n    } else {\r\n      const off = 4;\r\n      const horizontal = a"]
[331.993848, "o", ".y === b.y;\r\n      if (horizontal) {\r\n        lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy - off, x2: p2.cx, y2: p2.cy - off });\r\n        lines.push({ key: k, idx: 1, x1: p1.cx, y1: p1.cy + off, x2: p2.cx, y2: p2.cy + off });\r\n      } else {\r\n        lines.push({ key: k, idx: 0, x1: p1.cx - off, y1: p1.cy, x2: p2.cx - off, y2: p2.cy });\r\n        lines.push({ key: k, idx: 1, x1: p1.cx + off, y1: p1.cy, x2: p2.cx + off, y2: p2.cy });\r\n      }\r\n    }\r\n  }\r\n\r\n  return lines;\r\n}\r\n\r\nexport default function App() {\r\n  const [puzzleName, setPuzzleName] = useState('Easy');\r\n  const puzzle = useMemo(() => puzzles.find((p) => p.name === puzzleName) ?? puzzles[0], [puzzleName]);\r\n  const islands = puzzle.islands;\r\n\r\n  const [bridges, setBridges] = useState(() => new Map());\r\n  const [selectedId, setSelectedId] = useState(null); // mouse selection\r\n  const [cursorId, setCursorId] = useState(() => pickInitialCursor(islands));\r\n  const [kbFromId, setKbFromId] = useState(null); // keyboard selection start\r\n  const [erro"]
[331.99387, "o", "r, setError] = useState(null);\r\n\r\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\r\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\r\n  const bridgeLines = useMemo(() => computeBridgeLines(islands, bridges), [islands, bridges]);\r\n\r\n  const rootRef = useRef(null);\r\n\r\n  useEffect(() => {\r\n    setBridges(new Map());\r\n    setSelectedId(null);\r\n    setKbFromId(null);\r\n    setError(null);\r\n    setCursorId(pickInitialCursor(islands));\r\n  }, [puzzleName]);\r\n\r\n  useEffect(() => {\r\n    rootRef.current?.focus();\r\n  }, []);\r\n\r\n  function applyBridgeDelta(from, to, delta) {\r\n    const res = canAddBridge(islands, bridges, from, to, delta);\r\n    if (!res.valid) {\r\n      setError(res.error);\r\n      return false;\r\n    }\r\n\r\n    setBridges((prev) => {\r\n      const next = new Map(prev);\r\n      const k = bridgeKey(from, to);\r\n      const existing = next.get(k) ?? 0;\r\n      const v = existing + delta;\r\n      if (v <= 0) next.delete(k);\r\n      else next.set"]
[331.99462, "o", "(k, v);\r\n      return next;\r\n    });\r\n    setError(null);\r\n    return true;\r\n  }\r\n\r\n  function cycleBridge(from, to) {\r\n    const k = bridgeKey(from, to);\r\n    const existing = bridges.get(k) ?? 0;\r\n    if (existing === 0) return applyBridgeDelta(from, to, +1);\r\n    if (existing === 1) return applyBridgeDelta(from, to, +1);\r\n    return applyBridgeDelta(from, to, -2);\r\n  }\r\n\r\n  function removeBridgeEntirely(from, to) {\r\n    const k = bridgeKey(from, to);\r\n    const existing = bridges.get(k) ?? 0;\r\n    if (existing <= 0) return false;\r\n    setBridges((prev) => {\r\n      const next = new Map(prev);\r\n      next.delete(k);\r\n      return next;\r\n    });\r\n    setError(null);\r\n    return true;\r\n  }\r\n\r\n  function onIslandClick(e, isl) {\r\n    if (e.ctrlKey && selectedId != null && selectedId !== isl.id) {\r\n      const from = findIslandById(islands, selectedId);\r\n      if (from) {\r\n        removeBridgeEntirely(from, isl);\r\n        setSelectedId(null);\r\n        return;\r\n      }\r\n    }\r\n\r\n    if (selectedId == null) {\r\n    "]
[331.994661, "o", "  setSelectedId(isl.id);\r\n      setCursorId(isl.id);\r\n      setKbFromId(null);\r\n      return;\r\n    }\r\n\r\n    if (selectedId === isl.id) return;\r\n\r\n    const from = findIslandById(islands, selectedId);\r\n    if (!from) {\r\n      setSelectedId(null);\r\n      return;\r\n    }\r\n\r\n    cycleBridge(from, isl);\r\n    setSelectedId(null);\r\n  }\r\n\r\n  function onIslandContextMenu(e, isl) {\r\n    e.preventDefault();\r\n    if (selectedId != null && selectedId !== isl.id) {\r\n      const from = findIslandById(islands, selectedId);\r\n      if (from) removeBridgeEntirely(from, isl);\r\n      setSelectedId(null);\r\n    }\r\n  }\r\n\r\n  function onKeyDown(e) {\r\n    const cur = cursorId == null ? null : findIslandById(islands, cursorId);\r\n    if (!cur) return;\r\n\r\n    if (e.key === 'Escape') {\r\n      setKbFromId(null);\r\n      setSelectedId(null);\r\n      setError(null);\r\n      return;\r\n    }\r\n\r\n    const dirMap = {\r\n      ArrowLeft: 'left',\r\n      ArrowRight: 'right',\r\n      ArrowUp: 'up',\r\n      ArrowDown: 'down',\r\n    };\r\n    const dir = dirMap[e."]
[331.994693, "o", "key];\r\n    if (dir) {\r\n      e.preventDefault();\r\n      const next = findNextIslandInDirection(islands, cur, dir);\r\n      if (next) setCursorId(next.id);\r\n      return;\r\n    }\r\n\r\n    if (e.key === 'Enter') {\r\n      e.preventDefault();\r\n      if (kbFromId == null) {\r\n        setKbFromId(cur.id);\r\n        setSelectedId(null);\r\n        return;\r\n      }\r\n      if (kbFromId === cur.id) return;\r\n      const from = findIslandById(islands, kbFromId);\r\n      if (!from) {\r\n        setKbFromId(null);\r\n        return;\r\n      }\r\n"]
