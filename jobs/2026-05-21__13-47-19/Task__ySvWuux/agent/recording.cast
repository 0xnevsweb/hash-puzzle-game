[263.147864, "o", "total 28\r\ndrwxr-xr-x 3 root root 4096 May 21 17:52 .\r\ndrwxr-xr-x 1 root root 4096 May 21 17:52 ..\r\ndrwxr-xr-x 2 root root 4096 May 21 17:52 assets\r\n-rw-rw-r-- 1 root root  216 May 21 17:52 favicon.svg\r\n-rw-r--r-- 1 root root  404 May 21 17:52 index.html\r\n-rw-rw-r-- 1 root root   23 May 21 17:52 robots.txt\r\n\u001b[?2004hroot@4bf7c83d9c7d:/app# "]
[320.950798, "i", "\u0003"]
[320.951549, "o", "^C\u001b[?2004l\r\u001b[?2004h\u001b[?2004l\r\r\n\u001b[?2004h"]
[320.960787, "o", "root@4bf7c83d9c7d:/app# "]
[327.929921, "i", "sed -n '1,260p' /app/src/utils/hashiLogic.js\n"]
[327.931762, "o", "sed -n '1,260p' /app/src/utils/hashiLogic.js\r\n\u001b[?2004l\r"]
[327.934276, "o", "// Core Hashi (Bridges) puzzle logic."]
[327.934503, "o", "\r\n"]
[327.93464, "o", "// Bridges are stored as Map<string, number> keyed by canonical \"x1,y1,x2,y2\" (grid units),"]
[327.934831, "o", "\r\n"]
[327.935011, "o", "// where (x1,y1) is lexicographically <= (x2,y2). Value is 1 or 2."]
[327.935154, "o", "\r\n\r\n"]
[327.935288, "o", "export const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';"]
[327.935457, "o", "\r\nexport const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';\r\nexport const ERR_EXCEED_ISLAND = 'Island would exceed its number';\r\nexport const ERR_CROSSING = 'Bridges would cross';"]
[327.935581, "o", "\r\n\r\nfunction cmpPoint(a, b) {\r\n  if (a.x !== b.x) return a.x - b.x;\r\n  return a.y - b.y;\r\n}"]
[327.935745, "o", "\r\n\r\nexport function bridgeKey(from, to) {\r\n  const a = { x: from.x, y: from.y };"]
[327.935897, "o", "\r\n  const b = { x: to.x, y: to.y };\r\n  const [p1, p2] = cmpPoint(a, b) <= 0 ? [a, b] : [b, a];\r\n  return `${p1.x},${p1.y},${p2.x},${p2.y}`;"]
[327.936017, "o", "\r\n}\r\n\r\nexport function parseBridgeKey(key) {"]
[327.93614, "o", "\r\n"]
[327.936258, "o", "  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));\r\n  return { x1, y1, x2, y2 };\r\n}"]
[327.936401, "o", "\r\n\r\nfunction isAxisAligned(a, b) {\r\n  return a.x === b.x || a.y === b.y;"]
[327.936574, "o", "\r\n}\r\n\r\nfunction between(v, a, b) {\r\n  const min = Math.min(a, b);\r\n  const max = Math.max(a, b);"]
[327.936665, "o", "\r\n  return v > min && v < max;\r\n}\r\n\r\nfunction buildIslandLookup(islands) {\r\n  const byId = new Map();\r\n  const byCoord = new Map();\r\n  for (const isl of islands) {\r\n"]
[327.937152, "o", "    byId.set(isl.id, isl);\r\n    byCoord.set(`${isl.x},${isl.y}`, isl);\r\n  }\r\n  return { byId, byCoord };\r\n"]
[327.937298, "o", "}\r\n\r\n// Two segments cross if one is vertical and the other horizontal and their interiors intersect.\r\nfunction segmentsCross(segA, segB) {\r\n  const aVertical = segA.x1 === segA.x2;\r\n  const bVertical = segB.x1 === segB.x2;"]
[327.937398, "o", "\r\n  if (aVertical === bVertical) return false;\r\n\r\n  const v = aVertical ? segA : segB;\r\n  const h = aVertical ? segB : segA;\r\n\r\n"]
[327.93743, "o", "  // Proper crossing must be strictly inside both segments (not at endpoints).\r\n  const x = v.x1;\r\n  const y = h.y1;\r\n  const inV = between(y, v.y1, v.y2);"]
[327.937502, "o", "\r\n  const inH = between(x, h.x1, h.x2);"]
[327.937703, "o", "\r\n  return inV && inH;\r\n}\r\n"]
[327.937739, "o", "\r\nexport function wouldCross(bridges, from, to) {\r\n  const candidate = { x1: from.x, y1: from.y, x2: to.x, y2: to.y };\r\n  for (const [k, count] of bridges.entries()) {\r\n    if (!count) continue;\r\n    const existing = parseBridgeKey(k);"]
[327.937883, "o", "\r\n    if (segmentsCross(candidate, existing)) return true;"]
[327.938192, "o", "\r\n  }\r\n  return false;\r\n}\r\n\r\n// Returns true only if to is the nearest island to from in that cardinal direction with no island between.\r\n"]
[327.938247, "o", "export function areAdjacent(islands, from, to) {\r\n  if (from.id === to.id) return false;\r\n  if (!isAxisAligned(from, to)) return false;\r\n\r\n  if (from.x === to.x) {\r\n    const x = from.x;\r\n    const dir = Math.sign(to.y - from.y);\r\n    if (dir === 0) return false;\r\n    let best = null;\r\n    let bestDist = Infinity;\r\n    for (const isl of islands) {\r\n      if (isl.id === from.id) continue;\r\n      if (isl.x !== x) continue;\r\n      const d = isl.y - from.y;\r\n      if (Math.sign(d) !== dir) continue;\r\n      const ad = Math.abs(d);"]
[327.938271, "o", "\r\n      if (ad < bestDist) {\r\n        bestDist = ad;\r\n"]
[327.938294, "o", "        best = isl;"]
[327.938318, "o", "\r\n      }"]
[327.938432, "o", "\r\n    }"]
[327.938462, "o", "\r\n    return best?.id === to.id;\r\n  }\r\n\r\n  // horizontal\r\n"]
[327.938699, "o", "  const y = from.y;\r\n"]
[327.938742, "o", "  const dir = Math.sign(to.x - from.x);\r\n  if (dir === 0) return false;\r\n  let best = null;\r\n  let bestDist = Infinity;\r\n  for (const isl of islands) {\r\n    if (isl.id === from.id) continue;\r\n    if (isl.y !== y) continue;\r\n    const d = isl.x - from.x;\r\n    if (Math.sign(d) !== dir) continue;"]
[327.938766, "o", "\r\n    const ad = Math.abs(d);\r\n    if (ad < bestDist) {"]
[327.938785, "o", "\r\n      bestDist = ad;"]
[327.938953, "o", "\r\n"]
[327.938993, "o", "      best = isl;\r\n    }\r\n  }\r\n  return best?.id === to.id;\r\n}\r\n\r\n"]
[327.939019, "o", "export function computeCurrentCounts(islands, bridges) {\r\n  const counts = new Map();"]
[327.939098, "o", "\r\n  for (const isl of islands) counts.set(isl.id, 0);"]
[327.93945, "o", "\r\n\r\n  const { byCoord } = buildIslandLookup(islands);\r\n  for (const [k, n] of bridges.entries()) {"]
[327.939493, "o", "\r\n    if (!n) continue;\r\n    const { x1, y1, x2, y2 } = parseBridgeKey(k);\r\n    const a = byCoord.get(`${x1},${y1}`);\r\n    const b = byCoord.get(`${x2},${y2}`);\r\n    if (!a || !b) continue;\r\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\r\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\r\n  }\r\n  return counts;\r\n}\r\n\r\nexport function canAddBridge(islands, bridges, from, to, delta) {\r\n  if (!areAdjacent(islands, from, to)) {\r\n"]
[327.939533, "o", "    return { valid: false, error: ERR_NON_ADJACENT };\r\n  }"]
[327.939548, "o", "\r\n  const key = bridgeKey(from, to);"]
[327.940187, "o", "\r\n  const existing = bridges.get(key) ?? 0;\r\n  const next = existing + delta;\r\n\r\n  if (next < 0) return { valid: true, error: null };\r\n  if (next > 2) return { valid: false, error: ERR_MAX_PER_PAIR };\r\n  if (next === 0) return { valid: true, error: null };\r\n\r\n  if (delta > 0 && wouldCross(bridges, from, to)) {\r\n    return { valid: false, error: ERR_CROSSING };\r\n  }\r\n\r\n  const counts = computeCurrentCounts(islands, bridges);\r\n"]
[327.940559, "o", "  const fromCount = counts.get(from.id) ?? 0;\r\n  const toCount = counts.get(to.id) ?? 0;\r\n\r\n  if (delta > 0) {\r\n    if (fromCount + 1 > from.value || toCount + 1 > to.value) {\r\n      return { valid: false, error: ERR_EXCEED_ISLAND };\r\n    }\r\n  }\r\n\r\n  return { valid: true, error: null };\r\n}\r\n\r\nexport function checkConnectivity(islands, bridges) {\r\n  if (islands.length === 0) return true;\r\n  const { byCoord } = buildIslandLookup(islands);\r\n\r\n  const adj = new Map();\r\n  for (const isl of islands) adj.set(isl.id, []);\r\n\r\n"]
