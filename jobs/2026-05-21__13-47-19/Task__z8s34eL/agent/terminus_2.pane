[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   // from/to are {x,y} in grid units
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const swap = a.x > b.x || (a.x === b.x && a.y > b.y);
[?2004l[?2004h>   const p = swap ? b : a;
[?2004l[?2004h>   const q = swap ? a : b;
[?2004l[?2004h>   return `${p.x},${p.y},${q.x},${q.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function parseKey(key) {
