    50	  const isH = py1 === py2;
    51	  const isV = px1 === px2;
    52	
    53	  const lines = [];
    54	  if (count === 1) {
    55	    lines.push({ x1: px1, y1: py1, x2: px2, y2: py2 });
    56	  } else if (count === 2) {
    57	    const off = 6;
