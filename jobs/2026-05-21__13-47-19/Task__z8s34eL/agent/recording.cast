[131.379422, "o", "bridgeSegmentsFromKey(newKey);\r\n  for (const [key, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    if (key === newKey) continue;\r\n    const seg = bridgeSegmentsFromKey(key);\r\n    if (segmentsCross(newSeg, seg)) return true;\r\n  }\r\n  return false;\r\n}\r\n\r\nexport function canAddBridge(islands, bridges, from, to, delta) {\r\n  // delta: +1, +2, -1, -2, or special removal handled by caller.\r\n  const adj = isCardinalAdjacent(islands, from, to);\r\n  if (!adj.ok) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\r\n  const key = canonicalBridgeKey(from, to);\r\n  const existing = bridges.get(key) ?? 0;\r\n  const next = existing + delta;\r\n\r\n  if (next < 0) return { valid: true, error: null };\r\n  if (next > 2) return { valid: false, error: ERROR_MAX_2 };\r\n\r\n  // crossing check only if we are adding (increasing)\r\n  if (delta > 0) {\r\n    const temp = new Map(bridges);\r\n    temp.set(key, next);\r\n    if (wouldCrossExisting(bridges, key)) return { valid: false, error: ERROR_CROSS };\r\n    // also ensure adding this does not"]
