[90.455726, "i", "h the new one (symmetric)\n    // counts check\n    const counts = computeCurrentCounts(islands, temp);\n    for (const isl of islands) {\n      if ((counts.get(isl.id) ?? 0) > isl.value) return { valid: false, error: ERROR_EXCEED };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n\n  // Build adjacency by island id.\n  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n  const adj = new Map(islands.map((i) => [i.id, []]));\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const queue = [startId];\n  while (queue.length) {\n    const cur = queue.shift();\n    for (const nxt of adj.get(cur) || []) {\n"]
