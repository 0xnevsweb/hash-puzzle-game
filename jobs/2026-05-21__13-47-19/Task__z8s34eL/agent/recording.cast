[90.503376, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> function segmentsCross(segA, segB) {\r\n\u001b[?2004l\r\u001b[?2004h>   // Bridges that share an endpoint (i.e. touch at an island) are OK.\r\n\u001b[?2004l\r\u001b[?2004h>   if (!segA || !segB) return false;\r\n\u001b[?2004l\r\u001b[?2004h>   if (segA.type === segB.type) return false; // parallel won't cross in Hashi model\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   const h = segA.type === 'h' ? segA : segB;\r\n\u001b[?2004l\r\u001b[?2004h>   const v = segA.type === 'v' ? segA : segB;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   // intersection point\r\n\u001b[?2004l\r\u001b[?2004h>   const ix = v.x;\r\n\u001b[?2004l\r\u001b[?2004h>   const iy = h.y;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   const withinH = ix > h.x1 && ix < h.x2;\r\n\u001b[?2004l\r\u001b[?2004h> "]
