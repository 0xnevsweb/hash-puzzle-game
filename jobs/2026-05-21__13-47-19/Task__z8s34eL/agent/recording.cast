[131.482457, "o", "2: py2 + off });\r\n    } else if (isV) {\r\n      lines.push({ x1: px1 - off, y1: py1, x2: px2 - off, y2: py2 });\r\n      lines.push({ x1: px1 + off, y1: py1, x2: px2 + off, y2: py2 });\r\n    }\r\n  }\r\n  return lines;\r\n}\r\n\r\nexport default function App() {\r\n  const [difficulty, setDifficulty] = useState('Easy');\r\n  const puzzle = useMemo(() => puzzles.find((p) => p.name === difficulty) ?? puzzles[0], [difficulty]);\r\n  const islands = puzzle.islands;\r\n\r\n  const [bridges, setBridges] = useState(() => new Map());\r\n  const [selectedIslandId, setSelectedIslandId] = useState(null); // mouse selection\r\n\r\n  const [cursorIslandId, setCursorIslandId] = useState(islands[0]?.id ?? 0);\r\n  const [kbFromId, setKbFromId] = useState(null);\r\n\r\n  const [error, setError] = useState(null);\r\n\r\n  const svgRef = useRef(null);\r\n\r\n  // reset when puzzle changes\r\n  useEffect(() => {\r\n    setBridges(new Map());\r\n    setSelectedIslandId(null);\r\n    setKbFromId(null);\r\n    setError(null);\r\n    setCursorIslandId(islands[0]?.id ?? 0);\r\n  }, [puzzle"]
[131.482468, "o", ".id]);\r\n\r\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\r\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\r\n\r\n  function applyValidUpdate(nextBridges) {\r\n    setBridges(nextBridges);\r\n    setError(null);\r\n  }\r\n\r\n  function toggleBridge(from, to) {\r\n    const key = canonicalBridgeKey(from, to);\r\n    const existing = bridges.get(key) ?? 0;\r\n    const next = (existing + 1) % 3; // 0->1->2->0\r\n\r\n    const nextMap = new Map(bridges);\r\n\r\n    if (next === 0) {\r\n      nextMap.delete(key);\r\n      applyValidUpdate(nextMap);\r\n      return;\r\n    }\r\n\r\n    const delta = next - existing;\r\n    const res = canAddBridge(islands, bridges, from, to, delta);\r\n    if (!res.valid) {\r\n      setError(res.error);\r\n      return;\r\n    }\r\n    nextMap.set(key, next);\r\n    applyValidUpdate(nextMap);\r\n  }\r\n\r\n  function removeBridgeIfExists(from, to) {\r\n    const key = canonicalBridgeKey(from, to);\r\n    const existing = bridges.get(key) ?? 0;\r\n    if (!existing) {"]
