[92.294316, "i", "cat > /app/src/index.css <<'EOF'\n:root {\n  color-scheme: dark;\n}\n\nbody {\n  margin: 0;\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n  background-color: black;\n  color: #0f0;\n}\n\n.app-root {\n  position: relative;\n}\n\n.ui-bar {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  padding: 8px;\n}\n\nselect,\nbutton {\n  background: black;\n  color: #0f0;\n  border: 1px solid #0f0;\n  font-family: inherit;\n  padding: 4px 8px;\n}\n\nbutton:hover,\nselect:hover {\n  filter: brightness(1.15);\n}\n\n.error-message {\n  padding: 6px 8px;\n  border-top: 1px solid #0f0;\n  border-bottom: 1px solid #0f0;\n  color: #0f0;\n}\n\n.victory-banner {\n  padding: 6px 8px;\n  border-top: 1px solid #0f0;\n  border-bottom: 1px solid #0f0;\n  font-weight: 700;\n}\n\n.board-svg {\n  width: 800px;\n  height: 600px;\n}\n\n.counts-hint {\n  font-size: 12px;\n  opacity: 0.9;\n}\nEOF\n"]
