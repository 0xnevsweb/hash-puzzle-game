[91.278644, "i", "cat > /app/src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { puzzles } from './data/puzzles';\nimport {\n  canAddBridge,\n  canonicalBridgeKey,\n  computeCurrentCounts,\n  isVictory,\n} from './utils/hashiLogic';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction islandKey(i) {\n  return `${i.x},${i.y}`;\n}\n\nfunction getIslandById(islands, id) {\n  return islands.find((i) => i.id === id) ?? null;\n}\n\nfunction getIslandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y) ?? null;\n}\n\nfunction neighborsInDirection(islands, from, dir) {\n  // returns closest island in that direction if any\n  if (!from) return null;\n  if (dir === 'left') {\n    const cands = islands.filter((i) => i.y === from.y && i.x < from.x);\n    if (!cands.length) return null;\n    return cands.reduce((a, b) => (b.x > a.x ? b : a));\n  }\n  if (dir === 'right') {\n    const cands = islands.filter((i) => i.y === from.y && i.x > from.x);\n    if (!cands.length) return null;\n    re"]
[91.278871, "i", "turn cands.reduce((a, b) => (b.x < a.x ? b : a));\n  }\n  if (dir === 'up') {\n    const cands = islands.filter((i) => i.x === from.x && i.y < from.y);\n    if (!cands.length) return null;\n    return cands.reduce((a, b) => (b.y > a.y ? b : a));\n  }\n  if (dir === 'down') {\n    const cands = islands.filter((i) => i.x === from.x && i.y > from.y);\n    if (!cands.length) return null;\n    return cands.reduce((a, b) => (b.y < a.y ? b : a));\n  }\n  return null;\n}\n\nfunction bridgeLinesFor(key, count) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  const px1 = x1 * GRID;\n  const py1 = y1 * GRID;\n  const px2 = x2 * GRID;\n  const py2 = y2 * GRID;\n\n  const isH = py1 === py2;\n  const isV = px1 === px2;\n\n  const lines = [];\n  if (count === 1) {\n    lines.push({ x1: px1, y1: py1, x2: px2, y2: py2 });\n  } else if (count === 2) {\n    const off = 6;\n    if (isH) {\n      lines.push({ x1: px1, y1: py1 - off, x2: px2, y2: py2 - off });\n      lines.push({ x1: px1, y1: py1 + off, x2: px2, y2: py2 + off });\n    } else if (isV) "]
[91.278899, "i", "{\n      lines.push({ x1: px1 - off, y1: py1, x2: px2 - off, y2: py2 });\n      lines.push({ x1: px1 + off, y1: py1, x2: px2 + off, y2: py2 });\n    }\n  }\n  return lines;\n}\n\nexport default function App() {\n  const [difficulty, setDifficulty] = useState('Easy');\n  const puzzle = useMemo(() => puzzles.find((p) => p.name === difficulty) ?? puzzles[0], [difficulty]);\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedIslandId, setSelectedIslandId] = useState(null); // mouse selection\n\n  const [cursorIslandId, setCursorIslandId] = useState(islands[0]?.id ?? 0);\n  const [kbFromId, setKbFromId] = useState(null);\n\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  // reset when puzzle changes\n  useEffect(() => {\n    setBridges(new Map());\n    setSelectedIslandId(null);\n    setKbFromId(null);\n    setError(null);\n    setCursorIslandId(islands[0]?.id ?? 0);\n  }, [puzzle.id]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands,"]
