Sending keys: ["cat > src/utils/hashiLogic.js <<'EOF'\nexport const ERROR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\nexport const ERROR_MAX_PER_PAIR = 'Max 2 bridges per pair';\nexport const ERROR_EXCEED_NUMBER = 'Island would exceed its number';\nexport const ERROR_CROSS = 'Bridges would cross';\n\nexport function canonicalBridgeKey(a, b) {\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\n  const second = first === p1 ? p2 : p1;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction isHorizontal(a, b) {\n  return a.y === b.y && a.x !== b.x;\n}\nfunction isVertical(a, b) {\n  return a.x === b.x && a.y !== b.y;\n}\n\nexport function areAdjacent(islands, from, to, bridges) {\n  if (!from || !to) return false;\n  if (!(isHorizontal(from, to) || isVertical(from, to))) return false;\n\n  // must have clear path: no island between\n  if (isHorizontal(from, to)) {\n    const y = from.y;\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === y && i.x > minX && i.x < maxX);\n    if (between) return false;\n  } else {\n    const x = from.x;\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    const between = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === x && i.y > minY && i.y < maxY);\n    if (between) return false;\n  }\n\n  // cannot pass through existing bridge segment (collinear overlap is fine only if it's the same pair)\n  const key = canonicalBridgeKey(from, to);\n  for (const [k, count] of bridges.entries()) {\n    if (count <= 0) continue;\n    if (k === key) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const A = { x: x1, y: y1 };\n    const B = { x: x2, y: y2 };\n\n    // if candidate is horizontal, disallow any vertical bridge crossing its path\n    if (isHorizontal(from, to) && A.x === B.x) {\n      const cxMin = Math.min(from.x, to.x);\n      const cxMax = Math.max(from.x, to.x);\n      const byMin = Math.min(A.y, B.y);\n      const byMax = Math.max(A.y, B.y);\n      if (A.x > cxMin && A.x < cxMax && from.y > byMin && from.y < byMax) return false;\n    }\n    // if candidate is vertical, disallow any horizontal bridge crossing its path\n    if (isVertical(from, to) && A.y === B.y) {\n      const cyMin = Math.min(from.y, to.y);\n      const cyMax = Math.max(from.y, to.y);\n      const bxMin = Math.min(A.x, B.x);\n      const bxMax = Math.max(A.x, B.x);\n      if (from.x > bxMin && from.x < bxMax && A.y > cyMin && A.y < cyMax) return false;\n    }\n  }\n\n  return true;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nfunction segmentsCross(k1, k2) {\n  const [x1, y1, x2, y2] = k1.split(',').map(Number);\n  const [x3, y3, x4, y4] = k2.split(',').map(Number);\n\n  // ignore if share endpoints\n  const endpoints1 = [\n    `${x1},${y1}`,\n    `${x2},${y2}`,\n  ];\n  const endpoints2 = [\n    `${x3},${y3}`,\n    `${x4},${y4}`,\n  ];\n  if (endpoints1.some((e) => endpoints2.includes(e))) return false;\n\n  const h1 = y1 === y2;\n  const v1 = x1 === x2;\n  const h2 = y3 === y4;\n  const v2 = x3 === x4;\n  if (!(h1 || v1) || !(h2 || v2)) return false;\n  if ((h1 && h2) || (v1 && v2)) return false; // collinear cannot cross in this puzzle definition\n\n  const hx1 = h1 ? [Math.min(x1, x2), Math.max(x1, x2), y1] : [Math.