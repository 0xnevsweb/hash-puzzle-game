h={2}\n            strokeDasharray={kbFromId !== null ? \'4 3\' : \'0\'}\n          />\n        ) : null}\n\n        {islands.map((isl) => {\n          const px = isl.x * GRID;\n          const py = isl.y * GRID;\n          const isSelected = selectedIslandId === isl.id || kbFromId === isl.id;\n          const current = counts.get(isl.id) ?? 0;\n\n          return (\n            <g key={isl.id}>\n              <circle\n                cx={px}\n                cy={py}\n                r={16}\n                fill="black"\n                stroke={isSelected ? \'#9f9\' : \'#0f0\'}\n                strokeWidth={2}\n                onClick={(e) => handleIslandClick(e, isl)}\n                onContextMenu={(e) => handleIslandContextMenu(e, isl)}\n              />\n              <text\n                x={px}\n                y={py + 5}\n                textAnchor="middle"\n                fontFamily="monospace"\n                fontSize={16}\n                fill="#0f0"\n                style={{ userSelect: \'none\', pointerEvents: \'none\' }}\n              >\n                {isl.value}\n              </text>\n              <text\n                x={px}\n                y={py + 28}\n                textAnchor="middle"\n                fontFamily="monospace"\n                fontSize={10}\n                fill="#0f0"\n                style={{ userSelect: \'none\', pointerEvents: \'none\' }}\n              >\n                {current}/{isl.value}\n              </text>\n            </g>\n          );\n        })}\n      </svg>\n\n      {/* UI overlay that does not move the SVG from (0,0) */}\n      <div className="ui-overlay">\n        <div className="ui-bar">\n          <label>\n            Puzzle:{\' \'}\n            <select value={difficulty} onChange={(e) => setDifficulty(e.target.value)} aria-label="Puzzle difficulty">\n              <option value="Easy">Easy</option>\n              <option value="Medium">Medium</option>\n              <option value="Hard">Hard</optio