Sending keys: ['cat > /app/src/App.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\';\nimport { puzzles } from \'./data/puzzles\';\nimport {\n  bridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n} from \'./utils/hashiLogic\';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction islandPx(isl) {\n  return { cx: isl.x * GRID, cy: isl.y * GRID };\n}\n\nfunction pickInitialCursor(islands) {\n  return islands.length ? islands[0].id : null;\n}\n\nfunction findIslandById(islands, id) {\n  return islands.find((i) => i.id === id) ?? null;\n}\n\nfunction findNextIslandInDirection(islands, from, dir) {\n  let best = null;\n  let bestDist = Infinity;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (dir === \'left\' && isl.y === from.y && isl.x < from.x) {\n      const d = from.x - isl.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n    if (dir === \'right\' && isl.y === from.y && isl.x > from.x) {\n      const d = isl.x - from.x;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n    if (dir === \'up\' && isl.x === from.x && isl.y < from.y) {\n      const d = from.y - isl.y;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n    if (dir === \'down\' && isl.x === from.x && isl.y > from.y) {\n      const d = isl.y - from.y;\n      if (d < bestDist) {\n        bestDist = d;\n        best = isl;\n      }\n    }\n  }\n  return best;\n}\n\nfunction computeBridgeLines(islands, bridges) {\n  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n  const lines = [];\n\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = k.split(\',\').map((v) => Number(v));\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n\n    const p1 = islandPx(a);\n    const p2 = islandPx(b);\n\n    if (n === 1) {\n      lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy, x2: p2.cx, y2: p2.cy });\n    } else {\n      const off = 4;\n      const horizontal = a.y === b.y;\n      if (horizontal) {\n        lines.push({ key: k, idx: 0, x1: p1.cx, y1: p1.cy - off, x2: p2.cx, y2: p2.cy - off });\n        lines.push({ key: k, idx: 1, x1: p1.cx, y1: p1.cy + off, x2: p2.cx, y2: p2.cy + off });\n      } else {\n        lines.push({ key: k, idx: 0, x1: p1.cx - off, y1: p1.cy, x2: p2.cx - off, y2: p2.cy });\n        lines.push({ key: k, idx: 1, x1: p1.cx + off, y1: p1.cy, x2: p2.cx + off, y2: p2.cy });\n      }\n    }\n  }\n\n  return lines;\n}\n\nexport default function App() {\n  const [puzzleName, setPuzzleName] = useState(\'Easy\');\n  const puzzle = useMemo(() => puzzles.find((p) => p.name === puzzleName) ?? puzzles[0], [puzzleName]);\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null); // mouse selection\n  const [cursorId, setCursorId] = useState(() => pickInitialCursor(islands));\n  const [kbFromId, setKbFromId] = useState(null); // keyboard selection start\n  const [error, setError] = useState(null);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n  const bridgeLines = useMemo(() => computeBridgeLines(islands, bridges), [islands, bridges]);\n\n  const rootRef = useRef(null);\n\n  useEffect(() => {\n    setBridges(new Map());\n    setSelectedId(null);\n    setKbFromId(null);\n    setError(null);\n    setCursorId(pickInitialCursor(islands));\n  }, [puzzleName]);\n\n  useEffect(() => {\n    rootRef.current?.focus();\n  }, []);\n\n  function applyBridgeDelta(from, to, delta) {\n    const res = canAddBridge(islands, bridges, from, to, delta);\n    if (!res.valid) {\n      setError(res.error);\n      return false;\n    }\n\n    setBridges((prev) => {\n      const next = new Map(prev);\n      const k = bridgeKey(from, to);\n      const existing = next.get(k) ?? 0;\n      const v = existing + delta;\n      if (v <= 0) next.delete(k);\n      else next.set(k, v);\n      return next;\n    });\n    setError(null);\n    return true;\n  }\n\n  function cycleBridge(from, to) {\n    const k = bridgeKey(from, to);\n    const existing = bridges.get(k) ?? 0;\n    if (existing === 0) return applyBridgeDelta(from, to, +1);\n    if (existing === 1) return applyBridgeDelta(from, to, +1);\n    return applyBridgeDelta(from, to, -2);\n  }\n\n  function removeBridgeEntirely(from, to) {\n    const k = bridgeKey(from, to);\n    const existing = bridges.get(k) ?? 0;\n    if (existing <= 0) return false;\n    setBridges((prev) => {\n      const next = new Map(prev);\n      next.delete(k);\n      return next;\n    });\n    setError(null);\n    return true;\n  }\n\n  function onIslandClick(e, isl) {\n    if (e.ctrlKey && selectedId != null && selectedId !== isl.id) {\n      const from = findIslandById(islands, selectedId);\n      if (from) {\n        removeBridgeEntirely(from, isl);\n        setSelectedId(null);\n        return;\n      }\n    }\n\n    if (selectedId == null) {\n      setSelectedId(isl.id);\n      setCursorId(isl.id);\n      setKbFromId(null);\n      return;\n    }\n\n    if (selectedId === isl.id) return;\n\n    const from = findIslandById(islands, selectedId);\n    if (!from) {\n      setSelectedId(null);\n      return;\n    }\n\n    cycleBridge(from, isl);\n    setSelectedId(null);\n  }\n\n  function onIslandContextMenu(e, isl) {\n    e.preventDefault();\n    if (selectedId != null && selectedId !== isl.id) {\n      const from = findIslandById(islands, selectedId);\n      if (from) removeBridgeEntirely(from, isl);\n      setSelectedId(null);\n    }\n  }\n\n  function onKeyDown(e) {\n    const cur = cursorId == null ? null : findIslandById(islands, cursorId);\n    if (!cur) return;\n\n    if (e.key === \'Escape\') {\n      setKbFromId(null);\n      setSelectedId(null);\n      setError(null);\n      return;\n    }\n\n    const dirMap = {\n      ArrowLeft: \'left\',\n      ArrowRight: \'right\',\n      ArrowUp: \'up\',\n      ArrowDown: \'down\',\n    };\n    const dir = dirMap[e.key];\n    if (dir) {\n      e.preventDefault();\n      const next = findNextIslandInDirection(islands, cur, dir);\n      if (next) setCursorId(next.id);\n      return;\n    }\n\n    if (e.key === \'Enter\') {\n      e.preventDefault();\n      if (kbFromId == null) {\n        setKbFromId(cur.id);\n        setSelectedId(null);\n        return;\n      }\n      if (kbFromId === cur.id) return;\n      const from = findIslandById(islands, kbFromId);\n      if (!from) {\n        setKbFromId(null);\n        return;\n      }\n      cycleBridge(from, cur);\n      setKbFromId(null);\n    }\n  }\n\n  const cursorIsland = cursorId == null ? null : findIslandById(islands, cursorId);\n\n  return (\n    <div ref={rootRef} tabIndex={0} onKeyDown={onKeyDown} style={{ outline: \'none\' }}>\n      <div style={{ padding: 8 }}>\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={puzzleName}\n            onChange={(e) => setPuzzleName(e.target.value)}\n            style={{\n              background: \'black\',\n              color: \'#0f0\',\n              border: \'1px solid #0f0\',\n              fontFamily: \'monospace\',\n            }}\n          >\n            <option value="Easy">Easy</option>\n            <option value="Medium">Medium</option>\n            <option value="Hard">Hard</option>\n          </select>\n        </label>\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedId(null);\n            setKbFromId(null);\n            setError(null);\n          }}\n          style={{\n            marginLeft: 12,\n            background: \'black\',\n            color: \'#0f0\',\n            border: \'1px solid #0f0\',\n            fontFamily: \'monospace\',\n            cursor: \'pointer\',\n          }}\n        >\n          Reset\n        </button>\n\n        {error ? (\n          <div className="error-message" style={{ marginTop: 8 }}>\n            {error}\n          </div>\n        ) : null}\n        {solved ? (\n          <div className="victory-banner" style={{ marginTop: 8 }}>\n            SOLVED!\n          </div>\n        ) : null}\n      </div>\n\n      <svg width={SVG_W} height={SVG_H} viewBox={`0 0 ${SVG_W} ${SVG_H}`} style={{ display: \'block\' }}>\n        {/* Bridges */}\n        <g stroke="#0f0" strokeWidth={3} strokeLinecap="round">\n          {bridgeLines.map((ln) => (\n            <line key={`${ln.key}:${ln.idx}`} x1={ln.x1} y1={ln.y1} x2={ln.x2} y2={ln.y2} />\n          ))}\n        </g>\n\n        {/* Keyboard cursor (must not be a circle) */}\n        {cursorIsland\n          ? (() => {\n              const p = islandPx(cursorIsland);\n              const size = 26;\n              return (\n                <rect\n                  x={p.cx - size / 2}\n                  y={p.cy - size / 2}\n                  width={size}\n                  height={size}\n                  fill="none"\n                  stroke="#0f0"\n                  strokeWidth={2}\n                  strokeDasharray="4 3"\n                />\n              );\n            })()\n          : null}\n\n        {/* Islands */}\n        <g>\n          {islands.map((isl) => {\n            const { cx, cy } = islandPx(isl);\n            const isSelected = selectedId === isl.id;\n            const isKbFrom = kbFromId === isl.id;\n            return (\n              <g key={isl.id}>\n                <circle\n                  cx={cx}\n                  cy={cy}\n                  r={14}\n                  fill="black"\n                  stroke={isSelected || isKbFrom ? \'#0f0\' : \'#0a0\'}\n                  strokeWidth={isSelected || isKbFrom ? 3 : 2}\n                  onClick={(e) => onIslandClick(e, isl)}\n                  onContextMenu={(e) => onIslandContextMenu(e, isl)}\n                  style={{ cursor: \'pointer\' }}\n                />\n                <text\n                  x={cx}\n                  y={cy + 5}\n                  textAnchor="middle"\n                  fontFamily="monospace"\n                  fontSize={14}\n                  fill="#0f0"\n                  style={{ userSelect: \'none\' }}\n                >\n                  {isl.value}\n                </text>\n              </g>\n            );\n          })}\n        </g>\n      </svg>\n    </div>\n  );\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
