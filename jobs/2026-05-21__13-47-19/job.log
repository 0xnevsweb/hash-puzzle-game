st y = h.y1;\n+  const inV = between(y, v.y1, v.y2);\n+  const inH = between(x, h.x1, h.x2);\n+  return inV && inH;\n+}\n+\n+export function wouldCross(bridges, from, to) {\n+  const candidate = { x1: from.x, y1: from.y, x2: to.x, y2: to.y };\n+  for (const [k, count] of bridges.entries()) {\n+    if (!count) continue;\n+    const existing = parseBridgeKey(k);\n+    if (segmentsCross(candidate, existing)) return true;\n+  }\n+  return false;\n+}\n+\n+// Returns true only if to is the nearest island to from in that cardinal direction with no island between.\n+export function areAdjacent(islands, from, to) {\n+  if (from.id === to.id) return false;\n+  if (!isAxisAligned(from, to)) return false;\n+\n+  if (from.x === to.x) {\n+    const x = from.x;\n+    const dir = Math.sign(to.y - from.y);\n+    if (dir === 0) return false;\n+    let best = null;\n+    let bestDist = Infinity;\n+    for (const isl of islands) {\n+      if (isl.id === from.id) continue;\n+      if (isl.x !== x) continue;\n+      const d = isl.y - from.y;\n+      if (Math.sign(d) !== dir) continue;\n+      const ad = Math.abs(d);\n+      if (ad < bestDist) {\n+        bestDist = ad;\n+        best = isl;\n+      }\n+    }\n+    return best?.id === to.id;\n+  }\n+\n+  // horizontal\n+  const y = from.y;\n+  const dir = Math.sign(to.x - from.x);\n+  if (dir === 0) return false;\n+  let best = null;\n+  let bestDist = Infinity;\n+  for (const isl of islands) {\n+    if (isl.id === from.id) continue;\n+    if (isl.y !== y) continue;\n+    const d = isl.x - from.x;\n+    if (Math.sign(d) !== dir) continue;\n+    const ad = Math.abs(d);\n+    if (ad < bestDist) {\n+      bestDist = ad;\n+      best = isl;\n+    }\n+  }\n+  return best?.id === to.id;\n+}\n+\n+export function computeCurrentCounts(islands, bridges) {\n+  const counts = new Map();\n+  for (const isl of islands) counts.set(isl.id, 0);\n+\n+  // For each bridge, add its count to both endpoints.\n+  const { byCoord } = buildIslandLookup(islands);\