Sending keys: ['cat > src/utils/hashiLogic.js <<\'EOF\'\nconst ERROR_NON_ADJ = "Cannot connect non-adjacent islands";\nconst ERROR_MAX2 = "Max 2 bridges per pair";\nconst ERROR_EXCEED = "Island would exceed its number";\nconst ERROR_CROSS = "Bridges would cross";\n\nfunction isAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\nfunction canonicalKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  if (a.x < b.x) return `${a.x},${a.y},${b.x},${b.y}`;\n  if (a.x > b.x) return `${b.x},${b.y},${a.x},${a.y}`;\n  if (a.y <= b.y) return `${a.x},${a.y},${b.x},${b.y}`;\n  return `${b.x},${b.y},${a.x},${a.y}`;\n}\n\nfunction parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nfunction islandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y) || null;\n}\n\nfunction isAdjacent(islands, from, to) {\n  if (!from || !to) return false;\n  if (from.id === to.id) return false;\n  if (!isAligned(from, to)) return false;\n\n  const dx = Math.sign(to.x - from.x);\n  const dy = Math.sign(to.y - from.y);\n  let cx = from.x + dx;\n  let cy = from.y + dy;\n  while (cx !== to.x || cy !== to.y) {\n    if (islandAt(islands, cx, cy)) return false;\n    cx += dx;\n    cy += dy;\n  }\n  return true;\n}\n\nfunction segmentsCross(segA, segB) {\n  // seg: {x1,y1,x2,y2} axis-aligned in grid units\n  const aH = segA.y1 === segA.y2;\n  const bH = segB.y1 === segB.y2;\n  if (aH === bH) return false;\n\n  const h = aH ? segA : segB;\n  const v = aH ? segB : segA;\n\n  const hxMin = Math.min(h.x1, h.x2);\n  const hxMax = Math.max(h.x1, h.x2);\n  const vyMin = Math.min(v.y1, v.y2);\n  const vyMax = Math.max(v.y1, v.y2);\n\n  const ix = v.x1;\n  const iy = h.y1;\n\n  // Only count interior intersections; touching at endpoints doesn\'t count as crossing.\n  const withinH = ix > hxMin && ix < hxMax;\n  const withinV = iy > vyMin && iy < vyMax;\n  return withinH && withinV;\n}\n\nfunction wouldCrossExisting(bridges, from, to) {\n  const newSeg = { x1: from.x, y1: from.y, x2: to.x, y2: to.y };\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const seg = parseKey(key);\n\n    const sharesEndpoint =\n      (seg.x1 === newSeg.x1 && seg.y1 === newSeg.y1) ||\n      (seg.x2 === newSeg.x1 && seg.y2 === newSeg.y1) ||\n      (seg.x1 === newSeg.x2 && seg.y1 === newSeg.y2) ||\n      (seg.x2 === newSeg.x2 && seg.y2 === newSeg.y2);\n    if (sharesEndpoint) continue;\n\n    if (segmentsCross(seg, newSeg)) return true;\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islandAt(islands, x1, y1);\n    const b = islandAt(islands, x2, y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!isAdjacent(islands, from, to)) {\n    return { valid: false, error: ERROR_NON_ADJ };\n  }\n\n  const key = canonicalKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = current + delta;\n\n  if (next > 2) return { valid: false, error: ERROR_MAX2 };\n  if (next < 0) return { valid: false, error: null };\n\n  if (delta > 0 && wouldCrossExisting(bridges, from, to)) {\n    return { valid: false, error: ERROR_CROSS };\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) {\n    return { valid: false, error: ERROR_EXCEED };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islandAt(islands, x1, y1);\n    const b = islandAt(islands, x2, y2);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const start = islands[0].id;\n  const stack = [start];\n  const seen = new Set([start]);\n\n  while (stack.length) {\n    const cur = stack.pop();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        stack.push(nxt);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // crossings check\n  const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);\n  for (let i = 0; i < keys.length; i++) {\n    for (let j = i + 1; j < keys.length; j++) {\n      const a = parseKey(keys[i]);\n      const b = parseKey(keys[j]);\n      const sharesEndpoint =\n        (a.x1 === b.x1 && a.y1 === b.y1) ||\n        (a.x1 === b.x2 && a.y1 === b.y2) ||\n        (a.x2 === b.x1 && a.y2 === b.y1) ||\n        (a.x2 === b.x2 && a.y2 === b.y2);\n      if (sharesEndpoint) continue;\n      if (segmentsCross(a, b)) return false;\n    }\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\n\nexport function getCanonicalBridgeKey(from, to) {\n  return canonicalKey(from, to);\n}\n\nexport function getAdjacentIslands(islands, from) {\n  // nearest island in each cardinal direction\n  const result = [];\n  const dirs = [\n    { dx: 1, dy: 0 },\n    { dx: -1, dy: 0 },\n    { dx: 0, dy: 1 },\n    { dx: 0, dy: -1 }\n  ];\n\n  for (const { dx, dy } of dirs) {\n    let cx = from.x + dx;\n    let cy = from.