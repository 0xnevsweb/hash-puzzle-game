[227.449247, "i", "\n              strokeWidth=\"3\"\n              style={{ cursor: 'pointer' }}\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeContextMenu(key, e)}\n            />\n          );\n          lines.push(\n            <line\n              key={key + '_b'}\n              x1={x1 + offset} y1={y1} x2={x2 + offset} y2={y2}\n              stroke=\"#0f0\"\n              strokeWidth=\"3\"\n              style={{ cursor: 'pointer' }}\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeContextMenu(key, e)}\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands as circles with numbers\n  const renderIslands = () => {\n    return islands.map((isl) => {\n      const px = isl.x * GRID;\n      const py = isl.y * GRID;\n      const isSelected = selectedIsland && selectedIsland.id === isl.id;\n\n      return (\n        <g key={isl.id}>\n          <circle\n            cx={px}\n            cy={py}\n            "]
