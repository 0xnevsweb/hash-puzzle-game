[97.883098, "i", "cat > /app/src/utils/hashiLogic.js << 'LOGIC'\n// Canonical bridge key: smaller endpoint first (by x, then y)\nexport function bridgeKey(island1, island2) {\n  const x1 = island1.x, y1 = island1.y;\n  const x2 = island2.x, y2 = island2.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are adjacent (same row/col, no island between them)\nexport function areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n  \n  if (from.x === to.x) {\n    // Vertical\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const isl of islands) {\n      if (isl.id === from.id || isl.id === to.id) continue;\n      if (isl.x === from.x && isl.y > minY && isl.y < maxY) return false;\n    }\n  } else {\n    // Horizontal\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for (const isl"]
[97.883301, "i", " of islands) {\n      if (isl.id === from.id || isl.id === to.id) continue;\n      if (isl.y === from.y && isl.x > minX && isl.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if a bridge between from and to would cross any existing bridge\nexport function wouldCross(islands, bridges, from, to) {\n  // Get all existing bridge segments\n  for (const [key, count] of bridges.entries()) {\n    if (count === 0) continue;\n    const parts = key.split(',').map(Number);\n    const bx1 = parts[0], by1 = parts[1], bx2 = parts[2], by2 = parts[3];\n    \n    // Check crossing: one horizontal one vertical\n    if (from.x === to.x) {\n      // New bridge is vertical\n      if (by1 === by2) {\n        // Existing bridge is horizontal\n        const crossX = from.x;\n        const crossY = by1;\n        const minY = Math.min(from.y, to.y);\n        const maxY = Math.max(from.y, to.y);\n        const minX = Math.min(bx1, bx2);\n        const maxX = Math.max(bx1, bx2);\n        if (crossX > minX && crossX < maxX && crossY > minY && cro"]
