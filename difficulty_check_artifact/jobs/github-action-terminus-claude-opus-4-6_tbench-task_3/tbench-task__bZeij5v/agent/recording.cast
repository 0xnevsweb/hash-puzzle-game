[227.449096, "o", "> "]
[227.449158, "i", "urrentIsland.x) candidates.push(isl);\n        }\n\n        if (candidates.length > 0) {\n          candidates.sort((a, b) => {\n            const da = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);\n            const db = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);\n            return da - db;\n          });\n          setCursorIslandId(candidates[0].id);\n        }\n        return;\n      }\n\n      if (e.key === 'Enter') {\n        if (!kbMode || cursorIslandId === null) return;\n        e.preventDefault();\n\n        const cursorIsland = islands.find(i => i.id === cursorIslandId);\n        if (!cursorIsland) return;\n\n        if (selectedIsland === null) {\n          setSelectedIsland(cursorIsland);\n          setError(null);\n        } else {\n          if (selectedIsland.id === cursorIsland.id) {\n            setSelectedIsland(null);\n          } else {\n            toggleBridge(selectedIsland, cursorIsland, false);\n            setSelectedIsland(null);\n          }\n        }\n        retur"]
