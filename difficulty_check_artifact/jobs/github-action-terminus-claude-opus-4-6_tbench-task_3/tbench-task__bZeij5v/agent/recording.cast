[371.1966, "o", "// Canonical bridge key: smaller endpoint first (by x, then y)\r\nexport function bridgeKey(island1, island2) {\r\n  const x1 = island1.x, y1 = island1.y;\r\n  const x2 = island2.x, y2 = island2.y;\r\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\r\n"]
