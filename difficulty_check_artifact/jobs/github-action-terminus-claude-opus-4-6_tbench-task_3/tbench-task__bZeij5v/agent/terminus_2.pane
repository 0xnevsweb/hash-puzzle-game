[?2004l[?2004h> // Canonical bridge key: smaller endpoint first (by x, then y)
[?2004l[?2004h> export function bridgeKey(island1, island2) {
[?2004l[?2004h>   const x1 = island1.x, y1 = island1.y;
[?2004l[?2004h>   const x2 = island2.x, y2 = island2.y;
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col, no island between them)
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     // Vertical
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.x === from.x && isl.y > minY && isl.y < maxY) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   } else {
[?2004l[?2004h>     // Horizontal
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.y === from.y && isl.x > minX && isl.x < maxX) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if a bridge between from and to would cross any existing bridge
[?2004l[?2004h> export function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   // Get all existing bridge segments
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const bx1 = parts[0], by1 = parts[1], bx2 = parts[2], by2 = parts[3];
[?2004l[?2004h>     
[?2004l[?2004h>     // Check crossing: one horizontal one vertical
[?2004l[?2004h>     if (from.x === to.x) {
[?2004l[?2004h>       // New bridge is vertical
[?2004l[?2004h>       if (by1 === by2) {
[?2004l[?2004h>         // Existing bridge is horizontal
[?2004l[?2004h>         const crossX = from.x;
[?2004l[?2004h>         const crossY = by1;
[?2004l[?2004h>         const minY = Math.min(from.y, to.y);
[?2004l[?2004h>         const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>         const minX = Math.min(bx1, bx2);
[?2004l[?2004h>         const maxX = Math.max(bx1, bx2);
[?2004l[?2004h>         if (crossX > minX && crossX < maxX && crossY > minY && crossY < maxY) {
[?2004l[?2004h>           return true;
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // New bridge is horizontal
[?2004l[?2004h>       if (bx1 === bx2) {
[?2004l[?2004h>         // Existing bridge is vertical
[?2004l[?2004h>         const crossX = bx1;
[?2004l[?2004h>         const crossY = from.y;
[?2004l[?2004h>         const minX = Math.min(from.x, to.x);
[?2004l[?2004h>         const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>         const minY = Math.min(by1, by2);
[?2004l[?2004h>         const maxY = Math.max(by1, by2);
[?2004l[?2004h>         if (crossY > minY && crossY < maxY && crossX > minX && crossX < maxX) {
[?2004l[?2004h>           return true;
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts per island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     counts.set(isl.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const x1 = parts[0], y1 = parts[1], x2 = parts[2], y2 = parts[3];
[?2004l[?2004h>     
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if ((isl.x === x1 && isl.y === y1) || (isl.x === x2 && isl.y === y2)) {
[?2004l[?2004h>         counts.set(isl.id, (counts.get(isl.id) || 0) + count);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges between from and to is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = bridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check max 2
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing (only if adding)
[?2004l[?2004h>   if (delta > 0 && current === 0) {
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check connectivity: all islands with at least one bridge are connected
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency from bridges
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     adj.set(isl.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const x1 = parts[0], y1 = parts[1], x2 = parts[2], y2 = parts[3];
[?2004l[?2004h>     
[?2004l[?2004h>     let id1 = null, id2 = null;
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.x === x1 && isl.y === y1) id1 = isl.id;
[?2004l[?2004h>       if (isl.x === x2 && isl.y === y2) id2 = isl.id;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (id1 !== null && id2 !== null) {
[?2004l[?2004h>       adj.get(id1).push(id2);
[?2004l[?2004h>       adj.get(id2).push(id1);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h>   
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const curr = queue.shift();
[?2004l[?2004h>     for (const neighbor of (adj.get(curr) || [])) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if puzzle is solved
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all islands have exact count
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) || 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no bridges cross
[?2004l[?2004h>   const bridgeList = [];
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     bridgeList.push({ x1: parts[0], y1: parts[1], x2: parts[2], y2: parts[3] });
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (let i = 0; i < bridgeList.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < bridgeList.length; j++) {
[?2004l[?2004h>       const a = bridgeList[i];
[?2004l[?2004h>       const b = bridgeList[j];
[?2004l[?2004h>       // One horizontal, one vertical
[?2004l[?2004h>       if (a.x1 === a.x2 && b.y1 === b.y2) {
[?2004l[?2004h>         // a vertical, b horizontal
[?2004l[?2004h>         const crossX = a.x1;
[?2004l[?2004h>         const crossY = b.y1;
[?2004l[?2004h>         if (crossX > Math.min(b.x1, b.x2) && crossX < Math.max(b.x1, b.x2) &&
[?2004l[?2004h>             crossY > Math.min(a.y1, a.y2) && crossY < Math.max(a.y1, a.y2)) {
[?2004l[?2004h>           return false;
[?2004l[?2004h>         }
[?2004l[?2004h>       } else if (a.y1 === a.y2 && b.x1 === b.x2) {
[?2004l[?2004h>         // a horizontal, b vertical
[?2004l[?2004h>         const crossX = b.x1;
[?2004l[?2004h>         const crossY = a.y1;
[?2004l[?2004h>         if (crossX > Math.min(a.x1, a.x2) && crossX < Math.max(a.x1, a.x2) &&
[?2004l[?2004h>             crossY > Math.min(b.y1, b.y2) && crossY < Math.max(b.y1, b.y2)) {
[?2004l[?2004h>           return false;
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> LOGIC
[?2004l[?2004hroot@9b533a5833b1:/app# cat > /app/src/App.jsx << 'APPEOF'
[?2004l[?2004h> import React, { useState, useCallback, useEffect, useRef } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles.js';
[?2004l[?2004h> import {
[?2004l[?2004h>   bridgeKey,
[?2004l[?2004h>   canAddBridge,
[?2004l[?2004h>   computeCurrentCounts,
[?2004l[?2004h>   isVictory
[?2004l[?2004h> } from './utils/hashiLogic.js';
[?2004l[?2004h> 
[?2004l[?2004h> const GRID = 40;
[?2004l[?2004h> const ISLAND_RADIUS = 16;
[?2004l[?2004h> 
[?2004l[?2004h> function App() {
[?2004l[?2004h>   const [puzzleIndex, setPuzzleIndex] = useState(0);
[?2004l[?2004h>   const [bridges, setBridges] = useState(new Map());
