ax(from.x, to.x);\n      const newY = from.y;\n      const existX = bx1; // vertical bridge has same x\n      const existMinY = Math.min(by1, by2);\n      const existMaxY = Math.max(by1, by2);\n      \n      if (existX > newMinX && existX < newMaxX && newY > existMinY && newY < existMaxY) {\n        return true;\n      }\n    } else {\n      // new bridge is vertical, existing is horizontal\n      const newMinY = Math.min(from.y, to.y);\n      const newMaxY = Math.max(from.y, to.y);\n      const newX = from.x;\n      const existY = by1; // horizontal bridge has same y\n      const existMinX = Math.min(bx1, bx2);\n      const existMaxX = Math.max(bx1, bx2);\n      \n      if (newX > existMinX && newX < existMaxX && existY > newMinY && existY < newMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const [x1, y1, x2, y2] = parts;\n    \n    // Find the islands at these coordinates\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    \n    if (island1) counts.set(island1.id, (counts.get(island1.id) || 0) + count);\n    if (island2) counts.set(island2.id, (counts.get(island2.id) || 0) + count);\n  }\n  \n  return counts;\n}\n\n// Check if adding delta bridges would exceed either island\'s value\nexport function wouldExceedValue(islands, bridges, from, to, delta) {\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value) return true;\n  if (toCount + delta > to.value) return true;\n  return false;\n}\n\n// Main validation: can we add delta bridges between from and to?\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n  \n  // Check max 2 bridges\n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  if (current + delta > 2) {\n    return { valid: false, error: "Max 2 bridges per pair" };\n  }\n  \n  // Check island values\n  if (wouldExceedValue(islands, bridges, from, to, delta)) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n  \n  // Check crossing (only if adding new bridge where none existed, or going from 1 to 2)\n  if (current === 0 && wouldCross(islands, bridges, from, to)) {\n    return { valid: false, error: "Bridges would cross" };\n  }\n  \n  return { valid: true, error: null };\n}\n\n// Check connectivity: all islands reachable from each other via bridges\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  \n  // Build adjacency from bridges\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const [x1, y1, x2, y2] = parts;\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    if (island1 && island2) {\n      adj.get(island1.id).push(island2.id);\n      adj.get(island2.id).push(island1.id);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const current = queue.shift();\n    for (const neighbor of adj.get(current)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  // Check all counts match values\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) return false;\n  }\n  \n  // Check connectivity\n  if (!checkConnectivity(islands, bridges)) return false;\n  \n  // Check no crossings among existing bridges\n  const bridgeList = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    bridgeList.push(parts);\n  }\n  \n  for (let i = 0; i < bridgeList.length; i++) {\n    for (let j = i + 1; j < bridgeList.length; j++) {\n      const [ax1, ay1, ax2, ay2] = bridgeList[i];\n      const [bx1, by1, bx2, by2] = bridgeList[j];\n      const aHoriz = ay1 === ay2;\n      const bHoriz = by1 === by2;\n      if (aHoriz === bHoriz) continue; // parallel can\'t cross\n      \n      if (aHoriz) {\n        // a is horizontal, b is vertical\n        const aMinX = Math.min(ax1, ax2), aMaxX = Math.max(ax1, ax2);\n        const aY = ay1;\n        const bX = bx1;\n        const bMinY = Math.min(by1, by2), bMaxY = Math.max(by1, by2);\n        if (bX > aMinX && bX < aMaxX && aY > bMinY && aY < bMaxY) return false;\n      } else {\n        // a is vertical, b is horizontal\n        const aMinY = Math.min(ay1, ay2), aMaxY = Math.max(ay1, ay2);\n        const aX = ax1;\n        const bY = by1;\n        const bMinX = Math.min(bx1, bx2), bMaxX = Math.max(bx1, bx2);\n        if (aX > bMinX && aX < bMaxX && bY > aMinY && bY < aMaxY) return false;\n      }\n    }\n  }\n  \n  return true;\n}\nEOF\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
