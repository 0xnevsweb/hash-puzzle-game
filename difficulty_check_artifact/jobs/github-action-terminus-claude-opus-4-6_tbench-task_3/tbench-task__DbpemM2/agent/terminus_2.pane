[?2004l[?2004h> import React, { useState, useEffect, useCallback, useRef } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles.js';
[?2004l[?2004h> import { getBridgeKey, canAddBridge, isVictory } from './utils/hashiLogic.js';
[?2004l[?2004h> 
[?2004l[?2004h> const GRID_SIZE = 40;
