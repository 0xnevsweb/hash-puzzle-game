[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   // Render islands
[?2004l[?2004h>   const renderIslands = () => {
[?2004l[?2004h>     return islands.map(island => {
[?2004l[?2004h>       const px = island.x * GRID_SIZE;
[?2004l[?2004h>       const py = island.y * GRID_SIZE;
[?2004l[?2004h>       const isSelected = selectedIsland === island.id;
[?2004l[?2004h> 
[?2004l[?2004h>       return (
[?2004l[?2004h>         <g key={`island-${island.id}`} onClick={() => handleIslandClick(island)} style={{ cursor: 'pointer' }}>
[?2004l[?2004h>           <circle
[?2004l[?2004h>             cx={px}
[?2004l[?2004h>             cy={py}
[?2004l[?2004h>             r={ISLAND_RADIUS}
