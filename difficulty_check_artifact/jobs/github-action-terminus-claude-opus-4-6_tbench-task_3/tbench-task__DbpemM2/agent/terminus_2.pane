[?2004l[?2004h> 
[?2004l [?2004h>   // Reset state when puzzle changes
[?2004l[?2004h>   const handlePuzzleChange = (e) => {
[?2004l[?2004h>     const idx = parseInt(e.target.value, 10);
[?2004l[?2004h>     setPuzzleIndex(idx);
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedIsland(null);
[?2004l[?2004h>     setCursorIslandId(0);
[?2004l[?2004h>     setErrorMessage(null);
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const handleReset = () => {
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedIsland(null);
[?2004l[?2004h>     setCursorIslandId(0);
[?2004l[?2004h>     setErrorMessage(null);
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   // Toggle bridge between two islands
[?2004l[?2004h>   const toggleBridge = useCallback((fromIsland, toIsland) => {
[?2004l[?2004h>     const key = getBridgeKey(fromIsland, toIsland);
[?2004l[?2004h>     const current = bridges.get(key) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>     if (current >= 2) {
[?2004l[?2004h>       // Cycle back to 0
[?2004l[?2004h>       const newBridges = new Map(bridges);
[?2004l[?2004h>       newBridges.delete(key);
[?2004l[?2004h>       setBridges(newBridges);
