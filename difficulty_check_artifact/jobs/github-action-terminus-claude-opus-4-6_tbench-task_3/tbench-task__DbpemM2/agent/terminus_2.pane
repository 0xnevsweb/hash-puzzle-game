[?2004l[?2004h>               y1={py1 - offset}
[?2004l[?2004h>               x2={px2}
[?2004l[?2004h>               y2={py2 - offset}
[?2004l[?2004h>               stroke="#0f0"
[?2004l[?2004h>               strokeWidth="2"
[?2004l[?2004h>               style={{ cursor: 'pointer' }}
[?2004l[?2004h>               onClick={(e) => handleBridgeClick(key, e)}
[?2004l[?2004h>               onContextMenu={(e) => handleBridgeRemove(key, e)}
[?2004l[?2004h>             />
[?2004l[?2004h>           );
[?2004l[?2004h>           lines.push(
[?2004l[?2004h>             <line
[?2004l[?2004h>               key={`${key}-b`}
[?2004l[?2004h>               x1={px1}
[?2004l[?2004h>               y1={py1 + offset}
[?2004l[?2004h>               x2={px2}
[?2004l[?2004h>               y2={py2 + offset}
[?2004l[?2004h>               stroke="#0f0"
[?2004l[?2004h>               strokeWidth="2"
[?2004l[?2004h>               style={{ cursor: 'pointer' }}
[?2004l[?2004h>               onClick={(e) => handleBridgeClick(key, e)}
[?2004l[?2004h>               onContextMenu={(e) => handleBridgeRemove(key, e)}
[?2004l[?2004h>             />
[?2004l[?2004h>           );
[?2004l[?2004h>         } else {
[?2004l[?2004h>           lines.push(
[?2004l[?2004h>             <line
[?2004l[?2004h>               key={`${key}-a`}
