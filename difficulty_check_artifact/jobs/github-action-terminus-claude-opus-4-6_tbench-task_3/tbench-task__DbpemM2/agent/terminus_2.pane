[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }, [bridges, islands]);
[?2004l[?2004h> 
[?2004l[?2004h>   // Mouse click on island
[?2004l[?2004h>   const handleIslandClick = useCallback((island) => {
[?2004l[?2004h>     setCursorIslandId(island.id);
[?2004l[?2004h>     if (selectedIsland === null) {
[?2004l[?2004h>       setSelectedIsland(island.id);
[?2004l[?2004h>     } else if (selectedIsland === island.id) {
[?2004l[?2004h>       setSelectedIsland(null);
[?2004l[?2004h>     } else {
[?2004l[?2004h>       const fromIsland = islands.find(i => i.id === selectedIsland);
[?2004l[?2004h>       toggleBridge(fromIsland, island);
[?2004l[?2004h>       setSelectedIsland(null);
[?2004l[?2004h>     }
[?2004l[?2004h>   }, [selectedIsland, islands, toggleBridge]);
[?2004l[?2004h> 
[?2004l[?2004h>   // Right-click / Ctrl+click on bridge line to remove
[?2004l[?2004h>   const handleBridgeRemove = useCallback((key, e) => {
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h>     e.stopPropagation();
[?2004l[?2004h>     const newBridges = new Map(bridges);
[?2004l[?2004h>     newBridges.delete(key);
[?2004l[?2004h>     setBridges(newBridges);
[?2004l[?2004h>     setErrorMessage(null);
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>     if (isVictory(islands, newBridges)) {
[?2004l[?2004h>       setVictory(true);
[?2004l[?2004h>     }
[?2004l[?2004h>   }, [bridges, islands]);
[?2004l[?2004h> 
[?2004l[?2004h>   const handleBridgeClick = useCallback((key, e) => {
[?2004l[?2004h>     if (e.ctrlKey) {
[?2004l[?2004h>       e.preventDefault();
[?2004l[?2004h>       e.stopPropagation();
[?2004l[?2004h>       const newBridges = new Map(bridges);
[?2004l[?2004h>       newBridges.delete(key);
[?2004l[?2004h>       setBridges(newBridges);
[?2004l[?2004h>       setErrorMessage(null);
[?2004l[?2004h>       setVictory(false);
[?2004l[?2004h>       if (isVictory(islands, newBridges)) {
[?2004l[?2004h>         setVictory(true);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }, [bridges, islands]);
[?2004l[?2004h> 
[?2004l [?2004h>   // Keyboard navigation
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     const handleKeyDown = (e) => {
[?2004l[?2004h>       const currentIsland = islands.find(i => i.id === cursorIslandId);
[?2004l[?2004h>       if (!currentIsland) return;
[?2004l[?2004h> 
[?2004l[?2004h>       if (e.key === 'Escape') {
[?2004l[?2004h>         setSelectedIsland(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       if (e.key === 'Enter') {
[?2004l[?2004h>         handleIslandClick(currentIsland);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l [?2004h>       let targetIsland = null;
[?2004l[?2004h> 
[?2004le[?2004h>       if (e.key === 'ArrowRight') {
[?2004l[?2004h>         // Find nearest island to the right
[?2004l[?2004h>         const candidates = islands.filter(i => i.x > currentIsland.x);
[?2004l[?2004h>         if (candidates.length > 0) {
[?2004l[?2004h>           candidates.sort((a, b) => {
[?2004l[?2004h>             const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);
[?2004l[?2004h>             const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);
[?2004l[?2004h>             return distA - distB;
[?2004l[?2004h>           });
[?2004l[?2004h>           targetIsland = candidates[0];
[?2004l[?2004h>         }
[?2004l[?2004h>       } else if (e.key === 'ArrowLeft') {
[?2004l[?2004h>         const candidates = islands.filter(i => i.x < currentIsland.x);
[?2004l[?2004h>         if (candidates.length > 0) {
[?2004l[?2004h>           candidates.sort((a, b) => {
[?2004l[?2004h>             const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);
[?2004l[?2004h>             const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);
[?2004l[?2004h>             return distA - distB;
[?2004l[?2004h>           });
[?2004l[?2004h>           targetIsland = candidates[0];
[?2004l[?2004h>         }
[?2004l[?2004h>       } else if (e.key === 'ArrowDown') {
[?2004l[?2004h>         const candidates = islands.filter(i => i.y > currentIsland.y);
[?2004l[?2004h>         if (candidates.length > 0) {
[?2004l[?2004h>           candidates.sort((a, b) => {
[?2004l[?2004h>             const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);
[?2004l[?2004h>             const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);
[?2004l[?2004h>             return distA - distB;
[?2004l[?2004h>           });
[?2004l[?2004h>           targetIsland = candidates[0];
[?2004l[?2004h>         }
[?2004l[?2004h>       } else if (e.key === 'ArrowUp') {
[?2004l[?2004h>         const candidates = islands.filter(i => i.y < currentIsland.y);
[?2004l[?2004h>         if (candidates.length > 0) {
[?2004l[?2004h>           candidates.sort((a, b) => {
[?2004l[?2004h>             const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);
[?2004l[?2004h>             const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);
[?2004l[?2004h>             return distA - distB;
[?2004l[?2004h>           });
[?2004l[?2004h>           targetIsland = candidates[0];
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l [?2004h>       if (targetIsland) {
[?2004l[?2004h>         setCursorIslandId(targetIsland.id);
[?2004l[?2004h>         e.preventDefault();
[?2004l[?2004h>       }
[?2004l[?2004h>     };
[?2004l[?2004h> 
[?2004l[?2004h>     window.addEventListener('keydown', handleKeyDown);
[?2004l[?2004h>     return () => window.removeEventListener('keydown', handleKeyDown);
[?2004l[?2004h>   }, [cursorIslandId, islands, handleIslandClick]);
[?2004l[?2004h> 
[?2004l[?2004h>   // Render bridges
[?2004l[?2004h>   const renderBridges = () => {
[?2004l[?2004h>     const lines = [];
[?2004l[?2004h>     for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>       if (count === 0) continue;
[?2004l[?2004h>       const parts = key.split(',').map(Number);
[?2004l[?2004h>       const [x1, y1, x2, y2] = parts;
[?2004l[?2004h>       const px1 = x1 * GRID_SIZE;
[?2004l[?2004h>       const py1 = y1 * GRID_SIZE;
[?2004l[?2004h>       const px2 = x2 * GRID_SIZE;
[?2004l[?2004h>       const py2 = y2 * GRID_SIZE;
[?2004l[?2004h> 
[?2004lz[?2004h>       if (count === 1) {
[?2004l[?2004h>         lines.push(
[?2004l[?2004h>           <line
[?2004l[?2004h>             key={key}
[?2004l[?2004h>             x1={px1}
[?2004l[?2004h>             y1={py1}
[?2004l[?2004h>             x2={px2}
[?2004l[?2004h>             y2={py2}
[?2004l[?2004h>             stroke="#0f0"
[?2004l[?2004h>             strokeWidth="2"
[?2004l[?2004h>             style={{ cursor: 'pointer' }}
[?2004l[?2004h>             onClick={(e) => handleBridgeClick(key, e)}
