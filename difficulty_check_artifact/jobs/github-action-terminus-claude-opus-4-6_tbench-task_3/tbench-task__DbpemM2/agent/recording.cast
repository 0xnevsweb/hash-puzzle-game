[140.27091, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Bridge key: canonical \"x1,y1,x2,y2\" where endpoint with smaller (x, then y) sorts first\nexport function getBridgeKey(island1, island2) {\n  const a = { x: island1.x, y: island1.y };\n  const b = { x: island2.x, y: island2.y };\n  if (a.x < b.x || (a.x === b.x && a.y < b.y)) {\n    return `${a.x},${a.y},${b.x},${b.y}`;\n  }\n  return `${b.x},${b.y},${a.x},${a.y}`;\n}\n\n// Check if two islands are adjacent (same row/col, no island between them)\nfunction areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n\n  if (from.x === to.x) {\n    // Vertical\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) return false;\n    }\n  } else {\n    // Horizontal\n    const minX = Math.min(from.x, to.x);"]
