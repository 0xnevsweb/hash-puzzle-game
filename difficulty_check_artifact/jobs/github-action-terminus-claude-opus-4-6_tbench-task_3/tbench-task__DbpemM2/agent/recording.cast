[140.876381, "i", "cat > /app/src/App.jsx << 'JSXEOF'\nimport React, { useState, useEffect, useCallback, useRef } from 'react';\nimport { puzzles } from './data/puzzles.js';\nimport { getBridgeKey, canAddBridge, isVictory } from './utils/hashiLogic.js';\n\nconst GRID_SIZE = 40;\nconst SVG_WIDTH = 800;\nconst SVG_HEIGHT = 600;\nconst ISLAND_RADIUS = 16;\nconst BRIDGE_OFFSET = 4;\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [cursorIslandId, setCursorIslandId] = useState(0);\n  const [errorMessage, setErrorMessage] = useState(null);\n  const [victory, setVictory] = useState(false);\n\n  const puzzle = puzzles[puzzleIndex];\n  const islands = puzzle.islands;\n\n  // Reset state when puzzle changes\n  const handlePuzzleChange = (e) => {\n    const idx = parseInt(e.target.value, 10);\n    setPuzzleIndex(idx);\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMess"]
[140.876536, "i", "age(null);\n    setVictory(false);\n  };\n\n  const handleReset = () => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n  };\n\n  // Toggle bridge between two islands\n  const toggleBridge = useCallback((fromIsland, toIsland) => {\n    const key = getBridgeKey(fromIsland, toIsland);\n    const current = bridges.get(key) || 0;\n\n    if (current >= 2) {\n      // Cycle back to 0\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setErrorMessage(null);\n      setVictory(false);\n      // Check victory after removal\n      if (isVictory(islands, newBridges)) {\n        setVictory(true);\n      }\n      return true;\n    }\n\n    // Try to add one bridge\n    const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n    if (!result.valid) {\n      setErrorMessage(result.error);\n      setSelectedIsland(null);\n      return false;\n    }\n\n    const newBridges = new Map(bridges);\n    n"]
[140.876564, "o", "cat > /app/src/App.jsx << 'JSXEOF'"]
[140.876575, "i", "ewBridges.set(key, current + 1);\n    setBridges(newBridges);\n    setErrorMessage(null);\n    setVictory(false);\n    if (isVictory(islands, newBridges)) {\n      setVictory(true);\n    }\n    return true;\n  }, [bridges, islands]);\n\n  // Mouse click on island\n  const handleIslandClick = useCallback((island) => {\n    setCursorIslandId(island.id);\n    if (selectedIsland === null) {\n      setSelectedIsland(island.id);\n    } else if (selectedIsland === island.id) {\n      setSelectedIsland(null);\n    } else {\n      const fromIsland = islands.find(i => i.id === selectedIsland);\n      toggleBridge(fromIsland, island);\n      setSelectedIsland(null);\n    }\n  }, [selectedIsland, islands, toggleBridge]);\n\n  // Right-click / Ctrl+click on bridge line to remove\n  const handleBridgeRemove = useCallback((key, e) => {\n    e.preventDefault();\n    e.stopPropagation();\n    const newBridges = new Map(bridges);\n    newBridges.delete(key);\n    setBridges(newBridges);\n    setErrorMessage(null);\n    setVictory(false);\n    if (isVictory(is"]
[140.876583, "o", "\r\n\u001b[?2004l\r"]
[140.876593, "i", "lands, newBridges)) {\n      setVictory(true);\n    }\n  }, [bridges, islands]);\n\n  const handleBridgeClick = useCallback((key, e) => {\n    if (e.ctrlKey) {\n      e.preventDefault();\n      e.stopPropagation();\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setErrorMessage(null);\n      setVictory(false);\n      if (isVictory(islands, newBridges)) {\n        setVictory(true);\n      }\n    }\n  }, [bridges, islands]);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      const currentIsland = islands.find(i => i.id === cursorIslandId);\n      if (!currentIsland) return;\n\n      if (e.key === 'Escape') {\n        setSelectedIsland(null);\n        return;\n      }\n\n      if (e.key === 'Enter') {\n        handleIslandClick(currentIsland);\n        return;\n      }\n\n      let targetIsland = null;\n\n      if (e.key === 'ArrowRight') {\n        // Find nearest island to the right\n        const candidates = islands.filter(i => i.x > currentIs"]
[140.876602, "i", "land.x);\n        if (candidates.length > 0) {\n          candidates.sort((a, b) => {\n            const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);\n            const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);\n            return distA - distB;\n          });\n          targetIsland = candidates[0];\n        }\n      } else if (e.key === 'ArrowLeft') {\n        const candidates = islands.filter(i => i.x < currentIsland.x);\n        if (candidates.length > 0) {\n          candidates.sort((a, b) => {\n            const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);\n            const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);\n            return distA - distB;\n          });\n          targetIsland = candidates[0];\n        }\n      } else if (e.key === 'ArrowDown') {\n        const candidates = islands.filter(i => i.y > currentIsland.y);\n        if (candidates.length > 0) {\n          candidates.sort((a, b) ="]
[140.876618, "i", "> {\n            const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);\n            const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);\n            return distA - distB;\n          });\n          targetIsland = candidates[0];\n        }\n      } else if (e.key === 'ArrowUp') {\n        const candidates = islands.filter(i => i.y < currentIsland.y);\n        if (candidates.length > 0) {\n          candidates.sort((a, b) => {\n            const distA = Math.abs(a.x - currentIsland.x) + Math.abs(a.y - currentIsland.y);\n            const distB = Math.abs(b.x - currentIsland.x) + Math.abs(b.y - currentIsland.y);\n            return distA - distB;\n          });\n          targetIsland = candidates[0];\n        }\n      }\n\n      if (targetIsland) {\n        setCursorIslandId(targetIsland.id);\n        e.preventDefault();\n      }\n    };\n\n    window.addEventListener('keydown', handleKeyDown);\n    return () => window.removeEventListener('keydown', handleKeyDown);\n  }, [cursorIslan"]
[140.876632, "i", "dId, islands, handleIslandClick]);\n\n  // Render bridges\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges.entries()) {\n      if (count === 0) continue;\n      const parts = key.split(',').map(Number);\n      const [x1, y1, x2, y2] = parts;\n      const px1 = x1 * GRID_SIZE;\n      const py1 = y1 * GRID_SIZE;\n      const px2 = x2 * GRID_SIZE;\n      const py2 = y2 * GRID_SIZE;\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={px1}\n            y1={py1}\n            x2={px2}\n            y2={py2}\n            stroke=\"#0f0\"\n            strokeWidth=\"2\"\n            style={{ cursor: 'pointer' }}\n            onClick={(e) => handleBridgeClick(key, e)}\n            onContextMenu={(e) => handleBridgeRemove(key, e)}\n          />\n        );\n      } else if (count === 2) {\n        const isHorizontal = y1 === y2;\n        const offset = BRIDGE_OFFSET;\n        if (isHorizontal) {\n          lines.push(\n            <line\n              key={`${ke"]
[140.876646, "i", "y}-a`}\n              x1={px1}\n              y1={py1 - offset}\n              x2={px2}\n              y2={py2 - offset}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n              style={{ cursor: 'pointer' }}\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeRemove(key, e)}\n            />\n          );\n          lines.push(\n            <line\n              key={`${key}-b`}\n              x1={px1}\n              y1={py1 + offset}\n              x2={px2}\n              y2={py2 + offset}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n              style={{ cursor: 'pointer' }}\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeRemove(key, e)}\n            />\n          );\n        } else {\n          lines.push(\n            <line\n              key={`${key}-a`}\n              x1={px1 - offset}\n              y1={py1}\n              x2={px2 - offset}\n              y2={py2}\n              stroke=\"#0f0"]
[140.876669, "i", "\"\n              strokeWidth=\"2\"\n              style={{ cursor: 'pointer' }}\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeRemove(key, e)}\n            />\n          );\n          lines.push(\n            <line\n              key={`${key}-b`}\n              x1={px1 + offset}\n              y1={py1}\n              x2={px2 + offset}\n              y2={py2}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n              style={{ cursor: 'pointer' }}\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeRemove(key, e)}\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map(island => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland === island.id;\n\n      return (\n        <g key={`island-${island.id}`} onClick={() => handleIslandClick(island)} st"]
[140.876688, "i", "yle={{ cursor: 'pointer' }}>\n          <circle\n            cx={px}\n            cy={py}\n            r={ISLAND_RADIUS}\n            fill=\"#000\"\n            stroke={isSelected ? \"#ff0\" : \"#0f0\"}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px}\n            y={py}\n            textAnchor=\"middle\"\n            dominantBaseline=\"central\"\n            fill=\"#0f0\"\n            fontSize=\"14\"\n            fontFamily=\"'Courier New', monospace\"\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render cursor (not a circle!)\n  const renderCursor = () => {\n    const island = islands.find(i => i.id === cursorIslandId);\n    if (!island) return null;\n    const px = island.x * GRID_SIZE;\n    const py = island.y * GRID_SIZE;\n    const size = ISLAND_RADIUS + 6;\n\n    return (\n      <rect\n        x={px - size}\n        y={py - size}\n        width={size * 2}\n        height={size * 2}\n        fill=\"none\"\n        stroke=\"#0ff\"\n        strokeWidth=\"2\"\n "]
[140.876704, "i", "       strokeDasharray=\"4 2\"\n        pointerEvents=\"none\"\n      />\n    );\n  };\n\n  return (\n    <div className=\"app-container\">\n      <svg width={SVG_WIDTH} height={SVG_HEIGHT} style={{ backgroundColor: '#000' }}>\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n      <div className=\"controls\">\n        <select value={puzzleIndex} onChange={handlePuzzleChange}>\n          {puzzles.map((p, idx) => (\n            <option key={p.id} value={idx}>{p.name}</option>\n          ))}\n        </select>\n        <button onClick={handleReset}>Reset</button>\n      </div>\n      {errorMessage && <div className=\"error-message\">{errorMessage}</div>}\n      {victory && <div className=\"victory-banner\">SOLVED!</div>}\n    </div>\n  );\n}\n\nexport default App;\nJSXEOF\n"]
