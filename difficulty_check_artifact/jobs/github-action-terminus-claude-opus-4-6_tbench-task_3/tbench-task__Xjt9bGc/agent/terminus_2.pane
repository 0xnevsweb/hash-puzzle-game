[?2004l[?2004h>         {victory && <span className="victory-banner">SOLVED!</span>}
[?2004l[?2004h>       </div>
[?2004l[?2004h>     </div>
[?2004l[?2004h>   );
[?2004l[?2004h> }
[?2004l[?2004h> 
