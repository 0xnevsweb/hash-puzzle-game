[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     return lines;
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const renderIslands = () => {
[?2004l[?2004h>     return islands.map(island => {
[?2004l[?2004h>       const px = island.x * GRID;
[?2004l[?2004h>       const py = island.y * GRID;
[?2004l[?2004h>       const isSelected = selectedIsland === island.id;
[?2004l[?2004h>       return (
[?2004l[?2004h>         <g key={island.id}
[?2004l[?2004h>           onClick={(e) => handleIslandClick(island, e)}
[?2004l[?2004h>           onContextMenu={(e) => handleIslandRightClick(island, e)}
[?2004l[?2004h>           style={{ cursor: 'pointer' }}
[?2004l[?2004h>         >
[?2004l[?2004h>           <circle
[?2004l[?2004h>             cx={px} cy={py} r={ISLAND_RADIUS}
[?2004l[?2004h>             fill="#000"
[?2004l[?2004h>             stroke={isSelected ? '#ff0' : '#0f0'}
[?2004l[?2004h>             strokeWidth={isSelected ? 3 : 2}
[?2004l[?2004h>           />
[?2004l[?2004h>           <text
[?2004l[?2004h>             x={px} y={py}
[?2004l[?2004h>             textAnchor="middle" dominantBaseline="central"
[?2004l[?2004h>             fill="#0f0" fontSize="14"
[?2004l[?2004h>             fontFamily="'Courier New', monospace"
[?2004l[?2004h>           >
[?2004l[?2004h>             {island.value}
[?2004l[?2004h>           </text>
[?2004l[?2004h>         </g>
[?2004l[?2004h>       );
[?2004l[?2004h>     });
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const renderCursor = () => {
[?2004l[?2004h>     const island = islands.find(i => i.id === cursorIslandId);
[?2004l[?2004h>     if (!island) return null;
[?2004l[?2004h>     const px = island.x * GRID;
[?2004l[?2004h>     const py = island.y * GRID;
[?2004l[?2004h>     const size = ISLAND_RADIUS + 6;
[?2004l[?2004h>     return (
[?2004l[?2004h>       <rect
[?2004l[?2004h>         x={px - size} y={py - size}
[?2004l[?2004h>         width={size * 2} height={size * 2}
[?2004l[?2004h>         fill="none" stroke="#0ff" strokeWidth="2"
[?2004l[?2004h>         strokeDasharray="4,2" pointerEvents="none"
[?2004l[?2004h>       />
[?2004l[?2004h>     );
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   return (
[?2004l[?2004h>     <div className="app-container" onContextMenu={handleContextMenu}>
[?2004l[?2004h>       <svg width="800" height="600" style={{ display: 'block', background: '#000' }}>
[?2004l[?2004h>         {renderBridges()}
[?2004l[?2004h>         {renderIslands()}
[?2004l[?2004h>         {renderCursor()}
[?2004l[?2004h>       </svg>
[?2004l[?2004h>       <div className="controls">
