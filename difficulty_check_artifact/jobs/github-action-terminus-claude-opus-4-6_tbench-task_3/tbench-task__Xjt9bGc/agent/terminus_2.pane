[?2004l[?2004h>             const toIsland = islands.find(i => i.id === cursorIslandId);
[?2004l[?2004h>             if (fromIsland && toIsland) {
[?2004l[?2004h>               toggleBridge(fromIsland, toIsland);
[?2004l[?2004h>             }
[?2004l[?2004h>           }
[?2004l[?2004h>           setKbSelecting(false);
[?2004l[?2004h>           setKbFrom(null);
[?2004l[?2004h>           setSelectedIsland(null);
[?2004l[?2004h>           setCursorIslandId(0);
[?2004l[?2004h>         }
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
[?2004l[?2004h>         e.preventDefault();
[?2004l[?2004h>         const neighbor = findNeighborInDirection(cursorIslandId, e.key);
[?2004l[?2004h>         if (neighbor) {
[?2004l[?2004h>           setCursorIslandId(neighbor.id);
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h>     };
[?2004l[?2004h> 
[?2004l[?2004h>     window.addEventListener('keydown', handleKeyDown);
[?2004l[?2004h>     return () => window.removeEventListener('keydown', handleKeyDown);
[?2004l[?2004h>   }, [islands, cursorIslandId, kbSelecting, kbFrom, toggleBridge]);
[?2004l[?2004h> 
[?2004l[?2004h>   const handleContextMenu = useCallback((e) => {
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h>   }, []);
[?2004l[?2004h> 
[?2004l[?2004h>   const renderBridges = () => {
[?2004l[?2004h>     const lines = [];
[?2004l[?2004h>     for (const [key, count] of bridges) {
[?2004l[?2004h>       if (count === 0) continue;
[?2004l[?2004h>       const parts = key.split(',').map(Number);
[?2004l[?2004h>       const [x1, y1, x2, y2] = parts;
[?2004l[?2004h>       const px1 = x1 * GRID;
[?2004l[?2004h>       const py1 = y1 * GRID;
[?2004l[?2004h>       const px2 = x2 * GRID;
[?2004l[?2004h>       const py2 = y2 * GRID;
[?2004l[?2004h> 
[?2004l[?2004h>       if (count === 1) {
[?2004l[?2004h>         lines.push(
[?2004l[?2004h>           <line
[?2004l[?2004h>             key={key}
[?2004l[?2004h>             x1={px1} y1={py1} x2={px2} y2={py2}
[?2004l[?2004h>             stroke="#0f0" strokeWidth="2"
[?2004l[?2004h>             onClick={(e) => handleBridgeClick(key, e)}
[?2004l[?2004h>             onContextMenu={(e) => handleBridgeRightClick(key, e)}
[?2004l[?2004h>             style={{ cursor: 'pointer' }}
[?2004l[?2004h>           />
[?2004l[?2004h>         );
[?2004l[?2004h>       } else {
[?2004l[?2004h>         const isHoriz = y1 === y2;
[?2004l[?2004h>         const off = 4;
[?2004l[?2004h>         if (isHoriz) {
[?2004l[?2004h>           lines.push(
[?2004l[?2004h>             <line key={key + '_a'}
[?2004l[?2004h>               x1={px1} y1={py1 - off} x2={px2} y2={py2 - off}
[?2004l[?2004h>               stroke="#0f0" strokeWidth="2"
[?2004l[?2004h>               onClick={(e) => handleBridgeClick(key, e)}
[?2004l[?2004h>               onContextMenu={(e) => handleBridgeRightClick(key, e)}
[?2004l[?2004h>               style={{ cursor: 'pointer' }}
[?2004l[?2004h>             />
[?2004l[?2004h>           );
[?2004l[?2004h>           lines.push(
[?2004l[?2004h>             <line key={key + '_b'}
[?2004l[?2004h>               x1={px1} y1={py1 + off} x2={px2} y2={py2 + off}
[?2004l[?2004h>               stroke="#0f0" strokeWidth="2"
[?2004l[?2004h>               onClick={(e) => handleBridgeClick(key, e)}
[?2004l[?2004h>               onContextMenu={(e) => handleBridgeRightClick(key, e)}
[?2004l[?2004h>               style={{ cursor: 'pointer' }}
[?2004l[?2004h>             />
