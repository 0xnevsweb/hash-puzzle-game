[?2004l[?2004h>               return da - db;
[?2004l[?2004h>             });
[?2004l[?2004h>           break;
[?2004l[?2004h>         case 'ArrowDown':
[?2004l[?2004h>           candidates = islands.filter(i => i.y > current.y)
