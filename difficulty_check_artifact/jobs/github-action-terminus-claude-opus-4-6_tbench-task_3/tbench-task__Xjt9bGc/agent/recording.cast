[243.618388, "i", "     const fromIsland = islands.find(i => i.id === selectedIsland);\n      toggleBridge(fromIsland, island, true);\n      setSelectedIsland(null);\n      setCursorIslandId(0);\n    }\n  }, [selectedIsland, islands, toggleBridge]);\n\n  // Keyboard handling\n  useEffect(() => {\n    const findNeighborInDirection = (currentId, direction) => {\n      const current = islands.find(i => i.id === currentId);\n      if (!current) return null;\n\n      let candidates = [];\n      switch (direction) {\n        case 'ArrowRight':\n          candidates = islands.filter(i => i.x > current.x)\n            .sort((a, b) => {\n              const da = Math.abs(a.y - current.y) * 1000 + (a.x - current.x);\n              const db = Math.abs(b.y - current.y) * 1000 + (b.x - current.x);\n              return da - db;\n            });\n          break;\n        case 'ArrowLeft':\n          candidates = islands.filter(i => i.x < current.x)\n            .sort((a, b) => {\n              const da = Math.abs(a.y - current.y) * 1000 + (current.x - a.x);\n        "]
