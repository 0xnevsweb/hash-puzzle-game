[90.140388, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Canonical key for a bridge between two islands (grid coords)\nexport function bridgeKey(island1, island2) {\n  const x1 = island1.x, y1 = island1.y;\n  const x2 = island2.x, y2 = island2.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are adjacent (same row or column, no island in between)\nexport function areAdjacent(islands, from, to) {\n  if (from.id === to.id) return false;\n  if (from.x !== to.x && from.y !== to.y) return false;\n  \n  // Check no island in between\n  if (from.x === to.x) {\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) return false;\n    }\n  } else {\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for (const i"]
[90.140588, "i", "sland of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nexport function wouldCross(islands, bridges, from, to) {\n  // The new bridge segment\n  const isHorizontal = from.y === to.y;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(',').map(Number);\n    const [bx1, by1, bx2, by2] = parts;\n    const bridgeIsHorizontal = by1 === by2;\n    \n    // Parallel bridges can't cross\n    if (isHorizontal === bridgeIsHorizontal) continue;\n    \n    // Perpendicular: check intersection\n    if (isHorizontal) {\n      // new bridge is horizontal, existing is vertical\n      const newMinX = Math.min(from.x, to.x);\n      const newMaxX = Math.max(from.x, to.x);\n      const newY = from.y;\n      const existX = bx1; // vertical bridge has same x\n      const existMinY"]
[90.140612, "o", "cat > /app/src/utils/hashiLogic.js << 'EOF'\r\n\u001b[?2004l\r"]
