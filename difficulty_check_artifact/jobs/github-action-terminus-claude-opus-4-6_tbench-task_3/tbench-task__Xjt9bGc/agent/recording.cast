[90.166444, "o", "  const fromCount = counts.get(from.id) || 0;\r\n\u001b[?2004l\r"]
[90.166519, "o", "\u001b[?2004h> "]
[90.166611, "o", "  const toCount = counts.get(to.id) || 0;\r\n\u001b[?2004l\r"]
[90.166697, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[90.166757, "o", "\u001b[?2004h> "]
[90.166873, "o", "  if (fromCount + delta > from.value) return true;\r\n\u001b[?2004l\r"]
[90.166928, "o", "\u001b[?2004h"]
[90.166987, "o", "> "]
[90.167083, "o", "  if (toCount + delta > to.value) return true;\r\n\u001b[?2004l\r"]
[90.167155, "o", "\u001b[?2004h> "]
[90.167199, "o", "  return false;\r\n\u001b[?2004l\r"]
[90.167242, "o", "\u001b[?2004h> }\r\n"]
[90.167281, "o", "\u001b[?2004l\r\u001b[?2004h"]
[90.167319, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[90.167362, "o", "> "]
[90.16755, "o", "// Main validation: can we add delta bridges between from and to?\r\n\u001b[?2004l\r"]
[90.167593, "o", "\u001b[?2004h> "]
[90.167811, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[90.16785, "o", "\u001b[?2004h> "]
[90.167934, "o", "  // Check adjacency\r\n\u001b[?2004l\r"]
[90.167967, "o", "\u001b[?2004h"]
[90.168013, "o", "> "]
[90.168133, "o", "  if (!areAdjacent(islands, from, to)) {\r\n\u001b[?2004l\r"]
[90.168182, "o", "\u001b[?2004h> "]
[90.1684, "o", "    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\r\n\u001b[?2004l\r"]
[90.168451, "o", "\u001b[?2004h> "]
[90.168465, "o", "  }\r\n\u001b[?2004l\r"]
[90.168497, "o", "\u001b[?2004h"]
[90.168519, "o", ">   \r\n"]
[90.168535, "o", "\u001b[?2004l\r"]
[90.168568, "o", "\u001b[?2004h"]
[90.168669, "o", "> "]
[90.168712, "o", "  // Check max 2 bridges\r\n\u001b[?2004l\r"]
[90.168756, "o", "\u001b[?2004h> "]
[90.168849, "o", "  const key = bridgeKey(from, to);\r\n\u001b[?2004l\r"]
[90.168887, "o", "\u001b[?2004h"]
[90.168902, "o", "> "]
[90.169028, "o", "  const current = bridges.get(key) || 0;\r\n\u001b[?2004l\r"]
[90.16907, "o", "\u001b[?2004h> "]
[90.16917, "o", "  if (current + delta > 2) {\r\n\u001b[?2004l\r"]
[90.169212, "o", "\u001b[?2004h"]
[90.169228, "o", "> "]
[90.169409, "o", "    return { valid: false, error: \"Max 2 bridges per pair\" };\r\n\u001b[?2004l\r"]
[90.16945, "o", "\u001b[?2004h"]
[90.169467, "o", ">   }\r\n\u001b[?2004l\r"]
[90.169525, "o", "\u001b[?2004h> "]
[90.169542, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[90.169592, "o", "> "]
[90.169664, "o", "  // Check island values\r\n\u001b[?2004l\r"]
[90.169736, "o", "\u001b[?2004h> "]
[90.169912, "o", "  if (wouldExceedValue(islands, bridges, from, to, delta)) {\r\n\u001b[?2004l\r"]
[90.169953, "o", "\u001b[?2004h> "]
[90.170172, "o", "    return { valid: false, error: \"Island would exceed its number\" };\r\n\u001b[?2004l\r"]
[90.170215, "o", "\u001b[?2004h> "]
[90.170267, "o", "  }"]
[90.170315, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>   \r\n"]
[90.170349, "o", "\u001b[?2004l\r"]
[90.170366, "o", "\u001b[?2004h> "]
[90.170616, "o", "  // Check crossing (only if adding new bridge where none existed, or going from 1 to 2)\r\n\u001b[?2004l\r"]
[90.17072, "o", "\u001b[?2004h> "]
[90.170874, "o", "  if (current === 0 && wouldCross(islands, bridges, from, to)) {\r\n\u001b[?2004l\r"]
[90.170937, "o", "\u001b[?2004h> "]
[90.171103, "o", "    return { valid: false, error: \"Bridges would cross\" };\r\n\u001b[?2004l\r"]
[90.17122, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[90.171325, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.171411, "o", "  return { valid: true, error: null };\r\n\u001b[?2004l\r"]
[90.171468, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[90.171489, "o", "\u001b[?2004h"]
[90.17159, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.171793, "o", "// Check connectivity: all islands reachable from each other via bridges\r\n\u001b[?2004l\r"]
[90.171816, "o", "\u001b[?2004h"]
[90.17183, "o", "> "]
[90.172017, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[90.172083, "o", "\u001b[?2004h> "]
[90.172196, "o", "  if (islands.length === 0) return true;\r\n\u001b[?2004l\r"]
[90.172262, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[90.172349, "o", "\u001b[?2004h> "]
[90.172423, "o", "  // Build adjacency from bridges\r\n\u001b[?2004l\r"]
[90.17251, "o", "\u001b[?2004h> "]
[90.172602, "o", "  const adj = new Map();\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.172657, "o", "> "]
[90.172774, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.172862, "o", "    adj.set(island.id, []);\r\n\u001b[?2004l\r"]
[90.172919, "o", "\u001b[?2004h"]
[90.172938, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.173, "o", "> "]
[90.173018, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.17316, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[90.173183, "o", "\u001b[?2004h"]
[90.173194, "o", "> "]
[90.173299, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[90.173345, "o", "\u001b[?2004h> "]
[90.173485, "o", "    const parts = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[90.173563, "o", "\u001b[?2004h> "]
[90.173656, "o", "    const [x1, y1, x2, y2] = parts;\r\n\u001b[?2004l\r"]
[90.173692, "o", "\u001b[?2004h"]
[90.173758, "o", "> "]
[90.173911, "o", "    const island1 = islands.find(i => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[90.17396, "o", "\u001b[?2004h> "]
[90.174149, "o", "    const island2 = islands.find(i => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[90.174231, "o", "\u001b[?2004h> "]
[90.174297, "o", "    if (island1 && island2) {\r\n\u001b[?2004l\r"]
[90.174315, "o", "\u001b[?2004h"]
[90.174362, "o", "> "]
[90.174481, "o", "      adj.get(island1.id).push(island2.id);\r\n\u001b[?2004l\r"]
[90.174511, "o", "\u001b[?2004h"]
[90.174524, "o", "> "]
[90.174682, "o", "      adj.get(island2.id).push(island1.id);\r\n\u001b[?2004l\r"]
[90.174712, "o", "\u001b[?2004h"]
[90.174765, "o", "> "]
[90.174824, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[90.17488, "o", "\u001b[?2004h>   \r\n"]
[90.174936, "o", "\u001b[?2004l\r\u001b[?2004h"]
[90.174974, "o", "> "]
[90.175034, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[90.175065, "o", "\u001b[?2004h"]
[90.175108, "o", "> "]
[90.175188, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[90.17522, "o", "\u001b[?2004h"]
[90.175234, "o", "> "]
[90.175353, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[90.1754, "o", "\u001b[?2004h"]
[90.17544, "o", "> "]
[90.175516, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[90.175563, "o", "\u001b[?2004h> "]
[90.175579, "o", "  \r\n\u001b[?2004l\r"]
[90.175591, "o", "\u001b[?2004h"]
[90.175649, "o", "> "]
[90.175726, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[90.175756, "o", "\u001b[?2004h"]
[90.175769, "o", "> "]
[90.175884, "o", "    const current = queue.shift();\r\n\u001b[?2004l\r"]
[90.1759, "o", "\u001b[?2004h"]
[90.17591, "o", "> "]
[90.176054, "o", "    for (const neighbor of adj.get(current)) {\r\n\u001b[?2004l\r"]
[90.176068, "o", "\u001b[?2004h"]
[90.176171, "o", "> "]
[90.17625, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.176313, "o", "> "]
[90.176377, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r"]
[90.176442, "o", "\u001b[?2004h> "]
[90.176521, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[90.176581, "o", "\u001b[?2004h> "]
[90.176643, "o", "      }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.176709, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.17678, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.17683, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[90.176885, "o", "> "]
[90.176984, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r"]
[90.177004, "o", "\u001b[?2004h"]
[90.177027, "o", "> "]
[90.177129, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.17722, "o", "// Check victory condition\r\n\u001b[?2004l\r"]
[90.177236, "o", "\u001b[?2004h"]
[90.177247, "o", "> "]
[90.177386, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[90.177407, "o", "\u001b[?2004h"]
[90.177418, "o", "> "]
[90.177542, "o", "  // Check all counts match values\r\n\u001b[?2004l\r"]
[90.177595, "o", "\u001b[?2004h> "]
[90.177781, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[90.177799, "o", "\u001b[?2004h"]
[90.177886, "o", "> "]
[90.177933, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[90.178013, "o", "\u001b[?2004h> "]
[90.178195, "o", "    if ((counts.get(island.id) || 0) !== island.value) return false;\r\n\u001b[?2004l\r"]
[90.178217, "o", "\u001b[?2004h"]
[90.17823, "o", "> "]
[90.178243, "o", "  }"]
[90.178257, "o", "\r\n\u001b[?2004l\r"]
[90.178339, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[90.178356, "o", "\u001b[?2004h> "]
[90.178447, "o", "  // Check connectivity\r\n\u001b[?2004l\r"]
[90.178493, "o", "\u001b[?2004h> "]
[90.178662, "o", "  if (!checkConnectivity(islands, bridges)) return false;\r\n\u001b[?2004l\r"]
[90.178705, "o", "\u001b[?2004h> "]
[90.178723, "o", "  \r\n\u001b[?2004l\r"]
[90.178774, "o", "\u001b[?2004h> "]
[90.178921, "o", "  // Check no crossings among existing bridges\r\n\u001b[?2004l\r"]
[90.179039, "o", "\u001b[?2004h"]
[90.179107, "o", ">   const bridgeList = [];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.179245, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[90.17932, "o", "\u001b[?2004h> "]
[90.179404, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[90.179497, "o", "\u001b[?2004h"]
[90.179518, "o", "> "]
[90.179608, "o", "    const parts = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[90.179703, "o", "\u001b[?2004h> "]
[90.179771, "o", "    bridgeList.push(parts);\r\n\u001b[?2004l\r"]
[90.179855, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.179874, "o", "> "]
[90.179964, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[90.180031, "o", "> "]
[90.180087, "o", "  for (let i = 0; i < bridgeList.length; i++) {\r\n\u001b[?2004l\r"]
[90.180156, "o", "\u001b[?2004h> "]
[90.180298, "o", "    for (let j = i + 1; j < bridgeList.length; j++) {\r\n\u001b[?2004l\r"]
[90.180386, "o", "\u001b[?2004h"]
[90.18048, "o", "> "]
[90.180547, "o", "      const [ax1, ay1, ax2, ay2] = bridgeList[i];\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.180565, "o", "> "]
[90.180708, "o", "      const [bx1, by1, bx2, by2] = bridgeList[j];\r\n\u001b[?2004l\r"]
[90.180737, "o", "\u001b[?2004h"]
[90.180803, "o", "> "]
[90.180898, "o", "      const aHoriz = ay1 === ay2;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.181005, "o", "      const bHoriz = by1 === by2;\r\n\u001b[?2004l\r"]
[90.18102, "o", "\u001b[?2004h"]
[90.181051, "o", "> "]
[90.181223, "o", "      if (aHoriz === bHoriz) continue; // parallel can't cross\r\n\u001b[?2004l\r"]
[90.18124, "o", "\u001b[?2004h"]
[90.1813, "o", ">       \r\n\u001b[?2004l\r"]
[90.181379, "o", "\u001b[?2004h> "]
[90.181441, "o", "      if (aHoriz) {\r\n\u001b[?2004l\r"]
[90.1815, "o", "\u001b[?2004h> "]
[90.181589, "o", "        // a is horizontal, b is vertical\r\n\u001b[?2004l\r"]
[90.181605, "o", "\u001b[?2004h"]
[90.181617, "o", "> "]
[90.181859, "o", "        const aMinX = Math.min(ax1, ax2), aMaxX = Math.max(ax1, ax2);\r\n\u001b[?2004l\r"]
[90.181913, "o", "\u001b[?2004h> "]
[90.181994, "o", "        const aY = ay1;\r\n\u001b[?2004l\r"]
[90.182026, "o", "\u001b[?2004h"]
[90.182041, "o", "> "]
[90.18214, "o", "        const bX = bx1;\r\n\u001b[?2004l\r"]
[90.18222, "o", "\u001b[?2004h> "]
[90.182385, "o", "        const bMinY = Math.min(by1, by2), bMaxY = Math.max(by1, by2);\r\n\u001b[?2004l\r"]
[90.182463, "o", "\u001b[?2004h> "]
[90.18266, "o", "        if (bX > aMinX && bX < aMaxX && aY > bMinY && aY < bMaxY) return false;\r\n\u001b[?2004l\r"]
[90.18272, "o", "\u001b[?2004h> "]
[90.182793, "o", "      } else {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.182928, "o", "        // a is vertical, b is horizontal\r\n\u001b[?2004l\r"]
[90.182982, "o", "\u001b[?2004h> "]
[90.183175, "o", "        const aMinY = Math.min(ay1, ay2), aMaxY = Math.max(ay1, ay2);\r\n\u001b[?2004l\r"]
[90.183192, "o", "\u001b[?2004h"]
[90.183204, "o", "> "]
[90.183338, "o", "        const aX = ax1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[90.183404, "o", "        const bY = by1;\r\n\u001b[?2004l\r"]
[90.183421, "o", "\u001b[?2004h"]
[90.183466, "o", "> "]
[90.183651, "o", "        const bMinX = Math.min(bx1, bx2), bMaxX = Math.max(bx1, bx2);\r\n\u001b[?2004l\r"]
[90.183694, "o", "\u001b[?2004h"]
[90.183708, "o", "> "]
[90.183948, "o", "        if (aX > bMinX && aX < bMaxX && bY > aMinY && bY < aMaxY) return false;\r\n\u001b[?2004l\r"]
[90.183976, "o", "\u001b[?2004h"]
[90.184, "o", "> "]
[90.184066, "o", "      }\r\n\u001b[?2004l\r"]
[90.184084, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[90.184132, "o", "\u001b[?2004h> "]
[90.184167, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[90.184183, "o", "> "]
[90.184225, "o", "  \r\n\u001b[?2004l\r"]
[90.184241, "o", "\u001b[?2004h"]
[90.184251, "o", "> "]
[90.184309, "o", "  return true;\r\n\u001b[?2004l\r"]
[90.184341, "o", "\u001b[?2004h"]
[90.184355, "o", "> "]
[90.184365, "o", "}\r\n\u001b[?2004l\r"]
[90.184415, "o", "\u001b[?2004h> "]
[90.18443, "o", "EOF\r\n\u001b[?2004l\r"]
[90.185317, "o", "\u001b[?2004h"]
