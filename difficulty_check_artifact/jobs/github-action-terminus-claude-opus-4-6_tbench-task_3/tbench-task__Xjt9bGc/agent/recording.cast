[90.427114, "i", "cat > /app/src/index.css << 'EOF'\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml, body, #root {\n  width: 100%;\n  height: 100%;\n  background: #000;\n  color: #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  overflow: hidden;\n}\n\n.app-container {\n  position: absolute;\n  top: 0;\n  left: 0;\n}\n\n.controls {\n  position: absolute;\n  top: 610px;\n  left: 0;\n  padding: 10px;\n  display: flex;\n  gap: 15px;\n  align-items: center;\n}\n\nselect, button {\n  background: #000;\n  color: #0f0;\n  border: 1px solid #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 14px;\n  padding: 4px 8px;\n  cursor: pointer;\n}\n\nselect:focus, button:focus {\n  outline: 1px solid #0f0;\n}\n\nbutton:hover {\n  background: #0f0;\n  color: #000;\n}\n\n.error-message {\n  color: #f00;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 14px;\n  margin-left: 10px;\n}\n\n.victory-banner {\n  color: #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 24px;\n  font-weight: bold;\n  margin-left: 10px;\n  text"]
[90.427213, "i", "-shadow: 0 0 10px #0f0;\n  animation: blink 1s infinite;\n}\n\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\nEOF\n"]
[90.42743, "o", "cat > /app/src/index.css << 'EOF'"]
