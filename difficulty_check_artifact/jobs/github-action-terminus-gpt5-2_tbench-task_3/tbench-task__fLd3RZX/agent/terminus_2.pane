[?2004l[?2004h> // Game logic utilities for Hashi (Bridges)
[?2004l[?2004h> 
[?2004l[?2004h> export const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> export const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';
[?2004l[?2004h> export const ERR_EXCEED_ISLAND = 'Island would exceed its number';
[?2004l[?2004h> export const ERR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalKey(a, b) {
[?2004l[?2004h>   const p1 = { x: a.x, y: a.y };
[?2004l[?2004h>   const p2 = { x: b.x, y: b.y };
[?2004l[?2004h>   const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;
[?2004l[?2004h>   const second = first === p1 ? p2 : p1;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l [?2004h> function isBetween(v, a, b) {
[?2004l[?2004h>   return v > Math.min(a, b) && v < Math.max(a, b);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function getBridgeSegments(bridges) {
[?2004l[?2004h>   // returns array of {x1,y1,x2,y2}
[?2004l[?2004h>   const segs = [];
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     segs.push({ x1, y1, x2, y2, count });
[?2004l[?2004h>   }
[?2004l[?2004h>   return segs;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!from || !to) return false;
[?2004l[?2004h>   if (!isAligned(from, to)) return false;
[?2004l[?2004h>   // No island strictly between them along the line.
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const x = from.x;
[?2004l[?2004h>     const y1 = from.y;
[?2004l[?2004h>     const y2 = to.y;
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.x === x && isBetween(isl.y, y1, y2)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   const y = from.y;
[?2004l[?2004h>   const x1 = from.x;
[?2004l[?2004h>   const x2 = to.x;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>     if (isl.y === y && isBetween(isl.x, x1, x2)) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(segA, segB) {
[?2004l[?2004h>   // Only consider perpendicular crossings that intersect at a point that is not an endpoint.
[?2004l[?2004h>   const aVert = segA.x1 === segA.x2;
[?2004l[?2004h>   const bVert = segB.x1 === segB.x2;
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const vert = aVert ? segA : segB;
[?2004l[?2004h>   const hori = aVert ? segB : segA;
[?2004l[?2004h> 
[?2004l[?2004h>   const ix = vert.x1;
[?2004l[?2004h>   const iy = hori.y1;
[?2004l[?2004h> 
[?2004l[?2004h>   // intersection must be strictly inside both segments
[?2004l[?2004h>   if (!isBetween(ix, hori.x1, hori.x2)) return false;
[?2004l[?2004h>   if (!isBetween(iy, vert.y1, vert.y2)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function anyCrossing(bridges) {
[?2004l[?2004h>   const segs = getBridgeSegments(bridges);
[?2004l[?2004h>   for (let i = 0; i < segs.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < segs.length; j++) {
[?2004l[?2004h>       if (segmentsCross(segs[i], segs[j])) return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + count);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const startId = islands[0].id;
[?2004l[?2004h>   const seen = new Set([startId]);
[?2004l[?2004h>   const q = [startId];
[?2004l[?2004h>   while (q.length) {
[?2004l[?2004h>     const cur = q.shift();
[?2004l[?2004h>     for (const nxt of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt);
[?2004l[?2004h>         q.push(nxt);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to || from.id === to.id) return { valid: true, error: null };
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) return { valid: false, error: ERR_NON_ADJACENT };
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: true, error: null };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PER_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   // island counts
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED_ISLAND };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // crossing check with hypothetical update
[?2004l[?2004h>   const nextBridges = new Map(bridges);
[?2004l[?2004h>   if (next === 0) nextBridges.delete(key);
[?2004l[?2004h>   else nextBridges.set(key, next);
[?2004l[?2004h> 
[?2004l[?2004h>   if (anyCrossing(nextBridges)) return { valid: false, error: ERR_CROSS };
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Must be satisfied counts, connected, and no crossings.
[?2004l[?2004h>   if (anyCrossing(bridges)) return false;
