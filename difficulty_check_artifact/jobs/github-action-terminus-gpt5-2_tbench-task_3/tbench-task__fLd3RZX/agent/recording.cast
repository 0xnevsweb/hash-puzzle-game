[91.584203, "i", "cat > src/utils/hashiLogic.js <<'EOF'\n// Game logic utilities for Hashi (Bridges)\n\nexport const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\nexport const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';\nexport const ERR_EXCEED_ISLAND = 'Island would exceed its number';\nexport const ERR_CROSS = 'Bridges would cross';\n\nexport function canonicalKey(a, b) {\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\n  const second = first === p1 ? p2 : p1;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction isAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\nfunction isBetween(v, a, b) {\n  return v > Math.min(a, b) && v < Math.max(a, b);\n}\n\nexport function getBridgeSegments(bridges) {\n  // returns array of {x1,y1,x2,y2}\n  const segs = [];\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    segs.push({ x1, y1, x2, y2, c"]
[91.584259, "i", "ount });\n  }\n  return segs;\n}\n\nexport function areAdjacent(islands, from, to) {\n  if (!from || !to) return false;\n  if (!isAligned(from, to)) return false;\n  // No island strictly between them along the line.\n  if (from.x === to.x) {\n    const x = from.x;\n    const y1 = from.y;\n    const y2 = to.y;\n    for (const isl of islands) {\n      if (isl.id === from.id || isl.id === to.id) continue;\n      if (isl.x === x && isBetween(isl.y, y1, y2)) return false;\n    }\n    return true;\n  }\n  const y = from.y;\n  const x1 = from.x;\n  const x2 = to.x;\n  for (const isl of islands) {\n    if (isl.id === from.id || isl.id === to.id) continue;\n    if (isl.y === y && isBetween(isl.x, x1, x2)) return false;\n  }\n  return true;\n}\n\nfunction segmentsCross(segA, segB) {\n  // Only consider perpendicular crossings that intersect at a point that is not an endpoint.\n  const aVert = segA.x1 === segA.x2;\n  const bVert = segB.x1 === segB.x2;\n  if (aVert === bVert) return false;\n\n  const vert = aVert ? segA : segB;\n  const hori = aVert ? seg"]
[91.584279, "i", "B : segA;\n\n  const ix = vert.x1;\n  const iy = hori.y1;\n\n  // intersection must be strictly inside both segments\n  if (!isBetween(ix, hori.x1, hori.x2)) return false;\n  if (!isBetween(iy, vert.y1, vert.y2)) return false;\n\n  return true;\n}\n\nexport function anyCrossing(bridges) {\n  const segs = getBridgeSegments(bridges);\n  for (let i = 0; i < segs.length; i++) {\n    for (let j = i + 1; j < segs.length; j++) {\n      if (segmentsCross(segs[i], segs[j])) return true;\n    }\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + count);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + count"]
[91.584293, "i", ");\n  }\n  return counts;\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const q = [startId];\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: true, error: null };\n  if (!areAdjacent"]
[91.584309, "i", "(islands, from, to)) return { valid: false, error: ERR_NON_ADJACENT };\n\n  const key = canonicalKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = current + delta;\n\n  if (next < 0) return { valid: true, error: null };\n  if (next > 2) return { valid: false, error: ERR_MAX_PER_PAIR };\n\n  // island counts\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) {\n    return { valid: false, error: ERR_EXCEED_ISLAND };\n  }\n\n  // crossing check with hypothetical update\n  const nextBridges = new Map(bridges);\n  if (next === 0) nextBridges.delete(key);\n  else nextBridges.set(key, next);\n\n  if (anyCrossing(nextBridges)) return { valid: false, error: ERR_CROSS };\n\n  return { valid: true, error: null };\n}\n\nexport function isVictory(islands, bridges) {\n  // Must be satisfied counts, connected, and no crossings.\n  if (anyCrossing(bridges)) return"]
[91.584322, "i", " false;\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"]
