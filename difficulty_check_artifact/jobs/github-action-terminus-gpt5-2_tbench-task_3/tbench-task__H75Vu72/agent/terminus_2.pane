        ) : null}

        {/* Islands */}
        <g>
          {islands.map((isl) => {
            const px = isl.x * GRID;
            const py = isl.y * GRID;
            const curCount = counts.get(isl.id) ?? 0;
            const satisfied = curCount === isl.value;
            return (
              <g
                key={isl.id}
                transform={`translate(${px}, ${py})`}
                onClick={() => handleIslandClick(isl)}
                style={{ cursor: 'pointer' }}
              >
                <circle
                  r={16}
                  fill="black"
                  stroke={satisfied ? 'rgba(0,255,102,0.95)' : 'rgba(0,255,102,0.6)'}
                  strokeWidth={2}
                />
                <text
                  x={0}
                  y={6}
                  textAnchor="middle"
                  fontSize={16}
                  fill="var(--fg)"
                >
                  {isl.value}
                </text>
              </g>
            );
          })}
        </g>
      </svg>
    </div>
  );
}
