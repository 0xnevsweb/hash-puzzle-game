[?2004l[?2004h>     const minY = Math.min(ay, by);
[?2004l[?2004h>     const maxY = Math.max(ay, by);
[?2004l[?2004h>     return Math.abs(px - ax) <= tol && py >= minY && py <= maxY;
[?2004l[?2004h>   }
[?2004l[?2004h>   // horizontal
[?2004l[?2004h>   const minX = Math.min(ax, bx);
[?2004l[?2004h>   const maxX = Math.max(ax, bx);
[?2004l[?2004h>   return Math.abs(py - ay) <= tol && px >= minX && px <= maxX;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleKey, setPuzzleKey] = useState('easy');
[?2004l[?2004h>   const islands = useMemo(() => puzzles[puzzleKey].islands, [puzzleKey]);
[?2004l[?2004h> 
[?2004l[?2004h>   const [bridges, setBridges] = useState(() => new Map());
[?2004l[?2004h>   const [selectedId, setSelectedId] = useState(null);
[?2004l[?2004h>   const [cursorId, setCursorId] = useState(0);
[?2004l[?2004h>   const [kbFromId, setKbFromId] = useState(null);
[?2004l[?2004h>   const [error, setError] = useState(null);
[?2004l[?2004h> 
[?2004l[?2004h>   const svgRef = useRef(null);
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);
[?2004l[?2004h>   const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     // On puzzle change: reset everything (bridges + selections)
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>     setKbFromId(null);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setCursorId(islands[0]?.id ?? 0);
[?2004l[?2004h>   }, [puzzleKey]); // eslint-disable-line react-hooks/exhaustive-deps
[?2004l[?2004h> 
[?2004l[?2004h>   function clearErrorOnValidMove(result) {
[?2004l[?2004h>     if (result?.valid) setError(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function applyBridgeDelta(from, to, delta) {
[?2004l[?2004h>     const res = canAddBridge(islands, bridges, from, to, delta);
[?2004l[?2004h>     if (!res.valid) {
[?2004l[?2004h>       setError(res.error);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const key = canonicalKey(from, to);
[?2004l[?2004h>     const current = bridges.get(key) ?? 0;
[?2004l[?2004h>     const next = Math.max(0, Math.min(2, current + delta));
[?2004l[?2004h> 
[?2004l[?2004h>     const nextMap = new Map(bridges);
[?2004l[?2004h>     if (next === 0) nextMap.delete(key);
[?2004l[?2004h>     else nextMap.set(key, next);
[?2004l[?2004h> 
[?2004l[?2004h>     setBridges(nextMap);
[?2004l[?2004h>     clearErrorOnValidMove(res);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function cycleBridge(from, to) {
[?2004l[?2004h>     const key = canonicalKey(from, to);
[?2004l[?2004h>     const current = bridges.get(key) ?? 0;
[?2004l[?2004h>     const desired = current === 0 ? 1 : current === 1 ? 2 : 0;
[?2004l[?2004h>     const delta = desired - current;
[?2004l[?2004h>     if (delta === 0) return;
[?2004l[?2004h> 
[?2004l[?2004h>     if (desired === 0) {
[?2004l[?2004h>       // always allowed
[?2004l[?2004h>       const nextMap = new Map(bridges);
[?2004l[?2004h>       nextMap.delete(key);
[?2004l[?2004h>       setBridges(nextMap);
[?2004l[?2004h>       setError(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     applyBridgeDelta(from, to, delta);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function handleIslandClick(isl) {
[?2004l[?2004h>     if (selectedId == null) {
[?2004l[?2004h>       setSelectedId(isl.id);
[?2004l[?2004h>       setKbFromId(null);
[?2004l[?2004h>       setCursorId(isl.id);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l>[?2004h>     if (selectedId === isl.id) {
[?2004l[?2004h>       // keep selection
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const from = findIslandById(islands, selectedId);
[?2004l[?2004h>     const to = isl;
[?2004l[?2004h>     cycleBridge(from, to);
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l{[?2004h>   function removeBridgeByKey(key) {
[?2004l[?2004h>     if (!bridges.has(key)) return;
[?2004l[?2004h>     const nextMap = new Map(bridges);
[?2004l[?2004h>     nextMap.delete(key);
[?2004l[?2004h>     setBridges(nextMap);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function handleSvgPointerDown(e) {
[?2004l[?2004h>     // Right click or ctrl+click on existing bridge removes it.
[?2004l[?2004h>     if (!(e.button === 2 || e.ctrlKey)) return;
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h> 
[?2004l[?2004h>     const svg = svgRef.current;
[?2004l[?2004h>     if (!svg) return;
[?2004l[?2004h>     const pt = svg.createSVGPoint();
[?2004l[?2004h>     pt.x = e.clientX;
[?2004l[?2004h>     pt.y = e.clientY;
[?2004l[?2004h>     const ctm = svg.getScreenCTM();
[?2004l[?2004h>     if (!ctm) return;
[?2004l[?2004h>     const loc = pt.matrixTransform(ctm.inverse());
[?2004l[?2004h> 
[?2004l[?2004h>     for (const [key] of bridges.entries()) {
[?2004l[?2004h>       if (bridgeHitTest(key, loc.x, loc.y)) {
[?2004l[?2004h>         removeBridgeByKey(key);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
