[?2004l[?2004h>       const d = isl.y - from.y;
[?2004l[?2004h>       if (d < bestDist) {
[?2004l[?2004h>         bestDist = d;
[?2004l[?2004h>         best = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return best;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function keyToEndpoints(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function bridgeHitTest(bridgeKey, px, py) {
[?2004l[?2004h>   // Detect clicks near the visible line(s). Keep simple: distance to segment <= 6.
[?2004l[?2004h>   const { x1, y1, x2, y2 } = keyToEndpoints(bridgeKey);
[?2004l[?2004h>   const ax = x1 * GRID;
[?2004l[?2004h>   const ay = y1 * GRID;
[?2004l[?2004h>   const bx = x2 * GRID;
[?2004l[?2004h>   const by = y2 * GRID;
[?2004l[?2004h> 
[?2004l[?2004h>   const tol = 6;
