  const stack = [islands[0].id];
  while (stack.length) {
    const cur = stack.pop();
    if (seen.has(cur)) continue;
    seen.add(cur);
    for (const nxt of adj.get(cur) ?? []) {
      if (!seen.has(nxt)) stack.push(nxt);
    }
  }

  return seen.size === islands.length;
