[?2004l:root {
  --bg: #000000;
  --fg: #00ff66;
  --fg-dim: rgba(0, 255, 102, 0.7);
  --stroke: #00ff66;
}

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--fg);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}

#root {
  margin: 0;
  padding: 0;
}

.app {
  position: relative;
  width: 800px;
  height: 600px;
}

.hud {
  position: absolute;
  left: 8px;
  top: 8px;
  z-index: 2;
  display: flex;
  gap: 8px;
  align-items: center;
}

select, button {
  background: transparent;
  color: var(--fg);
  border: 1px solid var(--fg);
  padding: 4px 8px;
  font-family: inherit;
}

button { cursor: pointer; }

.error-message {
  position: absolute;
  left: 8px;
  top: 44px;
  z-index: 2;
  color: #ff4d4d;
}

.victory-banner {
  position: absolute;
  left: 8px;
  top: 44px;
  z-index: 2;
  color: var(--fg);
  border: 1px solid var(--fg);
  padding: 6px 10px;
  background: rgba(0,0,0,0.85);
}

svg.board {
  position: absolute;
  left: 0;
  top: 0;
  width: 800px;
  height: 600px;
  display: block;
}
