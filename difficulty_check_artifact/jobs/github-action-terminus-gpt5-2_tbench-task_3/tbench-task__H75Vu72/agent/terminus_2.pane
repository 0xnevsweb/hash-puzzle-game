export function isVictory(islands, bridges) {
  const counts = computeCurrentCounts(islands, bridges);
  for (const isl of islands) {
    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
  }

  // Ensure no crossings (defensive)
  const keys = [...bridges.keys()].filter((k) => (bridges.get(k) ?? 0) > 0);
  for (let i = 0; i < keys.length; i++) {
    const { x1: ax1, y1: ay1, x2: ax2, y2: ay2 } = parseKey(keys[i]);
    const a1 = islands.find((isl) => isl.x === ax1 && isl.y === ay1);
    const a2 = islands.find((isl) => isl.x === ax2 && isl.y === ay2);
    if (!a1 || !a2) continue;
    const segA = segmentFromIslands(a1, a2);

    for (let j = i + 1; j < keys.length; j++) {
      const { x1: bx1, y1: by1, x2: bx2, y2: by2 } = parseKey(keys[j]);
      const b1 = islands.find((isl) => isl.x === bx1 && isl.y === by1);
      const b2 = islands.find((isl) => isl.x === bx2 && isl.y === by2);
      if (!b1 || !b2) continue;

      const shareEndpoint = a1.id === b1.id || a1.id === b2.id || a2.id === b1.id || a2.id === b2.id;
      if (shareEndpoint) continue;

      const segB = segmentFromIslands(b1, b2);
      if (segmentsCross(segA, segB)) return false;
    }
  }

  return checkConnectivity(islands, bridges);
}
