[?2004l[?2004h>       (from.x === x1 && from.y === y1) ||
[?2004l[?2004h>       (from.x === x2 && from.y === y2) ||
[?2004l[?2004h>       (to.x === x1 && to.y === y1) ||
[?2004l[?2004h>       (to.x === x2 && to.y === y2);
[?2004l[?2004h>     if (sharesEndpoint) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     const segOld = segmentFromIslands(a, b);
[?2004l[?2004h>     if (segmentsCross(segNew, segOld)) return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   if (!isAxisAligned(from, to) || !areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: true, error: null };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   if (delta > 0 && wouldCrossExisting(islands, bridges, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERR_CROSS };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>   const adj = new Map(islands.map((i) => [i.id, []]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = byCoord.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byCoord.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const seen = new Set();
[?2004l[?2004h>   const stack = [islands[0].id];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     if (seen.has(cur)) continue;
[?2004l[?2004h>     seen.add(cur);
[?2004l[?2004h>     for (const nxt of adj.get(cur) ?? []) {
[?2004l[?2004h>       if (!seen.has(nxt)) stack.push(nxt);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // no crossings
[?2004l[?2004h>   for (const [keyA, nA] of bridges.entries()) {
[?2004l[?2004h>     if (!nA) continue;
[?2004l[?2004h>     const { x1: ax1, y1: ay1, x2: ax2, y2: ay2 } = parseKey(keyA);
[?2004l[?2004h>     const a1 = islands.find((i) => i.x === ax1 && i.y === ay1);
[?2004l[?2004h>     const a2 = islands.find((i) => i.x === ax2 && i.y === ay2);
[?2004l[?2004h>     if (!a1 || !a2) continue;
[?2004l[?2004h>     const segA = segmentFromIslands(a1, a2);
[?2004l[?2004h> 
[?2004l[?2004h>     for (const [keyB, nB] of bridges.entries()) {
[?2004l[?2004h>       if (!nB || keyB <= keyA) continue;
[?2004l[?2004h>       const { x1: bx1, y1: by1, x2: bx2, y2: by2 } = parseKey(keyB);
[?2004l[?2004h>       const b1 = islands.find((i) => i.x === bx1 && i.y === by1);
[?2004l[?2004h>       const b2 = islands.find((i) => i.x === bx2 && i.y === by2);
[?2004l[?2004h>       if (!b1 || !b2) continue;
[?2004l[?2004h> 
[?2004l[?2004h>       // if share endpoints, ignore
[?2004l[?2004h>       const sharesEndpoint =
[?2004l[?2004h>         (a1.id === b1.id || a1.id === b2.id || a2.id === b1.id || a2.id === b2.id);
[?2004l[?2004h>       if (sharesEndpoint) continue;
[?2004l[?2004h> 
[?2004l[?2004h>       const segB = segmentFromIslands(b1, b2);
[?2004l[?2004h>       if (segmentsCross(segA, segB)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
