[105.164727, "o", "          />\r\n        ) : null}\r\n\r\n        {/* Islands */}\r\n        <g>\r\n          {islands.map((isl) => {\r\n            const px = isl.x * GRID;\r\n            const py = isl.y * GRID;\r\n            const curCount = counts.get(isl.id) ?? 0;\r\n            const satisfied = curCount === isl.value;\r\n            return (\r\n              <g\r\n                key={isl.id}\r\n                transform={`translate(${px}, ${py})`}\r\n                onClick={() => handleIslandClick(isl)}\r\n                style={{ cursor: 'pointer' }}\r\n              >\r\n                <circle\r\n                  r={16}\r\n                  fill=\"black\"\r\n                  stroke={satisfied ? 'rgba(0,255,102,0.95)' : 'rgba(0,255,102,0.6)'}\r\n                  strokeWidth={2}\r\n                />\r\n                <text\r\n                  x={0}\r\n                  y={6}\r\n                  textAnchor=\"middle\"\r\n                  fontSize={16}\r\n                  fill=\"var(--fg)\"\r\n                >\r\n                  {isl.value}\r\n                </text>\r\n    "]
[105.164758, "o", "          </g>\r\n            );\r\n          })}\r\n        </g>\r\n      </svg>\r\n    </div>\r\n  );\r\n}\r\n"]
