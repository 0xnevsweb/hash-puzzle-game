[105.272431, "o", ":root {\r\n  --bg: #000000;\r\n  --fg: #00ff66;\r\n  --fg-dim: rgba(0, 255, 102, 0.7);\r\n  --stroke: #00ff66;\r\n}\r\n\r\nhtml, body {\r\n  margin: 0;\r\n  padding: 0;\r\n  background: var(--bg);\r\n  color: var(--fg);\r\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\r\n}\r\n\r\n#root {\r\n  margin: 0;\r\n  padding: 0;\r\n}\r\n\r\n.app {\r\n  position: relative;\r\n  width: 800px;\r\n  height: 600px;\r\n}\r\n\r\n.hud {\r\n  position: absolute;\r\n  left: 8px;\r\n  top: 8px;\r\n  z-index: 2;\r\n  display: flex;\r\n  gap: 8px;\r\n  align-items: center;\r\n}\r\n\r\nselect, button {\r\n  background: transparent;\r\n  color: var(--fg);\r\n  border: 1px solid var(--fg);\r\n  padding: 4px 8px;\r\n"]
[105.272921, "o", "  font-family: inherit;\r\n}\r\n\r\nbutton { cursor: pointer; }\r\n\r\n.error-message {\r\n  position: absolute;\r\n  left: 8px;\r\n  top: 44px;\r\n  z-index: 2;\r\n  color: #ff4d4d;\r\n}\r\n\r\n.victory-banner {\r\n  position: absolute;\r\n  left: 8px;\r\n  top: 44px;\r\n  z-index: 2;\r\n  color: var(--fg);\r\n  border: 1px solid var(--fg);\r\n  padding: 6px 10px;\r\n  background: rgba(0,0,0,0.85);\r\n}\r\n\r\nsvg.board {\r\n  position: absolute;\r\n  left: 0;\r\n  top: 0;\r\n  width: 800px;\r\n  height: 600px;\r\n  display: block;\r\n}\r\n\u001b[?2004hroot@f5160cef3cb3:/app# "]
