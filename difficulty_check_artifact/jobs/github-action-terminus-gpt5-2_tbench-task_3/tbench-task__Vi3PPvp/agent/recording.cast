[60.196907, "i", "cat > src/index.css <<'EOF'\n:root {\n  color-scheme: dark;\n}\n\nhtml,\nbody {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n}\n\nbody {\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\",\n    \"Courier New\", monospace;\n  background-color: #000;\n  color: #0f0;\n}\n\n.app-root {\n  position: relative;\n  width: 100%;\n  height: 100%;\n}\n\n.hud {\n  position: absolute;\n  top: 0;\n  left: 0;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  padding: 8px;\n  z-index: 2;\n  background: rgba(0, 0, 0, 0.6);\n}\n\nselect,\nbutton {\n  background: #000;\n  color: #0f0;\n  border: 1px solid #0f0;\n  font-family: inherit;\n  padding: 4px 8px;\n}\n\nbutton {\n  cursor: pointer;\n}\n\n.error-message {\n  position: absolute;\n  top: 44px;\n  left: 8px;\n  z-index: 3;\n  border: 1px solid #0f0;\n  padding: 6px 8px;\n  background: rgba(0, 0, 0, 0.85);\n}\n\n.victory-banner {\n  position: absolute;\n  top: 44px;\n  right: 8px;\n  z-index: 3;\n  border: 1px solid #0f0;\n  padding: 6px 10px;\n  background: rgba(0, 0, 0, 0.85);"]
[60.197133, "i", "\n  font-weight: 700;\n}\n\n.board {\n  position: absolute;\n  top: 0;\n  left: 0;\n  display: block;\n}\n\n.island {\n  cursor: pointer;\n}\n\n.cursor {\n  pointer-events: none;\n}\nEOF\n"]
