[59.918519, "i", "cat > src/utils/hashiLogic.js <<'EOF'\nconst DIRS = [\n  { dx: 1, dy: 0 },\n  { dx: -1, dy: 0 },\n  { dx: 0, dy: 1 },\n  { dx: 0, dy: -1 }\n];\n\nexport function canonicalKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const firstIsA = a.x < b.x || (a.x === b.x && a.y <= b.y);\n  const p1 = firstIsA ? a : b;\n  const p2 = firstIsA ? b : a;\n  return `${p1.x},${p1.y},${p2.x},${p2.y}`;\n}\n\nexport function parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));\n  return { x1, y1, x2, y2 };\n}\n\nfunction isHorizontal(seg) {\n  return seg.y1 === seg.y2;\n}\n\nfunction isVertical(seg) {\n  return seg.x1 === seg.x2;\n}\n\nfunction segsCross(segA, segB) {\n  // Cross only if one is horizontal and the other vertical, and they intersect at a point\n  // that is strictly inside both segments (not at endpoints).\n  const a = segA;\n  const b = segB;\n  if (isHorizontal(a) && isVertical(b)) {\n    const ay = a.y1;\n    const axMin = Math.min(a.x1, a.x2);\n    const axMax = Math.max(a.x"]
[59.91865, "i", "1, a.x2);\n\n    const bx = b.x1;\n    const byMin = Math.min(b.y1, b.y2);\n    const byMax = Math.max(b.y1, b.y2);\n\n    const intersects = bx > axMin && bx < axMax && ay > byMin && ay < byMax;\n    return intersects;\n  }\n  if (isVertical(a) && isHorizontal(b)) {\n    return segsCross(b, a);\n  }\n  return false;\n}\n\nfunction hasCrossing(bridges, candidateKey) {\n  const cand = parseKey(candidateKey);\n  for (const [key, count] of bridges.entries()) {\n    if (count <= 0) continue;\n    if (key === candidateKey) continue;\n    const seg = parseKey(key);\n    if (segsCross(cand, seg)) return true;\n  }\n  return false;\n}\n\nfunction buildIslandByXY(islands) {\n  const m = new Map();\n  for (const isl of islands) {\n    m.set(`${isl.x},${isl.y}`, isl);\n  }\n  return m;\n}\n\nfunction isClearLine(islandsByXY, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  const dx = Math.sign(to.x - from.x);\n  const dy = Math.sign(to.y - from.y);\n  let x = from.x + dx;\n  let y = from.y + dy;\n  while (x !== to.x || y !== to.y) {\n   "]
[59.918861, "i", " if (islandsByXY.has(`${x},${y}`)) return false;\n    x += dx;\n    y += dy;\n  }\n  return true;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to) return { valid: false, error: 'Invalid islands' };\n  if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };\n  if (from.x !== to.x && from.y !== to.y) {\n    return { valid: false, error: 'Cannot connect non-adjacent islands' };\n  }\n\n  const islandsByXY = buildIslandByXY(isl"]
[59.918881, "o", "cat > src/utils/hashiLogic.js <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.91892, "i", "ands);\n  if (!isClearLine(islandsByXY, from, to)) {\n    return { valid: false, error: 'Cannot connect non-adjacent islands' };\n  }\n\n  const key = canonicalKey(from, to);\n  const existing = bridges.get(key) ?? 0;\n  const next = existing + delta;\n\n  if (next < 0) {\n    return { valid: false, error: 'Invalid bridge change' };\n  }\n  if (next > 2) {\n    return { valid: false, error: 'Max 2 bridges per pair' };\n  }\n\n  // Crossing check only relevant if adding (increasing count)\n  if (delta > 0) {\n    if (hasCrossing(bridges, key)) {\n      return { valid: false, error: 'Bridges would cross' };\n    }\n  }\n\n  // Island counts constraint (only for adding)\n  if (delta > 0) {\n    const counts = computeCurrentCounts(islands, bridges);\n    const fromCount = counts.get(from.id) ?? 0;\n    const toCount = counts.get(to.id) ?? 0;\n    if (fromCount + delta > from.value || toCount + delta > to.value) {\n      return { valid: false, error: 'Island would exceed its number' };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexpo"]
