[60.052746, "i", "entListener('keydown', onKeyDown);\n  }, [islands]);\n\n  function toggleBridgeByIslands(fromId, toId) {\n    const from = islandsById.get(fromId);\n    const to = islandsById.get(toId);\n    if (!from || !to) return;\n\n    setBridges((prev) => {\n      const next = new Map(prev);\n      const key = canonicalKey(from, to);\n      const existing = next.get(key) ?? 0;\n      const desired = existing === 0 ? 1 : existing === 1 ? 2 : 0;\n      const delta = desired - existing;\n\n      // If removing (delta<0), allow directly (no need for canAddBridge)\n      if (delta < 0) {\n        if (desired === 0) next.delete(key);\n        else next.set(key, desired);\n        // valid move\n        setError(null);\n        setSelectedIslandId(null);\n        setCursorIslandId(0);\n        return next;\n      }\n\n      if (delta === 0) {\n        setSelectedIslandId(null);\n        return next;\n      }\n\n      const res = canAddBridge(islands, next, from, to, delta);\n      if (!res.valid) {\n        // Error must reset in-progress selection so next c"]
