[?2004l[?2004h> const DIRS = [
[?2004l[?2004h>   { dx: 1, dy: 0 },
[?2004l[?2004h>   { dx: -1, dy: 0 },
[?2004l[?2004h>   { dx: 0, dy: 1 },
[?2004l[?2004h>   { dx: 0, dy: -1 }
[?2004l[?2004h> ];
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const firstIsA = a.x < b.x || (a.x === b.x && a.y <= b.y);
[?2004l[?2004h>   const p1 = firstIsA ? a : b;
[?2004l[?2004h>   const p2 = firstIsA ? b : a;
[?2004l[?2004h>   return `${p1.x},${p1.y},${p2.x},${p2.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isHorizontal(seg) {
[?2004l[?2004h>   return seg.y1 === seg.y2;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isVertical(seg) {
[?2004l[?2004h>   return seg.x1 === seg.x2;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segsCross(segA, segB) {
[?2004l[?2004h>   // Cross only if one is horizontal and the other vertical, and they intersect at a point
[?2004l[?2004h>   // that is strictly inside both segments (not at endpoints).
[?2004l[?2004h>   const a = segA;
[?2004l[?2004h>   const b = segB;
[?2004l[?2004h>   if (isHorizontal(a) && isVertical(b)) {
[?2004l[?2004h>     const ay = a.y1;
[?2004l[?2004h>     const axMin = Math.min(a.x1, a.x2);
[?2004l[?2004h>     const axMax = Math.max(a.x1, a.x2);
[?2004l[?2004h> 
[?2004l[?2004h>     const bx = b.x1;
[?2004l[?2004h>     const byMin = Math.min(b.y1, b.y2);
[?2004l[?2004h>     const byMax = Math.max(b.y1, b.y2);
[?2004l[?2004h> 
[?2004l[?2004h>     const intersects = bx > axMin && bx < axMax && ay > byMin && ay < byMax;
[?2004l[?2004h>     return intersects;
[?2004l[?2004h>   }
[?2004l[?2004h>   if (isVertical(a) && isHorizontal(b)) {
[?2004l[?2004h>     return segsCross(b, a);
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function hasCrossing(bridges, candidateKey) {
[?2004l[?2004h>   const cand = parseKey(candidateKey);
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count <= 0) continue;
[?2004l[?2004h>     if (key === candidateKey) continue;
[?2004l[?2004h>     const seg = parseKey(key);
[?2004l[?2004h>     if (segsCross(cand, seg)) return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function buildIslandByXY(islands) {
[?2004l[?2004h>   const m = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     m.set(`${isl.x},${isl.y}`, isl);
[?2004l[?2004h>   }
[?2004l[?2004h>   return m;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isClearLine(islandsByXY, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   const dx = Math.sign(to.x - from.x);
[?2004l[?2004h>   const dy = Math.sign(to.y - from.y);
[?2004l[?2004h>   let x = from.x + dx;
[?2004l[?2004h>   let y = from.y + dy;
[?2004l[?2004h>   while (x !== to.x || y !== to.y) {
[?2004l[?2004h>     if (islandsByXY.has(`${x},${y}`)) return false;
[?2004l[?2004h>     x += dx;
[?2004l[?2004h>     y += dy;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (n <= 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: 'Invalid islands' };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) {
[?2004l[?2004h>     return { valid: false, error: 'Cannot connect non-adjacent islands' };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const islandsByXY = buildIslandByXY(islands);
[?2004l[?2004h>   if (!isClearLine(islandsByXY, from, to)) {
[?2004l[?2004h>     return { valid: false, error: 'Cannot connect non-adjacent islands' };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
[?2004l[?2004h>   const existing = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = existing + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) {
[?2004l[?2004h>     return { valid: false, error: 'Invalid bridge change' };
[?2004l[?2004h>   }
[?2004l[?2004h>   if (next > 2) {
[?2004l[?2004h>     return { valid: false, error: 'Max 2 bridges per pair' };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Crossing check only relevant if adding (increasing count)
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     if (hasCrossing(bridges, key)) {
[?2004l[?2004h>       return { valid: false, error: 'Bridges would cross' };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Island counts constraint (only for adding)
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>     const fromCount = counts.get(from.id) ?? 0;
[?2004l[?2004h>     const toCount = counts.get(to.id) ?? 0;
[?2004l[?2004h>     if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>       return { valid: false, error: 'Island would exceed its number' };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const byXY = buildIslandByXY(islands);
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (n <= 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = byXY.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byXY.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
