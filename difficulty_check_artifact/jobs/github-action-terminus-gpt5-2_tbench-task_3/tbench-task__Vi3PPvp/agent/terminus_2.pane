[?2004l[?2004h>             setSelectedIslandId(null);
[?2004l[?2004h>             setCursorIslandId(0);
[?2004l[?2004h>             setError(null);
[?2004l[?2004h>             setVictory(false);
[?2004l[?2004h>           }}
[?2004l[?2004h>         >
[?2004l[?2004h>           Reset
[?2004l[?2004h>         </button>
[?2004l[?2004h>         <div className="status">
[?2004l[?2004h>           {selectedIslandId != null ? `Selected: ${selectedIslandId}` : 'Selected: (none)'}
[?2004l[?2004h>         </div>
[?2004l[?2004h>       </div>
[?2004l[?2004h> 
[?2004l[?2004h>       {error ? <div className="error-message">{error}</div> : null}
[?2004l[?2004h>       {victory ? <div className="victory-banner">SOLVED!</div> : null}
[?2004l[?2004h> 
[?2004l[?2004h>       <svg
[?2004l[?2004h>         width={SVG_W}
[?2004l[?2004h>         height={SVG_H}
[?2004l[?2004h>         viewBox={`0 0 ${SVG_W} ${SVG_H}`}
[?2004l[?2004h>         className="board"
[?2004l[?2004h>       >
[?2004l[?2004h>         {/* Bridges */}
[?2004l[?2004h>         {renderBridgeLines()}
[?2004l[?2004h> 
[?2004l[?2004h>         {/* Cursor (must not be a circle) */}
[?2004l[?2004h>         <rect
[?2004l[?2004h>           x={cursorPx.x - 18}
[?2004l[?2004h>           y={cursorPx.y - 18}
[?2004l[?2004h>           width={36}
[?2004l[?2004h>           height={36}
[?2004l[?2004h>           fill="none"
[?2004l[?2004h>           stroke="#0f0"
[?2004l[?2004h>           strokeWidth={2}
[?2004l[?2004h>           strokeDasharray="4 3"
[?2004l[?2004h>           className="cursor"
[?2004l[?2004h>         />
[?2004l[?2004h> 
[?2004l[?2004h>         {/* Islands */}
[?2004l[?2004h>         {islands.map((isl) => {
[?2004l[?2004h>           const px = isl.x * GRID;
[?2004l[?2004h>           const py = isl.y * GRID;
[?2004l[?2004h>           const isSelected = selectedIslandId === isl.id;
[?2004l[?2004h>           const curCount = counts.get(isl.id) ?? 0;
[?2004l[?2004h>           return (
[?2004l[?2004h>             <g key={isl.id} className="island" onClick={() => onIslandClick(isl.id)}>
[?2004l[?2004h>               <circle
[?2004l[?2004h>                 cx={px}
[?2004l[?2004h>                 cy={py}
[?2004l[?2004h>                 r={16}
[?2004l[?2004h>                 fill="black"
[?2004l[?2004h>                 stroke={isSelected ? '#9f9' : '#0f0'}
[?2004l[?2004h>                 strokeWidth={isSelected ? 4 : 2}
[?2004l[?2004h>               />
[?2004l[?2004h>               <text
[?2004l[?2004h>                 x={px}
[?2004l[?2004h>                 y={py + 5}
[?2004l[?2004h>                 textAnchor="middle"
[?2004l[?2004h>                 fontSize="16"
[?2004l[?2004h>                 fill="#0f0"
[?2004l[?2004h>               >
[?2004l[?2004h>                 {isl.value}
[?2004l[?2004h>               </text>
[?2004l[?2004h>               <text
[?2004l[?2004h>                 x={px}
[?2004l[?2004h>                 y={py + 28}
[?2004l[?2004h>                 textAnchor="middle"
[?2004l[?2004h>                 fontSize="10"
[?2004l[?2004h>                 fill="#0f0"
[?2004l[?2004h>               >
[?2004l[?2004h>                 {curCount}/{isl.value}
[?2004l[?2004h>               </text>
[?2004l[?2004h>             </g>
[?2004l[?2004h>           );
[?2004l[?2004h>         })}
[?2004l[?2004h>       </svg>
[?2004l[?2004h>     </div>
[?2004l[?2004h>   );
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default App;
