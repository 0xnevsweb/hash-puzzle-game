x - from.x);\n  const dy = Math.sign(to.y - from.y);\n  let x = from.x + dx;\n  let y = from.y + dy;\n  while (x !== to.x || y !== to.y) {\n    if (islandsByXY.has(`${x},${y}`)) return false;\n    x += dx;\n    y += dy;\n  }\n  return true;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to) return { valid: false, error: 'Invalid islands' };\n  if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };\n  if (from.x !== to.x && from.y !== to.y) {\n    return { valid: false, error: 'Cannot connect non-adjacent islands' };\n  }\n\n  const islandsByXY = buildIslandByXY(islands);\n  if (!isClearLine(islandsByXY, from, to)) {\n    return { valid: false, error: 'Cannot connect non-adjacent islands' };\n  }\n\n  const key = canonicalKey(from, to);\n  const existing = bridges.get(key) ?? 0;\n  const next = existing + delta;\n\n  if (next < 0) {\n    return { valid: false, error: 'Invalid bridge change' };\n  }\n  if (next > 2) {\n    return { valid: false, error: 'Max 2 bridges per pair' };\n  }\n\n  // Crossing check only relevant if adding (increasing count)\n  if (delta > 0) {\n    if (hasCrossing(bridges, key)) {\n      return { valid: false, error: 'Bridges would cross' };\n    }\n  }\n\n  // Island counts constraint (only for adding)\n  if (delta > 0) {\n    const counts = computeCurrentCounts(islands, bridges);\n    const fromCount = counts.get(from.id) ?? 0;\n    const toCount = counts.get(to.id) ?? 0;\n    if (fromCount + delta > from.value || toCount + delta > to.value) {\n      return { valid: false, error: 'Island would exceed its number' };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  const byXY = buildIslandByXY(islands);\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, n] of bridges.entries()) {\n    if (n <= 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = byXY.get(`${x1},${y1}`);\n    const b = byXY.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const startId = islands[0].id;\n  const q = [startId];\n  const seen = new Set([startId]);\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // Counts must match\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  // No crossings\n  const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);\n  for (let i = 0; i < keys.length; i++) {\n    for (let j = i + 1; j < keys.length; j++) {\n      const a = parseKey(keys[i]);\n      const b = parseKey(keys[j]);\n      if (segsCross(a, b)) return false;\n    }\n  }\n\n  // Connected\n  return checkConnectivity(islands, bridges);\n}\n\nexport function findNextIsland(islands, fromId, dir) {\n  const from = islands.find((i) => i.id === fromId);\n  if (!from) return fromId;\n\n  let best = null;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    const dx = isl.x - from.x;\n    const dy = isl.y - from.y;\n\n    if (dir.dx !== 0) {\n      if (dy !== 0) continue;\n      if (Math.sign(dx) !== dir.dx) continue;\n      const dist = Math.abs(dx);\n      if (!best || dist < best.dist) best = { id: isl.id, dist };\n    } else {\n      if (dx !== 0) continue;\n      if (Math.sign(dy) !== dir.dy) continue;\n      const dist = Math.abs(dy);\n      if (!best || dist < best.dist) best = { id: isl.id, dist };\n    }\n  }\n  return best ? best.id : fromId;\n}\n\nexport { DIRS };\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > src/App.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\';\nimport { puzzles } from \'./data/puzzles\';\nimport {\n  DIRS,\n  canAddBridge,\n  canonicalKey,\n  computeCurrentCounts,\n  findNextIsland,\n  isVictory\n} from \'./utils/hashiLogic\';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction keyToEndpoints(islandsByXY, key) {\n  const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n  const a = islandsByXY.get(`${x1},${y1}`);\n  const b = islandsByXY.get(`${x2},${y2}`);\n  return { a, b, x1, y1, x2, y2 };\n}\n\nfunction App() {\n  const [puzzleName, setPuzzleName] = useState(\'Easy\');\n  const puzzle = useMemo(\n    () => puzzles.find((p) => p.name === puzzleName) || puzzles[0],\n    [puzzleName]\n  );\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedIslandId, setSelectedIslandId] = useState(null);\n  const [cursorIslandId, setCursorIslandId] = useState(0);\n  const [error, setError] = useState(null);\n  const [victory, setVictory] = useState(false);\n\n  const islands = puzzle.islands;\n  const islandsById = useMemo(() => {\n    const m = new Map();\n    for (const isl of islands) m.set(isl.id, isl);\n    return m;\n  }, [islands]);\n\n  const islandsByXY = useMemo(() => {\n    const m = new Map();\n    for (const isl of islands) m.set(`${isl.x},${isl.y}`, isl);\n    return m;\n  }, [islands]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n\n  const pendingSelectionRef = useRef({ cursorIslandId, selectedIslandId });\n  useEffect(() => {\n    pendingSelectionRef.current = { cursorIslandId, selectedIslandId };\n  }, [cursorIslandId, selectedIslandId]);\n\n  // Reset cursor to island 0 after any puzzle change\n  useEffect(() => {\n    setBridges(new Map());\n    setSelectedIslandId(null);\n    setCursorIslandId(0);\n    setError(null);\n    setVictory(false);\n  }, [puzzleName]);\n\n  // Recompute victory when bridges change\n  useEffect(() => {\n    setVictory(isVictory(islands, bridges));\n  }, [islands, bridges]);\n\n  useEffect(() => {\n    function onKeyDown(e) {\n      // Global listeners: do not require focused node\n      const { cursorIslandId: cur, selectedIslandId: sel } = pendingSelectionRef.current;\n\n      if (e.key === \'Escape\') {\n        setSelectedIslandId(null);\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        if (sel == null) {\n          setSelectedIslandId(cur);\n        } else {\n          if (sel === cur) {\n            // Keep selection as-is\n            return;\n          }\n          toggleBridgeByIslands(sel, cur);\n        }\n        return;\n      }\n\n      let dir = null;\n      if (e.key === \'ArrowLeft\') dir = { dx: -1, dy: 0 };\n      if (e.key === \'ArrowRight\') dir = { dx: 1, dy: 0 };\n      if (e.key === \'ArrowUp\') dir = { dx: 0, dy: -1 };\n      if (e.key === \'ArrowDown\') dir = { dx: 0, dy: 1 };\n      if (!dir) return;\n\n      e.preventDefault();\n      const nextId = findNextIsland(islands, cur, dir);\n      setCursorIslandId(nextId);\n    }\n\n    window.addEventListener(\'keydown\', onKeyDown);\n    return () => window.removeEventListener(\'keydown\', onKeyDown);\n  }, [islands]);\n\n  function toggleBridgeByIslands(fromId, toId) {\n    const from = islandsById.get(fromId);\n    const to = islandsById.get(toId);\n    if (!from || !to) return;\n\n    setBridges((prev) => {\n      const next = new Map(prev);\n      const key = canonicalKey(from, to);\n      const existing = next.get(key) ?? 0;\n      const desired = existing === 0 ? 1 : existing === 1 ? 2 : 0;\n      const delta = desired - existing;\n\n      // If removing (delta<0), allow directly (no need for canAddBridge)\n      if (delta < 0) {\n        if (desired === 0) next.delete(key);\n        else next.set(key, desired);\n        // valid move\n        setError(null);\n        setSelectedIslandId(null);\n        setCursorIslandId(0);\n        return next;\n      }\n\n      if (delta === 0) {\n        setSelectedIslandId(null);\n        return next;\n      }\n\n      const res = canAddBridge(islands, next, from, to, delta);\n      if (!res.valid) {\n        // Error must reset in-progress selection so next click starts fresh\n        setError(res.error);\n        setSelectedIslandId(null);\n        return prev;\n      }\n\n      // apply\n      if (desired === 0) next.delete(key);\n      else next.set(key, desired);\n\n      setError(null);\n      setSelectedIslandId(null);\n      setCursorIslandId(0);\n      return next;\n    });\n  }\n\n  function onIslandClick(islandId) {\n    setCursorIslandId(islandId);\n    if (selectedIslandId == null) {\n      setSelectedIslandId(islandId);\n      return;\n    }\n    if (selectedIslandId === islandId) {\n      // Deselect\n      setSelectedIslandId(null);\n      return;\n    }\n    toggleBridgeByIslands(selectedIslandId, islandId);\n  }\n\n  function removeBridgePairByKey(key) {\n    setBridges((prev) => {\n      if (!prev.has(key)) return prev;\n      const next = new Map(prev);\n      next.delete(key);\n      setError(null);\n      setSelectedIslandId(null);\n      setCursorIslandId(0);\n      return next;\n    });\n  }\n\n  function renderBridgeLines() {\n    const lines = [];\n    for (const [key, n] of bridges.entries()) {\n      if (n <= 0) continue;\n      const { a, b, x1, y1, x2, y2 } = keyToEndpoints(islandsByXY, key);\n      if (!a || !b) continue;\n\n      const px1 = x1 * GRID;\n      const py1 = y1 * GRID;\n      const px2 = x2 * GRID;\n      const py2 = y2 * GRID;\n\n      const isH = y1 === y2;\n      const isV = x1 === x2;\n\n      const baseStyle = {\n        stroke: \'#0f0\',\n        strokeWidth: 4,\n        strokeLinecap: \'round\'\n      };\n\n      const attachHandlers = (lineKeySuffix) => ({\n        onClick: (e) => {\n          if (e.ctrlKey) {\n            e.preventDefault();\n            removeBridgePairByKey(key);\n          }\n        },\n        onContextMenu: (e) => {\n          e.preventDefault();\n          removeBridgePairByKey(key);\n        },\n        \'data-bridge\': `${key}:${lineKeySuffix}`\n      });\n\n      if (n === 1) {\n        lines.push(\n          <line\n            key={`b-${key}-single`}\n            x1={px1}\n            y1={py1}\n            x2={px2}\n            y2={py2}\n            {...attachHandlers(\'single\')}\n            style={baseStyle}\n          />\n        );\n      } else if (n === 2) {\n        // Parallel offset in pixels\n        const offset = 6;\n        const dx = isH ? 0 : offset;\n        const dy = isV ? 0 : offset;\n\n        // For horizontal line, offset in Y; for vertical line, offset in X\n        if (isH) {\n          lines.push(\n            <line\n              key={`b-${key}-d1`}\n              x1={px1}\n              y1={py1 - offset}\n              x2={px2}\n              y2={py2 - offset}\n              {...attachHandlers(\'double1\')}\n              style={baseStyle}\n            />\n          );\n          lines.push(\n            <line\n              key={`b-${key}-d2`}\n              x1={px1}\n              y1={py1 + offset}\n              x2={px2}\n              y2={py2 + offset}\n              {...attachHandlers(\'double2\')}\n              style={baseStyle}\n            />\n          );\n        } else if (isV) {\n          lines.push(\n            <line\n              key={`b-${key}-d1`}\n              x1={px1 - offset}\n              y1={py1}\n              x2={px2 - offset}\n              y2={py2}\n              {...attachHandlers(\'double1\')}\n              style={baseStyle}\n            />\n          );\n          lines.push(\n            <line\n              key={`b-${key}-d2`}\n              x1={px1 + offset}\n              y1={py1}\n              x2={px2 + offset}\n              y2={py2}\n              {...attachHandlers(\'double2\')}\n              style={baseStyle}\n            />\n          );\n        } else {\n          // Shouldn\'t happen\n          lines.push(\n            <line\n              key={`b-${key}-fallback`}\n              x1={px1 + dx}\n              y1={py1 + dy}\n              x2={px2 + dx}\n              y2={py2 + dy}\n              {...attachHandlers(\'fallback\')}\n              style={baseStyle}\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  }\n\n  const cursorIsland = islandsById.get(cursorIslandId) || islands[0];\n  const cursorPx = cursorIsland\n    ? { x: cursorIsland.x * GRID, y: cursorIsland.y * GRID }\n    : { x: 0, y: 0 };\n\n  return (\n    <div className="app-root">\n      <div className="hud">\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={puzzleName}\n            onChange={(e) => {\n              // fully reset bridges/selection/error/victory in same update via effect\n              setPuzzleName(e.target.value);\n            }}\n          >\n            <option value="Easy">Easy</option>\n            <option value="Medium">Medium</option>\n            <option value="Hard">Hard</option>\n          </select>\n        </label>\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedIslandId(null);\n            setCursorIslandId(0);\n            setError(null);\n            setVictory(false);\n          }}\n        >\n          Reset\n        </button>\n        <div className="status">\n          {selectedIslandId != null ? `Selected: ${selectedIslandId}` : \'Selected: (none)\'}\n        </div>\n      </div>\n\n      {error ? <div className="error-message">{error}</div> : null}\n      {victory ? <div className="victory-banner">SOLVED!</div> : null}\n\n      <svg\n        width={SVG_W}\n        height={SVG_H}\n        viewBox={`0 0 ${SVG_W} ${SVG_H}`}\n        className="board"\n      >\n        {/* Bridges */}\n        {renderBridgeLines()}\n\n        {/* Cursor (must not be a circle) */}\n        <rect\n          x={cursorPx.x - 18}\n          y={cursorPx.y - 18}\n          width={36}\n          height={36}\n          fill="none"\n          stroke="#0f0"\n          strokeWidth={2}\n          strokeDasharray="4 3"\n          className="cursor"\n        />\n\n        {/* Islands */}\n        {islands.map((isl) => {\n          const px = isl.x * GRID;\n          const py = isl.y * GRID;\n          const isSelected = selectedIslandId === isl.id;\n          const curCount = counts.get(isl.id) ?? 0;\n          return (\n            <g key={isl.id} className="island" onClick={() => onIslandClick(isl.id)}>\n              <circle\n                cx={px}\n                cy={py}\n                r={16}\n                fill="black"\n                stroke={isSelected ? \'#9f9\' : \'#0f0\'}\n                strokeWidth={isSelected ? 4 : 2}\n              />\n              <text\n                x={px}\n                y={py + 5}\n                textAnchor="middle"\n                fontSize="16"\n                fill="#0f0"\n              >\n                {isl.value}\n              </text>\n              <text\n                x={px}\n                y={py + 28}\n                textAnchor="middle"\n                fontSize="10"\n                fill="#0f0"\n              >\n                {curCount}/{isl.value}\n              </text>\n            </g>\n          );\n        })}\n      </svg>\n    </div>\n  );\n}\n\nexport default App;\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
