[?2004l[?2004h> }
[?2004le[?2004h> 
[?2004ly[?2004h> function findNextIslandInDirection(islands, from, dir) {
[?2004l[?2004h>   // dir: 'left'|'right'|'up'|'down'
[?2004l[?2004h>   let best = null;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h>     if (dir === 'left' && isl.y === from.y && isl.x < from.x) {
[?2004l[?2004h>       if (!best || isl.x > best.x) best = isl;
[?2004l[?2004h>     } else if (dir === 'right' && isl.y === from.y && isl.x > from.x) {
[?2004l[?2004h>       if (!best || isl.x < best.x) best = isl;
[?2004l[?2004h>     } else if (dir === 'up' && isl.x === from.x && isl.y < from.y) {
[?2004l[?2004h>       if (!best || isl.y > best.y) best = isl;
[?2004l[?2004h>     } else if (dir === 'down' && isl.x === from.x && isl.y > from.y) {
[?2004l[?2004h>       if (!best || isl.y < best.y) best = isl;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return best;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleName, setPuzzleName] = useState('Easy');
[?2004l[?2004h>   const puzzle = useMemo(
