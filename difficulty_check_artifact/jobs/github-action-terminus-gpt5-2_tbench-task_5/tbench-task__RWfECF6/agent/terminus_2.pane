[?2004l[?2004h> const ERR_NON_ADJ = "Cannot connect non-adjacent islands";
[?2004l[?2004h> const ERR_MAX_PAIR = "Max 2 bridges per pair";
[?2004l[?2004h> const ERR_EXCEED = "Island would exceed its number";
[?2004l[?2004h> const ERR_CROSS = "Bridges would cross";
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;
[?2004l[?2004h>   const second = first === a ? b : a;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!from || !to) return false;
[?2004l[?2004h>   if (from.id === to.id) return false;
[?2004l[?2004h>   if (!isAligned(from, to)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // Must be no island strictly between them on the segment.
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const x = from.x;
[?2004l[?2004h>     const y1 = Math.min(from.y, to.y);
[?2004l[?2004h>     const y2 = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.x === x && isl.y > y1 && isl.y < y2) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const y = from.y;
[?2004l[?2004h>   const x1 = Math.min(from.x, to.x);
[?2004l[?2004h>   const x2 = Math.max(from.x, to.x);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>     if (isl.y === y && isl.x > x1 && isl.x < x2) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentCrosses(aKey, bKey) {
[?2004l[?2004h>   const A = parseKey(aKey);
[?2004l[?2004h>   const B = parseKey(bKey);
[?2004l[?2004h> 
[?2004l[?2004h>   const Avert = A.x1 === A.x2;
[?2004l[?2004h>   const Bvert = B.x1 === B.x2;
[?2004l[?2004h> 
[?2004l[?2004h>   if (Avert === Bvert) return false; // parallel can't cross (collinear overlap can't happen with adjacency rules)
[?2004l[?2004h> 
[?2004l[?2004h>   const V = Avert ? A : B;
[?2004l[?2004h>   const H = Avert ? B : A;
[?2004l[?2004h> 
[?2004l[?2004h>   const vx = V.x1;
[?2004l[?2004h>   const vyMin = Math.min(V.y1, V.y2);
[?2004l[?2004h>   const vyMax = Math.max(V.y1, V.y2);
[?2004l[?2004h> 
[?2004l[?2004h>   const hy = H.y1;
[?2004l[?2004h>   const hxMin = Math.min(H.x1, H.x2);
[?2004l[?2004h>   const hxMax = Math.max(H.x1, H.x2);
[?2004l[?2004h> 
[?2004l[?2004h>   const ix = vx;
[?2004l[?2004h>   const iy = hy;
[?2004l[?2004h> 
[?2004l[?2004h>   // strict intersection interior to both segments
[?2004l[?2004h>   const withinV = iy > vyMin && iy < vyMax;
[?2004l[?2004h>   const withinH = ix > hxMin && ix < hxMax;
[?2004l[?2004h>   if (!withinV || !withinH) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // Crossing at an island coordinate is allowed, but with adjacency segments,
[?2004l[?2004h>   // interior intersection cannot be an endpoint. Still, keep guard:
[?2004l[?2004h>   const isEndpoint =
[?2004l[?2004h>     (ix === V.x1 && iy === V.y1) || (ix === V.x2 && iy === V.y2) ||
[?2004l[?2004h>     (ix === H.x1 && iy === H.y1) || (ix === H.x2 && iy === H.y2);
[?2004l[?2004h>   if (isEndpoint) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERR_NON_ADJ };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: true, error: null }; // removal always ok
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   // check island max
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // check crossing (for additions only)
[?2004l[?2004h>   if (delta > 0 && next > 0) {
[?2004l[?2004h>     for (const [otherKey, otherN] of bridges.entries()) {
[?2004l[?2004h>       if (!otherN) continue;
[?2004l[?2004h>       if (otherKey === key) continue;
[?2004l[?2004h>       if (segmentCrosses(key, otherKey)) {
[?2004l[?2004h>         return { valid: false, error: ERR_CROSS };
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));
[?2004l[?2004h>   const adj = new Map(islands.map((i) => [i.id, []]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = posToId.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = posToId.get(`${x2},${y2}`);
[?2004l[?2004h>     if (a == null || b == null) continue;
[?2004l[?2004h>     adj.get(a).push(b);
[?2004l[?2004h>     adj.get(b).push(a);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   const stack = [start];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     for (const nxt of adj.get(cur) ?? []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt);
[?2004l[?2004h>         stack.push(nxt);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // counts satisfied
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // no crossings
[?2004l[?2004h>   const keys = Array.from(bridges.entries()).filter(([, n]) => n > 0).map(([k]) => k);
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       if (segmentCrosses(keys[i], keys[j])) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // connected
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export const ERRORS = {
[?2004l[?2004h>   ERR_NON_ADJ,
[?2004l[?2004h>   ERR_MAX_PAIR,
[?2004l[?2004h>   ERR_EXCEED,
[?2004l[?2004h>   ERR_CROSS
[?2004l[?2004h> };
