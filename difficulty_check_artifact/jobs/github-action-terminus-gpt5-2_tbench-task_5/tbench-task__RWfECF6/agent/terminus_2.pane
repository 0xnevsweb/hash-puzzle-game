[?2004l[?2004h> }
[?2004lc[?2004h> 
[?2004lt[?2004h> function bridgeEndpointsPx(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return {
[?2004l[?2004h>     x1: x1 * GRID,
[?2004l[?2004h>     y1: y1 * GRID,
[?2004l[?2004h>     x2: x2 * GRID,
[?2004l[?2004h>     y2: y2 * GRID,
[?2004l[?2004h>     gx1: x1,
[?2004l[?2004h>     gy1: y1,
[?2004l[?2004h>     gx2: x2,
[?2004l[?2004h>     gy2: y2
[?2004l[?2004h>   };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function findIslandById(islands, id) {
