[70.658334, "i", "cat > src/index.css <<'EOF'\nhtml, body {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  font-family: monospace;\n  background-color: black;\n  color: #0f0;\n}\n\n#root {\n  width: 100%;\n  height: 100%;\n}\n\n.app {\n  padding: 0;\n  margin: 0;\n}\n\n.hud {\n  position: relative;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  padding: 8px;\n}\n\nselect, button {\n  background: black;\n  color: #0f0;\n  border: 1px solid #0f0;\n  font-family: monospace;\n  padding: 2px 6px;\n}\n\n.error-message {\n  padding: 6px 8px;\n  border-top: 1px solid #0f0;\n  border-bottom: 1px solid #0f0;\n  color: #0f0;\n}\n\n.victory-banner {\n  padding: 6px 8px;\n  border-top: 1px solid #0f0;\n  border-bottom: 1px solid #0f0;\n  font-weight: bold;\n}\n\n.board {\n  display: block;\n  position: relative;\n  left: 0;\n  top: 0;\n}\nEOF\n"]
