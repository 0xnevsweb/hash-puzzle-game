[72.162383, "o", "\u001b[2mdist/\u001b[22m\u001b[2massets/\u001b[22m\u001b[36mindex-_vzUv7gJ.js   \u001b[39m\u001b[1m\u001b[2m149.64 kB\u001b[22m\u001b[1m\u001b[22m\u001b[2m │ gzip: 48.57 kB\u001b[22m\r\n"]
