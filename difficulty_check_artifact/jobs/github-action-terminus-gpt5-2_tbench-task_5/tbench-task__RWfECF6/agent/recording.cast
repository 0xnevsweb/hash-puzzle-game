[81.354132, "o", "echo \"\\n--- build exit code: $? ---\" \r\n\u001b[?2004l\r\\n--- build exit code: 0 ---\r\n\u001b[?2004hroot@32828b302bc8:/app# "]
[81.477689, "i", "sed -n '1,220p' src/utils/hashiLogic.js\n"]
[81.478008, "o", "sed -n '1,220p' src/utils/hashiLogic.js\r\n\u001b[?2004l\r"]
[81.479954, "o", "const ERR_NON_ADJ = \"Cannot connect non-adjacent islands\";\r\nconst ERR_MAX_PAIR = \"Max 2 bridges per pair\";\r\nconst ERR_EXCEED = \"Island would exceed its number\";\r\nconst ERR_CROSS = \"Bridges would cross\";\r\n\r\n"]
[81.47999, "o", "export function canonicalBridgeKey(from, to) {\r\n  const a = { x: from.x, y: from.y };\r\n  const b = { x: to.x, y: to.y };\r\n  const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;\r\n  const second = first === a ? b : a;\r\n  return `${first.x},${first.y},${second.x},${second.y}`;\r\n}\r\n\r\nfunction isAligned(a, b) {\r\n  return a.x === b.x || a.y === b.y;\r\n}\r\n\r\nexport function areAdjacent(islands, from, to) {\r\n"]
[81.48, "o", "  if (!from || !to) return false;\r\n  if (from.id === to.id) return false;\r\n  if (!isAligned(from, to)) return false;\r\n\r\n  // Must be no island strictly between them on the segment.\r\n  if (from.x === to.x) {\r\n"]
[81.480012, "o", "    const x = from.x;\r\n    const y1 = Math.min(from.y, to.y);\r\n    const y2 = Math.max(from.y, to.y);\r\n    for (const isl of islands) {\r\n"]
[81.480022, "o", "      if (isl.id === from.id || isl.id === to.id) continue;\r\n      if (isl.x === x && isl.y > y1 && isl.y < y2) return false;\r\n    }\r\n"]
[81.480031, "o", "    return true;\r\n  }\r\n\r\n"]
[81.48004, "o", "  const y = from.y;\r\n  const x1 = Math.min(from.x, to.x);\r\n  const x2 = Math.max(from.x, to.x);\r\n"]
[81.480057, "o", "  for (const isl of islands) {\r\n    if (isl.id === from.id || isl.id === to.id) continue;\r\n    if (isl.y === y && isl.x > x1 && isl.x < x2) return false;\r\n  }"]
[81.480069, "o", "\r\n  return true;\r\n}\r\n\r\n"]
[81.480078, "o", "function parseKey(key) {\r\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n  return { x1, y1, x2, y2 };\r\n}\r\n"]
[81.480087, "o", "\r\nfunction segmentCrosses(aKey, bKey) {\r\n  const A = parseKey(aKey);\r\n"]
[81.480097, "o", "  const B = parseKey(bKey);\r\n\r\n  const Avert = A.x1 === A.x2;\r\n"]
[81.480109, "o", "  const Bvert = B.x1 === B.x2;\r\n\r\n  if (Avert === Bvert) return false; // parallel can't cross (collinear overlap can't happen with adjacency rules)\r\n\r\n"]
[81.480117, "o", "  const V = Avert ? A : B;\r\n  const H = Avert ? B : A;\r\n\r\n"]
[81.480126, "o", "  const vx = V.x1;\r\n  const vyMin = Math.min(V.y1, V.y2);\r\n  const vyMax = Math.max(V.y1, V.y2);\r\n"]
[81.480134, "o", "\r\n  const hy = H.y1;\r\n  const hxMin = Math.min(H.x1, H.x2);\r\n"]
[81.480142, "o", "  const hxMax = Math.max(H.x1, H.x2);\r\n\r\n  const ix = vx;\r\n"]
[81.480152, "o", "  const iy = hy;\r\n\r\n  // strict intersection interior to both segments\r\n"]
[81.480165, "o", "  const withinV = iy > vyMin && iy < vyMax;\r\n  const withinH = ix > hxMin && ix < hxMax;\r\n  if (!withinV || !withinH) return false;\r\n\r\n"]
[81.480179, "o", "  // Crossing at an island coordinate is allowed, but with adjacency segments,\r\n  // interior intersection cannot be an endpoint. Still, keep guard:\r\n  const isEndpoint =\r\n"]
[81.480187, "o", "    (ix === V.x1 && iy === V.y1) || (ix === V.x2 && iy === V.y2) ||\r\n    (ix === H.x1 && iy === H.y1) || (ix === H.x2 && iy === H.y2);\r\n  if (isEndpoint) return false;\r\n\r\n"]
[81.480198, "o", "  return true;\r\n}\r\n\r\n"]
[81.480207, "o", "export function computeCurrentCounts(islands, bridges) {\r\n"]
[81.480222, "o", "  const counts = new Map();\r\n  for (const isl of islands) counts.set(isl.id, 0);\r\n\r\n  for (const [key, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    const { x1, y1, x2, y2 } = parseKey(key);\r\n"]
[81.480239, "o", "    const a = islands.find((i) => i.x === x1 && i.y === y1);\r\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\r\n    if (!a || !b) continue;\r\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\r\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\r\n  }\r\n\r\n  return counts;\r\n}\r\n\r\nexport function canAddBridge(islands, bridges, from, to, delta) {\r\n"]
[81.480253, "o", "  if (!areAdjacent(islands, from, to)) {\r\n    return { valid: false, error: ERR_NON_ADJ };\r\n  }\r\n"]
[81.480263, "o", "\r\n  const key = canonicalBridgeKey(from, to);\r\n  const current = bridges.get(key) ?? 0;\r\n  const next = current + delta;\r\n\r\n"]
[81.480272, "o", "  if (next < 0) return { valid: true, error: null }; // removal always ok\r\n  if (next > 2) return { valid: false, error: ERR_MAX_PAIR };\r\n\r\n"]
[81.48029, "o", "  // check island max\r\n  const counts = computeCurrentCounts(islands, bridges);\r\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\r\n  const toCount = (counts.get(to.id) ?? 0) + delta;\r\n  if (fromCount > from.value || toCount > to.value) {\r\n"]
[81.480299, "o", "    return { valid: false, error: ERR_EXCEED };\r\n  }\r\n\r\n"]
[81.480315, "o", "  // check crossing (for additions only)\r\n  if (delta > 0 && next > 0) {\r\n    for (const [otherKey, otherN] of bridges.entries()) {\r\n      if (!otherN) continue;\r\n"]
[81.480327, "o", "      if (otherKey === key) continue;\r\n      if (segmentCrosses(key, otherKey)) {\r\n        return { valid: false, error: ERR_CROSS };\r\n"]
[81.480343, "o", "      }\r\n    }\r\n  }\r\n\r\n  return { valid: true, error: null };\r\n"]
[81.480353, "o", "}\r\n\r\nexport function checkConnectivity(islands, bridges) {\r\n"]
[81.480365, "o", "  if (islands.length === 0) return true;\r\n\r\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\r\n"]
[81.480374, "o", "  const adj = new Map(islands.map((i) => [i.id, []]));\r\n\r\n  for (const [key, n] of bridges.entries()) {\r\n"]
[81.480383, "o", "    if (!n) continue;\r\n    const { x1, y1, x2, y2 } = parseKey(key);\r\n    const a = posToId.get(`${x1},${y1}`);\r\n"]
[81.480391, "o", "    const b = posToId.get(`${x2},${y2}`);\r\n    if (a == null || b == null) continue;\r\n    adj.get(a).push(b);\r\n"]
[81.4804, "o", "    adj.get(b).push(a);\r\n  }\r\n\r\n"]
[81.480408, "o", "  const start = islands[0].id;\r\n  const seen = new Set([start]);\r\n  const stack = [start];\r\n"]
[81.480417, "o", "  while (stack.length) {\r\n    const cur = stack.pop();\r\n    for (const nxt of adj.get(cur) ?? []) {\r\n"]
[81.480425, "o", "      if (!seen.has(nxt)) {\r\n        seen.add(nxt);\r\n        stack.push(nxt);\r\n"]
[81.480434, "o", "      }\r\n    }\r\n  }\r\n"]
[81.480443, "o", "\r\n  return seen.size === islands.length;\r\n}\r\n"]
[81.480451, "o", "\r\nexport function isVictory(islands, bridges) {\r\n  // counts satisfied\r\n"]
[81.48046, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n  for (const isl of islands) {\r\n"]
[81.480469, "o", "    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n  }\r\n\r\n"]
[81.48048, "o", "  // no crossings\r\n  const keys = Array.from(bridges.entries()).filter(([, n]) => n > 0).map(([k]) => k);\r\n  for (let i = 0; i < keys.length; i++) {\r\n"]
[81.480488, "o", "    for (let j = i + 1; j < keys.length; j++) {\r\n      if (segmentCrosses(keys[i], keys[j])) return false;\r\n    }\r\n"]
[81.480502, "o", "  }\r\n\r\n  // connected\r\n"]
[81.48051, "o", "  return checkConnectivity(islands, bridges);\r\n}\r\n\r\nexport const ERRORS = {\r\n"]
[81.48052, "o", "  ERR_NON_ADJ,\r\n  ERR_MAX_PAIR,\r\n  ERR_EXCEED,\r\n  ERR_CROSS\r\n"]
[81.480532, "o", "};\r\n"]
[81.481615, "o", "\u001b[?2004hroot@32828b302bc8:/app# "]
