[147.816087, "o", "// Hashi (Bridges) game logic\r\n\r\nfunction keyFromCoords(a, b) {\r\n  const p1 = { x: a.x, y: a.y };\r\n  const p2 = { x: b.x, y: b.y };\r\n  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\r\n  const second = first === p1 ? p2 : p1;\r\n  return `${first.x},${first.y},${second.x},${second.y}`;\r\n"]
[147.816341, "o", "}\r\n\r\nfunction buildOccupancy(islands) {\r\n  const byXY = new Map();\r\n  const byId = new Map();\r\n  for (const isl of islands) {\r\n    byXY.set(`${isl.x},${isl.y}`, isl);\r\n    byId.set(isl.id, isl);\r\n  }\r\n"]
[147.816468, "o", "  return { byXY, byId };\r\n}\r\n\r\nfunction isOrthogonal(a, b) {\r\n  return a.x === b.x || a.y === b.y;\r\n}\r\n\r\n// Adjacent means: same row/col and no other island between them.\r\nfunction areAdjacent(islands, a, b) {\r\n  if (!isOrthogonal(a, b)) return false;\r\n  if (a.x === b.x) {\r\n    const x = a.x;\r\n    const y1 = Math.min(a.y, b.y);\r\n    const y2 = Math.max(a.y, b.y);\r\n    for (const isl of islands) {\r\n      if (isl.x === x && isl.y > y1 && isl.y < y2) return false;\r\n    }\r\n    return true;\r\n  }\r\n  const y = a.y;\r\n  const x1 = Math.min(a.x, b.x);\r\n  const x2 = Math.max(a.x, b.x);\r\n  for (const isl of islands) {\r\n"]
[147.817543, "o", "  // crossing check\r\n  const entries = [...bridges.entries()].filter(([, n]) => n);\r\n  for (let i = 0; i < entries.length; i++) {\r\n    const [kA] = entries[i];\r\n    const [ax1, ay1, ax2, ay2] = kA.split(',').map(Number);\r\n    const a1 = { x: ax1, y: ay1 };\r\n    const a2 = { x: ax2, y: ay2 };\r\n\r\n    for (let j = i + 1; j < entries.length; j++) {\r\n      const [kB] = entries[j];\r\n      const [bx1, by1, bx2, by2] = kB.split(',').map(Number);\r\n      const b1 = { x: bx1, y: by1 };\r\n      const b2 = { x: bx2, y: by2 };\r\n\r\n      const sharesEndpoint =\r\n        (a1.x === b1.x && a1.y === b1.y) ||\r\n        (a1.x === b2.x && a1.y === b2.y) ||\r\n        (a2.x === b1.x && a2.y === b1.y) ||\r\n        (a2.x === b2.x && a2.y === b2.y);\r\n      if (sharesEndpoint) continue;\r\n\r\n      if (segmentIntersectsStrict(a1, a2, b1, b2)) return false;\r\n    }\r\n  }\r\n\r\n"]
[147.817641, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n  for (const isl of islands) {\r\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n  }\r\n\r\n  return checkConnectivity(islands, bridges);\r\n}\r\n"]
[147.817732, "o", "\r\nexport function bridgeKey(from, to) {\r\n  return keyFromCoords(from, to);\r\n}\r\n\r\nexport function areIslandsAdjacent(islands, from, to) {\r\n  return areAdjacent(islands, from, to);\r\n}\r\n"]
