[137.265714, "i", "ckConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  const { byXY } = buildOccupancy(islands);\n\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, new Set());\n\n  for (const [k, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = k.split(',').map(Number);\n    const a = byXY.get(`${x1},${y1}`);\n    const b = byXY.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a.id).add(b.id);\n    adj.get(b.id).add(a.id);\n  }\n\n  const seen = new Set();\n  const stack = [islands[0].id];\n  while (stack.length) {\n    const cur = stack.pop();\n    if (seen.has(cur)) continue;\n    seen.add(cur);\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) stack.push(nxt);\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: true, error: null };\n\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: 'Canno"]
[137.265832, "i", "t connect non-adjacent islands' };\n  }\n\n  const k = keyFromCoords(from, to);\n  const current = bridges.get(k) ?? 0;\n  const next = current + delta;\n\n  if (next > 2) return { valid: false, error: 'Max 2 bridges per pair' };\n  if (next < 0) return { valid: true, error: null };\n\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = (counts.get(from.id) ?? 0) + delta;\n  const toCount = (counts.get(to.id) ?? 0) + delta;\n  if (fromCount > from.value || toCount > to.value) {\n    return { valid: false, error: 'Island would exceed its number' };\n  }\n\n  if (delta > 0 && bridgesWouldCross(bridges, from, to)) {\n    return { valid: false, error: 'Bridges would cross' };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function isVictory(islands, bridges) {\n  // crossing check\n  const entries = [...bridges.entries()].filter(([, n]) => n);\n  for (let i = 0; i < entries.length; i++) {\n    const [kA] = entries[i];\n    const [ax1, ay1, ax2, ay2] = kA.split(',').map(Number);\n    const a1 = { x: ax1, "]
[137.26589, "o", "> "]
[137.266646, "i", "y: ay1 };\n    const a2 = { x: ax2, y: ay2 };\n\n    for (let j = i + 1; j < entries.length; j++) {\n      const [kB] = entries[j];\n      const [bx1, by1, bx2, by2] = kB.split(',').map(Number);\n      const b1 = { x: bx1, y: by1 };\n      const b2 = { x: bx2, y: by2 };\n\n      const sharesEndpoint =\n        (a1.x === b1.x && a1.y === b1.y) ||\n        (a1.x === b2.x && a1.y === b2.y) ||\n        (a2.x === b1.x && a2.y === b1.y) ||\n        (a2.x === b2.x && a2.y === b2.y);\n      if (sharesEndpoint) continue;\n\n      if (segmentIntersectsStrict(a1, a2, b1, b2)) return false;\n    }\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\n\nexport function bridgeKey(from, to) {\n  return keyFromCoords(from, to);\n}\n\nexport function areIslandsAdjacent(islands, from, to) {\n  return areAdjacent(islands, from, to);\n}\nEOF\n"]
