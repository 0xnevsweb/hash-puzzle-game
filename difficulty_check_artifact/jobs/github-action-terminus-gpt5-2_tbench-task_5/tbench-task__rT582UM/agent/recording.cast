[158.24511, "o", "rror(null);\r\n  }\r\n\r\n  function applyBridgeDelta(from, to, delta) {\r\n    const { valid, error: err } = canAddBridge(islands, bridges, from, to, delta);\r\n    if (!valid) {\r\n      setError(err);\r\n      return false;\r\n    }\r\n\r\n    setBridges((prev) => {\r\n      const next = new Map(prev);\r\n      const k = bridgeKey(from, to);\r\n      const current = next.get(k) ?? 0;\r\n      const updated = current + delta;\r\n      if (updated <= 0) next.delete(k);\r\n      else next.set(k, updated);\r\n      return next;\r\n    });\r\n    clearErrorOnValid();\r\n    return true;\r\n  }\r\n\r\n  function cycleBridge(from, to) {\r\n    if (!areIslandsAdjacent(islands, from, to)) {\r\n      setError('Cannot connect non-adjacent islands');\r\n      return;\r\n    }\r\n\r\n    const k = bridgeKey(from, to);\r\n    const current = bridges.get(k) ?? 0;\r\n    const target = (current + 1) % 3;\r\n    const delta = target - current;\r\n    if (delta === 0) return;\r\n\r\n    if (delta > 0) {\r\n      for (let i = 0; i < delta; i++) {\r\n        const ok = applyBridgeDelta(from, to, 1)"]
[158.245138, "o", ";\r\n        if (!ok) break;\r\n      }\r\n    } else {\r\n      applyBridgeDelta(from, to, delta);\r\n    }\r\n  }\r\n\r\n  function removeBridgeCompletely(from, to) {\r\n    const k = bridgeKey(from, to);\r\n    const current = bridges.get(k) ?? 0;\r\n    if (current === 0) return;\r\n    applyBridgeDelta(from, to, -current);\r\n  }\r\n\r\n  function onIslandLeftClick(isl) {\r\n    if (selectedIslandId == null) {\r\n      setSelectedIslandId(isl.id);\r\n      clearErrorOnValid();\r\n      return;\r\n    }\r\n\r\n    const from = findIslandById(islands, selectedIslandId);\r\n    const to = isl;\r\n\r\n    if (!from || from.id === to.id) {\r\n      setSelectedIslandId(null);\r\n      clearErrorOnValid();\r\n      return;\r\n    }\r\n\r\n    cycleBridge(from, to);\r\n    setSelectedIslandId(null);\r\n  }\r\n\r\n  function onIslandRightClick(e, isl) {\r\n    e.preventDefault();\r\n    if (selectedIslandId == null) return;\r\n    const from = findIslandById(islands, selectedIslandId);\r\n    if (!from || from.id === isl.id) return;\r\n    removeBridgeCompletely(from, isl);\r\n    setSelectedI"]
