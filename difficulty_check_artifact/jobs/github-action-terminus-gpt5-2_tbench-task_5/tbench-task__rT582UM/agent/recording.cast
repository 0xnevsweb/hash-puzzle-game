[147.941423, "o", "} from './utils/hashiLogic';\r\n\r\nconst GRID = 40;\r\nconst SVG_W = 800;\r\nconst SVG_H = 600;\r\n\r\nfunction islandPixel(isl) {\r\n  return { cx: isl.x * GRID, cy: isl.y * GRID };\r\n}\r\n\r\nfunction findIslandById(islands, id) {\r\n  return islands.find((i) => i.id === id) || null;\r\n}\r\n\r\nfunction sortedIslands(islands) {\r\n  return [...islands].sort((a, b) => a.id - b.id);\r\n}\r\n\r\nfunction neighborInDirection(islands, from, dir) {\r\n  const candidates = [];\r\n  for (const isl of islands) {\r\n    if (isl.id === from.id) continue;\r\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) candidates.push(isl);\r\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) candidates.push(isl);\r\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) candidates.push(isl);\r\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) candidates.push(isl);\r\n  }\r\n  if (candidates.length === 0) return null;\r\n  candidates.sort((a, b) => {\r\n    if (dir === 'left') return b.x - a.x;\r\n"]
[147.941439, "o", "    if (dir === 'right') return a.x - b.x;\r\n    if (dir === 'up') return b.y - a.y;\r\n"]
