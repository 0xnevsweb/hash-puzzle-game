[137.524805, "i", "cat > src/index.css <<'EOF'\n:root {\n  color-scheme: dark;\n  --bg: #000000;\n  --fg: #00ff66;\n  --dim: rgba(0, 255, 102, 0.65);\n  --danger: #ff4d4d;\n}\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background: var(--bg);\n  color: var(--fg);\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n}\n\n#root {\n  margin: 0;\n  padding: 0;\n}\n\n.controls {\n  position: absolute;\n  top: 8px;\n  left: 8px;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  z-index: 2;\n}\n\nselect, button {\n  background: transparent;\n  color: var(--fg);\n  border: 1px solid var(--fg);\n  padding: 6px 10px;\n  font: inherit;\n}\n\nbutton { cursor: pointer; }\n\n.error-message {\n  position: absolute;\n  top: 44px;\n  left: 8px;\n  color: var(--danger);\n  z-index: 2;\n}\n\n.victory-banner {\n  position: absolute;\n  top: 72px;\n  left: 8px;\n  border: 1px solid var(--fg);\n  padding: 6px 10px;\n  z-index: 2;\n}\n\nsvg.board {\n  position: absolute;\n  top: 0;\n  left: 0;\n}\nEOF\n"]
