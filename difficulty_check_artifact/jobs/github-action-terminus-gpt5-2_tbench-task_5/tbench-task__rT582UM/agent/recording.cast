[147.941496, "o", "  const byXY = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\r\n"]
[147.941504, "o", "  const segs = [];\r\n  for (const [k, count] of bridges.entries()) {\r\n"]
[147.941514, "o", "    if (!count) continue;\r\n"]
[147.941527, "o", "    const [x1, y1, x2, y2] = k.split(',').map(Number);\r\n    const a = byXY.get(`${x1},${y1}`);\r\n"]
[147.941537, "o", "    const b = byXY.get(`${x2},${y2}`);\r\n    if (!a || !b) continue;\r\n    segs.push({ key: k, count, from: { x: x1, y: y1 }, to: { x: x2, y: y2 } });\r\n"]
[147.941546, "o", "  }\r\n  return segs;\r\n}\r\n"]
[147.941555, "o", "\r\nexport default function App() {\r\n  const [puzzleKey, setPuzzleKey] = useState('Easy');\r\n"]
[147.941565, "o", "  const islands = useMemo(() => sortedIslands(PUZZLES[puzzleKey].islands), [puzzleKey]);\r\n\r\n  const [bridges, setBridges] = useState(() => new Map());\r\n"]
[147.941578, "o", "  const [selectedIslandId, setSelectedIslandId] = useState(null);\r\n  const [cursorIslandId, setCursorIslandId] = useState(0);\r\n  const [error, setError] = useState(null);\r\n"]
[147.94159, "o", "\r\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\r\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\r\n\r\n  // Park cursor on id 0 from page load and after any puzzle change.\r\n  useEffect(() => {\r\n"]
[147.941599, "o", "    setCursorIslandId(0);\r\n    setSelectedIslandId(null);\r\n  }, [puzzleKey]);\r\n\r\n"]
[147.94161, "o", "  // Park cursor on id 0 after any puzzle change.\r\n"]
