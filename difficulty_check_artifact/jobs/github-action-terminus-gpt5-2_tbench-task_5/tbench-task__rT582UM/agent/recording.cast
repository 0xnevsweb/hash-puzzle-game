[83.402171, "i", "cat > src/utils/hashiLogic.js <<'EOF'\n// Hashi (Bridges) game logic\n\nfunction keyFromCoords(a, b) {\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\n  const second = first === p1 ? p2 : p1;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction buildOccupancy(islands) {\n  const byXY = new Map();\n  const byId = new Map();\n  for (const isl of islands) {\n    byXY.set(`${isl.x},${isl.y}`, isl);\n    byId.set(isl.id, isl);\n  }\n  return { byXY, byId };\n}\n\nfunction isOrthogonal(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\n// Adjacent means: same row/col and no other island between them.\nfunction areAdjacent(islands, a, b) {\n  if (!isOrthogonal(a, b)) return false;\n  if (a.x === b.x) {\n    const x = a.x;\n    const y1 = Math.min(a.y, b.y);\n    const y2 = Math.max(a.y, b.y);\n    for (const isl of islands) {\n      if (isl.x === x && isl.y > y1 && isl.y < y2) return false;\n    }\n    return true;\n  }\n  const y = a.y"]
[83.402508, "i", ";\n  const x1 = Math.min(a.x, b.x);\n  const x2 = Math.max(a.x, b.x);\n  for (const isl of islands) {\n    if (isl.y === y && isl.x > x1 && isl.x < x2) return false;\n  }\n  return true;\n}\n\nfunction segmentIntersectsStrict(a1, a2, b1, b2) {\n  // Only considering axis-aligned segments.\n  const aVert = a1.x === a2.x;\n  const bVert = b1.x === b2.x;\n  if (aVert === bVert) return false; // parallel do not cross in Hashi (overlap not possible with adjacency constraints)\n\n  const vert = aVert ? { p1: a1, p2: a2 } : { p1: b1, p2: b2 };\n  const horz = aVert ? { p1: b1, p2: b2 } : { p1: a1, p2: a2 };\n\n  const vx = vert.p1.x;\n  const vy1 = Math.min(vert.p1.y, vert.p2.y);\n  const vy2 = Math.max(vert.p1.y, vert.p2.y);\n\n  const hy = horz.p1.y;\n  const hx1 = Math.min(horz.p1.x, horz.p2.x);\n  const hx2 = Math.max(horz.p1.x, horz.p2.x);\n\n  const crosses = vx > hx1 && vx < hx2 && hy > vy1 && hy < vy2;\n  return crosses;\n}\n\nfunction bridgesWouldCross(islands, bridges, from, to) {\n  const a1 = { x: from.x, y: from.y };\n  const a2 = { x"]
