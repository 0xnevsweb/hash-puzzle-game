[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h>     if (dir === 'left' && isl.y === from.y && isl.x < from.x) candidates.push(isl);
[?2004l[?2004h>     if (dir === 'right' && isl.y === from.y && isl.x > from.x) candidates.push(isl);
[?2004l[?2004h>     if (dir === 'up' && isl.x === from.x && isl.y < from.y) candidates.push(isl);
[?2004l[?2004h>     if (dir === 'down' && isl.x === from.x && isl.y > from.y) candidates.push(isl);
[?2004l[?2004h>   }
[?2004l[?2004h>   if (candidates.length === 0) return null;
