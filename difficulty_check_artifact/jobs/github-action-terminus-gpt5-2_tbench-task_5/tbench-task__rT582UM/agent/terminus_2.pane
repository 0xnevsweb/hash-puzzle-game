[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // No crossings:
[?2004l[?2004h>   for (const [kA, nA] of bridges.entries()) {
[?2004l[?2004h>     if (!nA) continue;
[?2004l[?2004h>     const [ax1, ay1, ax2, ay2] = kA.split(',').map(Number);
