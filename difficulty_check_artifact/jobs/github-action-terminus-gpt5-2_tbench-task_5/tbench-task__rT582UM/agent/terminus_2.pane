[?2004l[?2004h> // Hashi (Bridges) game logic
[?2004l[?2004h> 
[?2004l[?2004h> function keyFromCoords(a, b) {
[?2004l[?2004h>   const p1 = { x: a.x, y: a.y };
[?2004l[?2004h>   const p2 = { x: b.x, y: b.y };
[?2004l[?2004h>   const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;
[?2004l[?2004h>   const second = first === p1 ? p2 : p1;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function buildOccupancy(islands) {
[?2004l[?2004h>   const byXY = new Map();
[?2004l[?2004h>   const byId = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     byXY.set(`${isl.x},${isl.y}`, isl);
[?2004l[?2004h>     byId.set(isl.id, isl);
[?2004l[?2004h>   }
[?2004l[?2004h>   return { byXY, byId };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isOrthogonal(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Adjacent means: same row/col and no other island between them.
[?2004l[?2004h> function areAdjacent(islands, a, b) {
[?2004l[?2004h>   if (!isOrthogonal(a, b)) return false;
[?2004l[?2004h>   if (a.x === b.x) {
[?2004l[?2004h>     const x = a.x;
[?2004l[?2004h>     const y1 = Math.min(a.y, b.y);
[?2004l[?2004h>     const y2 = Math.max(a.y, b.y);
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.x === x && isl.y > y1 && isl.y < y2) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   const y = a.y;
[?2004l[?2004h>   const x1 = Math.min(a.x, b.x);
[?2004l[?2004h>   const x2 = Math.max(a.x, b.x);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.y === y && isl.x > x1 && isl.x < x2) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentIntersectsStrict(a1, a2, b1, b2) {
[?2004l[?2004h>   // Only considering axis-aligned segments.
[?2004l[?2004h>   const aVert = a1.x === a2.x;
[?2004l[?2004h>   const bVert = b1.x === b2.x;
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const vert = aVert ? { p1: a1, p2: a2 } : { p1: b1, p2: b2 };
[?2004l[?2004h>   const horz = aVert ? { p1: b1, p2: b2 } : { p1: a1, p2: a2 };
[?2004l[?2004h> 
[?2004l[?2004h>   const vx = vert.p1.x;
[?2004l[?2004h>   const vy1 = Math.min(vert.p1.y, vert.p2.y);
[?2004l[?2004h>   const vy2 = Math.max(vert.p1.y, vert.p2.y);
[?2004l[?2004h> 
[?2004l[?2004h>   const hy = horz.p1.y;
[?2004l[?2004h>   const hx1 = Math.min(horz.p1.x, horz.p2.x);
[?2004l[?2004h>   const hx2 = Math.max(horz.p1.x, horz.p2.x);
[?2004l[?2004h> 
[?2004l[?2004h>   // Strict interior crossing only (not touching endpoints)
[?2004l[?2004h>   return vx > hx1 && vx < hx2 && hy > vy1 && hy < vy2;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function bridgesWouldCross(bridges, from, to) {
[?2004l[?2004h>   const a1 = { x: from.x, y: from.y };
[?2004l[?2004h>   const a2 = { x: to.x, y: to.y };
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>     const b1 = { x: x1, y: y1 };
[?2004l[?2004h>     const b2 = { x: x2, y: y2 };
[?2004l[?2004h> 
[?2004l[?2004h>     const sharesEndpoint =
[?2004l[?2004h>       (a1.x === b1.x && a1.y === b1.y) ||
[?2004l[?2004h>       (a1.x === b2.x && a1.y === b2.y) ||
[?2004l[?2004h>       (a2.x === b1.x && a2.y === b1.y) ||
[?2004l[?2004h>       (a2.x === b2.x && a2.y === b2.y);
[?2004l[?2004h>     if (sharesEndpoint) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     if (segmentIntersectsStrict(a1, a2, b1, b2)) return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const { byXY } = buildOccupancy(islands);
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>     const a = byXY.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byXY.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
