[?2004l[?2004h>       return next;
[?2004l[?2004h>     });
[?2004l[?2004h>     clearErrorOnValid();
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function cycleBridge(from, to) {
[?2004l[?2004h>     if (!areIslandsAdjacent(islands, from, to)) {
[?2004l[?2004h>       setError('Cannot connect non-adjacent islands');
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     const k = bridgeKey(from, to);
[?2004l[?2004h>     const current = bridges.get(k) ?? 0;
[?2004l[?2004h>     const target = (current + 1) % 3;
[?2004l[?2004h>     const delta = target - current;
[?2004l[?2004h>     if (delta === 0) return;
[?2004l[?2004h> 
[?2004l[?2004h>     if (delta > 0) {
[?2004l[?2004h>       for (let i = 0; i < delta; i++) {
[?2004l[?2004h>         const ok = applyBridgeDelta(from, to, 1);
[?2004l[?2004h>         if (!ok) break;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       applyBridgeDelta(from, to, delta);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   function removeBridgeCompletely(from, to) {
[?2004l[?2004h>     const k = bridgeKey(from, to);
[?2004l[?2004h>     const current = bridges.get(k) ?? 0;
[?2004l[?2004h>     if (current === 0) return;
[?2004l[?2004h>     applyBridgeDelta(from, to, -current);
[?2004l[?2004h>   }
[?2004l
[?2004h> 
[?2004l[?2004h>   function onIslandLeftClick(isl) {
