[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   const { byXY } = buildOccupancy(islands);
[?2004l[?2004h> 
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, new Set());
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = k.split(',').map(Number);
[?2004l[?2004h>     const a = byXY.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = byXY.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).add(b.id);
[?2004l[?2004h>     adj.get(b.id).add(a.id);
