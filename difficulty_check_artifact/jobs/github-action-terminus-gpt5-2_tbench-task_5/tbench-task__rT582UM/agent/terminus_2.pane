  useEffect(() => {
    setCursorIslandId(0);
  }, [bridges, puzzleKey]);

  function resetAllStateToPuzzle(nextPuzzleKey) {
    setPuzzleKey(nextPuzzleKey);
    setBridges(new Map());
    setSelectedIslandId(null);
    setError(null);
    setCursorIslandId(0);
  }

  function clearErrorOnValid() {
    if (error) setError(null);
  }

  function applyBridgeDelta(from, to, delta) {
    const { valid, error: err } = canAddBridge(islands, bridges, from, to, delta);
    if (!valid) {
      setError(err);
      return false;
    }

    setBridges((prev) => {
