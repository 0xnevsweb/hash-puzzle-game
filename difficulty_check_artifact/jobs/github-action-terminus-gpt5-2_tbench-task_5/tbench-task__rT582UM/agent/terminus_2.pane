[?2004l[?2004h>     const [ax1, ay1, ax2, ay2] = kA.split(',').map(Number);
[?2004l[?2004h>     const a1 = { x: ax1, y: ay1 };
[?2004l[?2004h>     const a2 = { x: ax2, y: ay2 };
[?2004l[?2004h> 
