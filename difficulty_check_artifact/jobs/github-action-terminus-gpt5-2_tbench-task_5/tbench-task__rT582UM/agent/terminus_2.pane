[?2004limport React, { useEffect, useMemo, useState } from 'react';
import { PUZZLES, PUZZLE_OPTIONS } from './data/puzzles';
import {
  areIslandsAdjacent,
  bridgeKey,
  canAddBridge,
  computeCurrentCounts,
  isVictory
} from './utils/hashiLogic';

const GRID = 40;
const SVG_W = 800;
const SVG_H = 600;

function islandPixel(isl) {
  return { cx: isl.x * GRID, cy: isl.y * GRID };
}

function findIslandById(islands, id) {
  return islands.find((i) => i.id === id) || null;
}

function sortedIslands(islands) {
  return [...islands].sort((a, b) => a.id - b.id);
}

function neighborInDirection(islands, from, dir) {
  const candidates = [];
  for (const isl of islands) {
    if (isl.id === from.id) continue;
    if (dir === 'left' && isl.y === from.y && isl.x < from.x) candidates.push(isl);
    if (dir === 'right' && isl.y === from.y && isl.x > from.x) candidates.push(isl);
    if (dir === 'up' && isl.x === from.x && isl.y < from.y) candidates.push(isl);
    if (dir === 'down' && isl.x === from.x && isl.y > from.y) candidates.push(isl);
  }
  if (candidates.length === 0) return null;
  candidates.sort((a, b) => {
    if (dir === 'left') return b.x - a.x;
    if (dir === 'right') return a.x - b.x;
    if (dir === 'up') return b.y - a.y;
    return a.y - b.y;
  });
  const nearest = candidates[0];
  if (!areIslandsAdjacent(islands, from, nearest)) return null;
  return nearest;
}

function computeBridgeSegments(islands, bridges) {
  const byXY = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));
  const segs = [];
  for (const [k, count] of bridges.entries()) {
    if (!count) continue;
    const [x1, y1, x2, y2] = k.split(',').map(Number);
    const a = byXY.get(`${x1},${y1}`);
    const b = byXY.get(`${x2},${y2}`);
    if (!a || !b) continue;
    segs.push({ key: k, count, from: { x: x1, y: y1 }, to: { x: x2, y: y2 } });
  }
  return segs;
}

