[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     if (seen.has(cur)) continue;
[?2004l[?2004h>     seen.add(cur);
[?2004l[?2004h>     for (const nxt of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nxt)) stack.push(nxt);
