[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     cycleBridge(from, to);
[?2004l[?2004h>     setSelectedIslandId(null);
[?2004l[?2004h>   }
[?2004l[?2004h> 
