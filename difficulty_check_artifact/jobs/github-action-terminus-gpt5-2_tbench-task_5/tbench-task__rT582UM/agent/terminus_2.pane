[?2004l[?2004h>     const to = isl;
[?2004l[?2004h> 
[?2004lz[?2004h>     if (!from || from.id === to.id) {
[?2004l[?2004h>       setSelectedIslandId(null);
[?2004l[?2004h>       clearErrorOnValid();
