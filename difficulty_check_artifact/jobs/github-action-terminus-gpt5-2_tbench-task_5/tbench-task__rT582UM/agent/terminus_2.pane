[?2004l[?2004h>       setError(err);
[?2004l[?2004h>       return false;
[?2004l[?2004h>     }
[?2004lla[?2004h> 
[?2004ls[?2004h>     setBridges((prev) => {
[?2004l[?2004h>       const next = new Map(prev);
[?2004l[?2004h>       const k = bridgeKey(from, to);
[?2004l[?2004h>       const current = next.get(k) ?? 0;
