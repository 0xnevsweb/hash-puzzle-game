// Hashi (Bridges) game logic

function keyFromCoords(a, b) {
  const p1 = { x: a.x, y: a.y };
  const p2 = { x: b.x, y: b.y };
  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;
  const second = first === p1 ? p2 : p1;
  return `${first.x},${first.y},${second.x},${second.y}`;
}

function buildOccupancy(islands) {
  const byXY = new Map();
  const byId = new Map();
  for (const isl of islands) {
    byXY.set(`${isl.x},${isl.y}`, isl);
    byId.set(isl.id, isl);
  }
  return { byXY, byId };
}

function isOrthogonal(a, b) {
  return a.x === b.x || a.y === b.y;
}

// Adjacent means: same row/col and no other island between them.
function areAdjacent(islands, a, b) {
  if (!isOrthogonal(a, b)) return false;
  if (a.x === b.x) {
    const x = a.x;
    const y1 = Math.min(a.y, b.y);
    const y2 = Math.max(a.y, b.y);
    for (const isl of islands) {
      if (isl.x === x && isl.y > y1 && isl.y < y2) return false;
    }
    return true;
  }
  const y = a.y;
  const x1 = Math.min(a.x, b.x);
  const x2 = Math.max(a.x, b.x);
  for (const isl of islands) {
  // crossing check
  const entries = [...bridges.entries()].filter(([, n]) => n);
  for (let i = 0; i < entries.length; i++) {
    const [kA] = entries[i];
    const [ax1, ay1, ax2, ay2] = kA.split(',').map(Number);
    const a1 = { x: ax1, y: ay1 };
    const a2 = { x: ax2, y: ay2 };

    for (let j = i + 1; j < entries.length; j++) {
      const [kB] = entries[j];
      const [bx1, by1, bx2, by2] = kB.split(',').map(Number);
      const b1 = { x: bx1, y: by1 };
      const b2 = { x: bx2, y: by2 };

      const sharesEndpoint =
        (a1.x === b1.x && a1.y === b1.y) ||
        (a1.x === b2.x && a1.y === b2.y) ||
        (a2.x === b1.x && a2.y === b1.y) ||
        (a2.x === b2.x && a2.y === b2.y);
      if (sharesEndpoint) continue;

      if (segmentIntersectsStrict(a1, a2, b1, b2)) return false;
    }
  }

  const counts = computeCurrentCounts(islands, bridges);
  for (const isl of islands) {
    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
  }

  return checkConnectivity(islands, bridges);
}

export function bridgeKey(from, to) {
  return keyFromCoords(from, to);
}

export function areIslandsAdjacent(islands, from, to) {
  return areAdjacent(islands, from, to);
}
