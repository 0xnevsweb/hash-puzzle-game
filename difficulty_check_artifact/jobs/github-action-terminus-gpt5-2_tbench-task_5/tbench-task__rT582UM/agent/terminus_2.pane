[?2004l[?2004h>       const b1 = { x: bx1, y: by1 };
[?2004l[?2004h>       const b2 = { x: bx2, y: by2 };
[?2004l[?2004h> 
[?2004l[?2004h>       const sharesEndpoint =
[?2004l[?2004h>         (a1.x === b1.x && a1.y === b1.y) ||
[?2004l[?2004h>         (a1.x === b2.x && a1.y === b2.y) ||
[?2004l[?2004h>         (a2.x === b1.x && a2.y === b1.y) ||
