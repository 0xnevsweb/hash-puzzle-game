   onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeContextMenu(key, e)}\n              style={{ cursor: \'pointer\' }}\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'-b\'}\n              x1={px1 + offset} y1={py1} x2={px2 + offset} y2={py2}\n              stroke="#0f0"\n              strokeWidth="3"\n              onClick={(e) => handleBridgeClick(key, e)}\n              onContextMenu={(e) => handleBridgeContextMenu(key, e)}\n              style={{ cursor: \'pointer\' }}\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map((island) => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland && selectedIsland.id === island.id;\n\n      return (\n        <g key={island.id}\n          onClick={(e) => handleIslandClick(island, e)}\n          onContextMenu={(e) => {\n            e.preventDefault();\n            e.stopPropagation();\n            if (selectedIsland !== null && selectedIsland.id !== island.id) {\n              const key = bridgeKey(selectedIsland, island);\n              removeBridgeByKey(key);\n              setSelectedIsland(null);\n            }\n          }}\n          style={{ cursor: \'pointer\' }}\n        >\n          <circle\n            cx={px} cy={py} r={ISLAND_RADIUS}\n            fill="black"\n            stroke={isSelected ? "#ff0" : "#0f0"}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px} y={py}\n            textAnchor="middle"\n            dominantBaseline="central"\n            fill="#0f0"\n            fontSize="14"\n            fontFamily="monospace"\n            style={{ pointerEvents: \'none\' }}\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render keyboard cursor