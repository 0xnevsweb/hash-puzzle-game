   if (!result.valid) {\n        setError(result.error);\n        return;\n      }\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 2);\n      setBridges(newBridges);\n      if (isVictory(islands, newBridges)) setVictory(true);\n      else setVictory(false);\n    } else {\n      // current === 2, cycle to none\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges, islands]);\n\n  // Remove bridge entirely\n  const removeBridgeByKey = useCallback((key) => {\n    const current = bridges.get(key) || 0;\n    if (current > 0) {\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges]);\n\n  // Handle island click\n  const handleIslandClick = useCallback((island, e) => {\n    if (e.button === 2 || e.ctrlKey) {\n      // Right-click or ctrl+click on island with selection: remove bridge\n      if (selectedIsland !== null && selectedIsland.id !== island.id) {\n        const key = bridgeKey(selectedIsland, island);\n        removeBridgeByKey(key);\n        setSelectedIsland(null);\n      }\n      return;\n    }\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island);\n      setError(null);\n    } else if (selectedIsland.id === island.id) {\n      setSelectedIsland(null);\n    } else {\n      toggleBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    }\n  }, [selectedIsland, toggleBridge, removeBridgeByKey]);\n\n  // Handle right-click/ctrl+click on bridge lines\n  const handleBridgeClick = useCallback((key, e) => {\n    if (e.button === 2 || e.ctrlKey) {\n      e.stopPropagation();\n      removeBridgeByKey(key);\n    }\n  }, [removeBridgeByKey]);\n\n  const handleBridgeContextMenu = useCallback((key, e) => {\n    e.preventDefault();\n    e.stopPropagation();\n    removeBridgeByKey(key);\n  }, [removeBridgeByKey]);\n\n  const handleContextMenu = useCallback((e) => {\n    e.preventDefault();\n  }, []);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      if (e.key === \'Escape\') {\n        setSelectedIsland(null);\n        setKeyboardMode(true);\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        setKeyboardMode(true);\n        const currentIsland = islands[cursorIndex];\n        if (selectedIsland === null) {\n          setSelectedIsland(currentIsland);\n          setError(null);\n        } else if (selectedIsland.id === currentIsland.id) {\n          setSelectedIsland(null);\n        } else {\n          toggleBridge(selectedIsland, currentIsland);\n          setSelectedIsland(null);\n        }\n        return;\n      }\n\n      if ([\'ArrowUp\', \'ArrowDown\', \'ArrowLeft\', \'ArrowRight\'].includes(e.key)) {\n        e.preventDefault();\n        setKeyboardMode(true);\n        const current = islands[cursorIndex];\n        let bestIndex = cursorIndex;\n        let bestDist = Infinity;\n\n        for (let i = 0; i < islands.length; i++) {\n          if (i === cursorIndex) continue;\n          const target = islands[i];\n          const dx = target.x - current.x;\n          const dy = target.y - current.y;\n\n          let valid = false;\n          if (e.key === \'ArrowRight\' && dx > 0) valid = true;\n          if (e.key === \'ArrowLeft\' && dx < 0) valid = true;\n          if (e.key === \'ArrowDown\' && dy > 0) valid = true;\n          if (e.key === \'ArrowUp\' && dy < 0) valid = true;\n\n          if (valid) {\n            const dist = Math.abs(dx) + Math.abs(dy);\n            if (dist < bestDist) {\n              bestDist = dist;\n              bestIndex = i;\n            }\n          }\n        }\n        setCursorIndex(bestIndex);\n      }\n    };\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown