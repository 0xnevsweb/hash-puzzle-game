Sending keys: ['cat > /app/src/utils/hashiLogic.js << \'EOF\'\n// Generate canonical bridge key: smaller endpoint first (by x, then y)\nexport function bridgeKey(x1, y1, x2, y2) {\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Parse a bridge key back to coordinates\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\n// Check if two islands are adjacent (same row/col, no island between)\nexport function areAdjacent(islands, from, to) {\n  if (from.x === to.x) {\n    // Same column - check no island between\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) {\n        return false;\n      }\n    }\n    return true;\n  } else if (from.y === to.y) {\n    // Same row - check no island between\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) {\n        return false;\n      }\n    }\n    return true;\n  }\n  return false; // Not same row or column\n}\n\n// Check if a bridge between two points would cross any existing bridge\nexport function wouldCross(bridges, x1, y1, x2, y2) {\n  const isHorizontal = y1 === y2;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const b = parseBridgeKey(key);\n    const bIsHorizontal = b.y1 === b.y2;\n    \n    // Parallel bridges can\'t cross\n    if (isHorizontal === bIsHorizontal) continue;\n    \n    // Perpendicular bridges: check intersection\n    if (isHorizontal) {\n      // Our bridge is horizontal, existing is vertical\n      const ourMinX = Math.min(x1, x2);\n      const ourMaxX = Math.max(x1, x2);\n      const ourY = y1;\n      const theirX = b.x1;\n      const theirMinY = Math.min(b.y1, b.y2);\n      const theirMaxY = Math.max(b.y1, b.y2);\n      \n      if (theirX > ourMinX && theirX < ourMaxX &&\n          ourY > theirMinY && ourY < theirMaxY) {\n        return true;\n      }\n    } else {\n      // Our bridge is vertical, existing is horizontal\n      const ourMinY = Math.min(y1, y2);\n      const ourMaxY = Math.max(y1, y2);\n      const ourX = x1;\n      const theirY = b.y1;\n      const theirMinX = Math.min(b.x1, b.x2);\n      const theirMaxX = Math.max(b.x1, b.x2);\n      \n      if (ourX > theirMinX && ourX < theirMaxX &&\n          theirY > ourMinY && theirY < ourMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    \n    for (const island of islands) {\n      if (island.x === x1 && island.y === y1) {\n        counts.set(island.id, (counts.get(island.id) || 0) + count);\n      }\n      if (island.x === x2 && island.y === y2) {\n        counts.set(island.id, (counts.get(island.id) || 0) + count);\n      }\n    }\n  }\n  \n  return counts;\n}\n\n// Check if adding delta bridges is valid\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Guard: same island\n  if (from.id === to.id) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n  \n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n  \n  const key = bridgeKey(from.x, from.y, to.x, to.y);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n  \n  // Check max bridges\n  if (newCount > 2) {\n    return { valid: false, error: "Max 2 bridges per pair" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n  \n  // Check crossing (only for new bridges, not when adding second to existing)\n  if (current === 0) {\n    if (wouldCross(bridges, from.x, from.y, to.x, to.y)) {\n      return { valid: false, error: "Bridges would cross" };\n    }\n  }\n  \n  return { valid: true, error: null };\n}\n\n// Check connectivity: all islands with bridges are connected\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  \n  // Build adjacency list\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    \n    let fromId = null, toId = null;\n    for (const island of islands) {\n      if (island.x === x1 && island.y === y1) fromId = island.id;\n      if (island.x === x2 && island.y === y2) toId = island.id;\n    }\n    \n    if (fromId !== null && toId !== null) {\n      adj.get(fromId).push(toId);\n      adj.get(toId).push(fromId);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const curr = queue.shift();\n    for (const neighbor of adj.get(curr)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check if puzzle is solved\nexport function isVictory(islands, bridges) {\n  // Check all counts satisfied\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) {\n      return false;\n    }\n  }\n  \n  // Check no bridges cross\n  const activeBridges = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    activeBridges.push(parseBridgeKey(key));\n  }\n  \n  for (let i = 0; i < activeBridges.length; i++) {\n    for (let j = i + 1; j < activeBridges.length; j++) {\n      const a = activeBridges[i];\n      const b = activeBridges[j];\n      const aHoriz = a.y1 === a.y2;\n      const bHoriz = b.y1 === b.y2;\n      \n      if (aHoriz === bHoriz) continue;\n      \n      if (aHoriz) {\n        const minX = Math.min(a.x1, a.x2);\n        const maxX = Math.max(a.x1, a.x2);\n        const aY = a.y1;\n        const bX = b.x1;\n        const minY = Math.min(b.y1, b.y2);\n        const maxY = Math.max(b.y1, b.y2);\n        if (bX > minX && bX < maxX && aY > minY && aY < maxY) return false;\n      } else {\n        const minY = Math.min(a.y1, a.y2);\n        const maxY = Math.max(a.y1, a.y2);\n        const aX = a.x1;\n        const bY = b.y1;\n        const minX = Math.min(b.x1, b.x2);\n        const maxX = Math.max(b.x1, b.x2);\n        if (aX > minX && aX < maxX && bY > minY && bY < maxY) return false;\n      }\n    }\n  }\n  \n  // Check connectivity\n  return checkConnectivity(islands, bridges);\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
