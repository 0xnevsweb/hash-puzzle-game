gle bridge between kbFrom and current cursor\n          if (kbFrom && kbFrom.id !== cursorIslandId) {\n            const toIsland = islands.find(i => i.id === cursorIslandId);\n            if (toIsland) {\n              const newBridges = toggleBridge(kbFrom, toIsland, bridges);\n              setBridges(newBridges);\n              checkVictoryState(newBridges);\n            }\n          }\n          setKbSelecting(false);\n          setKbFrom(null);\n          setSelectedIsland(null);\n          setCursorIslandId(islands[0].id);\n        }\n        return;\n      }\n\n      if ([\'ArrowUp\', \'ArrowDown\', \'ArrowLeft\', \'ArrowRight\'].includes(e.key)) {\n        e.preventDefault();\n        const nextIsland = findNextIsland(cursorIsland, e.key, islands);\n        if (nextIsland) {\n          setCursorIslandId(nextIsland.id);\n        }\n      }\n    };\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [cursorIslandId, islands, kbSelecting, kbFrom, bridges, victory, toggleBridge]);\n\n  // Find next island in arrow direction\n  function findNextIsland(current, direction, islandList) {\n    let candidates = [];\n\n    switch (direction) {\n      case \'ArrowUp\':\n        candidates = islandList.filter(i => i.y < current.y);\n        candidates.sort((a, b) => {\n          const da = Math.abs(a.x - current.x) + (current.y - a.y);\n          const db = Math.abs(b.x - current.x) + (current.y - b.y);\n          return da - db;\n        });\n        break;\n      case \'ArrowDown\':\n        candidates = islandList.filter(i => i.y > current.y);\n        candidates.sort((a, b) => {\n          const da = Math.abs(a.x - current.x) + (a.y - current.y);\n          const db = Math.abs(b.x - current.x) + (b.y - current.y);\n          return da - db;\n        });\n        break;\n      case \'ArrowLeft\':\n        candidates = islandList.filter(i => i.x < current.x);\n        candidates.so