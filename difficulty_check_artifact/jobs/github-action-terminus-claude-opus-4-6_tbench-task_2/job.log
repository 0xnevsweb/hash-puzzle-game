onst newMaxX = Math.max(from.x, to.x);\n      const newY = from.y;\n      const existX = x1;\n      const existMinY = Math.min(y1, y2);\n      const existMaxY = Math.max(y1, y2);\n\n      if (existX > newMinX && existX < newMaxX && newY > existMinY && newY < existMaxY) {\n        return true;\n      }\n    } else {\n      // New bridge is vertical (from.x constant), existing is horizontal (y1 constant)\n      const newMinY = Math.min(from.y, to.y);\n      const newMaxY = Math.max(from.y, to.y);\n      const newX = from.x;\n      const existY = y1;\n      const existMinX = Math.min(x1, x2);\n      const existMaxX = Math.max(x1, x2);\n\n      if (newX > existMinX && newX < existMaxX && existY > newMinY && existY < newMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    // Find islands at these positions\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    if (island1) counts.set(island1.id, (counts.get(island1.id) || 0) + count);\n    if (island2) counts.set(island2.id, (counts.get(island2.id) || 0) + count);\n  }\n  return counts;\n}\n\n// Check if adding delta bridges would exceed island values\nfunction wouldExceedValue(islands, bridges, from, to, delta) {\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n\n  if (fromCount + delta > from.value) return true;\n  if (toCount + delta > to.value) return true;\n  return false;\n}\n\n// Main validation function\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n\n  // Check max bridges\n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  if (current + delta > 2) {\n    return { valid: false, error: "Max 2 bridges per pair" };\n  }\n\n  // Check island values won\'t be exceeded\n  if (wouldExceedValue(islands, bridges, from, to, delta)) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n\n  // Check crossing (only if adding, not removing)\n  if (delta > 0 && current === 0 && wouldCross(islands, bridges, from, to)) {\n    return { valid: false, error: "Bridges would cross" };\n  }\n\n  return { valid: true, error: null };\n}\n\n// Check if all islands are connected via bridges\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  if (islands.length === 1) return true;\n\n  // Build adjacency list\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    if (island1 && island2) {\n      adj.get(island1.id).push(island2.id);\n      adj.get(island2.id).push(island1.id);\n    }\n  }\n\n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n\n  while (queue.length > 0) {\n    const current = queue.shift();\n    for (const neighbor of adj.get(current)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  // Check all island counts match values\n  const count