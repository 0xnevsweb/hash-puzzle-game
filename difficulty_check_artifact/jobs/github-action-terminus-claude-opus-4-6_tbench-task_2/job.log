current === 1) {\n      // Try to add second bridge\n      const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        // If can\'t add, remove instead (cycle to none)\n        setError(null);\n        const newBridges = new Map(bridges);\n        newBridges.delete(key);\n        setBridges(newBridges);\n        setVictory(false);\n        return;\n      }\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 2);\n      setBridges(newBridges);\n      if (isVictory(islands, newBridges)) setVictory(true);\n    } else {\n      // current === 2, cycle to none\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges, islands]);\n\n  // Remove bridge entirely\n  const removeBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const current = bridges.get(key) || 0;\n    if (current > 0) {\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges]);\n\n  // Handle island click\n  const handleIslandClick = useCallback((island, e) => {\n    // Right-click or Ctrl+click = remove\n    if (e.button === 2 || e.ctrlKey) {\n      if (selectedIsland !== null) {\n        removeBridge(selectedIsland, island);\n        setSelectedIsland(null);\n      }\n      return;\n    }\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island);\n      setError(null);\n    } else if (selectedIsland.id === island.id) {\n      // Clicking same island deselects\n      setSelectedIsland(null);\n    } else {\n      toggleBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    }\n  }, [selectedIsland, toggleBridge, removeBridge]);\n\n  // Handle right-click on SVG for bridge removal\n  const handleContextMenu = useCallback((e) => {\n    e.preventDefault();\n  }, []);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      if (e.key === \'Escape\') {\n        setSelectedIsland(null);\n        setKeyboardMode(true);\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        setKeyboardMode(true);\n        const currentIsland = islands[cursorIndex];\n        if (selectedIsland === null) {\n          setSelectedIsland(currentIsland);\n          setError(null);\n        } else if (selectedIsland.id === currentIsland.id) {\n          setSelectedIsland(null);\n        } else {\n          toggleBridge(selectedIsland, currentIsland);\n          setSelectedIsland(null);\n        }\n        return;\n      }\n\n      if ([\'ArrowUp\', \'ArrowDown\', \'ArrowLeft\', \'ArrowRight\'].includes(e.key)) {\n        e.preventDefault();\n        setKeyboardMode(true);\n        const current = islands[cursorIndex];\n        let bestIndex = cursorIndex;\n        let bestDist = Infinity;\n\n        for (let i = 0; i < islands.length; i++) {\n          if (i === cursorIndex) continue;\n          const target = islands[i];\n          const dx = target.x - current.x;\n          const dy = target.y - current.y;\n\n          let valid = false;\n          if (e.key === \'ArrowRight\' && dx > 0 && Math.abs(dy) <= Math.abs(dx)) valid = true;\n          if (e.key === \'ArrowLeft\' && dx < 0 && Math.abs(dy) <= Math.abs(dx)) valid = true;\n          if (e.key === \'ArrowDown\' && dy > 0 && Math.abs(dx) <= Math.abs(dy)) valid = true;\n          if (e.key === \'ArrowUp\' && dy < 0 && Math.abs(dx) <= Math.abs(dy)) valid = true;\n\n          if (valid) {\n            const dist = Math.abs(dx) + Math.abs(dy);\n            if (dist < bestDist) {\n              bestDist = dist;\n              bestIndex = i;\n            }\n          }\n        }\n        setCursorIndex(bestIndex);\n      }\n    };\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [islands, cursorIndex, selectedIsland, toggleBridge]);\n\n  // Render bridges as SVG lines\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges) {\n      if (count === 0) continue;\n      const { x1, y1, x2, y2 } = parseKey(key);\n      const px1 = x1 * GRID_SIZE;\n      const py1 = y1 * GRID_SIZE;\n      const px2 = x2 * GRID_SIZE;\n      const py2 = y2 * GRID_SIZE;\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={px1} y1={py1} x2={px2} y2={py2}\n            stroke="#0f0"\n            strokeWidth="2"\n          />\n        );\n      } else if (count === 2) {\n        // Two parallel lines offset by 4px\n        const isHorizontal = y1 === y2;\n        const offset = 4;\n        if (isHorizontal) {\n          lines.push(\n            <line\n              key={key + \'-a\'}\n              x1={px1} y1={py1 - offset} x2={px2} y2={py2 - offset}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'-b\'}\n              x1={px1} y1={py1 + offset} x2={px2} y2={py2 + offset}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n        } else {\n          lines.push(\n            <line\n              key={key + \'-a\'}\n              x1={px1 - offset} y1={py1} x2={px2 - offset} y2={py2}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'-b\'}\n              x1={px1 + offset} y1={py1} x2={px2 + offset} y2={py2}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map((island) => {\n      const px