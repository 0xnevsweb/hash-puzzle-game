[?2004l[?2004h> // Get canonical bridge key - endpoint with smaller x (then y) comes first
[?2004l[?2004h> export function getBridgeKey(island1, island2) {
[?2004l[?2004h>   const x1 = island1.x, y1 = island1.y;
[?2004l[?2004h>   const x2 = island2.x, y2 = island2.y;
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col, no island between them)
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.id === to.id) return false;
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     // Same column - check for islands between them vertically
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.x === from.x && island.y > minY && island.y < maxY) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   } else {
[?2004l[?2004h>     // Same row - check for islands between them horizontally
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.y === from.y && island.x > minX && island.x < maxX) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if a bridge between from and to would cross any existing bridge
[?2004l[?2004h> export function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   // The new bridge segment
[?2004l[?2004h>   const isHorizontal = from.y === to.y;
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const existingHorizontal = y1 === y2;
[?2004l[?2004h>     
[?2004l[?2004h>     // Parallel bridges cannot cross
[?2004l[?2004h>     if (isHorizontal === existingHorizontal) continue;
[?2004l[?2004h>     
[?2004l[?2004h>     // Perpendicular - check intersection
[?2004l[?2004h>     if (isHorizontal) {
[?2004l[?2004h>       // New bridge is horizontal, existing is vertical
[?2004l[?2004h>       const hMinX = Math.min(from.x, to.x);
[?2004l[?2004h>       const hMaxX = Math.max(from.x, to.x);
[?2004l[?2004h>       const hY = from.y;
[?2004l[?2004h>       const vX = x1; // x1 === x2 for vertical
[?2004l[?2004h>       const vMinY = Math.min(y1, y2);
[?2004l[?2004h>       const vMaxY = Math.max(y1, y2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // New bridge is vertical, existing is horizontal
[?2004l[?2004h>       const vMinY = Math.min(from.y, to.y);
[?2004l[?2004h>       const vMaxY = Math.max(from.y, to.y);
[?2004l[?2004h>       const vX = from.x;
[?2004l[?2004h>       const hY = y1; // y1 === y2 for horizontal
[?2004l[?2004h>       const hMinX = Math.min(x1, x2);
[?2004l[?2004h>       const hMaxX = Math.max(x1, x2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts for each island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if ((island.x === x1 && island.y === y1) || (island.x === x2 && island.y === y2)) {
[?2004l[?2004h>         counts.set(island.id, (counts.get(island.id) || 0) + count);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges between from and to is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = getBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check max bridges
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing (only for new bridges, not existing ones being incremented)
[?2004l[?2004h>   if (current === 0) {
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected through bridges
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency list based on bridges
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     let id1 = null, id2 = null;
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.x === x1 && island.y === y1) id1 = island.id;
[?2004l[?2004h>       if (island.x === x2 && island.y === y2) id2 = island.id;
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     if (id1 !== null && id2 !== null) {
[?2004l[?2004h>       adj.get(id1).push(id2);
[?2004l[?2004h>       adj.get(id2).push(id1);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h>   
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const current = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(current)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check victory condition
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all island counts are satisfied
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if ((counts.get(island.id) || 0) !== island.value) {
[?2004l[?2004h>       return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no bridges cross
[?2004l[?2004h>   const bridgeList = [];
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     bridgeList.push({ x1, y1, x2, y2, horizontal: y1 === y2 });
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (let i = 0; i < bridgeList.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < bridgeList.length; j++) {
[?2004l[?2004h>       const a = bridgeList[i];
[?2004l[?2004h>       const b = bridgeList[j];
[?2004l[?2004h>       if (a.horizontal === b.horizontal) continue;
[?2004l[?2004h>       
[?2004l[?2004h>       const h = a.horizontal ? a : b;
[?2004l[?2004h>       const v = a.horizontal ? b : a;
[?2004l[?2004h>       
[?2004l[?2004h>       const hMinX = Math.min(h.x1, h.x2);
[?2004l[?2004h>       const hMaxX = Math.max(h.x1, h.x2);
[?2004l[?2004h>       const hY = h.y1;
[?2004l[?2004h>       const vX = v.x1;
[?2004l[?2004h>       const vMinY = Math.min(v.y1, v.y2);
[?2004l[?2004h>       const vMaxY = Math.max(v.y1, v.y2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> EOF
