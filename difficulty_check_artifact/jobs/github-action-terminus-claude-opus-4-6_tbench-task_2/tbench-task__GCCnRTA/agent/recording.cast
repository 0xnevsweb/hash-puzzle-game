[292.357776, "i", ");\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n    setKbSelecting(false);\n    setKbFrom(null);\n  };\n\n  const handleReset = () => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n    setKbSelecting(false);\n    setKbFrom(null);\n  };\n\n  const checkVictoryState = (newBridges) => {\n    if (isVictory(islands, newBridges)) {\n      setVictory(true);\n    }\n  };\n\n  // Toggle bridge: none -> single -> double -> none\n  // Returns { newBridges, error } where error is null on success\n  const toggleBridge = useCallback((fromIsland, toIsland, currentBridges) => {\n    const key = getBridgeKey(fromIsland, toIsland);\n    const current = currentBridges.get(key) || 0;\n\n    if (current === 0) {\n      const result = canAddBridge(islands, currentBridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        return { newBridges: currentBridges, error: result.error };\n      }\n      const newBridges = new Map(curr"]
