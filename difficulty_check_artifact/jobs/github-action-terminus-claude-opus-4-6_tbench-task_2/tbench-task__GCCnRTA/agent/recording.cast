[88.418733, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[88.418761, "o", "\u001b[?2004h> "]
[88.418873, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[88.418979, "o", "\u001b[?2004h> "]
[88.419123, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[88.419189, "o", "\u001b[?2004h> "]
[88.419215, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[88.419228, "o", "> "]
[88.41935, "o", "    let id1 = null, id2 = null;\r\n"]
[88.41937, "o", "\u001b[?2004l\r"]
[88.419444, "o", "\u001b[?2004h> "]
[88.419534, "o", "    for (const island of islands) {\r\n\u001b[?2004l\r"]
[88.419579, "o", "\u001b[?2004h> "]
[88.419789, "o", "      if (island.x === x1 && island.y === y1) id1 = island.id;\r\n\u001b[?2004l\r"]
[88.419851, "o", "\u001b[?2004h> "]
[88.420044, "o", "      if (island.x === x2 && island.y === y2) id2 = island.id;\r\n\u001b[?2004l\r"]
[88.420094, "o", "\u001b[?2004h"]
[88.420182, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[88.420297, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[88.420391, "o", "    if (id1 !== null && id2 !== null) {\r\n\u001b[?2004l\r"]
[88.420444, "o", "\u001b[?2004h> "]
[88.420548, "o", "      adj.get(id1).push(id2);\r\n\u001b[?2004l\r"]
[88.420578, "o", "\u001b[?2004h> "]
[88.420691, "o", "      adj.get(id2).push(id1);\r\n\u001b[?2004l\r"]
[88.420752, "o", "\u001b[?2004h> "]
[88.420815, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[88.420837, "o", ">   }\r\n\u001b[?2004l\r"]
[88.420944, "o", "\u001b[?2004h>   \r\n"]
[88.42103, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[88.42108, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[88.421122, "o", "\u001b[?2004h> "]
[88.421206, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[88.421239, "o", "\u001b[?2004h"]
[88.421296, "o", "> "]
[88.421388, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[88.421467, "o", "\u001b[?2004h> "]
[88.421534, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[88.421557, "o", "\u001b[?2004h"]
[88.421621, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h"]
[88.421649, "o", "> "]
[88.421743, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[88.421767, "o", "\u001b[?2004h"]
[88.421778, "o", "> "]
[88.421897, "o", "    const current = queue.shift();\r\n\u001b[?2004l\r"]
[88.421916, "o", "\u001b[?2004h"]
[88.421965, "o", "> "]
[88.422094, "o", "    for (const neighbor of adj.get(current)) {\r\n\u001b[?2004l\r"]
[88.42217, "o", "\u001b[?2004h"]
[88.422221, "o", "> "]
[88.422292, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r"]
[88.422309, "o", "\u001b[?2004h> "]
[88.422422, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r"]
[88.422454, "o", "\u001b[?2004h"]
[88.422468, "o", "> "]
[88.422576, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[88.422622, "o", "\u001b[?2004h> "]
[88.422664, "o", "      }\r\n\u001b[?2004l\r"]
[88.422705, "o", "\u001b[?2004h> "]
[88.422781, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[88.422808, "o", "  }\r\n\u001b[?2004l\r"]
[88.42291, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[88.422937, "o", "\u001b[?2004h> "]
[88.423066, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r"]
[88.423092, "o", "\u001b[?2004h"]
[88.423134, "o", "> }\r\n\u001b[?2004l\r"]
[88.423146, "o", "\u001b[?2004h"]
[88.423158, "o", "> \r\n"]
[88.423172, "o", "\u001b[?2004l\r"]
[88.423309, "o", "\u001b[?2004h> "]
[88.423329, "o", "// Check victory condition\r\n\u001b[?2004l\r"]
[88.423343, "o", "\u001b[?2004h"]
[88.423356, "o", "> "]
[88.423505, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[88.423572, "o", "\u001b[?2004h"]
[88.423594, "o", "> "]
[88.423692, "o", "  // Check all island counts are satisfied\r\n\u001b[?2004l\r"]
[88.423726, "o", "\u001b[?2004h"]
[88.423826, "o", "> "]
[88.423933, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[88.424028, "o", "\u001b[?2004h> "]
[88.4241, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[88.42416, "o", "\u001b[?2004h"]
[88.424254, "o", "> "]
[88.424346, "o", "    if ((counts.get(island.id) || 0) !== island.value) {\r\n\u001b[?2004l\r"]
[88.424411, "o", "\u001b[?2004h> "]
[88.42449, "o", "      return false;\r\n\u001b[?2004l\r\u001b[?2004h"]
[88.424562, "o", ">     }\r\n\u001b[?2004l\r"]
[88.424646, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[88.424709, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[88.42481, "o", "  // Check no bridges cross\r\n\u001b[?2004l\r"]
[88.424875, "o", "\u001b[?2004h> "]
[88.424965, "o", "  const bridgeList = [];\r\n\u001b[?2004l\r\u001b[?2004h"]
[88.425015, "o", "> "]
[88.425111, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[88.425213, "o", "\u001b[?2004h> "]
[88.425283, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[88.425369, "o", "\u001b[?2004h> "]
[88.425503, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[88.425527, "o", "\u001b[?2004h"]
[88.425629, "o", "> "]
[88.425755, "o", "    bridgeList.push({ x1, y1, x2, y2, horizontal: y1 === y2 });\r\n\u001b[?2004l\r"]
[88.425817, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[88.425883, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[88.42595, "o", "\u001b[?2004h> "]
[88.426075, "o", "  for (let i = 0; i < bridgeList.length; i++) {\r\n\u001b[?2004l\r"]
[88.426098, "o", "\u001b[?2004h"]
[88.426123, "o", "> "]
[88.426284, "o", "    for (let j = i + 1; j < bridgeList.length; j++) {\r\n\u001b[?2004l\r"]
[88.426361, "o", "\u001b[?2004h> "]
[88.426455, "o", "      const a = bridgeList[i];\r\n\u001b[?2004l\r"]
[88.426532, "o", "\u001b[?2004h> "]
[88.42661, "o", "      const b = bridgeList[j];\r\n\u001b[?2004l\r"]
[88.42669, "o", "\u001b[?2004h> "]
[88.426804, "o", "      if (a.horizontal === b.horizontal) continue;\r\n\u001b[?2004l\r"]
[88.426834, "o", "\u001b[?2004h"]
[88.426962, "o", ">       \r\n\u001b[?2004l\r\u001b[?2004h"]
[88.427023, "o", "> "]
[88.427077, "o", "      const h = a.horizontal ? a : b;\r\n\u001b[?2004l\r"]
[88.427171, "o", "\u001b[?2004h> "]
[88.427265, "o", "      const v = a.horizontal ? b : a;\r\n\u001b[?2004l\r"]
[88.427291, "o", "\u001b[?2004h"]
[88.427303, "o", "> "]
[88.427423, "o", "      \r\n\u001b[?2004l\r\u001b[?2004h"]
[88.427444, "o", "> "]
[88.42753, "o", "      const hMinX = Math.min(h.x1, h.x2);\r\n\u001b[?2004l\r"]
[88.427606, "o", "\u001b[?2004h"]
[88.427663, "o", "> "]
[88.427725, "o", "      const hMaxX = Math.max(h.x1, h.x2);\r\n\u001b[?2004l\r"]
[88.427816, "o", "\u001b[?2004h> "]
[88.42788, "o", "      const hY = h.y1;\r\n\u001b[?2004l\r"]
[88.427945, "o", "\u001b[?2004h> "]
[88.427993, "o", "      const vX = v.x1;\r\n\u001b[?2004l\r"]
[88.428064, "o", "\u001b[?2004h"]
[88.42812, "o", "> "]
[88.428196, "o", "      const vMinY = Math.min(v.y1, v.y2);\r\n\u001b[?2004l\r"]
[88.428217, "o", "\u001b[?2004h"]
[88.428231, "o", "> "]
[88.428367, "o", "      const vMaxY = Math.max(v.y1, v.y2);\r\n\u001b[?2004l\r"]
[88.428383, "o", "\u001b[?2004h"]
[88.428495, "o", ">       \r\n\u001b[?2004l\r\u001b[?2004h"]
[88.428547, "o", "> "]
[88.428714, "o", "      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\r\n\u001b[?2004l\r"]
[88.428774, "o", "\u001b[?2004h> "]
[88.428863, "o", "        return false;\r\n\u001b[?2004l\r"]
[88.428894, "o", "\u001b[?2004h"]
[88.428914, "o", "> "]
[88.429027, "o", "      }\r\n\u001b[?2004l\r"]
[88.429086, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[88.429112, "o", "  }\r\n\u001b[?2004l\r"]
[88.429208, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[88.429288, "o", "\u001b[?2004h> "]
[88.429308, "o", "  // Check connectivity\r\n\u001b[?2004l\r"]
[88.429356, "o", "\u001b[?2004h> "]
[88.429509, "o", "  return checkConnectivity(islands, bridges);\r\n\u001b[?2004l\r"]
[88.429652, "o", "\u001b[?2004h> }\r\n"]
[88.429672, "o", "\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[88.43067, "o", "\u001b[?2004hroot@c86fca3e4905:/app# "]
[88.693971, "i", "cat > /app/src/index.css << 'EOF'\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  background-color: #000;\n  color: #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  overflow: hidden;\n}\n\n.game-container {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n}\n\n.controls {\n  padding: 8px;\n  display: flex;\n  gap: 16px;\n  align-items: center;\n}\n\n.controls select,\n.controls button {\n  background: #000;\n  color: #0f0;\n  border: 1px solid #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 14px;\n  padding: 4px 8px;\n  cursor: pointer;\n}\n\n.controls select:hover,\n.controls button:hover {\n  background: #0f0;\n  color: #000;\n}\n\n.error-message {\n  color: #f00;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 14px;\n  padding: 4px 8px;\n  min-height: 20px;\n}\n\n.victory-banner {\n  color: #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 24px;\n  padding: 8px;\n  border: 2px solid #0f0;\n  text-align: center;\n  animation: blink 1s infini"]
[88.695965, "i", "te;\n}\n\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\n\nsvg {\n  display: block;\n}\nEOF\n"]
