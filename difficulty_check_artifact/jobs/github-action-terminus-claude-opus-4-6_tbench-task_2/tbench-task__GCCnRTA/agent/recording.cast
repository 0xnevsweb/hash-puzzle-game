[88.386775, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Get canonical bridge key - endpoint with smaller x (then y) comes first\nexport function getBridgeKey(island1, island2) {\n  const x1 = island1.x, y1 = island1.y;\n  const x2 = island2.x, y2 = island2.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are adjacent (same row/col, no island between them)\nexport function areAdjacent(islands, from, to) {\n  if (from.id === to.id) return false;\n  if (from.x !== to.x && from.y !== to.y) return false;\n  \n  if (from.x === to.x) {\n    // Same column - check for islands between them vertically\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) {\n        return false;\n      }\n    }\n  } else {\n    // Same row - check for islands bet"]
[88.387253, "i", "ween them horizontally\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) {\n        return false;\n      }\n    }\n  }\n  return true;\n}\n\n// Check if a bridge between from and to would cross any existing bridge\nexport function wouldCross(islands, bridges, from, to) {\n  // The new bridge segment\n  const isHorizontal = from.y === to.y;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const existingHorizontal = y1 === y2;\n    \n    // Parallel bridges cannot cross\n    if (isHorizontal === existingHorizontal) continue;\n    \n    // Perpendicular - check intersection\n    if (isHorizontal) {\n      // New bridge is horizontal, existing is vertical\n      const hMinX = Math.min(from.x, to.x);\n      const hMaxX = Math.max(from.x, to.x);\n     "]
[88.387287, "o", "cat > /app/src/utils/hashiLogic.js << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[88.387303, "i", " const hY = from.y;\n      const vX = x1; // x1 === x2 for vertical\n      const vMinY = Math.min(y1, y2);\n      const vMaxY = Math.max(y1, y2);\n      \n      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\n        return true;\n      }\n    } else {\n      // New bridge is vertical, existing is horizontal\n      const vMinY = Math.min(from.y, to.y);\n      const vMaxY = Math.max(from.y, to.y);\n      const vX = from.x;\n      const hY = y1; // y1 === y2 for horizontal\n      const hMinX = Math.min(x1, x2);\n      const hMaxX = Math.max(x1, x2);\n      \n      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts for each island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    \n   "]
[88.387316, "i", " for (const island of islands) {\n      if ((island.x === x1 && island.y === y1) || (island.x === x2 && island.y === y2)) {\n        counts.set(island.id, (counts.get(island.id) || 0) + count);\n      }\n    }\n  }\n  \n  return counts;\n}\n\n// Check if adding delta bridges between from and to is valid\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n  \n  const key = getBridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n  \n  // Check max bridges\n  if (newCount > 2) {\n    return { valid: false, error: \"Max 2 bridges per pair\" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: \"Island "]
[88.387336, "i", "would exceed its number\" };\n  }\n  \n  // Check crossing (only for new bridges, not existing ones being incremented)\n  if (current === 0) {\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: \"Bridges would cross\" };\n    }\n  }\n  \n  return { valid: true, error: null };\n}\n\n// Check if all islands are connected through bridges\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  if (islands.length === 1) return true;\n  \n  // Build adjacency list based on bridges\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    \n    let id1 = null, id2 = null;\n    for (const island of islands) {\n      if (island.x === x1 && island.y === y1) id1 = island.id;\n      if (island.x === x2 && island.y === y2) id2 = island.id;\n    }\n    \n    if (id1 !== null && id2 !== null) {\n      adj.ge"]
[88.387345, "i", "t(id1).push(id2);\n      adj.get(id2).push(id1);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const current = queue.shift();\n    for (const neighbor of adj.get(current)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  // Check all island counts are satisfied\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) {\n      return false;\n    }\n  }\n  \n  // Check no bridges cross\n  const bridgeList = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    bridgeList.push({ x1, y1, x2, y2, horizontal: y1 === y2 });\n  }\n  \n  for (let i = 0; "]
[88.389513, "i", "i < bridgeList.length; i++) {\n    for (let j = i + 1; j < bridgeList.length; j++) {\n      const a = bridgeList[i];\n      const b = bridgeList[j];\n      if (a.horizontal === b.horizontal) continue;\n      \n      const h = a.horizontal ? a : b;\n      const v = a.horizontal ? b : a;\n      \n      const hMinX = Math.min(h.x1, h.x2);\n      const hMaxX = Math.max(h.x1, h.x2);\n      const hY = h.y1;\n      const vX = v.x1;\n      const vMinY = Math.min(v.y1, v.y2);\n      const vMaxY = Math.max(v.y1, v.y2);\n      \n      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\n        return false;\n      }\n    }\n  }\n  \n  // Check connectivity\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"]
