[86.119466, "o", "\u001b[?2004h"]
[86.119477, "o", "> "]
[86.119571, "o", "}\r\n\u001b[?2004l\r"]
[86.119593, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
