[86.109945, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[86.110045, "o", "\u001b[?2004h> "]
[86.110118, "o", "  // Check adjacency\r\n\u001b[?2004l\r\u001b[?2004h> "]
