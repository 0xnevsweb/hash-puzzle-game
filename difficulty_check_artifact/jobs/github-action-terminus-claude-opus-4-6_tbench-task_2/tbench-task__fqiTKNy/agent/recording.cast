[86.111583, "o", "    return { valid: false, error: \"Max 2 bridges per pair\" };\r\n\u001b[?2004l\r"]
[86.111611, "o", "\u001b[?2004h"]
[86.111631, "o", "> "]
[86.111649, "o", "  }\r\n\u001b[?2004l\r"]
