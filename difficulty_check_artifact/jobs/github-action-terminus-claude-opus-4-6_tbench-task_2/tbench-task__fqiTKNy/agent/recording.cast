[86.111925, "o", "  // Check island values won't be exceeded\r\n\u001b[?2004l\r"]
[86.111941, "o", "\u001b[?2004h"]
[86.111966, "o", "> "]
[86.11216, "o", "  if (wouldExceedValue(islands, bridges, from, to, delta)) {\r\n\u001b[?2004l\r"]
[86.11219, "o", "\u001b[?2004h"]
[86.112203, "o", "> "]
[86.112442, "o", "    return { valid: false, error: \"Island would exceed its number\" };\r\n\u001b[?2004l\r"]
[86.112475, "o", "\u001b[?2004h"]
[86.112495, "o", "> "]
[86.112509, "o", "  }\r\n\u001b[?2004l\r"]
[86.112547, "o", "\u001b[?2004h"]
[86.112563, "o", "> \r\n\u001b[?2004l\r"]
[86.112711, "o", "\u001b[?2004h"]
[86.112779, "o", "> "]
[86.112833, "o", "  // Check crossing (only if adding, not removing)\r\n\u001b[?2004l\r"]
[86.112905, "o", "\u001b[?2004h> "]
[86.113097, "o", "  if (delta > 0 && current === 0 && wouldCross(islands, bridges, from, to)) {\r\n\u001b[?2004l\r"]
