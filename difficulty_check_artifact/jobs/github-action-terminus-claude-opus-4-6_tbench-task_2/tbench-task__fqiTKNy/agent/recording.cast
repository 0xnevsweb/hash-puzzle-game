[86.081869, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Generate canonical bridge key: smaller coordinate pair first\nexport function bridgeKey(from, to) {\n  const x1 = from.x, y1 = from.y, x2 = to.x, y2 = to.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Parse a bridge key back into coordinates\nexport function parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\n// Check if two islands are aligned (same row or column) with no island between them\nfunction areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n\n  // Check no island between them\n  for (const island of islands) {\n    if (island.id === from.id || island.id === to.id) continue;\n    if (from.x === to.x && island.x === from.x) {\n      const minY = Math.min(from.y, to.y);\n      const maxY = Math.max(from.y, to.y);\n      if (island.y > minY &"]
[86.082001, "i", "& island.y < maxY) return false;\n    }\n    if (from.y === to.y && island.y === from.y) {\n      const minX = Math.min(from.x, to.x);\n      const maxX = Math.max(from.x, to.x);\n      if (island.x > minX && island.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nfunction wouldCross(islands, bridges, from, to) {\n  // The new bridge is between from and to\n  const isHorizontal = from.y === to.y;\n\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const existingHorizontal = y1 === y2;\n\n    // Only perpendicular bridges can cross\n    if (isHorizontal === existingHorizontal) continue;\n\n    if (isHorizontal) {\n      // New bridge is horizontal (from.y constant), existing is vertical (x1 constant)\n      const newMinX = Math.min(from.x, to.x);\n      const newMaxX = Math.max(from.x, to.x);\n      const newY = from.y;\n      const existX = x1;\n      const existMinY = Math.mi"]
[86.082053, "i", "n(y1, y2);\n      const existMaxY = Math.max(y1, y2);\n\n      if (existX > newMinX && existX < newMaxX && newY > existMinY && newY < existMaxY) {\n        return true;\n      }\n    } else {\n      // New bridge is vertical (from.x constant), existing is horizontal (y1 constant)\n      const newMinY = Math.min(from.y, to.y);\n      const newMaxY = Math.max(from.y, to.y);\n      const newX = from.x;\n      const existY = y1;\n      const existMinX = Math.min(x1, x2);\n      const existMaxX = Math.max(x1, x2);\n\n      if (newX > existMinX && newX < existMaxX && existY > newMinY && existY < newMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    // Find islands at these positions\n    const island1 ="]
