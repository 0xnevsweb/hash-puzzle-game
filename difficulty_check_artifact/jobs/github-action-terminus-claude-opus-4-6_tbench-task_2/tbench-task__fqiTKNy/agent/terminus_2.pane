[?2004l[?2004h> // Generate canonical bridge key: smaller coordinate pair first
[?2004l[?2004h> export function bridgeKey(from, to) {
[?2004l[?2004h>   const x1 = from.x, y1 = from.y, x2 = to.x, y2 = to.y;
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Parse a bridge key back into coordinates
[?2004l[?2004h> export function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are aligned (same row or column) with no island between them
[?2004l[?2004h> function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // Check no island between them
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>     if (from.x === to.x && island.x === from.x) {
[?2004l[?2004h>       const minY = Math.min(from.y, to.y);
[?2004l[?2004h>       const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>       if (island.y > minY && island.y < maxY) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (from.y === to.y && island.y === from.y) {
[?2004l[?2004h>       const minX = Math.min(from.x, to.x);
[?2004l[?2004h>       const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>       if (island.x > minX && island.x < maxX) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding a bridge between from and to would cross any existing bridge
[?2004l[?2004h> function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   // The new bridge is between from and to
[?2004l[?2004h>   const isHorizontal = from.y === to.y;
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const existingHorizontal = y1 === y2;
[?2004leck [?2004h> 
[?2004la[?2004h>     // Only perpendicular bridges can cross
[?2004l[?2004h>     if (isHorizontal === existingHorizontal) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     if (isHorizontal) {
[?2004l[?2004h>       // New bridge is horizontal (from.y constant), existing is vertical (x1 constant)
[?2004l[?2004h>       const newMinX = Math.min(from.x, to.x);
[?2004l[?2004h>       const newMaxX = Math.max(from.x, to.x);
[?2004l[?2004h>       const newY = from.y;
[?2004l[?2004h>       const existX = x1;
[?2004l[?2004h>       const existMinY = Math.min(y1, y2);
[?2004l[?2004h>       const existMaxY = Math.max(y1, y2);
[?2004l[?2004h> 
[?2004l[?2004h>       if (existX > newMinX && existX < newMaxX && newY > existMinY && newY < existMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // New bridge is vertical (from.x constant), existing is horizontal (y1 constant)
[?2004l[?2004h>       const newMinY = Math.min(from.y, to.y);
[?2004l[?2004h>       const newMaxY = Math.max(from.y, to.y);
[?2004l[?2004h>       const newX = from.x;
[?2004l[?2004h>       const existY = y1;
[?2004l[?2004h>       const existMinX = Math.min(x1, x2);
[?2004l[?2004h>       const existMaxX = Math.max(x1, x2);
[?2004l[?2004h> 
[?2004l[?2004h>       if (newX > existMinX && newX < existMaxX && existY > newMinY && existY < newMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts per island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     // Find islands at these positions
[?2004l[?2004h>     const island1 = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const island2 = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (island1) counts.set(island1.id, (counts.get(island1.id) || 0) + count);
[?2004l[?2004h>     if (island2) counts.set(island2.id, (counts.get(island2.id) || 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges would exceed island values
[?2004l[?2004h> function wouldExceedValue(islands, bridges, from, to, delta) {
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>   if (fromCount + delta > from.value) return true;
[?2004l[?2004h>   if (toCount + delta > to.value) return true;
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Main validation function
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check max bridges
[?2004l[?2004h>   const key = bridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   if (current + delta > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check island values won't be exceeded
[?2004l[?2004h>   if (wouldExceedValue(islands, bridges, from, to, delta)) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check crossing (only if adding, not removing)
[?2004l[?2004h>   if (delta > 0 && current === 0 && wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected via bridges
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   // Build adjacency list
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const island1 = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const island2 = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (island1 && island2) {
[?2004l[?2004h>       adj.get(island1.id).push(island2.id);
[?2004l[?2004h>       adj.get(island2.id).push(island1.id);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h> 
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const current = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(current)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check victory condition
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all island counts match values
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if ((counts.get(island.id) || 0) !== island.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   if (!checkConnectivity(islands, bridges)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
