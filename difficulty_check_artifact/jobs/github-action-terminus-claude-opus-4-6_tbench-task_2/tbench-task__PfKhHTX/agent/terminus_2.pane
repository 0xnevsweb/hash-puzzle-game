[?2004l[?2004h> // Generate canonical bridge key: smaller endpoint first (by x, then y)
[?2004l[?2004h> export function bridgeKey(x1, y1, x2, y2) {
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Parse a bridge key back to coordinates
[?2004l[?2004h> export function parseBridgeKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col, no island between)
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x === to.x) {
[?2004lC[?2004h>     // Same column - check no island between
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.x === from.x && island.y > minY && island.y < maxY) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   } else if (from.y === to.y) {
[?2004l[?2004h>     // Same row - check no island between
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.y === from.y && island.x > minX && island.x < maxX) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false; // Not same row or column
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if a bridge between two points would cross any existing bridge
[?2004l[?2004h> export function wouldCross(bridges, x1, y1, x2, y2) {
[?2004l[?2004h>   const isHorizontal = y1 === y2;
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const b = parseBridgeKey(key);
[?2004l[?2004h>     const bIsHorizontal = b.y1 === b.y2;
[?2004l[?2004h>     
[?2004l[?2004h>     // Parallel bridges can't cross
[?2004l[?2004h>     if (isHorizontal === bIsHorizontal) continue;
[?2004l[?2004h>     
[?2004l[?2004h>     // Perpendicular bridges: check intersection
[?2004l[?2004h>     if (isHorizontal) {
[?2004l[?2004h>       // Our bridge is horizontal, existing is vertical
[?2004l[?2004h>       const ourMinX = Math.min(x1, x2);
[?2004l[?2004h>       const ourMaxX = Math.max(x1, x2);
[?2004l[?2004h>       const ourY = y1;
[?2004l[?2004h>       const theirX = b.x1;
[?2004l[?2004h>       const theirMinY = Math.min(b.y1, b.y2);
[?2004l[?2004h>       const theirMaxY = Math.max(b.y1, b.y2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (theirX > ourMinX && theirX < ourMaxX &&
[?2004l[?2004h>           ourY > theirMinY && ourY < theirMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // Our bridge is vertical, existing is horizontal
[?2004l[?2004h>       const ourMinY = Math.min(y1, y2);
[?2004l[?2004h>       const ourMaxY = Math.max(y1, y2);
[?2004l[?2004h>       const ourX = x1;
[?2004l[?2004h>       const theirY = b.y1;
[?2004l[?2004h>       const theirMinX = Math.min(b.x1, b.x2);
[?2004l[?2004h>       const theirMaxX = Math.max(b.x1, b.x2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (ourX > theirMinX && ourX < theirMaxX &&
[?2004l[?2004h>           theirY > ourMinY && theirY < ourMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004lf[?2004h> 
[?2004la[?2004h> // Compute current bridge counts per island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.x === x1 && island.y === y1) {
[?2004l[?2004h>         counts.set(island.id, (counts.get(island.id) || 0) + count);
[?2004l[?2004h>       }
[?2004l[?2004h>       if (island.x === x2 && island.y === y2) {
[?2004l[?2004h>         counts.set(island.id, (counts.get(island.id) || 0) + count);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Guard: same island
[?2004l[?2004h>   if (from.id === to.id) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = bridgeKey(from.x, from.y, to.x, to.y);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check max bridges
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing (only for new bridges, not when adding second to existing)
[?2004l[?2004h>   if (current === 0) {
[?2004l[?2004h>     if (wouldCross(bridges, from.x, from.y, to.x, to.y)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check connectivity: all islands with bridges are connected
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency list
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     
[?2004l[?2004h>     let fromId = null, toId = null;
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.x === x1 && island.y === y1) fromId = island.id;
[?2004l[?2004h>       if (island.x === x2 && island.y === y2) toId = island.id;
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     if (fromId !== null && toId !== null) {
[?2004l[?2004h>       adj.get(fromId).push(toId);
[?2004l[?2004h>       adj.get(toId).push(fromId);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h>   
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const curr = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(curr)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if puzzle is solved
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all counts satisfied
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if ((counts.get(island.id) || 0) !== island.value) {
[?2004l[?2004h>       return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no bridges cross
[?2004l[?2004h>   const activeBridges = [];
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     activeBridges.push(parseBridgeKey(key));
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (let i = 0; i < activeBridges.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < activeBridges.length; j++) {
[?2004l[?2004h>       const a = activeBridges[i];
[?2004l[?2004h>       const b = activeBridges[j];
[?2004l[?2004h>       const aHoriz = a.y1 === a.y2;
[?2004l[?2004h>       const bHoriz = b.y1 === b.y2;
[?2004l[?2004h>       
[?2004l[?2004h>       if (aHoriz === bHoriz) continue;
[?2004l[?2004h>       
[?2004l[?2004h>       if (aHoriz) {
[?2004l[?2004h>         const minX = Math.min(a.x1, a.x2);
[?2004l[?2004h>         const maxX = Math.max(a.x1, a.x2);
[?2004l[?2004h>         const aY = a.y1;
[?2004l[?2004h>         const bX = b.x1;
[?2004l[?2004h>         const minY = Math.min(b.y1, b.y2);
[?2004l[?2004h>         const maxY = Math.max(b.y1, b.y2);
[?2004l[?2004h>         if (bX > minX && bX < maxX && aY > minY && aY < maxY) return false;
[?2004l[?2004h>       } else {
[?2004l[?2004h>         const minY = Math.min(a.y1, a.y2);
[?2004l[?2004h>         const maxY = Math.max(a.y1, a.y2);
[?2004l[?2004h>         const aX = a.x1;
[?2004l[?2004h>         const bY = b.y1;
[?2004l[?2004h>         const minX = Math.min(b.x1, b.x2);
[?2004l[?2004h>         const maxX = Math.max(b.x1, b.x2);
[?2004l[?2004h>         if (aX > minX && aX < maxX && bY > minY && bY < maxY) return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
