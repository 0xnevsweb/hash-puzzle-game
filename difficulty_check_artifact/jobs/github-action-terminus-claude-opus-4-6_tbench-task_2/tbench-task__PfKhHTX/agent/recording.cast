[82.243999, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Generate canonical bridge key: smaller endpoint first (by x, then y)\nexport function bridgeKey(x1, y1, x2, y2) {\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Parse a bridge key back to coordinates\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\n// Check if two islands are adjacent (same row/col, no island between)\nexport function areAdjacent(islands, from, to) {\n  if (from.x === to.x) {\n    // Same column - check no island between\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) {\n        return false;\n      }\n    }\n    return true;\n  } else if (from.y === to.y) {\n    // Same row - check no island between\n "]
[82.244256, "i", "   const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) {\n        return false;\n      }\n    }\n    return true;\n  }\n  return false; // Not same row or column\n}\n\n// Check if a bridge between two points would cross any existing bridge\nexport function wouldCross(bridges, x1, y1, x2, y2) {\n  const isHorizontal = y1 === y2;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const b = parseBridgeKey(key);\n    const bIsHorizontal = b.y1 === b.y2;\n    \n    // Parallel bridges can't cross\n    if (isHorizontal === bIsHorizontal) continue;\n    \n    // Perpendicular bridges: check intersection\n    if (isHorizontal) {\n      // Our bridge is horizontal, existing is vertical\n      const ourMinX = Math.min(x1, x2);\n      const ourMaxX = Math.max(x1, x2);\n      const ourY = y1;\n      const theirX = b.x1;\n   "]
[82.244282, "o", "cat > /app/src/utils/hashiLogic.js << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.244296, "i", "   const theirMinY = Math.min(b.y1, b.y2);\n      const theirMaxY = Math.max(b.y1, b.y2);\n      \n      if (theirX > ourMinX && theirX < ourMaxX &&\n          ourY > theirMinY && ourY < theirMaxY) {\n        return true;\n      }\n    } else {\n      // Our bridge is vertical, existing is horizontal\n      const ourMinY = Math.min(y1, y2);\n      const ourMaxY = Math.max(y1, y2);\n      const ourX = x1;\n      const theirY = b.y1;\n      const theirMinX = Math.min(b.x1, b.x2);\n      const theirMaxX = Math.max(b.x1, b.x2);\n      \n      if (ourX > theirMinX && ourX < theirMaxX &&\n          theirY > ourMinY && theirY < ourMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    \n    for (const "]
[82.24431, "i", "island of islands) {\n      if (island.x === x1 && island.y === y1) {\n        counts.set(island.id, (counts.get(island.id) || 0) + count);\n      }\n      if (island.x === x2 && island.y === y2) {\n        counts.set(island.id, (counts.get(island.id) || 0) + count);\n      }\n    }\n  }\n  \n  return counts;\n}\n\n// Check if adding delta bridges is valid\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Guard: same island\n  if (from.id === to.id) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n  \n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n  \n  const key = bridgeKey(from.x, from.y, to.x, to.y);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n  \n  // Check max bridges\n  if (newCount > 2) {\n    return { valid: false, error: \"Max 2 bridges per pair\" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  co"]
