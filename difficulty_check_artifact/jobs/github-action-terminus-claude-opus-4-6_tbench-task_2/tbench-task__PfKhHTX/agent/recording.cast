[82.269338, "o", "  // Guard: same island\r\n\u001b[?2004l\r"]
[82.26936, "o", "\u001b[?2004h> "]
[82.269446, "o", "  if (from.id === to.id) {\r\n\u001b[?2004l\r"]
[82.269462, "o", "\u001b[?2004h"]
[82.269548, "o", "> "]
[82.2697, "o", "    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\r\n\u001b[?2004l\r"]
[82.269722, "o", "\u001b[?2004h"]
[82.269734, "o", "> "]
[82.26976, "o", "  }\r\n\u001b[?2004l\r"]
[82.269838, "o", "\u001b[?2004h> "]
[82.269856, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.269929, "o", "  // Check adjacency\r\n\u001b[?2004l\r"]
[82.269957, "o", "\u001b[?2004h"]
[82.269986, "o", "> "]
[82.270116, "o", "  if (!areAdjacent(islands, from, to)) {\r\n\u001b[?2004l\r"]
[82.270146, "o", "\u001b[?2004h"]
[82.270199, "o", "> "]
[82.27039, "o", "    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\r\n\u001b[?2004l\r"]
[82.27042, "o", "\u001b[?2004h"]
[82.270431, "o", "> "]
[82.270586, "o", "  }\r\n\u001b[?2004l\r"]
[82.270702, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.270756, "o", "  const key = bridgeKey(from.x, from.y, to.x, to.y);\r\n\u001b[?2004l\r"]
[82.270782, "o", "\u001b[?2004h"]
[82.270793, "o", "> "]
[82.270936, "o", "  const current = bridges.get(key) || 0;\r\n\u001b[?2004l\r"]
[82.270955, "o", "\u001b[?2004h"]
[82.270977, "o", "> "]
[82.271102, "o", "  const newCount = current + delta;\r\n\u001b[?2004l\r"]
[82.271127, "o", "\u001b[?2004h"]
[82.271138, "o", "> "]
[82.271163, "o", "  \r\n\u001b[?2004l\r"]
[82.271186, "o", "\u001b[?2004h> "]
[82.271282, "o", "  // Check max bridges\r\n\u001b[?2004l\r"]
[82.271312, "o", "\u001b[?2004h"]
[82.271331, "o", "> "]
[82.271409, "o", "  if (newCount > 2) {\r\n\u001b[?2004l\r"]
[82.271462, "o", "\u001b[?2004h> "]
[82.271655, "o", "    return { valid: false, error: \"Max 2 bridges per pair\" };\r\n\u001b[?2004l\r"]
[82.271682, "o", "\u001b[?2004h"]
[82.271747, "o", "> "]
[82.271803, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[82.271822, "o", "\u001b[?2004h> "]
[82.271914, "o", "  // Check island capacity\r\n\u001b[?2004l\r"]
[82.271952, "o", "\u001b[?2004h> "]
[82.272131, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[82.272171, "o", "\u001b[?2004h> "]
[82.272327, "o", "  const fromCount = counts.get(from.id) || 0;\r\n\u001b[?2004l\r"]
[82.272377, "o", "\u001b[?2004h> "]
[82.272523, "o", "  const toCount = counts.get(to.id) || 0;\r\n\u001b[?2004l\r"]
[82.272589, "o", "\u001b[?2004h"]
[82.27262, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.272634, "o", "> "]
[82.272845, "o", "  if (fromCount + delta > from.value || toCount + delta > to.value) {\r\n\u001b[?2004l\r"]
[82.272929, "o", "\u001b[?2004h> "]
[82.273087, "o", "    return { valid: false, error: \"Island would exceed its number\" };\r\n\u001b[?2004l\r"]
[82.273152, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[82.273212, "o", "\u001b[?2004h"]
[82.273284, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.273356, "o", "> "]
[82.273487, "o", "  // Check crossing (only for new bridges, not when adding second to existing)\r\n\u001b[?2004l\r"]
[82.273548, "o", "\u001b[?2004h"]
[82.273593, "o", "> "]
[82.27366, "o", "  if (current === 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.273824, "o", "    if (wouldCross(bridges, from.x, from.y, to.x, to.y)) {\r\n\u001b[?2004l\r"]
[82.273888, "o", "\u001b[?2004h"]
[82.27393, "o", "> "]
[82.274058, "o", "      return { valid: false, error: \"Bridges would cross\" };\r\n\u001b[?2004l\r"]
[82.274118, "o", "\u001b[?2004h"]
[82.274172, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.274219, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.274292, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.274412, "o", "  return { valid: true, error: null };\r\n\u001b[?2004l\r"]
[82.274468, "o", "\u001b[?2004h> }\r\n"]
[82.274537, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.274586, "o", "> "]
[82.274743, "o", "// Check connectivity: all islands with bridges are connected\r\n\u001b[?2004l\r"]
[82.274805, "o", "\u001b[?2004h"]
[82.274848, "o", "> "]
[82.274958, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[82.275017, "o", "\u001b[?2004h"]
[82.275059, "o", "> "]
[82.275138, "o", "  if (islands.length === 0) return true;\r\n\u001b[?2004l\r"]
[82.275198, "o", "\u001b[?2004h"]
[82.275223, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.275316, "o", ">   // Build adjacency list\r\n\u001b[?2004l\r"]
[82.275379, "o", "\u001b[?2004h> "]
[82.27545, "o", "  const adj = new Map();\r\n\u001b[?2004l\r"]
[82.275472, "o", "\u001b[?2004h"]
[82.275483, "o", "> "]
[82.275594, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[82.275614, "o", "\u001b[?2004h> "]
[82.275712, "o", "    adj.set(island.id, []);\r\n\u001b[?2004l\r"]
[82.275725, "o", "\u001b[?2004h"]
[82.275736, "o", "> "]
[82.275746, "o", "  }"]
[82.275758, "o", "\r\n\u001b[?2004l\r"]
[82.275791, "o", "\u001b[?2004h"]
[82.27583, "o", ">   \r\n"]
[82.275851, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[82.275995, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[82.276022, "o", "\u001b[?2004h"]
[82.276034, "o", "> "]
[82.276155, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[82.276262, "o", "\u001b[?2004h> "]
[82.276384, "o", "    const { x1, y1, x2, y2 } = parseBridgeKey(key);\r\n\u001b[?2004l\r"]
[82.27644, "o", "\u001b[?2004h>     \r\n"]
[82.276534, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[82.276644, "o", "    let fromId = null, toId = null;\r\n\u001b[?2004l\r"]
[82.276728, "o", "\u001b[?2004h> "]
[82.276812, "o", "    for (const island of islands) {\r\n\u001b[?2004l\r"]
[82.276848, "o", "\u001b[?2004h"]
[82.276905, "o", "> "]
[82.277063, "o", "      if (island.x === x1 && island.y === y1) fromId = island.id;\r\n\u001b[?2004l\r"]
[82.277092, "o", "\u001b[?2004h"]
[82.277147, "o", "> "]
[82.277309, "o", "      if (island.x === x2 && island.y === y2) toId = island.id;\r\n\u001b[?2004l\r"]
[82.277338, "o", "\u001b[?2004h"]
[82.277396, "o", "> "]
[82.277448, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[82.277475, "o", "\u001b[?2004h"]
[82.277486, "o", "> "]
[82.277642, "o", "    if (fromId !== null && toId !== null) {\r\n\u001b[?2004l\r"]
[82.277669, "o", "\u001b[?2004h"]
[82.277722, "o", "> "]
[82.277808, "o", "      adj.get(fromId).push(toId);\r\n\u001b[?2004l\r"]
[82.277842, "o", "\u001b[?2004h"]
[82.277854, "o", "> "]
[82.27798, "o", "      adj.get(toId).push(fromId);\r\n\u001b[?2004l\r"]
[82.278026, "o", "\u001b[?2004h> "]
[82.278068, "o", "    }\r\n\u001b[?2004l\r"]
[82.278135, "o", "\u001b[?2004h> "]
[82.278175, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.278224, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.27826, "o", "> "]
[82.278329, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[82.278374, "o", "\u001b[?2004h> "]
[82.278504, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[82.278558, "o", "\u001b[?2004h> "]
[82.278649, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[82.278713, "o", "\u001b[?2004h> "]
[82.278794, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[82.278856, "o", "\u001b[?2004h"]
[82.278902, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.278969, "o", "> "]
[82.279005, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[82.279072, "o", "\u001b[?2004h> "]
[82.279132, "o", "    const curr = queue.shift();\r\n\u001b[?2004l\r"]
[82.279195, "o", "\u001b[?2004h"]
[82.279238, "o", "> "]
[82.27932, "o", "    for (const neighbor of adj.get(curr)) {\r\n\u001b[?2004l\r"]
[82.279381, "o", "\u001b[?2004h"]
[82.279423, "o", "> "]
[82.279499, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r"]
[82.279589, "o", "\u001b[?2004h> "]
[82.27966, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.279705, "o", "> "]
[82.27978, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[82.279846, "o", "\u001b[?2004h>       }\r\n\u001b[?2004l\r"]
[82.279908, "o", "\u001b[?2004h> "]
[82.279981, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[82.280043, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[82.280117, "o", "\u001b[?2004h"]
[82.280185, "o", "> "]
[82.280257, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.280297, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[82.280364, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[82.280443, "o", "// Check if puzzle is solved\r\n\u001b[?2004l\r"]
[82.280528, "o", "\u001b[?2004h"]
[82.280596, "o", "> "]
[82.280651, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[82.280697, "o", "\u001b[?2004h> "]
[82.280795, "o", "  // Check all counts satisfied\r\n\u001b[?2004l\r"]
[82.280843, "o", "\u001b[?2004h> "]
[82.28102, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[82.281048, "o", "\u001b[?2004h"]
[82.281112, "o", "> "]
[82.281175, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[82.281255, "o", "\u001b[?2004h> "]
[82.281401, "o", "    if ((counts.get(island.id) || 0) !== island.value) {\r\n\u001b[?2004l\r"]
[82.281482, "o", "\u001b[?2004h> "]
[82.281579, "o", "      return false;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.281659, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.281732, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.281755, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.281852, "o", "  // Check no bridges cross\r\n\u001b[?2004l\r"]
[82.281873, "o", "\u001b[?2004h"]
[82.281953, "o", "> "]
[82.281997, "o", "  const activeBridges = [];\r\n\u001b[?2004l\r"]
[82.282085, "o", "\u001b[?2004h> "]
[82.28217, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[82.28225, "o", "\u001b[?2004h> "]
[82.282325, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[82.282419, "o", "\u001b[?2004h> "]
[82.282542, "o", "    activeBridges.push(parseBridgeKey(key));\r\n\u001b[?2004l\r"]
[82.282644, "o", "\u001b[?2004h"]
[82.282714, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.282855, "o", "  for (let i = 0; i < activeBridges.length; i++) {\r\n\u001b[?2004l\r"]
[82.282915, "o", "\u001b[?2004h"]
[82.282982, "o", "> "]
[82.283074, "o", "    for (let j = i + 1; j < activeBridges.length; j++) {\r\n\u001b[?2004l\r"]
[82.283134, "o", "\u001b[?2004h"]
[82.2832, "o", "> "]
[82.283269, "o", "      const a = activeBridges[i];\r\n\u001b[?2004l\r"]
[82.283343, "o", "\u001b[?2004h> "]
[82.283405, "o", "      const b = activeBridges[j];\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.283476, "o", "> "]
[82.283543, "o", "      const aHoriz = a.y1 === a.y2;\r\n\u001b[?2004l\r"]
[82.283608, "o", "\u001b[?2004h> "]
[82.283695, "o", "      const bHoriz = b.y1 === b.y2;\r\n\u001b[?2004l\r"]
[82.283771, "o", "\u001b[?2004h>       \r\n\u001b[?2004l\r"]
[82.283838, "o", "\u001b[?2004h> "]
[82.283937, "o", "      if (aHoriz === bHoriz) continue;\r\n\u001b[?2004l\r"]
[82.28397, "o", "\u001b[?2004h"]
[82.284033, "o", ">       \r\n\u001b[?2004l\r\u001b[?2004h"]
[82.284096, "o", "> "]
[82.284171, "o", "      if (aHoriz) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.284289, "o", "        const minX = Math.min(a.x1, a.x2);\r\n\u001b[?2004l\r"]
[82.284354, "o", "\u001b[?2004h> "]
[82.284483, "o", "        const maxX = Math.max(a.x1, a.x2);\r\n\u001b[?2004l\r"]
[82.284557, "o", "\u001b[?2004h> "]
[82.28461, "o", "        const aY = a.y1;\r\n\u001b[?2004l\r"]
[82.284673, "o", "\u001b[?2004h> "]
[82.284749, "o", "        const bX = b.x1;\r\n\u001b[?2004l\r"]
[82.284894, "o", "\u001b[?2004h> "]
[82.284938, "o", "        const minY = Math.min(b.y1, b.y2);\r\n\u001b[?2004l\r"]
[82.284994, "o", "\u001b[?2004h> "]
[82.285118, "o", "        const maxY = Math.max(b.y1, b.y2);\r\n\u001b[?2004l\r"]
[82.285162, "o", "\u001b[?2004h> "]
[82.285396, "o", "        if (bX > minX && bX < maxX && aY > minY && aY < maxY) return false;\r\n\u001b[?2004l\r"]
[82.285439, "o", "\u001b[?2004h> "]
[82.285497, "o", "      } else {\r\n\u001b[?2004l\r"]
[82.28554, "o", "\u001b[?2004h"]
[82.28559, "o", "> "]
[82.285709, "o", "        const minY = Math.min(a.y1, a.y2);\r\n\u001b[?2004l\r"]
[82.285782, "o", "\u001b[?2004h> "]
[82.285885, "o", "        const maxY = Math.max(a.y1, a.y2);\r\n\u001b[?2004l\r"]
[82.285956, "o", "\u001b[?2004h> "]
[82.286024, "o", "        const aX = a.x1;\r\n\u001b[?2004l\r"]
[82.286091, "o", "\u001b[?2004h> "]
[82.286134, "o", "        const bY = b.y1;\r\n\u001b[?2004l\r"]
[82.286181, "o", "\u001b[?2004h> "]
[82.286324, "o", "        const minX = Math.min(b.x1, b.x2);\r\n\u001b[?2004l\r"]
[82.286369, "o", "\u001b[?2004h> "]
[82.286502, "o", "        const maxX = Math.max(b.x1, b.x2);\r\n\u001b[?2004l\r"]
[82.286562, "o", "\u001b[?2004h"]
[82.28658, "o", "> "]
[82.286775, "o", "        if (aX > minX && aX < maxX && bY > minY && bY < maxY) return false;\r\n\u001b[?2004l\r"]
[82.28687, "o", "\u001b[?2004h> "]
[82.286959, "o", "      }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.287045, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.287138, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.2872, "o", "  // Check connectivity\r\n\u001b[?2004l\r"]
[82.287256, "o", "\u001b[?2004h> "]
[82.287397, "o", "  return checkConnectivity(islands, bridges);\r\n\u001b[?2004l\r"]
[82.28751, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.287591, "o", "EOF\r\n\u001b[?2004l\r"]
