[101.165629, "o", "\u001b[?2004h> "]
[101.165938, "o", "function checkPerpendicularCross(h1, h2, v1, v2) {\r\n\u001b[?2004l\r"]
[101.165987, "o", "\u001b[?2004h> "]
[101.166089, "o", "  const hY = h1.y;\r\n\u001b[?2004l\r"]
[101.166135, "o", "\u001b[?2004h> "]
[101.166347, "o", "  const hMinX = Math.min(h1.x, h2.x);\r\n\u001b[?2004l\r"]
[101.166545, "o", "\u001b[?2004h> "]
[101.16665, "o", "  const hMaxX = Math.max(h1.x, h2.x);\r\n\u001b[?2004l\r"]
[101.166668, "o", "\u001b[?2004h"]
[101.166679, "o", "> "]
[101.166805, "o", "  const vX = v1.x;\r\n\u001b[?2004l\r"]
[101.166888, "o", "\u001b[?2004h> "]
[101.167089, "o", "  const vMinY = Math.min(v1.y, v2.y);\r\n\u001b[?2004l\r"]
[101.167159, "o", "\u001b[?2004h> "]
