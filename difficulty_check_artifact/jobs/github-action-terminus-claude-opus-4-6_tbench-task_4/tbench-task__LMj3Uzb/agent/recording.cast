[604.257203, "o", "\u001b[?2004l\r"]
[604.259362, "o", "// Bridge key: canonical \"x1,y1,x2,y2\" where first endpoint sorts smaller (x then y)\r\nexport function bridgeKey(a, b) {\r\n  // a and b are {x, y} objects (grid coords)\r\n  if (a.x < b.x || (a.x === b.x && a.y < b.y)) {\r\n    return `${a.x},${a.y},${b.x},${b.y}`;\r\n  }\r\n  return `${b.x},${b.y},${a.x},${a.y}`;\r\n}\r\n\r\n// Parse a bridge key back into two points\r\nexport function parseBridgeKey(key) {\r\n"]
[604.259395, "o", "  const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n  return [{ x: x1, y: y1 }, { x: x2, y: y2 }];\r\n}\r\n\r\n// Check if two islands are adjacent (same row or col, no island between them)\r\nexport function areAdjacent(islands, from, to) {\r\n  if (from.x !== to.x && from.y !== to.y) return false;\r\n  if (from.x === to.x && from.y === to.y) return false;\r\n\r\n"]
[604.259569, "o", "\u001b[?2004h"]
[604.259619, "o", "root@7ac4ab2c80d7:/app# "]
