[101.170663, "o", "      }\r\n\u001b[?2004l\r"]
[101.170675, "o", "\u001b[?2004h"]
[101.170701, "o", "> "]
[101.170852, "o", "      if (island.x === b.x && island.y === b.y) {\r\n\u001b[?2004l\r"]
[101.170997, "o", "\u001b[?2004h> "]
[101.171117, "o", "        counts.set(island.id, (counts.get(island.id) || 0) + count);\r\n\u001b[?2004l\r"]
