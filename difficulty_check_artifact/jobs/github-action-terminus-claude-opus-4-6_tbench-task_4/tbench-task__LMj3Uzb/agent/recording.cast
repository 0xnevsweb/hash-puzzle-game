[101.16975, "o", "> "]
[101.169901, "o", "    // Find islands at these positions\r\n\u001b[?2004l\r"]
[101.169972, "o", "\u001b[?2004h> "]
[101.170071, "o", "    for (const island of islands) {\r\n\u001b[?2004l\r"]
