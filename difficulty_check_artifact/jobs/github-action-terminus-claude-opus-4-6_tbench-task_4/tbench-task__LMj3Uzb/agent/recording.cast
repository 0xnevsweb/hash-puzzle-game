[101.143387, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Bridge key: canonical \"x1,y1,x2,y2\" where first endpoint sorts smaller (x then y)\nexport function bridgeKey(a, b) {\n  // a and b are {x, y} objects (grid coords)\n  if (a.x < b.x || (a.x === b.x && a.y < b.y)) {\n    return `${a.x},${a.y},${b.x},${b.y}`;\n  }\n  return `${b.x},${b.y},${a.x},${a.y}`;\n}\n\n// Parse a bridge key back into two points\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return [{ x: x1, y: y1 }, { x: x2, y: y2 }];\n}\n\n// Check if two islands are adjacent (same row or col, no island between them)\nexport function areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n\n  // Check no island between them\n  for (const island of islands) {\n    if (island.id === from.id || island.id === to.id) continue;\n    if (from.x === to.x && island.x === from.x) {\n      const minY = Math.min(from.y, to.y);\n      const maxY = Math.m"]
[101.143838, "i", "ax(from.y, to.y);\n      if (island.y > minY && island.y < maxY) return false;\n    }\n    if (from.y === to.y && island.y === from.y) {\n      const minX = Math.min(from.x, to.x);\n      const maxX = Math.max(from.x, to.x);\n      if (island.x > minX && island.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if a bridge between a and b would cross any existing bridge\nexport function wouldCross(bridges, a, b) {\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const [c, d] = parseBridgeKey(key);\n    if (segmentsCross(a, b, c, d)) return true;\n  }\n  return false;\n}\n\n// Check if two segments cross (one horizontal, one vertical)\nfunction segmentsCross(a, b, c, d) {\n  // Determine orientation of each segment\n  const seg1Horizontal = a.y === b.y;\n  const seg1Vertical = a.x === b.x;\n  const seg2Horizontal = c.y === d.y;\n  const seg2Vertical = c.x === d.x;\n\n  // Only perpendicular segments can cross\n  if (seg1Horizontal && seg2Vertical) {\n    return checkPerpendicularCross(a, b, c, d);"]
