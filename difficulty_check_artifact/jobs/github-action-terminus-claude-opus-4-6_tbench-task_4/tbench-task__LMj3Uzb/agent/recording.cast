[101.171598, "o", "\u001b[?2004h"]
[101.171644, "o", "> "]
[101.171822, "o", "// Check if adding delta bridges between from and to is valid\r\n\u001b[?2004l\r"]
[101.171843, "o", "\u001b[?2004h"]
[101.171861, "o", "> "]
[101.172081, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[101.172146, "o", "\u001b[?2004h"]
[101.17223, "o", "> "]
[101.172281, "o", "  // Check adjacency\r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.1724, "o", "  if (!areAdjacent(islands, from, to)) {\r\n\u001b[?2004l\r"]
