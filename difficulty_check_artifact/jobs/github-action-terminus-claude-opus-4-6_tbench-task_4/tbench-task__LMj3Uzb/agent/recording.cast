[101.173562, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.173624, "o", "  // Check max 2\r\n\u001b[?2004l\r"]
[101.173651, "o", "\u001b[?2004h"]
[101.173663, "o", "> "]
[101.173757, "o", "  if (newCount > 2) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.173775, "o", "> "]
[101.173976, "o", "    return { valid: false, error: \"Max 2 bridges per pair\" };\r\n\u001b[?2004l\r"]
[101.174058, "o", "\u001b[?2004h"]
[101.174082, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
