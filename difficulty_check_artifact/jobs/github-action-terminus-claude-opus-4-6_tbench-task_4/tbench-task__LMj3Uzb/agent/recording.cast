[155.51776, "i", "python3 -c \"\nimport os\n\napp_code = '''import React, { useState, useEffect, useCallback, useRef } from 'react';\nimport { puzzles } from './data/puzzles';\nimport {\n  bridgeKey,\n  parseBridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n  areAdjacent\n} from './utils/hashiLogic';\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [cursorIslandId, setCursorIslandId] = useState(0);\n  const [errorMessage, setErrorMessage] = useState(null);\n  const [victory, setVictory] = useState(false);\n\n  const puzzle = puzzles[puzzleIndex];\n  const islands = puzzle.islands;\n\n  // Reset everything when puzzle changes\n  const resetPuzzle = useCallback(() => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n  }, []);\n\n  const handlePuzzleChange = (e) => {\n    const idx = parseInt(e.target.value, 10"]
[155.518051, "i", ");\n    setPuzzleIndex(idx);\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n  };\n\n  const handleReset = () => {\n    resetPuzzle();\n  };\n\n  // Toggle bridge between two islands: none -> single -> double -> none\n  const toggleBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const current = bridges.get(key) || 0;\n\n    if (current === 0) {\n      // Try to add single\n      const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        setErrorMessage(result.error);\n        return;\n      }\n      setErrorMessage(null);\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 1);\n      setBridges(newBridges);\n      // Check victory\n      if (isVictory(islands, newBridges)) {\n        setVictory(true);\n      }\n    } else if (current === 1) {\n      // Try to add second\n      const result = canAddBridge(islands, bridges, fromIsland"]
