[101.154205, "o", "// Check if a bridge between a and b would cross any existing bridge\r\n\u001b[?2004l\r"]
[101.154308, "o", "\u001b[?2004h> "]
[101.154533, "o", "export function wouldCross(bridges, a, b) {\r\n\u001b[?2004l\r"]
[101.154597, "o", "\u001b[?2004h"]
[101.154624, "o", "> "]
