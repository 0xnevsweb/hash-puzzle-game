[101.169433, "o", "\u001b[?2004h"]
[101.169453, "o", "> "]
[101.169551, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.16965, "o", "> "]
[101.169708, "o", "    const [a, b] = parseBridgeKey(key);\r\n\u001b[?2004l\r"]
