[101.156384, "o", "// Check if two segments cross (one horizontal, one vertical)\r\n\u001b[?2004l\r"]
[101.156448, "o", "\u001b[?2004h> "]
[101.156645, "o", "function segmentsCross(a, b, c, d) {\r\n\u001b[?2004l\r"]
[101.156694, "o", "\u001b[?2004h> "]
[101.15693, "o", "  // Determine orientation of each segment\r\n\u001b[?2004l\r"]
[101.156978, "o", "\u001b[?2004h> "]
[101.1572, "o", "  const seg1Horizontal = a.y === b.y;\r\n\u001b[?2004l\r"]
[101.157286, "o", "\u001b[?2004h> "]
[101.157449, "o", "  const seg1Vertical = a.x === b.x;\r\n\u001b[?2004l\r"]
[101.157585, "o", "\u001b[?2004h> "]
[101.157728, "o", "  const seg2Horizontal = c.y === d.y;\r\n\u001b[?2004l\r"]
[101.157773, "o", "\u001b[?2004h> "]
[101.157999, "o", "  const seg2Vertical = c.x === d.x;\r\n\u001b[?2004l\r"]
