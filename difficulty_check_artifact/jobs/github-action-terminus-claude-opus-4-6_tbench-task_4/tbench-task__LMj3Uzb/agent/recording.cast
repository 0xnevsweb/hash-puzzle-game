[101.159463, "o", "\u001b[?2004h> "]
[101.159747, "o", "    return checkPerpendicularCross(c, d, a, b);\r\n\u001b[?2004l\r"]
[101.159844, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.159915, "o", "> \r\n\u001b[?2004l\r{\u001b[?2004h> "]
[101.160177, "o", "  // Parallel segments - check collinear overlap\r\n\u001b[?2004l\r"]
[101.160199, "o", "\u001b[?2004h"]
[101.160214, "o", "> "]
[101.160461, "o", "  if (seg1Horizontal && seg2Horizontal) {\r\n\u001b[?2004l\r"]
[101.160505, "o", "\u001b[?2004h> "]
[101.160724, "o", "    if (a.y !== c.y) return false;\r\n\u001b[?2004l\r"]
[101.160783, "o", "\u001b[?2004h> "]
[101.16098, "o", "    const min1 = Math.min(a.x, b.x);\r\n\u001b[?2004l\r"]
[101.161032, "o", "\u001b[?2004h> "]
[101.161229, "o", "    const max1 = Math.max(a.x, b.x);\r\n\u001b[?2004l\r"]
[101.161283, "o", "\u001b[?2004h> "]
[101.161474, "o", "    const min2 = Math.min(c.x, d.x);\r\n\u001b[?2004l\r"]
[101.161527, "o", "\u001b[?2004h> "]
[101.161721, "o", "    const max2 = Math.max(c.x, d.x);\r\n\u001b[?2004l\r"]
[101.161777, "o", "\u001b[?2004h> "]
[101.16209, "o", "    // Overlap if ranges intersect (exclusive of endpoints)\r\n\u001b[?2004l\r"]
[101.162145, "o", "\u001b[?2004h> "]
[101.162549, "o", "    return min1 < max2 && min2 < max1 && !(max1 === min2 || max2 === min1);\r\n\u001b[?2004l\r"]
