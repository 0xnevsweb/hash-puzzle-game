[101.177989, "o", "> }\r\n\u001b[?2004l\r"]
[101.178007, "o", "\u001b[?2004h"]
[101.178024, "o", "> \r\n\u001b[?2004l\r"]
[101.178081, "o", "\u001b[?2004h> "]
[101.178319, "o", "// Check connectivity - all islands with at least one bridge must be connected\r\n\u001b[?2004l\r"]
[101.178366, "o", "\u001b[?2004h> "]
[101.178551, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[101.178601, "o", "\u001b[?2004h> "]
[101.178733, "o", "  if (islands.length === 0) return true;\r\n\u001b[?2004l\r"]
[101.178836, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.178949, "o", "  // Build adjacency from bridges\r\n\u001b[?2004l\r"]
[101.179037, "o", "\u001b[?2004h> "]
[101.179103, "o", "  const adj = new Map();\r\n\u001b[?2004l\r"]
[101.179124, "o", "\u001b[?2004h> "]
[101.179251, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[101.179322, "o", "\u001b[?2004h> "]
[101.179401, "o", "    adj.set(island.id, []);\r\n\u001b[?2004l\r"]
[101.179458, "o", "\u001b[?2004h"]
[101.179494, "o", ">   }\r\n\u001b[?2004l\r"]
[101.179505, "o", "\u001b[?2004h"]
[101.179566, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[101.179584, "o", "> "]
[101.179711, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[101.179759, "o", "\u001b[?2004h> "]
[101.179866, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[101.179883, "o", "\u001b[?2004h"]
[101.179935, "o", "> "]
[101.180045, "o", "    const [a, b] = parseBridgeKey(key);\r\n\u001b[?2004l\r"]
[101.180061, "o", "\u001b[?2004h"]
[101.180106, "o", "> "]
[101.180233, "o", "    let fromIsland = null, toIsland = null;\r\n\u001b[?2004l\r"]
[101.180276, "o", "\u001b[?2004h> "]
[101.180398, "o", "    for (const island of islands) {\r\n\u001b[?2004l\r"]
[101.180415, "o", "\u001b[?2004h"]
[101.180495, "o", "> "]
[101.180659, "o", "      if (island.x === a.x && island.y === a.y) fromIsland = island;\r\n\u001b[?2004l\r"]
[101.180706, "o", "\u001b[?2004h"]
[101.180724, "o", "> "]
[101.180918, "o", "      if (island.x === b.x && island.y === b.y) toIsland = island;\r\n\u001b[?2004l\r"]
[101.180939, "o", "\u001b[?2004h"]
[101.18096, "o", "> "]
[101.18098, "o", "    }\r\n\u001b[?2004l\r"]
[101.181001, "o", "\u001b[?2004h"]
[101.181093, "o", "> "]
[101.181179, "o", "    if (fromIsland && toIsland) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.181197, "o", "> "]
[101.181356, "o", "      adj.get(fromIsland.id).push(toIsland.id);\r\n\u001b[?2004l\r"]
[101.181377, "o", "\u001b[?2004h"]
[101.181398, "o", "> "]
[101.181554, "o", "      adj.get(toIsland.id).push(fromIsland.id);\r\n\u001b[?2004l\r"]
[101.181574, "o", "\u001b[?2004h"]
[101.181594, "o", "> "]
[101.181614, "o", "    }\r\n\u001b[?2004l\r"]
[101.181632, "o", "\u001b[?2004h"]
[101.181644, "o", "> "]
[101.181669, "o", "  }\r\n\u001b[?2004l\r"]
[101.181769, "o", "\u001b[?2004h"]
[101.181789, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.181863, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[101.181889, "o", "\u001b[?2004h"]
[101.181912, "o", "> "]
[101.182014, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[101.182041, "o", "\u001b[?2004h"]
[101.182053, "o", "> "]
[101.182187, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[101.18221, "o", "\u001b[?2004h"]
[101.182223, "o", "> "]
[101.18233, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[101.182362, "o", "\u001b[?2004h"]
[101.182395, "o", "> \r\n\u001b[?2004l\r"]
[101.182508, "o", "\u001b[?2004h> "]
[101.182577, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[101.182634, "o", "\u001b[?2004h> "]
[101.182741, "o", "    const curr = queue.shift();\r\n\u001b[?2004l\r"]
[101.182788, "o", "\u001b[?2004h> "]
[101.182945, "o", "    for (const neighbor of adj.get(curr)) {\r\n\u001b[?2004l\r"]
[101.182984, "o", "\u001b[?2004h"]
[101.182999, "o", "> "]
[101.183139, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r"]
[101.183172, "o", "\u001b[?2004h"]
[101.183187, "o", "> "]
[101.183311, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r"]
[101.183371, "o", "\u001b[?2004h> "]
[101.183493, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[101.183551, "o", "\u001b[?2004h> "]
[101.183602, "o", "      }\r\n\u001b[?2004l\r"]
[101.183652, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[101.183713, "o", "\u001b[?2004h> "]
[101.18378, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.183824, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.183972, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r"]
[101.184068, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.184157, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.184227, "o", "// Check victory condition\r\n\u001b[?2004l\r"]
[101.184295, "o", "\u001b[?2004h> "]
[101.184424, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[101.184486, "o", "\u001b[?2004h> "]
[101.184659, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[101.184691, "o", "\u001b[?2004h"]
[101.184705, "o", "> \r\n\u001b[?2004l\r"]
[101.184748, "o", "\u001b[?2004h> "]
[101.184957, "o", "  // Every island must have exactly its value in bridges\r\n\u001b[?2004l\r"]
[101.185017, "o", "\u001b[?2004h> "]
[101.185118, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[101.185161, "o", "\u001b[?2004h"]
[101.18518, "o", "> "]
[101.18539, "o", "    if ((counts.get(island.id) || 0) !== island.value) return false;\r\n\u001b[?2004l\r"]
[101.18544, "o", "\u001b[?2004h> "]
[101.185477, "o", "  }\r\n\u001b[?2004l\r"]
[101.185601, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.185663, "o", "  // Check connectivity\r\n\u001b[?2004l\r"]
[101.185715, "o", "\u001b[?2004h> "]
[101.185881, "o", "  if (!checkConnectivity(islands, bridges)) return false;\r\n\u001b[?2004l\r"]
[101.185921, "o", "\u001b[?2004h> "]
[101.185941, "o", "\r\n\u001b[?2004l\r"]
[101.185962, "o", "\u001b[?2004h"]
[101.186016, "o", "> "]
[101.186148, "o", "  // Check no crossings among existing bridges\r\n\u001b[?2004l\r"]
[101.186262, "o", "\u001b[?2004h> "]
[101.186355, "o", "  const bridgeList = [];\r\n\u001b[?2004l\r"]
[101.186449, "o", "\u001b[?2004h> "]
[101.186506, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[101.186594, "o", "\u001b[?2004h> "]
[101.186697, "o", "    if (count > 0) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.186816, "o", "      bridgeList.push(parseBridgeKey(key));\r\n\u001b[?2004l\r"]
[101.186836, "o", "\u001b[?2004h"]
[101.186915, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.186934, "o", "> "]
[101.186948, "o", "  }\r\n\u001b[?2004l\r"]
[101.187033, "o", "\u001b[?2004h> "]
[101.187154, "o", "  for (let i = 0; i < bridgeList.length; i++) {\r\n\u001b[?2004l\r"]
[101.187174, "o", "\u001b[?2004h"]
[101.187186, "o", "> "]
[101.187382, "o", "    for (let j = i + 1; j < bridgeList.length; j++) {\r\n\u001b[?2004l\r"]
[101.187431, "o", "\u001b[?2004h> "]
[101.187738, "o", "      if (segmentsCross(bridgeList[i][0], bridgeList[i][1], bridgeList[j][0], bridgeList[j][1])) {\r\n\u001b[?2004l\r"]
[101.187813, "o", "\u001b[?2004h> "]
[101.187899, "o", "        return false;\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.187979, "o", "> "]
[101.188058, "o", "      }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[101.188134, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[101.18821, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.188278, "o", "  return true;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.188343, "o", "}\r\n\u001b[?2004l\r"]
[101.188425, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
