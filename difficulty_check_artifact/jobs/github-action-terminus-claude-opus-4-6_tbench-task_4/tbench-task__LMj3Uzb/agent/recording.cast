[101.167407, "o", "\u001b[?2004h"]
[101.16746, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.167645, "o", "  // Cross if vX is strictly between hMinX and hMaxX\r\n\u001b[?2004l\r"]
[101.167705, "o", "\u001b[?2004h"]
[101.167763, "o", "> "]
[101.167873, "o", "  // and hY is strictly between vMinY and vMaxY\r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.168067, "o", "  return vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY;\r\n\u001b[?2004l\r"]
[101.168131, "o", "\u001b[?2004h"]
[101.168151, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.168241, "o", "\r\n\u001b[?2004l\r"]
[101.168339, "o", "\u001b[?2004h> "]
[101.168443, "o", "// Compute current bridge counts per island\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.168489, "o", "> "]
[101.168612, "o", "export function computeCurrentCounts(islands, bridges) {\r\n\u001b[?2004l\r"]
[101.168677, "o", "\u001b[?2004h"]
[101.168696, "o", "> "]
[101.168797, "o", "  const counts = new Map();\r\n\u001b[?2004l\r"]
[101.168818, "o", "\u001b[?2004h> "]
[101.16893, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
