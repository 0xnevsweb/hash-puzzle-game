[101.158356, "o", "\u001b[?2004h"]
[101.158479, "o", "> "]
[101.158715, "o", "  if (seg1Horizontal && seg2Vertical) {\r\n\u001b[?2004l\r"]
[101.158785, "o", "\u001b[?2004h> "]
