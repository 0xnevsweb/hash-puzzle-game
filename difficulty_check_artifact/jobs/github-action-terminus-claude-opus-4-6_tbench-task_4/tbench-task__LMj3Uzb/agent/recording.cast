[101.176137, "o", "\u001b[?2004h> "]
[101.176336, "o", "  // Check crossing - only need to check if adding (not removing)\r\n\u001b[?2004l\r"]
[101.176361, "o", "\u001b[?2004h"]
[101.176434, "o", "> "]
[101.176513, "o", "  if (delta > 0 && current === 0) {\r\n\u001b[?2004l\r"]
