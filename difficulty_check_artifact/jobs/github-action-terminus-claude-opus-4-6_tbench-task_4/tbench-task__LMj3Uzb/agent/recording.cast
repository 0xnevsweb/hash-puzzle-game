[101.17116, "o", "> "]
[101.171193, "o", "      }\r\n\u001b[?2004l\r"]
[101.171222, "o", "\u001b[?2004h"]
[101.17136, "o", ">     }\r\n\u001b[?2004l\r"]
[101.171427, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[101.171469, "o", "  return counts;\r\n\u001b[?2004l\r\u001b[?2004h"]
[101.171515, "o", "> }\r\n"]
