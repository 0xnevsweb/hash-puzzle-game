[101.174577, "o", "\u001b[?2004h"]
[101.174593, "o", "> "]
[101.17473, "o", "  const fromCount = counts.get(from.id) || 0;\r\n\u001b[?2004l\r"]
[101.174808, "o", "\u001b[?2004h> "]
[101.174935, "o", "  const toCount = counts.get(to.id) || 0;\r\n\u001b[?2004l\r"]
[101.174957, "o", "\u001b[?2004h"]
[101.175066, "o", "> \r\n\u001b[?2004l\r"]
[101.175125, "o", "\u001b[?2004h> "]
[101.175197, "o", "  if (fromCount + delta > from.value) {\r\n\u001b[?2004l\r"]
[101.175216, "o", "\u001b[?2004h> "]
[101.175442, "o", "    return { valid: false, error: \"Island would exceed its number\" };\r\n\u001b[?2004l\r"]
[101.175464, "o", "\u001b[?2004h"]
[101.175483, "o", "> "]
[101.175496, "o", "  }\r\n\u001b[?2004l\r"]
[101.175524, "o", "\u001b[?2004h"]
