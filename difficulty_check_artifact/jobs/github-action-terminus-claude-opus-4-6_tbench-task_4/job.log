Sending keys: ['cat > /app/src/utils/hashiLogic.js << \'EOF\'\n// Bridge key: canonical "x1,y1,x2,y2" where endpoint with smaller (x, then y) sorts first\nexport function bridgeKey(a, b) {\n  // a and b are {x, y} objects (grid units)\n  if (a.x < b.x || (a.x === b.x && a.y < b.y)) {\n    return `${a.x},${a.y},${b.x},${b.y}`;\n  }\n  return `${b.x},${b.y},${a.x},${a.y}`;\n}\n\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\n// Check if two islands are adjacent (same row/col, no island between them)\nfunction areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n  \n  // Check no island between them\n  if (from.x === to.x) {\n    // Vertical\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) return false;\n    }\n  } else {\n    // Horizontal\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if a bridge between from and to would cross any existing bridge\nfunction wouldCross(islands, bridges, from, to) {\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    if (segmentsIntersect(from.x, from.y, to.x, to.y, x1, y1, x2, y2)) {\n      return true;\n    }\n  }\n  return false;\n}\n\n// Check if two segments cross (not collinear overlap, just proper intersection)\nfunction segmentsIntersect(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2) {\n  // One is horizontal, one is vertical for them to cross\n  // (bridges are always H or V)\n  const aHoriz = (ay1 === ay2);\n  const aVert = (ax1 === ax2);\n  const bHoriz = (by1 === by2);\n  const bVert = (bx1 === bx2);\n  \n  // Both horizontal or both vertical - they can\'t cross (they might overlap but we handle adjacency separately)\n  if ((aHoriz && bHoriz) || (aVert && bVert)) return false;\n  \n  // a is horizontal, b is vertical\n  if (aHoriz && bVert) {\n    const aMinX = Math.min(ax1, ax2);\n    const aMaxX = Math.max(ax1, ax2);\n    const bMinY = Math.min(by1, by2);\n    const bMaxY = Math.max(by1, by2);\n    // Strict intersection (not at endpoints - endpoints are islands)\n    return bx1 > aMinX && bx1 < aMaxX && ay1 > bMinY && ay1 < bMaxY;\n  }\n  \n  // a is vertical, b is horizontal\n  if (aVert && bHoriz) {\n    const bMinX = Math.min(bx1, bx2);\n    const bMaxX = Math.max(bx1, bx2);\n    const aMinY = Math.min(ay1, ay2);\n    const aMaxY = Math.max(ay1, ay2);\n    return ax1 > bMinX && ax1 < bMaxX && by1 > aMinY && by1 < aMaxY;\n  }\n  \n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    // Find islands at these positions\n    const islandA = islands.find(i => i.x === x1 && i.y === y1);\n    const islandB = islands.find(i => i.x === x2 && i.y === y2);\n    if (islandA) counts.set(islandA.id, (counts.get(islandA.id) || 0) + count);\n    if (islandB) counts.set(islandB.id, (counts.get(islandB.id) || 0) + count);\n  }\n  \n  return counts;\n}\n\n// Check if all islands are connected\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  if (islands.length === 1) return true;\n  \n  // Build adjacency list based on bridges with count > 0\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const islandA = islands.find(i => i.x === x1 && i.y === y1);\n    const islandB = islands.find(i => i.x === x2 && i.y === y2);\n    if (islandA && islandB) {\n      adj.get(islandA.id).push(islandB.id);\n      adj.get(islandB.id).push(islandA.id);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const curr = queue.shift();\n    for (const neighbor of adj.get(curr)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  const counts = computeCurrentCounts(islands, bridges);\n  \n  // Every island\'s count must equal its value\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) return false;\n  }\n  \n  // Check connectivity\n  if (!checkConnectivity(islands, bridges)) return false;\n  \n  // Check no bridges cross\n  const bridgeList = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    bridgeList.push(parseBridgeKey(key));\n  }\n  for (let i = 0; i < bridgeList.length; i++) {\n    for (let j = i + 1; j < bridgeList.length; j++) {\n      const a = bridgeList[i];\n      const b = bridgeList[j];\n      if (segmentsIntersect(a.x1, a.y1, a.x2, a.y2, b.x1, b.y1, b.x2, b.y2)) {\n        return false;\n      }\n    }\n  }\n  \n  return true;\n}\n\n// canAddBridge: checks if we can add delta bridges between from and to\n// delta is typically +1 (adding one bridge in the cycle)\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Guard: same island\n  if (from.id === to.id) {\n    return { valid: false, error: "Cannot connect island to itself" };\n  }\n  \n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n  \n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n  \n  // Max 2 bridges\n  if (newCount > 2) {\n    return { valid: false, error: "Max 2 bridges per pair" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n  \n  // Check crossing - only if we\'re adding (not removing)\n  if (delta > 0 && current === 0) {\n    // Only check crossing when going from 0 to 1 (new bridge)\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: "Bridges would cross" };\n    }\n  }\n  \n  return { valid: true, error: null };\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
