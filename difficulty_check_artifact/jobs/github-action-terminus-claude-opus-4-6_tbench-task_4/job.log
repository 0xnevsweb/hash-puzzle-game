Sending keys: ['cat > /app/src/App.jsx << \'APPEOF\'\nimport React, { useState, useEffect, useCallback, useRef } from \'react\';\nimport { puzzles } from \'./data/puzzles\';\nimport { bridgeKey, canAddBridge, computeCurrentCounts, isVictory } from \'./utils/hashiLogic\';\n\nconst GRID_SIZE = 40;\nconst SVG_WIDTH = 800;\nconst SVG_HEIGHT = 600;\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [cursorIslandIdx, setCursorIslandIdx] = useState(0);\n  const [errorMessage, setErrorMessage] = useState(\'\');\n  const [victory, setVictory] = useState(false);\n  const [keyboardMode, setKeyboardMode] = useState(false);\n  const svgRef = useRef(null);\n\n  const currentPuzzle = puzzles[puzzleIndex];\n  const islands = currentPuzzle.islands;\n\n  // Reset when puzzle changes\n  const resetGame = useCallback(() => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setErrorMessage(\'\');\n    setVictory(false);\n    setCursorIslandIdx(0);\n    setKeyboardMode(false);\n  }, []);\n\n  useEffect(() => {\n    resetGame();\n  }, [puzzleIndex, resetGame]);\n\n  // Check victory after bridges change\n  useEffect(() => {\n    if (bridges.size > 0 && isVictory(islands, bridges)) {\n      setVictory(true);\n    } else {\n      setVictory(false);\n    }\n  }, [bridges, islands]);\n\n  const clearError = () => setErrorMessage(\'\');\n\n  const toggleBridge = useCallback((fromIsland, toIsland, forceRemove = false) => {\n    if (fromIsland.id === toIsland.id) return;\n\n    if (forceRemove) {\n      // Right-click / Ctrl+click: remove bridge entirely\n      const key = bridgeKey(fromIsland, toIsland);\n      const current = bridges.get(key) || 0;\n      if (current > 0) {\n        clearError();\n        const newBridges = new Map(bridges);\n        newBridges.delete(key);\n        setBridges(newBridges);\n      }\n      setSelectedIsland(null);\n      return;\n    }\n\n    // Cycle: none -> single -> double -> none\n    const key = bridgeKey(fromIsland, toIsland);\n    const current = bridges.get(key) || 0;\n\n    if (current === 2) {\n      // Remove bridge (cycle back to none)\n      clearError();\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setSelectedIsland(null);\n      return;\n    }\n\n    // Try to add one bridge\n    const delta = 1;\n    const result = canAddBridge(islands, bridges, fromIsland, toIsland, delta);\n    if (!result.valid) {\n      setErrorMessage(result.error);\n      setSelectedIsland(null);\n      return;\n    }\n\n    clearError();\n    const newBridges = new Map(bridges);\n    newBridges.set(key, current + delta);\n    setBridges(newBridges);\n    setSelectedIsland(null);\n  }, [bridges, islands]);\n\n  // Mouse click on island\n  const handleIslandClick = useCallback((island, e) => {\n    if (victory) return;\n    const isRightClickLike = e.ctrlKey || e.metaKey;\n\n    if (isRightClickLike && selectedIsland !== null) {\n      toggleBridge(selectedIsland, island, true);\n      return;\n    }\n\n    if (selectedIsland === null) {\n      clearError();\n      setSelectedIsland(island);\n    } else {\n      toggleBridge(selectedIsland, island, false);\n    }\n  }, [selectedIsland, victory, toggleBridge]);\n\n  // Right-click handler\n  const handleContextMenu = useCallback((island, e) => {\n    e.preventDefault();\n    if (victory) return;\n    if (selectedIsland !== null) {\n      toggleBridge(selectedIsland, island, true);\n    }\n  }, [selectedIsland, victory, toggleBridge]);\n\n  // Keyboard navigation\n  const handleKeyDown = useCallback((e) => {\n    if (victory) return;\n    const key = e.key;\n\n    if (key === \'Escape\') {\n      setSelectedIsland(null);\n      setKeyboardMode(false);\n      clearError();\n      return;\n    }\n\n    if (key === \'ArrowUp\' || key === \'ArrowDown\' || key === \'ArrowLeft\' || key === \'ArrowRight\') {\n      e.preventDefault();\n      setKeyboardMode(true);\n      const currentIsland = islands[cursorIslandIdx];\n      let bestIdx = cursorIslandIdx;\n      let bestDist = Infinity;\n\n      for (let i = 0; i < islands.length; i++) {\n        if (i === cursorIslandIdx) continue;\n        const other = islands[i];\n        const dx = other.x - currentIsland.x;\n        const dy = other.y - currentIsland.y;\n\n        let valid = false;\n        if (key === \'ArrowRight\' && dx > 0 && Math.abs(dy) <= Math.abs(dx)) valid = true;\n        if (key === \'ArrowLeft\' && dx < 0 && Math.abs(dy) <= Math.abs(dx)) valid = true;\n        if (key === \'ArrowDown\' && dy > 0 && Math.abs(dx) <= Math.abs(dy)) valid = true;\n        if (key === \'ArrowUp\' && dy < 0 && Math.abs(dx) <= Math.abs(dy)) valid = true;\n\n        if (valid) {\n          const dist = Math.abs(dx) + Math.abs(dy);\n          if (dist < bestDist) {\n            bestDist = dist;\n            bestIdx = i;\n          }\n        }\n      }\n      setCursorIslandIdx(bestIdx);\n      return;\n    }\n\n    if (key === \'Enter\') {\n      setKeyboardMode(true);\n      const cursorIsland = islands[cursorIslandIdx];\n      if (selectedIsland === null) {\n        clearError();\n        setSelectedIsland(cursorIsland);\n      } else {\n        toggleBridge(selectedIsland, cursorIsland, false);\n      }\n      return;\n    }\n  }, [victory, cursorIslandIdx, islands, selectedIsland, toggleBridge]);\n\n  useEffect(() => {\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [handleKeyDown]);\n\n  // Render bridges\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges) {\n      if (count === 0) continue;\n      const parts = key.split(\',\').map(Number);\n      const x1 = parts[0] * GRID_SIZE;\n      const y1 = parts[1] * GRID_SIZE;\n      const x2 = parts[2] * GRID_SIZE;\n      const y2 = parts[3] * GRID_SIZE;\n\n      const isHorizontal = y1 === y2;\n      const offset = 4;\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={x1} y1={y1} x2={x2} y2={y2}\n            stroke="#0f0"\n            strokeWidth="2"\n          />\n        );\n      } else if (count === 2) {\n        if (isHorizontal) {\n          lines.push(\n            <line\n              key={key + \'_a\'}\n              x1={x1} y1={y1 - offset} x2={x2} y2={y2 - offset}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'_b\'}\n              x1={x1} y1={y1 + offset} x2={x2} y2={y2 + offset}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n        } else {\n          lines.push(\n            <line\n              key={key + \'_a\'}\n              x1={x1 - offset} y1={y1} x2={x2 - offset} y2={y2}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'_b\'}\n              x1={x1 + offset} y1={y1} x2={x2 + offset} y2={y2}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map((island) => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland && selectedIsland.id === island.id;\n\n      return (\n        <g key={island.id}>\n          <circle\n            cx={px}\n            cy={py}\n            r={16}\n            fill="black"\n            stroke={isSelected ? \'#ff0\' : \'#0f0\'}\n            strokeWidth={isSelected ? 3 : 2}\n            style={{ cursor: \'pointer\' }}\n            onClick={(e) => handleIslandClick(island, e)}\n            onContextMenu={(e) => handleContextMenu(island, e)}\n          />\n          <text\n            x={px}\n            y={py}\n            textAnchor="middle"\n            dominantBaseline="central"\n            fill="#0f0"\n            fontSize="14"\n            fontFamily="monospace"\n            style={{ pointerEvents: \'none\' }}\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render keyboard cursor (rect, not circle)\n  const renderCursor = () => {\n    if (!keyboardMode) return null;\n    const island = islands[cursorIslandIdx];\n    if (!island) return null;\n    const px = island.x * GRID_SIZE;\n    const py = island.y * GRID_SIZE;\n\n    return (\n      <rect\n        x={px - 20}\n        y={py - 20}\n        width={40}\n        height={40}\n        fill="none"\n        stroke="#ff0"\n        strokeWidth="2"\n        strokeDasharray="4,2"\n        style={{ pointerEvents: \'none\' }}\n      />\n    );\n  };\n\n  return (\n    <div style={{ margin: 0, padding: 0 }}>\n      <div style={{ padding: \'8px\', fontFamily: \'monospace\', color: \'#0f0\' }}>\n        <label htmlFor="puzzle-select" style={{ marginRight: \'8px\' }}>Puzzle:</label>\n        <select\n          id="puzzle-select"\n          value={puzzleIndex}\n          onChange={(e) => setPuzzleIndex(Number(e.target.value))}\n          style={{ background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\' }}\n        >\n          {puzzles.map((p, idx) => (\n            <option key={p.id} value={idx}>{p.name}</option>\n          ))}\n        </select>\n        <button\n          onClick={resetGame}\n          style={{ marginLeft: \'16px\', background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\', cursor: \'pointer\' }}\n        >\n          Reset\n        </button>\n      </div>\n      {errorMessage && (\n        <div className="error-message" style={{ padding: \'4px