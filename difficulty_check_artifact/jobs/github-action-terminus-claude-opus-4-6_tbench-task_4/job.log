Sending keys: ['cat > /app/src/App.jsx << \'ENDOFFILE\'\nimport React, { useState, useEffect, useCallback } from \'react\';\nimport { puzzles } from \'./data/puzzles.js\';\nimport { bridgeKey, parseBridgeKey, canAddBridge, isVictory } from \'./utils/hashiLogic.js\';\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [errorMessage, setErrorMessage] = useState(null);\n  const [victory, setVictory] = useState(false);\n  const [cursorIslandId, setCursorIslandId] = useState(0);\n\n  const currentPuzzle = puzzles[puzzleIndex];\n  const islands = currentPuzzle.islands;\n\n  // Reset everything when puzzle changes\n  const resetPuzzle = useCallback(() => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setErrorMessage(null);\n    setVictory(false);\n    setCursorIslandId(0);\n  }, []);\n\n  const handlePuzzleChange = (e) => {\n    setPuzzleIndex(Number(e.target.value));\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setErrorMessage(null);\n    setVictory(false);\n    setCursorIslandId(0);\n  };\n\n  const handleReset = () => {\n    resetPuzzle();\n  };\n\n  // Toggle bridge between two islands (cycle: none -> single -> double -> none)\n  const toggleBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const current = bridges.get(key) || 0;\n\n    if (current === 2) {\n      // Cycle back to none\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setErrorMessage(null);\n      setSelectedIsland(null);\n      const v = isVictory(islands, newBridges);\n      setVictory(v);\n      return;\n    }\n\n    // Try to add one more bridge\n    const delta = 1;\n    const result = canAddBridge(islands, bridges, fromIsland, toIsland, delta);\n\n    if (!result.valid) {\n      setErrorMessage(result.error);\n      setSelectedIsland(null);\n      return;\n    }\n\n    const newBridges = new Map(bridges);\n    newBridges.set(key, current + 1);\n    setBridges(newBridges);\n    setErrorMessage(null);\n    setSelectedIsland(null);\n    const v = isVictory(islands, newBridges);\n    setVictory(v);\n  }, [bridges, islands]);\n\n  // Handle island click (mouse)\n  const handleIslandClick = useCallback((island) => {\n    if (victory) return;\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island.id);\n      setCursorIslandId(island.id);\n    } else if (selectedIsland === island.id) {\n      setSelectedIsland(null);\n    } else {\n      const fromIsland = islands.find(i => i.id === selectedIsland);\n      toggleBridge(fromIsland, island);\n    }\n  }, [selectedIsland, islands, toggleBridge, victory]);\n\n  // Handle right-click / ctrl+click on bridge line to remove\n  const handleBridgeRemove = useCallback((e, key) => {\n    e.preventDefault();\n    e.stopPropagation();\n    if (victory) return;\n    const newBridges = new Map(bridges);\n    newBridges.delete(key);\n    setBridges(newBridges);\n    setErrorMessage(null);\n    setSelectedIsland(null);\n    const v = isVictory(islands, newBridges);\n    setVictory(v);\n  }, [bridges, islands, victory]);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      if (e.key === \'Escape\') {\n        setSelectedIsland(null);\n        return;\n      }\n\n      const cursorIsland = islands.find(i => i.id === cursorIslandId);\n      if (!cursorIsland) return;\n\n      if (e.key === \'ArrowUp\' || e.key === \'ArrowDown\' || e.key === \'ArrowLeft\' || e.key === \'ArrowRight\') {\n        e.preventDefault();\n        let bestIsland = null;\n        let bestDist = Infinity;\n\n        for (const island of islands) {\n          if (island.id === cursorIslandId) continue;\n\n          let valid = false;\n          let dist = 0;\n\n          if (e.key === \'ArrowUp\' && island.x === cursorIsland.x && island.y < cursorIsland.y) {\n            valid = true;\n            dist = cursorIsland.y - island.y;\n          } else if (e.key === \'ArrowDown\' && island.x === cursorIsland.x && island.y > cursorIsland.y) {\n            valid = true;\n            dist = island.y - cursorIsland.y;\n          } else if (e.key === \'ArrowLeft\' && island.y === cursorIsland.y && island.x < cursorIsland.x) {\n            valid = true;\n            dist = cursorIsland.x - island.x;\n          } else if (e.key === \'ArrowRight\' && island.y === cursorIsland.y && island.x > cursorIsland.x) {\n            valid = true;\n            dist = island.x - cursorIsland.x;\n          }\n\n          if (valid && dist < bestDist) {\n            bestDist = dist;\n            bestIsland = island;\n          }\n        }\n\n        if (bestIsland) {\n          setCursorIslandId(bestIsland.id);\n        }\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        e.preventDefault();\n        if (victory) return;\n        const island = islands.find(i => i.id === cursorIslandId);\n        if (!island) return;\n        handleIslandClick(island);\n        return;\n      }\n    };\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [islands, cursorIslandId, selectedIsland, victory, handleIslandClick]);\n\n  // Render bridges\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges) {\n      if (count === 0) continue;\n      const { x1, y1, x2, y2 } = parseBridgeKey(key);\n      const px1 = x1 * 40;\n      const py1 = y1 * 40;\n      const px2 = x2 * 40;\n      const py2 = y2 * 40;\n\n      const isHorizontal = (y1 === y2);\n      const offset = 3;\n\n      const handleContext = (e) => {\n        handleBridgeRemove(e, key);\n      };\n      const handleClick = (e) => {\n        if (e.ctrlKey) {\n          handleBridgeRemove(e, key);\n        }\n      };\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={px1} y1={py1}\n            x2={px2} y2={py2}\n            stroke="#0f0"\n            strokeWidth="2"\n            onContextMenu={handleContext}\n            onClick={handleClick}\n            style={{ cursor: \'pointer\' }}\n          />\n        );\n      } else if (count === 2) {\n        const offX = isHorizontal ? 0 : offset;\n        const offY = isHorizontal ? offset : 0;\n        lines.push(\n          <line\n            key={key + \'_a\'}\n            x1={px1 - offX} y1={py1 - offY}\n            x2={px2 - offX} y2={py2 - offY}\n            stroke="#0f0"\n            strokeWidth="2"\n            onContextMenu={handleContext}\n            onClick={handleClick}\n            style={{ cursor: \'pointer\' }}\n          />\n        );\n        lines.push(\n          <line\n            key={key + \'_b\'}\n            x1={px1 + offX} y1={py1 + offY}\n            x2={px2 + offX} y2={py2 + offY}\n            stroke="#0f0"\n            strokeWidth="2"\n            onContextMenu={handleContext}\n            onClick={handleClick}\n            style={{ cursor: \'pointer\' }}\n          />\n        );\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map(island => {\n      const px = island.x * 40;\n      const py = island.y * 40;\n      const isSelected = selectedIsland === island.id;\n\n      return (\n        <g key={island.id} onClick={() => handleIslandClick(island)} style={{ cursor: \'pointer\' }}>\n          <circle\n            cx={px} cy={py} r={16}\n            fill="black"\n            stroke={isSelected ? \'#ff0\' : \'#0f0\'}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px} y={py}\n            textAnchor="middle"\n            dominantBaseline="central"\n            fill="#0f0"\n            fontSize="14"\n            fontFamily="monospace"\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render cursor (not a circle!)\n  const renderCursor = () => {\n    const island = islands.find(i => i.id === cursorIslandId);\n    if (!island) return null;\n    const px = island.x * 40;\n    const py = island.y * 40;\n    return (\n      <rect\n        x={px - 20} y={py - 20}\n        width={40} height={40}\n        fill="none"\n        stroke="#0ff"\n        strokeWidth="2"\n        strokeDasharray="4 2"\n        pointerEvents="none"\n      />\n    );\n  };\n\n  return (\n    <div>\n      <div style={{ position: \'absolute\', top: 0, left: 0, padding: \'4px 8px\', zIndex: 10 }}>\n        <select value={puzzleIndex} onChange={handlePuzzleChange} style={{ background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\', marginRight: \'8px\' }}>\n          {puzzles.map((p, idx) => (\n            <option key={p.id} value={idx}>{p.name}</option>\n          ))}\n        </select>\n        <button onClick={handleReset} style={{ background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\', cursor: \'pointer\' }}>Reset</button>\n      </div>\n      <svg width={800} height={600} style={{ display: \'block\', position: \'absolute\', top: 0, left: 0 }}>\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n      {errorMessage && (\n        <div className="error-message" style={{ position: \'absolute\', bottom: \'20px\', left: \'20px\', color: \'#f00\', fontFamily: \'monospace\', fontSize: \'14px\' }}>\n          {errorMessage}\n        </div>\n      )}\n      {victory && (\n        <div className="victory-banner" style={{ position: \'absolute\', top: \'50%\', left: \'50%\', transform: \'translate(-50%, -50%)\', color: \'#0f0\', fontFamily: \'monospace\', fontSize: \'48px\', border: \'2px solid #0f0\', padding: \'20px\', background: \'rgba(0,0,0,0.9)\' }}>\n          SOLVED!\n 