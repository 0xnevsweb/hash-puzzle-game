Sending keys: ['cat > /app/src/utils/hashiLogic.js << \'EOF\'\n// Canonical bridge key: smaller coordinate pair first\nexport function bridgeKey(from, to) {\n  const x1 = from.x, y1 = from.y, x2 = to.x, y2 = to.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are on the same row or column\nfunction areAligned(from, to) {\n  return from.x === to.x || from.y === to.y;\n}\n\n// Check if two islands are adjacent (no other island between them on same axis)\nfunction areAdjacent(islands, from, to) {\n  if (!areAligned(from, to)) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n  \n  const isHorizontal = from.y === to.y;\n  \n  for (const island of islands) {\n    if (island.id === from.id || island.id === to.id) continue;\n    if (isHorizontal) {\n      if (island.y === from.y) {\n        const minX = Math.min(from.x, to.x);\n        const maxX = Math.max(from.x, to.x);\n        if (island.x > minX && island.x < maxX) return false;\n      }\n    } else {\n      if (island.x === from.x) {\n        const minY = Math.min(from.y, to.y);\n        const maxY = Math.max(from.y, to.y);\n        if (island.y > minY && island.y < maxY) return false;\n      }\n    }\n  }\n  return true;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nfunction wouldCross(islands, bridges, from, to) {\n  const isHorizontal = from.y === to.y;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const bx1 = parts[0], by1 = parts[1], bx2 = parts[2], by2 = parts[3];\n    const bridgeIsHorizontal = by1 === by2;\n    \n    // Only check perpendicular bridges for crossing\n    if (isHorizontal === bridgeIsHorizontal) continue;\n    \n    if (isHorizontal) {\n      // New bridge is horizontal, existing is vertical\n      const newMinX = Math.min(from.x, to.x);\n      const newMaxX = Math.max(from.x, to.x);\n      const newY = from.y;\n      const existMinY = Math.min(by1, by2);\n      const existMaxY = Math.max(by1, by2);\n      const existX = bx1;\n      \n      if (existX > newMinX && existX < newMaxX &&\n          newY > existMinY && newY < existMaxY) {\n        return true;\n      }\n    } else {\n      // New bridge is vertical, existing is horizontal\n      const newMinY = Math.min(from.y, to.y);\n      const newMaxY = Math.max(from.y, to.y);\n      const newX = from.x;\n      const existMinX = Math.min(bx1, bx2);\n      const existMaxX = Math.max(bx1, bx2);\n      const existY = by1;\n      \n      if (newX > existMinX && newX < existMaxX &&\n          existY > newMinY && existY < newMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const x1 = parts[0], y1 = parts[1], x2 = parts[2], y2 = parts[3];\n    \n    for (const island of islands) {\n      if ((island.x === x1 && island.y === y1) ||\n          (island.x === x2 && island.y === y2)) {\n        counts.set(island.id, (counts.get(island.id) || 0) + count);\n      }\n    }\n  }\n  \n  return counts;\n}\n\n// Check if adding delta bridges is valid\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Check alignment and adjacency\n  if (!areAligned(from, to) || from.id === to.id) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n  \n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n  \n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n  \n  // Check max bridges\n  if (newCount > 2) {\n    return { valid: false, error: "Max 2 bridges per pair" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n  \n  // Check crossing (only if adding bridges)\n  if (delta > 0 && current === 0) {\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: "Bridges would cross" };\n    }\n  }\n  \n  return { valid: true, error: null };\n}\n\n// Check connectivity - all islands with at least one bridge are connected\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  \n  // Build adjacency from bridges\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const x1 = parts[0], y1 = parts[1], x2 = parts[2], y2 = parts[3];\n    \n    let id1 = null, id2 = null;\n    for (const island of islands) {\n      if (island.x === x1 && island.y === y1) id1 = island.id;\n      if (island.x === x2 && island.y === y2) id2 = island.id;\n    }\n    \n    if (id1 !== null && id2 !== null) {\n      adj.get(id1).push(id2);\n      adj.get(id2).push(id1);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const current = queue.shift();\n    for (const neighbor of adj.get(current) || []) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  if (islands.length === 0) return false;\n  \n  // Check all island counts are satisfied\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) {\n      return false;\n    }\n  }\n  \n  // Check connectivity\n  if (!checkConnectivity(islands, bridges)) {\n    return false;\n  }\n  \n  return true;\n}\nEOF\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
