[?2004l[?2004h> // Bridge key: canonical "x1,y1,x2,y2" where endpoint with smaller (x, then y) sorts first
[?2004l[?2004h> export function bridgeKey(a, b) {
[?2004l[?2004h>   // a and b are {x, y} objects (grid units)
[?2004l[?2004h>   if (a.x < b.x || (a.x === b.x && a.y < b.y)) {
[?2004l[?2004h>     return `${a.x},${a.y},${b.x},${b.y}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${b.x},${b.y},${a.x},${a.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseBridgeKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004lg[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col, no island between them)
[?2004l[?2004h> function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no island between them
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     // Vertical
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.x === from.x && island.y > minY && island.y < maxY) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   } else {
[?2004l[?2004h>     // Horizontal
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.y === from.y && island.x > minX && island.x < maxX) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if a bridge between from and to would cross any existing bridge
[?2004l[?2004h> function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     if (segmentsIntersect(from.x, from.y, to.x, to.y, x1, y1, x2, y2)) {
[?2004l[?2004h>       return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two segments cross (not collinear overlap, just proper intersection)
[?2004l[?2004h> function segmentsIntersect(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2) {
[?2004l[?2004h>   // One is horizontal, one is vertical for them to cross
[?2004l[?2004h>   // (bridges are always H or V)
[?2004l[?2004h>   const aHoriz = (ay1 === ay2);
[?2004l[?2004h>   const aVert = (ax1 === ax2);
[?2004l[?2004h>   const bHoriz = (by1 === by2);
[?2004l[?2004h>   const bVert = (bx1 === bx2);
[?2004l[?2004h>   
[?2004l[?2004h>   // Both horizontal or both vertical - they can't cross (they might overlap but we handle adjacency separately)
[?2004l[?2004h>   if ((aHoriz && bHoriz) || (aVert && bVert)) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   // a is horizontal, b is vertical
[?2004l[?2004h>   if (aHoriz && bVert) {
[?2004l[?2004h>     const aMinX = Math.min(ax1, ax2);
[?2004l[?2004h>     const aMaxX = Math.max(ax1, ax2);
[?2004l[?2004h>     const bMinY = Math.min(by1, by2);
[?2004l[?2004h>     const bMaxY = Math.max(by1, by2);
[?2004l[?2004h>     // Strict intersection (not at endpoints - endpoints are islands)
[?2004l[?2004h>     return bx1 > aMinX && bx1 < aMaxX && ay1 > bMinY && ay1 < bMaxY;
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // a is vertical, b is horizontal
[?2004l[?2004h>   if (aVert && bHoriz) {
[?2004l[?2004h>     const bMinX = Math.min(bx1, bx2);
[?2004l[?2004h>     const bMaxX = Math.max(bx1, bx2);
[?2004l[?2004h>     const aMinY = Math.min(ay1, ay2);
[?2004l[?2004h>     const aMaxY = Math.max(ay1, ay2);
[?2004l[?2004h>     return ax1 > bMinX && ax1 < bMaxX && by1 > aMinY && by1 < aMaxY;
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts per island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     // Find islands at these positions
[?2004l[?2004h>     const islandA = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const islandB = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (islandA) counts.set(islandA.id, (counts.get(islandA.id) || 0) + count);
[?2004l[?2004h>     if (islandB) counts.set(islandB.id, (counts.get(islandB.id) || 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency list based on bridges with count > 0
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const islandA = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const islandB = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (islandA && islandB) {
[?2004l[?2004h>       adj.get(islandA.id).push(islandB.id);
[?2004l[?2004h>       adj.get(islandB.id).push(islandA.id);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h>   
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const curr = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(curr)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check victory condition
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   
[?2004l[?2004h>   // Every island's count must equal its value
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if ((counts.get(island.id) || 0) !== island.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   if (!checkConnectivity(islands, bridges)) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no bridges cross
[?2004l[?2004h>   const bridgeList = [];
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     bridgeList.push(parseBridgeKey(key));
[?2004l[?2004h>   }
[?2004l[?2004h>   for (let i = 0; i < bridgeList.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < bridgeList.length; j++) {
[?2004l[?2004h>       const a = bridgeList[i];
[?2004l[?2004h>       const b = bridgeList[j];
[?2004l[?2004h>       if (segmentsIntersect(a.x1, a.y1, a.x2, a.y2, b.x1, b.y1, b.x2, b.y2)) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // canAddBridge: checks if we can add delta bridges between from and to
[?2004l[?2004h> // delta is typically +1 (adding one bridge in the cycle)
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Guard: same island
[?2004l[?2004h>   if (from.id === to.id) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect island to itself" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = bridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Max 2 bridges
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing - only if we're adding (not removing)
[?2004l[?2004h>   if (delta > 0 && current === 0) {
[?2004l[?2004h>     // Only check crossing when going from 0 to 1 (new bridge)
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> EOF
