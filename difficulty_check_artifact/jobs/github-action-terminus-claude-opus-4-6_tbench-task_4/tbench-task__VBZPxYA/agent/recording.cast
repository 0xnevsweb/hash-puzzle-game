[81.444471, "i", " const islandA = islands.find(i => i.x === x1 && i.y === y1);\n    const islandB = islands.find(i => i.x === x2 && i.y === y2);\n    if (islandA && islandB) {\n      adj.get(islandA.id).push(islandB.id);\n      adj.get(islandB.id).push(islandA.id);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const curr = queue.shift();\n    for (const neighbor of adj.get(curr)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  const counts = computeCurrentCounts(islands, bridges);\n  \n  // Every island's count must equal its value\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) return false;\n  }\n  \n  // Check connectivity\n  if (!checkConnectivity(islands, bridges)) return false;\n  \n "]
[81.444482, "i", " // Check no bridges cross\n  const bridgeList = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    bridgeList.push(parseBridgeKey(key));\n  }\n  for (let i = 0; i < bridgeList.length; i++) {\n    for (let j = i + 1; j < bridgeList.length; j++) {\n      const a = bridgeList[i];\n      const b = bridgeList[j];\n      if (segmentsIntersect(a.x1, a.y1, a.x2, a.y2, b.x1, b.y1, b.x2, b.y2)) {\n        return false;\n      }\n    }\n  }\n  \n  return true;\n}\n\n// canAddBridge: checks if we can add delta bridges between from and to\n// delta is typically +1 (adding one bridge in the cycle)\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Guard: same island\n  if (from.id === to.id) {\n    return { valid: false, error: \"Cannot connect island to itself\" };\n  }\n  \n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n  \n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  cons"]
[81.44458, "i", "t newCount = current + delta;\n  \n  // Max 2 bridges\n  if (newCount > 2) {\n    return { valid: false, error: \"Max 2 bridges per pair\" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: \"Island would exceed its number\" };\n  }\n  \n  // Check crossing - only if we're adding (not removing)\n  if (delta > 0 && current === 0) {\n    // Only check crossing when going from 0 to 1 (new bridge)\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: \"Bridges would cross\" };\n    }\n  }\n  \n  return { valid: true, error: null };\n}\nEOF\n"]
