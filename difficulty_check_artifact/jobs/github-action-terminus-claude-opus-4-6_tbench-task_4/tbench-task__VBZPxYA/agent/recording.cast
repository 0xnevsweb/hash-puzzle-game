[81.454861, "o", "function wouldCross(islands, bridges, from, to) {\r\n\u001b[?2004l\r"]
[81.454903, "o", "\u001b[?2004h"]
[81.454933, "o", "> "]
[81.455166, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[81.455219, "o", "\u001b[?2004h"]
[81.455234, "o", "> "]
[81.455415, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[81.455515, "o", "\u001b[?2004h> "]
[81.455793, "o", "    const { x1, y1, x2, y2 } = parseBridgeKey(key);\r\n\u001b[?2004l\r"]
[81.455914, "o", "\u001b[?2004h> "]
[81.456262, "o", "    if (segmentsIntersect(from.x, from.y, to.x, to.y, x1, y1, x2, y2)) {\r\n\u001b[?2004l\r"]
[81.456361, "o", "\u001b[?2004h> "]
[81.456436, "o", "      return true;\r\n\u001b[?2004l\r"]
[81.456496, "o", "\u001b[?2004h> "]
[81.456552, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.456571, "o", "> "]
[81.456633, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.456764, "o", "  return false;\r\n\u001b[?2004l\r"]
[81.456816, "o", "\u001b[?2004h> }\r\n"]
[81.45683, "o", "\u001b[?2004l\r"]
[81.456848, "o", "\u001b[?2004h"]
[81.456861, "o", "> "]
[81.456906, "o", "\r\n\u001b[?2004l\r"]
[81.456925, "o", "\u001b[?2004h> "]
[81.457425, "o", "// Check if two segments cross (not collinear overlap, just proper intersection)\r\n\u001b[?2004l\r"]
[81.457453, "o", "\u001b[?2004h"]
[81.457532, "o", "> "]
[81.457896, "o", "function segmentsIntersect(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2) {\r\n\u001b[?2004l\r"]
[81.457958, "o", "\u001b[?2004h> "]
[81.458314, "o", "  // One is horizontal, one is vertical for them to cross\r\n\u001b[?2004l\r"]
[81.458348, "o", "\u001b[?2004h> "]
[81.458578, "o", "  // (bridges are always H or V)\r\n\u001b[?2004l\r"]
[81.458603, "o", "\u001b[?2004h"]
[81.458617, "o", "> "]
[81.458848, "o", "  const aHoriz = (ay1 === ay2);\r\n\u001b[?2004l\r"]
[81.458872, "o", "\u001b[?2004h"]
[81.458883, "o", "> "]
[81.45911, "o", "  const aVert = (ax1 === ax2);\r\n\u001b[?2004l\r"]
[81.459183, "o", "\u001b[?2004h"]
[81.459203, "o", "> "]
[81.459382, "o", "  const bHoriz = (by1 === by2);\r\n\u001b[?2004l\r"]
[81.459481, "o", "\u001b[?2004h> "]
[81.459635, "o", "  const bVert = (bx1 === bx2);\r\n\u001b[?2004l\r"]
[81.459735, "o", "\u001b[?2004h> "]
[81.459843, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.460427, "o", "  // Both horizontal or both vertical - they can't cross (they might overlap but we handle adjacency separately)\r\n\u001b[?2004l\r"]
[81.460526, "o", "\u001b[?2004h> "]
[81.460843, "o", "  if ((aHoriz && bHoriz) || (aVert && bVert)) return false;\r\n\u001b[?2004l\r"]
[81.460958, "o", "\u001b[?2004h>   "]
[81.46106, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.461212, "o", "  // a is horizontal, b is vertical\r\n\u001b[?2004l\r"]
[81.461318, "o", "\u001b[?2004h> "]
[81.461444, "o", "  if (aHoriz && bVert) {\r\n\u001b[?2004l\r"]
[81.461548, "o", "\u001b[?2004h> "]
[81.461751, "o", "    const aMinX = Math.min(ax1, ax2);\r\n\u001b[?2004l\r"]
[81.461854, "o", "\u001b[?2004h> "]
[81.462051, "o", "    const aMaxX = Math.max(ax1, ax2);\r\n\u001b[?2004l\r"]
[81.462143, "o", "\u001b[?2004h> "]
[81.462325, "o", "    const bMinY = Math.min(by1, by2);\r\n\u001b[?2004l\r"]
[81.462371, "o", "\u001b[?2004h> "]
[81.462682, "o", "    const bMaxY = Math.max(by1, by2);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.463077, "o", "    // Strict intersection (not at endpoints - endpoints are islands)\r\n\u001b[?2004l\r"]
[81.46313, "o", "\u001b[?2004h"]
[81.463145, "o", "> "]
[81.463545, "o", "    return bx1 > aMinX && bx1 < aMaxX && ay1 > bMinY && ay1 < bMaxY;\r\n\u001b[?2004l\r"]
[81.463626, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[81.463698, "o", "\u001b[?2004h> "]
[81.463721, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[81.46381, "o", "> "]
[81.463951, "o", "  // a is vertical, b is horizontal\r\n\u001b[?2004l\r"]
[81.464061, "o", "\u001b[?2004h"]
[81.464113, "o", "> "]
[81.464278, "o", "  if (aVert && bHoriz) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.464447, "o", "    const bMinX = Math.min(bx1, bx2);\r\n\u001b[?2004l\r"]
[81.46452, "o", "\u001b[?2004h> "]
[81.46474, "o", "    const bMaxX = Math.max(bx1, bx2);\r\n\u001b[?2004l\r"]
[81.464812, "o", "\u001b[?2004h> "]
[81.465022, "o", "    const aMinY = Math.min(ay1, ay2);\r\n\u001b[?2004l\r"]
[81.465048, "o", "\u001b[?2004h"]
[81.465079, "o", "> "]
[81.465236, "o", "    const aMaxY = Math.max(ay1, ay2);\r\n\u001b[?2004l\r"]
[81.465262, "o", "\u001b[?2004h"]
[81.465278, "o", "> "]
[81.465527, "o", "    return ax1 > bMinX && ax1 < bMaxX && by1 > aMinY && by1 < aMaxY;\r\n\u001b[?2004l\r"]
[81.465547, "o", "\u001b[?2004h"]
[81.465563, "o", "> "]
[81.465579, "o", "  }\r\n\u001b[?2004l\r"]
[81.46567, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h"]
[81.46569, "o", "> "]
[81.465764, "o", "  return false;\r\n\u001b[?2004l\r"]
[81.46589, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.465958, "o", "\u001b[?2004h> "]
[81.466132, "o", "// Compute current bridge counts per island\r\n\u001b[?2004l\r"]
[81.466216, "o", "\u001b[?2004h> "]
[81.466366, "o", "export function computeCurrentCounts(islands, bridges) {\r\n\u001b[?2004l\r"]
[81.46643, "o", "\u001b[?2004h> "]
[81.466517, "o", "  const counts = new Map();\r\n\u001b[?2004l\r"]
[81.466611, "o", "\u001b[?2004h> "]
[81.466688, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[81.466749, "o", "\u001b[?2004h> "]
[81.466848, "o", "    counts.set(island.id, 0);\r\n\u001b[?2004l\r"]
[81.466873, "o", "\u001b[?2004h"]
[81.466889, "o", "> "]
[81.466906, "o", "  }\r\n\u001b[?2004l\r"]
[81.467013, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.467156, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[81.467179, "o", "\u001b[?2004h"]
[81.467196, "o", "> "]
[81.467314, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[81.467337, "o", "\u001b[?2004h"]
[81.467352, "o", "> "]
[81.467532, "o", "    const { x1, y1, x2, y2 } = parseBridgeKey(key);\r\n\u001b[?2004l\r"]
[81.4676, "o", "\u001b[?2004h"]
[81.467677, "o", "> "]
[81.467762, "o", "    // Find islands at these positions\r\n\u001b[?2004l\r"]
[81.467834, "o", "\u001b[?2004h> "]
[81.468022, "o", "    const islandA = islands.find(i => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[81.468047, "o", "\u001b[?2004h"]
[81.468126, "o", "> "]
[81.468288, "o", "    const islandB = islands.find(i => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[81.468345, "o", "\u001b[?2004h> "]
[81.468594, "o", "    if (islandA) counts.set(islandA.id, (counts.get(islandA.id) || 0) + count);\r\n\u001b[?2004l\r"]
[81.46869, "o", "\u001b[?2004h> "]
[81.468894, "o", "    if (islandB) counts.set(islandB.id, (counts.get(islandB.id) || 0) + count);\r\n\u001b[?2004l\r"]
[81.468924, "o", "\u001b[?2004h"]
[81.468936, "o", "> "]
[81.468965, "o", "  }\r\n\u001b[?2004l\r"]
[81.469057, "o", "\u001b[?2004h> "]
[81.469099, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.469137, "o", "  return counts;\r\n\u001b[?2004l\r"]
[81.46917, "o", "\u001b[?2004h"]
[81.46919, "o", "> "]
[81.469202, "o", "}\r\n\u001b[?2004l\r"]
[81.469251, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.469287, "o", "\u001b[?2004h"]
[81.469302, "o", "> "]
[81.469467, "o", "// Check if all islands are connected\r\n\u001b[?2004l\r"]
[81.469506, "o", "\u001b[?2004h> "]
[81.469699, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[81.46972, "o", "\u001b[?2004h"]
[81.469743, "o", "> "]
[81.46992, "o", "  if (islands.length === 0) return true;\r\n\u001b[?2004l\r"]
[81.470054, "o", "\u001b[?2004h> "]
[81.470131, "o", "  if (islands.length === 1) return true;\r\n\u001b[?2004l\r"]
[81.470223, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h"]
[81.470295, "o", "> "]
[81.470456, "o", "  // Build adjacency list based on bridges with count > 0\r\n\u001b[?2004l\r"]
[81.470567, "o", "\u001b[?2004h> "]
[81.470673, "o", "  const adj = new Map();\r\n"]
[81.470788, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[81.470905, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.470989, "o", "    adj.set(island.id, []);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.471014, "o", "  }\r\n"]
[81.47103, "o", "\u001b[?2004l\r"]
[81.471047, "o", "\u001b[?2004h"]
[81.471063, "o", "> "]
[81.47108, "o", "  \r\n\u001b[?2004l\r"]
[81.471195, "o", "\u001b[?2004h> "]
[81.471289, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[81.471358, "o", "\u001b[?2004h> "]
[81.471443, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[81.471498, "o", "\u001b[?2004h> "]
[81.471664, "o", "    const { x1, y1, x2, y2 } = parseBridgeKey(key);\r\n\u001b[?2004l\r"]
[81.471719, "o", "\u001b[?2004h> "]
[81.471921, "o", "    const islandA = islands.find(i => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[81.471978, "o", "\u001b[?2004h> "]
[81.472197, "o", "    const islandB = islands.find(i => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[81.47222, "o", "\u001b[?2004h"]
[81.472236, "o", "> "]
[81.472356, "o", "    if (islandA && islandB) {\r\n\u001b[?2004l\r"]
[81.472378, "o", "\u001b[?2004h"]
[81.47244, "o", "> "]
[81.472562, "o", "      adj.get(islandA.id).push(islandB.id);\r\n\u001b[?2004l\r"]
[81.472586, "o", "\u001b[?2004h"]
[81.472603, "o", "> "]
[81.472763, "o", "      adj.get(islandB.id).push(islandA.id);\r\n\u001b[?2004l\r"]
[81.472784, "o", "\u001b[?2004h"]
[81.472802, "o", "> "]
[81.472878, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.472934, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.47295, "o", "> "]
[81.472967, "o", "  \r\n\u001b[?2004l\r"]
[81.473043, "o", "\u001b[?2004h> "]
[81.473126, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[81.473147, "o", "\u001b[?2004h"]
[81.473163, "o", "> "]
[81.473279, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[81.4733, "o", "\u001b[?2004h"]
[81.473315, "o", "> "]
[81.473452, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[81.473474, "o", "\u001b[?2004h"]
[81.47349, "o", "> "]
[81.473609, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[81.47363, "o", "\u001b[?2004h"]
[81.473645, "o", "> "]
[81.473662, "o", "  \r\n\u001b[?2004l\r"]
[81.47375, "o", "\u001b[?2004h> "]
[81.473835, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[81.473924, "o", "\u001b[?2004h> "]
[81.474025, "o", "    const curr = queue.shift();\r\n\u001b[?2004l\r"]
[81.474125, "o", "\u001b[?2004h> "]
[81.474223, "o", "    for (const neighbor of adj.get(curr)) {\r\n\u001b[?2004l\r"]
[81.474243, "o", "\u001b[?2004h"]
[81.474267, "o", "> "]
[81.474397, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r"]
[81.474454, "o", "\u001b[?2004h> "]
[81.474553, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r"]
[81.474611, "o", "\u001b[?2004h> "]
[81.474714, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[81.474768, "o", "\u001b[?2004h> "]
[81.474801, "o", "      }\r\n\u001b[?2004l\r"]
[81.474863, "o", "\u001b[?2004h"]
[81.474912, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.47497, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.475019, "o", ">   \r\n\u001b[?2004l\r"]
[81.475067, "o", "\u001b[?2004h> "]
[81.475214, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r"]
[81.475251, "o", "\u001b[?2004h"]
[81.475298, "o", "> }\r\n\u001b[?2004l\r"]
[81.475335, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[81.475393, "o", "\u001b[?2004h"]
[81.475435, "o", "> "]
[81.475521, "o", "// Check victory condition\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.475566, "o", "> "]
[81.475704, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[81.475763, "o", "\u001b[?2004h> "]
[81.475939, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[81.476012, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[81.476048, "o", "\u001b[?2004h"]
[81.476117, "o", "> "]
[81.47621, "o", "  // Every island's count must equal its value\r\n\u001b[?2004l\r"]
[81.476256, "o", "\u001b[?2004h> "]
[81.476377, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[81.476424, "o", "\u001b[?2004h> "]
[81.476655, "o", "    if ((counts.get(island.id) || 0) !== island.value) return false;\r\n\u001b[?2004l\r"]
[81.476723, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[81.476786, "o", "\u001b[?2004h>   \r\n"]
[81.476865, "o", "\u001b[?2004l\r\u001b[?2004h"]
[81.476942, "o", "> "]
[81.477019, "o", "  // Check connectivity\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.477169, "o", "  if (!checkConnectivity(islands, bridges)) return false;\r\n\u001b[?2004l\r"]
[81.477239, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[81.477316, "o", "\u001b[?2004h> "]
[81.477383, "o", "  // Check no bridges cross\r\n\u001b[?2004l\r"]
[81.477464, "o", "\u001b[?2004h"]
[81.477557, "o", ">   const bridgeList = [];\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.477608, "o", "> "]
[81.477718, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[81.477791, "o", "\u001b[?2004h> "]
[81.477879, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[81.477896, "o", "\u001b[?2004h"]
[81.477911, "o", "> "]
[81.478076, "o", "    bridgeList.push(parseBridgeKey(key));\r\n\u001b[?2004l\r"]
[81.478094, "o", "\u001b[?2004h"]
[81.478106, "o", "> "]
[81.478131, "o", "  }\r\n\u001b[?2004l\r"]
[81.478211, "o", "\u001b[?2004h> "]
[81.478351, "o", "  for (let i = 0; i < bridgeList.length; i++) {\r\n\u001b[?2004l\r"]
[81.478406, "o", "\u001b[?2004h> "]
[81.478592, "o", "    for (let j = i + 1; j < bridgeList.length; j++) {\r\n\u001b[?2004l\r"]
[81.478637, "o", "\u001b[?2004h> "]
[81.478759, "o", "      const a = bridgeList[i];\r\n\u001b[?2004l\r"]
[81.478792, "o", "\u001b[?2004h"]
[81.478806, "o", "> "]
[81.478937, "o", "      const b = bridgeList[j];\r\n\u001b[?2004l\r"]
[81.478983, "o", "\u001b[?2004h"]
[81.479024, "o", "> "]
[81.479251, "o", "      if (segmentsIntersect(a.x1, a.y1, a.x2, a.y2, b.x1, b.y1, b.x2, b.y2)) {\r\n\u001b[?2004l\r"]
[81.47929, "o", "\u001b[?2004h"]
[81.479324, "o", "> "]
[81.479402, "o", "        return false;\r\n\u001b[?2004l\r"]
[81.479449, "o", "\u001b[?2004h> "]
[81.479497, "o", "      }\r\n\u001b[?2004l\r"]
[81.479513, "o", "\u001b[?2004h"]
[81.479573, "o", "> "]
[81.47959, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.479604, "o", "> "]
[81.479616, "o", "  }"]
[81.479645, "o", "\r\n\u001b[?2004l\r"]
[81.47966, "o", "\u001b[?2004h"]
[81.479673, "o", "> "]
[81.479768, "o", "  \r\n\u001b[?2004l\r"]
[81.479784, "o", "\u001b[?2004h>   return true;\r\n\u001b[?2004l\r"]
[81.479827, "o", "\u001b[?2004h"]
[81.479839, "o", "> }\r\n"]
[81.479859, "o", "\u001b[?2004l\r"]
[81.479878, "o", "\u001b[?2004h"]
[81.479926, "o", "> \r\n\u001b[?2004l\r"]
[81.479943, "o", "\u001b[?2004h> "]
[81.480181, "o", "// canAddBridge: checks if we can add delta bridges between from and to\r\n\u001b[?2004l\r"]
[81.480242, "o", "\u001b[?2004h> "]
[81.480413, "o", "// delta is typically +1 (adding one bridge in the cycle)\r\n\u001b[?2004l\r"]
[81.480431, "o", "\u001b[?2004h"]
[81.480453, "o", "> "]
[81.48065, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[81.480671, "o", "\u001b[?2004h"]
[81.4807, "o", "> "]
[81.480789, "o", "  // Guard: same island\r\n\u001b[?2004l\r"]
[81.480827, "o", "\u001b[?2004h> "]
[81.480936, "o", "  if (from.id === to.id) {\r\n\u001b[?2004l\r"]
[81.480958, "o", "\u001b[?2004h"]
[81.480975, "o", "> "]
[81.481213, "o", "    return { valid: false, error: \"Cannot connect island to itself\" };\r\n\u001b[?2004l\r"]
[81.481236, "o", "\u001b[?2004h"]
[81.481253, "o", "> "]
[81.481327, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.48135, "o", "  \r\n\u001b[?2004l\r"]
[81.481366, "o", "\u001b[?2004h"]
[81.481382, "o", "> "]
[81.481488, "o", "  // Check adjacency\r\n\u001b[?2004l\r"]
[81.481506, "o", "\u001b[?2004h"]
[81.481522, "o", "> "]
[81.48168, "o", "  if (!areAdjacent(islands, from, to)) {\r\n\u001b[?2004l\r"]
[81.481758, "o", "\u001b[?2004h> "]
[81.481966, "o", "    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\r\n\u001b[?2004l\r"]
[81.482004, "o", "\u001b[?2004h"]
[81.482019, "o", "> "]
[81.482037, "o", "  }\r\n\u001b[?2004l\r"]
[81.482129, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h"]
[81.48215, "o", "> "]
[81.482277, "o", "  const key = bridgeKey(from, to);\r\n\u001b[?2004l\r"]
[81.482299, "o", "\u001b[?2004h"]
[81.482316, "o", "> "]
[81.482466, "o", "  const current = bridges.get(key) || 0;\r\n\u001b[?2004l\r"]
[81.482488, "o", "\u001b[?2004h"]
[81.482506, "o", "> "]
[81.482641, "o", "  const newCount = current + delta;\r\n\u001b[?2004l\r"]
[81.482707, "o", "\u001b[?2004h"]
[81.482792, "o", ">   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.482877, "o", "  // Max 2 bridges\r\n\u001b[?2004l\r"]
[81.482946, "o", "\u001b[?2004h> "]
[81.483008, "o", "  if (newCount > 2) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.483068, "o", "> "]
[81.483255, "o", "    return { valid: false, error: \"Max 2 bridges per pair\" };\r\n\u001b[?2004l\r"]
[81.483279, "o", "\u001b[?2004h"]
[81.483295, "o", "> "]
[81.483313, "o", "  }\r\n\u001b[?2004l\r"]
[81.48345, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.483532, "o", "  // Check island capacity\r\n\u001b[?2004l\r"]
[81.483568, "o", "\u001b[?2004h"]
[81.483655, "o", "> "]
[81.483835, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.483903, "o", "> "]
[81.484025, "o", "  const fromCount = counts.get(from.id) || 0;\r\n\u001b[?2004l\r"]
[81.484082, "o", "\u001b[?2004h> "]
[81.484225, "o", "  const toCount = counts.get(to.id) || 0;\r\n\u001b[?2004l\r"]
[81.484252, "o", "\u001b[?2004h"]
[81.484373, "o", ">   \r\n\u001b[?2004l\r"]
[81.484417, "o", "\u001b[?2004h> "]
[81.484585, "o", "  if (fromCount + delta > from.value || toCount + delta > to.value) {\r\n\u001b[?2004l\r"]
[81.484609, "o", "\u001b[?2004h"]
[81.484639, "o", "> "]
[81.484854, "o", "    return { valid: false, error: \"Island would exceed its number\" };\r\n\u001b[?2004l\r"]
[81.484873, "o", "\u001b[?2004h"]
[81.484887, "o", "> "]
[81.484915, "o", "  }\r\n\u001b[?2004l\r"]
[81.484937, "o", "\u001b[?2004h"]
[81.484948, "o", "> "]
[81.484961, "o", "  \r\n\u001b[?2004l\r"]
[81.485139, "o", "\u001b[?2004h> "]
[81.485232, "o", "  // Check crossing - only if we're adding (not removing)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.485358, "o", "  if (delta > 0 && current === 0) {\r\n\u001b[?2004l\r"]
[81.485431, "o", "\u001b[?2004h> "]
[81.485625, "o", "    // Only check crossing when going from 0 to 1 (new bridge)\r\n\u001b[?2004l\r"]
[81.485648, "o", "\u001b[?2004h"]
[81.485665, "o", "> "]
[81.485846, "o", "    if (wouldCross(islands, bridges, from, to)) {\r\n\u001b[?2004l\r"]
[81.485868, "o", "\u001b[?2004h"]
[81.485886, "o", "> "]
[81.48611, "o", "      return { valid: false, error: \"Bridges would cross\" };\r\n\u001b[?2004l\r"]
[81.486134, "o", "\u001b[?2004h"]
[81.486148, "o", "> "]
[81.486227, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.486245, "o", "  }\r\n"]
[81.486262, "o", "\u001b[?2004l\r"]
[81.486348, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h"]
[81.486368, "o", "> "]
[81.486522, "o", "  return { valid: true, error: null };\r\n\u001b[?2004l\r"]
[81.486625, "o", "\u001b[?2004h> "]
[81.486703, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[81.48781, "o", "\u001b[?2004h"]
