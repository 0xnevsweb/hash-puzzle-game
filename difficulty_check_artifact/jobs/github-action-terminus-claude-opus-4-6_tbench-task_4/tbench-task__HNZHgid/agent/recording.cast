[199.309228, "i", "  lines.push(\n            <line\n              key={key + '_a'}\n              x1={x1} y1={y1 - offset} x2={x2} y2={y2 - offset}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n            />\n          );\n          lines.push(\n            <line\n              key={key + '_b'}\n              x1={x1} y1={y1 + offset} x2={x2} y2={y2 + offset}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n            />\n          );\n        } else {\n          lines.push(\n            <line\n              key={key + '_a'}\n              x1={x1 - offset} y1={y1} x2={x2 - offset} y2={y2}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n            />\n          );\n          lines.push(\n            <line\n              key={key + '_b'}\n              x1={x1 + offset} y1={y1} x2={x2 + offset} y2={y2}\n              stroke=\"#0f0\"\n              strokeWidth=\"2\"\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map((island)"]
[199.309236, "i", " => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland && selectedIsland.id === island.id;\n\n      return (\n        <g key={island.id}>\n          <circle\n            cx={px}\n            cy={py}\n            r={16}\n            fill=\"black\"\n            stroke={isSelected ? '#ff0' : '#0f0'}\n            strokeWidth={isSelected ? 3 : 2}\n            style={{ cursor: 'pointer' }}\n            onClick={(e) => handleIslandClick(island, e)}\n            onContextMenu={(e) => handleContextMenu(island, e)}\n          />\n          <text\n            x={px}\n            y={py}\n            textAnchor=\"middle\"\n            dominantBaseline=\"central\"\n            fill=\"#0f0\"\n            fontSize=\"14\"\n            fontFamily=\"monospace\"\n            style={{ pointerEvents: 'none' }}\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render keyboard cursor (rect, not circle)\n  const renderCursor = () => {\n    if (!keyboardMo"]
