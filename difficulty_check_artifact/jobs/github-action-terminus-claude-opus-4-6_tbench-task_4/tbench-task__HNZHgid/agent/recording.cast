[121.29178, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Canonical bridge key: smaller coordinate pair first\nexport function bridgeKey(from, to) {\n  const x1 = from.x, y1 = from.y, x2 = to.x, y2 = to.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are on the same row or column\nfunction areAligned(from, to) {\n  return from.x === to.x || from.y === to.y;\n}\n\n// Check if two islands are adjacent (no other island between them on same axis)\nfunction areAdjacent(islands, from, to) {\n  if (!areAligned(from, to)) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n  \n  const isHorizontal = from.y === to.y;\n  \n  for (const island of islands) {\n    if (island.id === from.id || island.id === to.id) continue;\n    if (isHorizontal) {\n      if (island.y === from.y) {\n        const minX = Math.min(from.x, to.x);\n        const maxX = Math.max(from.x, to.x);\n        if (island.x > minX && island.x < maxX) return false"]
[121.292233, "i", ";\n      }\n    } else {\n      if (island.x === from.x) {\n        const minY = Math.min(from.y, to.y);\n        const maxY = Math.max(from.y, to.y);\n        if (island.y > minY && island.y < maxY) return false;\n      }\n    }\n  }\n  return true;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nfunction wouldCross(islands, bridges, from, to) {\n  const isHorizontal = from.y === to.y;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(',').map(Number);\n    const bx1 = parts[0], by1 = parts[1], bx2 = parts[2], by2 = parts[3];\n    const bridgeIsHorizontal = by1 === by2;\n    \n    // Only check perpendicular bridges for crossing\n    if (isHorizontal === bridgeIsHorizontal) continue;\n    \n    if (isHorizontal) {\n      // New bridge is horizontal, existing is vertical\n      const newMinX = Math.min(from.x, to.x);\n      const newMaxX = Math.max(from.x, to.x);\n      const newY = from.y;\n      const existMinY = Math.min(by1, by2);\n      const"]
