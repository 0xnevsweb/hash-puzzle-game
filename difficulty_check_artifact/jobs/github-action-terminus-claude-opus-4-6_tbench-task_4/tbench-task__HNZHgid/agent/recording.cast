[127.993965, "o", "// Canonical bridge key: smaller coordinate pair first\r\nexport function bridgeKey(from, to) {\r\n  const x1 = from.x, y1 = from.y, x2 = to.x, y2 = to.y;\r\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\r\n    return `${x1},${y1},${x2},${y2}`;\r\n\u001b[?2004hroot@cbe01dbaecac:/app# "]
