[199.309155, "i", "st current = bridges.get(key) || 0;\n\n    if (current === 2) {\n      // Remove bridge (cycle back to none)\n      clearError();\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setSelectedIsland(null);\n      return;\n    }\n\n    // Try to add one bridge\n    const delta = 1;\n    const result = canAddBridge(islands, bridges, fromIsland, toIsland, delta);\n    if (!result.valid) {\n      setErrorMessage(result.error);\n      setSelectedIsland(null);\n      return;\n    }\n\n    clearError();\n    const newBridges = new Map(bridges);\n    newBridges.set(key, current + delta);\n    setBridges(newBridges);\n    setSelectedIsland(null);\n  }, [bridges, islands]);\n\n  // Mouse click on island\n  const handleIslandClick = useCallback((island, e) => {\n    if (victory) return;\n    const isRightClickLike = e.ctrlKey || e.metaKey;\n\n    if (isRightClickLike && selectedIsland !== null) {\n      toggleBridge(selectedIsland, island, true);\n      return;\n    }\n\n    if (selectedIsland =="]
