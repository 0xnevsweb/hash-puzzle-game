[199.309257, "i", "       </select>\n        <button\n          onClick={resetGame}\n          style={{ marginLeft: '16px', background: 'black', color: '#0f0', border: '1px solid #0f0', fontFamily: 'monospace', cursor: 'pointer' }}\n        >\n          Reset\n        </button>\n      </div>\n      {errorMessage && (\n        <div className=\"error-message\" style={{ padding: '4px 8px', color: '#f00', fontFamily: 'monospace' }}>\n          {errorMessage}\n        </div>\n      )}\n      {victory && (\n        <div className=\"victory-banner\" style={{ padding: '8px', color: '#0f0', fontFamily: 'monospace', fontSize: '24px', textAlign: 'center', border: '2px solid #0f0', margin: '8px' }}>\n          SOLVED!\n        </div>\n      )}\n      <svg\n        ref={svgRef}\n        width={SVG_WIDTH}\n        height={SVG_HEIGHT}\n        style={{ display: 'block' }}\n        tabIndex=\"0\"\n      >\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n    </div>\n  );\n}\n\nexport default App;\nAPPEOF\n"]
