[?2004l[?2004h> // Canonical key for a bridge between two islands (grid coords)
[?2004l[?2004h> export function bridgeKey(island1, island2) {
[?2004l[?2004h>   const x1 = island1.x, y1 = island1.y;
[?2004l[?2004h>   const x2 = island2.x, y2 = island2.y;
[?2004l[?2004h>   // Sort: smaller x first, then smaller y
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col with no islands between)
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.id === to.id) return false;
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no island between them
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.x === from.x && island.y > minY && island.y < maxY) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   } else {
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.y === from.y && island.x > minX && island.x < maxX) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding a bridge between from and to would cross any existing bridge
[?2004l[?2004h> export function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   // The new bridge segment
[?2004l[?2004h>   const horizontal = from.y === to.y;
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const [bx1, by1, bx2, by2] = parts;
[?2004l[?2004h>     const bHorizontal = by1 === by2;
[?2004l[?2004h>     
[?2004l[?2004h>     // Two parallel bridges can't cross
[?2004l[?2004h>     if (horizontal === bHorizontal) continue;
[?2004l[?2004h>     
[?2004l[?2004h>     // Perpendicular: check intersection
[?2004l[?2004h>     if (horizontal) {
[?2004l[?2004h>       // New bridge is horizontal (from.y constant), existing is vertical (bx1 constant)
[?2004l[?2004h>       const ny = from.y;
[?2004l[?2004h>       const nxMin = Math.min(from.x, to.x);
[?2004l[?2004h>       const nxMax = Math.max(from.x, to.x);
[?2004l[?2004h>       const bx = bx1; // vertical bridge x
[?2004l[?2004h>       const byMin = Math.min(by1, by2);
[?2004l[?2004h>       const byMax = Math.max(by1, by2);
[?2004l[?2004h>       
[?2004l[?2004h>       // Cross if bx is strictly between nxMin and nxMax, and ny is strictly between byMin and byMax
[?2004l[?2004h>       if (bx > nxMin && bx < nxMax && ny > byMin && ny < byMax) return true;
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // New bridge is vertical (from.x constant), existing is horizontal (by1 constant)
[?2004l[?2004h>       const nx = from.x;
[?2004l[?2004h>       const nyMin = Math.min(from.y, to.y);
[?2004l[?2004h>       const nyMax = Math.max(from.y, to.y);
[?2004l[?2004h>       const by = by1; // horizontal bridge y
[?2004l[?2004h>       const bxMin = Math.min(bx1, bx2);
[?2004l[?2004h>       const bxMax = Math.max(bx1, bx2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (nx > bxMin && nx < bxMax && by > nyMin && by < nyMax) return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts per island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const [x1, y1, x2, y2] = parts;
[?2004l[?2004h>     
[?2004l[?2004h>     // Find islands at these coordinates
[?2004l[?2004h>     const island1 = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const island2 = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     
[?2004l[?2004h>     if (island1 && island2) {
[?2004l[?2004h>       counts.set(island1.id, (counts.get(island1.id) || 0) + count);
[?2004l[?2004h>       counts.set(island2.id, (counts.get(island2.id) || 0) + count);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges between from and to is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = bridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check max bridges
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing (only if adding, not removing)
[?2004l[?2004h>   if (delta > 0 && current === 0) {
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected via bridges
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency from bridges
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const [x1, y1, x2, y2] = parts;
[?2004l[?2004h>     const island1 = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const island2 = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (island1 && island2) {
[?2004l[?2004h>       adj.get(island1.id).push(island2.id);
[?2004l[?2004h>       adj.get(island2.id).push(island1.id);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h>   
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const current = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(current)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check victory condition
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all counts match
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if ((counts.get(island.id) || 0) !== island.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   if (!checkConnectivity(islands, bridges)) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> EOF
