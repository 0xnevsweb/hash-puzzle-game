[?2004l[?2004h> import React, { useState, useCallback, useEffect, useRef } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles.js';
[?2004l[?2004h> import { bridgeKey, areAdjacent, canAddBridge, computeCurrentCounts, isVictory } from './utils/hashiLogic.js';
[?2004l[?2004h> 
[?2004l [?2004h> const GRID_SIZE = 40;
[?2004l[?2004h> const ISLAND_RADIUS = 16;
[?2004l[?2004h> 
[?2004l[?2004h> function App() {
[?2004l[?2004h>   const [puzzleIndex, setPuzzleIndex] = useState(0);
[?2004l[?2004h>   const [bridges, setBridges] = useState(new Map());
[?2004l[?2004h>   const [selectedIsland, setSelectedIsland] = useState(null);
[?2004l[?2004h>   const [cursorIndex, setCursorIndex] = useState(0);
[?2004l[?2004h>   const [errorMessage, setErrorMessage] = useState('');
[?2004l[?2004h>   const [victory, setVictory] = useState(false);
[?2004l[?2004h>   const [keyboardMode, setKeyboardMode] = useState(false);
[?2004l[?2004h>   const svgRef = useRef(null);
[?2004l[?2004h> 
[?2004l[?2004h>   const currentPuzzle = puzzles[puzzleIndex];
[?2004l[?2004h>   const islands = currentPuzzle.islands;
[?2004l[?2004h> 
[?2004l[?2004h>   // Reset when puzzle changes
[?2004l[?2004h>   const handlePuzzleChange = (e) => {
[?2004l[?2004h>     setPuzzleIndex(Number(e.target.value));
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedIsland(null);
[?2004l[?2004h>     setCursorIndex(0);
[?2004l[?2004h>     setErrorMessage('');
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>     setKeyboardMode(false);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const handleReset = () => {
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedIsland(null);
[?2004l[?2004h>     setErrorMessage('');
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   // Toggle bridge between two islands (cycle: none -> single -> double -> none)
[?2004l[?2004h>   const toggleBridge = useCallback((from, to) => {
[?2004l[?2004h>     const key = bridgeKey(from, to);
[?2004l[?2004h>     const current = bridges.get(key) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>     if (current === 0) {
[?2004l[?2004h>       // Try to add single bridge
[?2004l[?2004h>       const result = canAddBridge(islands, bridges, from, to, 1);
[?2004l[?2004h>       if (!result.valid) {
[?2004l[?2004h>         setErrorMessage(result.error);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h>       const newBridges = new Map(bridges);
[?2004l[?2004h>       newBridges.set(key, 1);
[?2004l[?2004h>       setErrorMessage('');
