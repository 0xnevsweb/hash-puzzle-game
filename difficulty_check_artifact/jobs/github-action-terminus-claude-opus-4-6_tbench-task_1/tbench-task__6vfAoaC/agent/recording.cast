[118.54847, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Canonical key for a bridge between two islands (grid coords)\nexport function bridgeKey(island1, island2) {\n  const x1 = island1.x, y1 = island1.y;\n  const x2 = island2.x, y2 = island2.y;\n  // Sort: smaller x first, then smaller y\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are adjacent (same row/col with no islands between)\nexport function areAdjacent(islands, from, to) {\n  if (from.id === to.id) return false;\n  if (from.x !== to.x && from.y !== to.y) return false;\n  \n  // Check no island between them\n  if (from.x === to.x) {\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) return false;\n    }\n  } else {\n    const minX = Math.min(from.x, to.x);\n    const maxX ="]
[118.54879, "i", " Math.max(from.x, to.x);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nexport function wouldCross(islands, bridges, from, to) {\n  // The new bridge segment\n  const horizontal = from.y === to.y;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(',').map(Number);\n    const [bx1, by1, bx2, by2] = parts;\n    const bHorizontal = by1 === by2;\n    \n    // Two parallel bridges can't cross\n    if (horizontal === bHorizontal) continue;\n    \n    // Perpendicular: check intersection\n    if (horizontal) {\n      // New bridge is horizontal (from.y constant), existing is vertical (bx1 constant)\n      const ny = from.y;\n      const nxMin = Math.min(from.x, to.x);\n      const nxMax = Math.max(from.x, to.x);\n      const bx = bx1; // "]
[118.549158, "o", "cat > /app/src/utils/hashiLogic.js << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> // Canonical key for a bridge between two islands (grid coords)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[118.549264, "i", "vertical bridge x\n      const byMin = Math.min(by1, by2);\n      const byMax = Math.max(by1, by2);\n      \n      // Cross if bx is strictly between nxMin and nxMax, and ny is strictly between byMin and byMax\n      if (bx > nxMin && bx < nxMax && ny > byMin && ny < byMax) return true;\n    } else {\n      // New bridge is vertical (from.x constant), existing is horizontal (by1 constant)\n      const nx = from.x;\n      const nyMin = Math.min(from.y, to.y);\n      const nyMax = Math.max(from.y, to.y);\n      const by = by1; // horizontal bridge y\n      const bxMin = Math.min(bx1, bx2);\n      const bxMax = Math.max(bx1, bx2);\n      \n      if (nx > bxMin && nx < bxMax && by > nyMin && by < nyMax) return true;\n    }\n  }\n  return false;\n}\n\n// Compute current bridge counts per island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const island of islands) {\n    counts.set(island.id, 0);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts ="]
[118.549311, "i", " key.split(',').map(Number);\n    const [x1, y1, x2, y2] = parts;\n    \n    // Find islands at these coordinates\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    \n    if (island1 && island2) {\n      counts.set(island1.id, (counts.get(island1.id) || 0) + count);\n      counts.set(island2.id, (counts.get(island2.id) || 0) + count);\n    }\n  }\n  return counts;\n}\n\n// Check if adding delta bridges between from and to is valid\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n  \n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n  \n  // Check max bridges\n  if (newCount > 2) {\n    return { valid: false, error: \"Max 2 bridges per pair\" };\n  }\n  \n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridg"]
[118.549372, "i", "es);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n  \n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: \"Island would exceed its number\" };\n  }\n  \n  // Check crossing (only if adding, not removing)\n  if (delta > 0 && current === 0) {\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: \"Bridges would cross\" };\n    }\n  }\n  \n  return { valid: true, error: null };\n}\n\n// Check if all islands are connected via bridges\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  if (islands.length === 1) return true;\n  \n  // Build adjacency from bridges\n  const adj = new Map();\n  for (const island of islands) {\n    adj.set(island.id, []);\n  }\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(',').map(Number);\n    const [x1, y1, x2, y2] = parts;\n    const island1 = islands.find(i => i.x === x1 && i.y =="]
[118.549537, "i", "= y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    if (island1 && island2) {\n      adj.get(island1.id).push(island2.id);\n      adj.get(island2.id).push(island1.id);\n    }\n  }\n  \n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n  \n  while (queue.length > 0) {\n    const current = queue.shift();\n    for (const neighbor of adj.get(current)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n  \n  return visited.size === islands.length;\n}\n\n// Check victory condition\nexport function isVictory(islands, bridges) {\n  // Check all counts match\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) return false;\n  }\n  \n  // Check connectivity\n  if (!checkConnectivity(islands, bridges)) return false;\n  \n  return true;\n}\nEOF\n"]
[118.549652, "o", "export function bridgeKey(island1, island2) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
