[118.583256, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.583301, "o", "\u001b[?2004h> "]
[118.583396, "o", "// Check victory condition\r\n\u001b[?2004l\r"]
[118.583444, "o", "\u001b[?2004h> "]
[118.583585, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[118.583634, "o", "\u001b[?2004h> "]
[118.583727, "o", "  // Check all counts match\r\n\u001b[?2004l\r"]
[118.583776, "o", "\u001b[?2004h> "]
[118.583947, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[118.583997, "o", "\u001b[?2004h> "]
[118.584108, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[118.584158, "o", "\u001b[?2004h> "]
[118.584363, "o", "    if ((counts.get(island.id) || 0) !== island.value) return false;\r\n\u001b[?2004l\r"]
[118.584412, "o", "\u001b[?2004h> "]
[118.584432, "o", "  }\r\n\u001b[?2004l\r"]
[118.584481, "o", "\u001b[?2004h>   \r\n"]
[118.5845, "o", "\u001b[?2004l\r"]
[118.58455, "o", "\u001b[?2004h> "]
[118.58463, "o", "  // Check connectivity\r\n\u001b[?2004l\r"]
[118.584677, "o", "\u001b[?2004h> "]
[118.584853, "o", "  if (!checkConnectivity(islands, bridges)) return false;\r\n\u001b[?2004l\r"]
[118.584899, "o", "\u001b[?2004h> "]
[118.584918, "o", "  \r\n\u001b[?2004l\r"]
