[118.578542, "o", "\u001b[?2004h> "]
[118.5786, "o", "    adj.set(island.id, []);\r\n\u001b[?2004l\r"]
[118.578682, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[118.578765, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h"]
