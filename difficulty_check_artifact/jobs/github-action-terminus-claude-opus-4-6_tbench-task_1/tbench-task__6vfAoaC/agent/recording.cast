[118.838243, "i", "cat > /app/src/App.jsx << 'APPEOF'\nimport React, { useState, useCallback, useEffect, useRef } from 'react';\nimport { puzzles } from './data/puzzles.js';\nimport { bridgeKey, areAdjacent, canAddBridge, computeCurrentCounts, isVictory } from './utils/hashiLogic.js';\n\nconst GRID_SIZE = 40;\nconst ISLAND_RADIUS = 16;\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [cursorIndex, setCursorIndex] = useState(0);\n  const [errorMessage, setErrorMessage] = useState('');\n  const [victory, setVictory] = useState(false);\n  const [keyboardMode, setKeyboardMode] = useState(false);\n  const svgRef = useRef(null);\n\n  const currentPuzzle = puzzles[puzzleIndex];\n  const islands = currentPuzzle.islands;\n\n  // Reset when puzzle changes\n  const handlePuzzleChange = (e) => {\n    setPuzzleIndex(Number(e.target.value));\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIndex("]
[118.838295, "i", "0);\n    setErrorMessage('');\n    setVictory(false);\n    setKeyboardMode(false);\n  };\n\n  const handleReset = () => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setErrorMessage('');\n    setVictory(false);\n  };\n\n  // Toggle bridge between two islands (cycle: none -> single -> double -> none)\n  const toggleBridge = useCallback((from, to) => {\n    const key = bridgeKey(from, to);\n    const current = bridges.get(key) || 0;\n\n    if (current === 0) {\n      // Try to add single bridge\n      const result = canAddBridge(islands, bridges, from, to, 1);\n      if (!result.valid) {\n        setErrorMessage(result.error);\n        return;\n      }\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 1);\n      setErrorMessage('');\n      setBridges(newBridges);\n      // Check victory\n      if (isVictory(islands, newBridges)) setVictory(true);\n    } else if (current === 1) {\n      // Try to add second bridge\n      const result = canAddBridge(islands, bridges, from, to, 1);\n      if (!result.valid) "]
[118.838306, "i", "{\n        setErrorMessage(result.error);\n        return;\n      }\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 2);\n      setErrorMessage('');\n      setBridges(newBridges);\n      if (isVictory(islands, newBridges)) setVictory(true);\n    } else {\n      // Remove bridge (double -> none)\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setErrorMessage('');\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges, islands]);\n\n  // Remove bridge entirely\n  const removeBridge = useCallback((from, to) => {\n    const key = bridgeKey(from, to);\n    const current = bridges.get(key) || 0;\n    if (current > 0) {\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setErrorMessage('');\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges]);\n\n  // Mouse click on island\n  const handleIslandClick = (island, e) => {\n    // Right-click or Ctrl+click to remove\n    if (e.ctrlKey) {\n      if (selectedIsland !== nu"]
[118.838315, "i", "ll) {\n        removeBridge(selectedIsland, island);\n        setSelectedIsland(null);\n      }\n      return;\n    }\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island);\n      setErrorMessage('');\n    } else {\n      if (selectedIsland.id === island.id) {\n        setSelectedIsland(null);\n        return;\n      }\n      toggleBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    }\n  };\n\n  const handleIslandContextMenu = (island, e) => {\n    e.preventDefault();\n    if (selectedIsland !== null) {\n      removeBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    } else {\n      // If right-clicking without selection, select then wait\n      // Actually, for right-click removal on existing bridge,\n      // we need two islands. Let's use: if there's a selected island, remove bridge to this one.\n      // If no selection, select this island for the next operation\n      setSelectedIsland(island);\n    }\n  };\n\n  // Keyboard handling\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n"]
[118.838334, "i", "      if (e.key === 'Escape') {\n        setSelectedIsland(null);\n        setKeyboardMode(false);\n        return;\n      }\n\n      if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {\n        e.preventDefault();\n        setKeyboardMode(true);\n        const currentIsland = islands[cursorIndex];\n        \n        // Find the nearest island in the arrow direction\n        let candidates = [];\n        for (let i = 0; i < islands.length; i++) {\n          if (i === cursorIndex) continue;\n          const other = islands[i];\n          switch (e.key) {\n            case 'ArrowUp':\n              if (other.y < currentIsland.y) candidates.push(i);\n              break;\n            case 'ArrowDown':\n              if (other.y > currentIsland.y) candidates.push(i);\n              break;\n            case 'ArrowLeft':\n              if (other.x < currentIsland.x) candidates.push(i);\n              break;\n            case 'ArrowRight':\n              if (other.x > currentIsland.x) candidates.push(i);\n              b"]
[118.838349, "i", "reak;\n          }\n        }\n\n        if (candidates.length > 0) {\n          // Sort by distance\n          candidates.sort((a, b) => {\n            const da = Math.abs(islands[a].x - currentIsland.x) + Math.abs(islands[a].y - currentIsland.y);\n            const db = Math.abs(islands[b].x - currentIsland.x) + Math.abs(islands[b].y - currentIsland.y);\n            return da - db;\n          });\n          setCursorIndex(candidates[0]);\n        }\n      }\n\n      if (e.key === 'Enter') {\n        setKeyboardMode(true);\n        const curIsland = islands[cursorIndex];\n        if (selectedIsland === null) {\n          setSelectedIsland(curIsland);\n          setErrorMessage('');\n        } else {\n          if (selectedIsland.id === curIsland.id) {\n            setSelectedIsland(null);\n            return;\n          }\n          toggleBridge(selectedIsland, curIsland);\n          setSelectedIsland(null);\n        }\n      }\n    };\n\n    window.addEventListener('keydown', handleKeyDown);\n    return () => window.removeEventListener('ke"]
[118.838363, "i", "ydown', handleKeyDown);\n  }, [cursorIndex, islands, selectedIsland, toggleBridge]);\n\n  // Render bridges as SVG lines\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges) {\n      if (count === 0) continue;\n      const parts = key.split(',').map(Number);\n      const [x1, y1, x2, y2] = parts;\n      const px1 = x1 * GRID_SIZE;\n      const py1 = y1 * GRID_SIZE;\n      const px2 = x2 * GRID_SIZE;\n      const py2 = y2 * GRID_SIZE;\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={px1} y1={py1} x2={px2} y2={py2}\n            stroke=\"#0f0\" strokeWidth=\"2\"\n          />\n        );\n      } else if (count === 2) {\n        // Two parallel lines offset by 4px\n        const isHorizontal = y1 === y2;\n        const offset = 4;\n        if (isHorizontal) {\n          lines.push(\n            <line\n              key={key + '_a'}\n              x1={px1} y1={py1 - offset} x2={px2} y2={py2 - offset}\n              stroke=\"#0f0\" strokeWidth=\"2\"\n    "]
[118.838377, "i", "        />\n          );\n          lines.push(\n            <line\n              key={key + '_b'}\n              x1={px1} y1={py1 + offset} x2={px2} y2={py2 + offset}\n              stroke=\"#0f0\" strokeWidth=\"2\"\n            />\n          );\n        } else {\n          lines.push(\n            <line\n              key={key + '_a'}\n              x1={px1 - offset} y1={py1} x2={px2 - offset} y2={py2}\n              stroke=\"#0f0\" strokeWidth=\"2\"\n            />\n          );\n          lines.push(\n            <line\n              key={key + '_b'}\n              x1={px1 + offset} y1={py1} x2={px2 + offset} y2={py2}\n              stroke=\"#0f0\" strokeWidth=\"2\"\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands as SVG circles with numbers\n  const renderIslands = () => {\n    const counts = computeCurrentCounts(islands, bridges);\n    return islands.map((island) => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland && selec"]
[118.838392, "i", "tedIsland.id === island.id;\n      const count = counts.get(island.id) || 0;\n      const satisfied = count === island.value;\n\n      return (\n        <g key={island.id}\n          onClick={(e) => handleIslandClick(island, e)}\n          onContextMenu={(e) => handleIslandContextMenu(island, e)}\n          style={{ cursor: 'pointer' }}\n        >\n          <circle\n            cx={px} cy={py} r={ISLAND_RADIUS}\n            fill=\"black\"\n            stroke={isSelected ? '#ff0' : satisfied ? '#0f0' : '#0a0'}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px} y={py}\n            textAnchor=\"middle\" dominantBaseline=\"central\"\n            fill=\"#0f0\" fontSize=\"14\" fontFamily=\"monospace\"\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render keyboard cursor (NOT a circle - using rect)\n  const renderCursor = () => {\n    if (!keyboardMode) return null;\n    const island = islands[cursorIndex];\n    if (!island) return null;\n    const px = i"]
[118.838403, "i", "sland.x * GRID_SIZE;\n    const py = island.y * GRID_SIZE;\n    const size = ISLAND_RADIUS + 6;\n    return (\n      <rect\n        x={px - size} y={py - size}\n        width={size * 2} height={size * 2}\n        fill=\"none\"\n        stroke=\"#ff0\"\n        strokeWidth=\"2\"\n        strokeDasharray=\"4 2\"\n      />\n    );\n  };\n\n  return (\n    <div style={{ background: 'black', minHeight: '100vh', padding: 0, margin: 0 }}>\n      <div style={{ padding: '8px', display: 'flex', gap: '16px', alignItems: 'center' }}>\n        <select value={puzzleIndex} onChange={handlePuzzleChange}\n          style={{ background: 'black', color: '#0f0', border: '1px solid #0f0', fontFamily: 'monospace', padding: '4px' }}>\n          {puzzles.map((p, i) => (\n            <option key={p.id} value={i}>{p.name}</option>\n          ))}\n        </select>\n        <button onClick={handleReset}\n          style={{ background: 'black', color: '#0f0', border: '1px solid #0f0', fontFamily: 'monospace', padding: '4px 8px', cursor: 'pointer' }}>\n          Reset\n  "]
[118.838443, "i", "      </button>\n        {errorMessage && <span className=\"error-message\" style={{ color: '#f00', fontFamily: 'monospace' }}>{errorMessage}</span>}\n        {victory && <span className=\"victory-banner\" style={{ color: '#0f0', fontFamily: 'monospace', fontSize: '20px', fontWeight: 'bold' }}>SOLVED!</span>}\n      </div>\n      <svg ref={svgRef} width=\"800\" height=\"600\"\n        style={{ display: 'block' }}\n        tabIndex=\"0\"\n      >\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n    </div>\n  );\n}\n\nexport default App;\nAPPEOF\n"]
