[118.576622, "o", ">     }\r\n\u001b[?2004l\r"]
[118.576666, "o", "\u001b[?2004h"]
[118.57671, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.576722, "o", ">   \r\n"]
[118.576768, "o", "\u001b[?2004l\r\u001b[?2004h"]
[118.576812, "o", "> "]
[118.576928, "o", "  return { valid: true, error: null };\r\n"]
