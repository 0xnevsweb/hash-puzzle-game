[118.572232, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[118.572259, "o", "\u001b[?2004h> "]
[118.572358, "o", "  // Check adjacency\r\n\u001b[?2004l\r"]
[118.572413, "o", "\u001b[?2004h"]
[118.572492, "o", "> "]
