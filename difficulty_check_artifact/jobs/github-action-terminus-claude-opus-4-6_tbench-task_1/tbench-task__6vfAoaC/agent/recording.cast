[118.580868, "o", "\u001b[?2004h> "]
[118.580953, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[118.581016, "o", "\u001b[?2004h> "]
[118.581114, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[118.58116, "o", "\u001b[?2004h"]
[118.581211, "o", "> "]
[118.581288, "o", "  const queue = [islands[0].id];\r\n"]
[118.581381, "o", "\u001b[?2004l\r"]
[118.581405, "o", "\u001b[?2004h> "]
[118.581542, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
