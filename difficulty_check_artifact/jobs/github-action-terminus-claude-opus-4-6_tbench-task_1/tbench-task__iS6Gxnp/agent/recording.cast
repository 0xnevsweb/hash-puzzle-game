[292.269992, "i", "    if (victory) return;\n    if (e.ctrlKey) {\n      e.stopPropagation();\n      removeBridgeByKey(key);\n      setSelectedIsland(null);\n    }\n  }, [removeBridgeByKey, victory]);\n\n  const handleBridgeContextMenu = useCallback((key, e) => {\n    e.preventDefault();\n    e.stopPropagation();\n    if (victory) return;\n    removeBridgeByKey(key);\n    setSelectedIsland(null);\n  }, [removeBridgeByKey, victory]);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      if (e.key === 'Escape') {\n        setSelectedIsland(null);\n        setErrorMsg(null);\n        return;\n      }\n\n      if (victory) return;\n\n      const currentIsland = islands.find(i => i.id === cursorIslandId);\n      if (!currentIsland) return;\n\n      if (e.key === 'Enter') {\n        e.preventDefault();\n        if (selectedIsland === null) {\n          setSelectedIsland(currentIsland);\n          setErrorMsg(null);\n        } else if (selectedIsland.id === cursorIslandId) {\n          setSelectedIsland(null);\n        } else {\n     "]
