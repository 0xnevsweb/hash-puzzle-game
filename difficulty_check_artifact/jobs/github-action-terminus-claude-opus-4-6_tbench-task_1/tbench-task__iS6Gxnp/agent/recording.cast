[203.380089, "o", "import React, { useState, useEffect, useCallback } from 'react';\r\nimport { puzzles } from './data/puzzles';\r\nimport { makeBridgeKey, canAddBridge, computeCurrentCounts, isVictory, areAdjacent } from './utils/hashiLogic';\r\n\r\nfunction App() {\r\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\r\n  const [bridges, setBridges] = useState(new Map());\r\n  const [selectedIsland, setSelectedIsland] = useState(null);\r\n  const [cursorIslandId, setCursorIslandId] = useState(0);\r\n  const [errorMsg, setErrorMsg] = useState(null);\r\n  const [victory, setVictory] = useState(false);\r\n\r\n  const puzzle = puzzles[puzzleIndex];\r\n  const islands = puzzle.islands;\r\n\r\n  // Reset everything when puzzle changes\r\n  const resetPuzzle = useCallback(() => {\r\n    setBridges(new Map());\r\n    setSelectedIsland(null);\r\n    setCursorIslandId(0);\r\n    setErrorMsg(null);\r\n    setVictory(false);\r\n  }, []);\r\n\r\n  const handlePuzzleChange = (e) => {\r\n    const idx = parseInt(e.target.value, 10);\r\n    setPuzzleIndex(idx);\r\n    setBridges(new Map());\r"]
[203.380145, "o", "\n    setSelectedIsland(null);\r\n    setCursorIslandId(0);\r\n    setErrorMsg(null);\r\n    setVictory(false);\r\n  };\r\n\r\n  const handleReset = () => {\r\n    setBridges(new Map());\r\n    setSelectedIsland(null);\r\n"]
[203.380183, "o", "    setCursorIslandId(0);\r\n    setErrorMsg(null);\r\n    setVictory(false);\r\n"]
