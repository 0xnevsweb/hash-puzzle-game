[99.032532, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[99.032592, "o", "\u001b[?2004h> "]
[99.032765, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[99.032808, "o", "\u001b[?2004h> "]
[99.032852, "o", "    \r\n\u001b[?2004l\r"]
[99.032892, "o", "\u001b[?2004h> "]
[99.032993, "o", "    let id1 = null, id2 = null;\r\n\u001b[?2004l\r"]
[99.033023, "o", "\u001b[?2004h"]
[99.033035, "o", "> "]
[99.033152, "o", "    for (const island of islands) {\r\n\u001b[?2004l\r"]
[99.033265, "o", "\u001b[?2004h> "]
[99.033407, "o", "      if (island.x === x1 && island.y === y1) id1 = island.id;\r\n\u001b[?2004l\r"]
[99.033524, "o", "\u001b[?2004h> "]
[99.033659, "o", "      if (island.x === x2 && island.y === y2) id2 = island.id;\r\n\u001b[?2004l\r"]
[99.03373, "o", "\u001b[?2004h>     }\r\n"]
[99.033756, "o", "\u001b[?2004l\r\u001b[?2004h"]
[99.03388, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[99.033985, "o", "    if (id1 !== null && id2 !== null) {\r\n\u001b[?2004l\r"]
[99.034037, "o", "\u001b[?2004h> "]
[99.034146, "o", "      adj.get(id1).push(id2);\r\n\u001b[?2004l\r"]
[99.034196, "o", "\u001b[?2004h> "]
[99.034294, "o", "      adj.get(id2).push(id1);\r\n\u001b[?2004l\r"]
[99.034343, "o", "\u001b[?2004h> "]
[99.034357, "o", "    }\r\n"]
[99.034371, "o", "\u001b[?2004l\r"]
[99.034427, "o", "\u001b[?2004h>   }\r\n"]
[99.034445, "o", "\u001b[?2004l\r"]
[99.034494, "o", "\u001b[?2004h>   \r\n"]
[99.034512, "o", "\u001b[?2004l\r"]
[99.034564, "o", "\u001b[?2004h> "]
[99.034649, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[99.034695, "o", "\u001b[?2004h> "]
[99.034793, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[99.034841, "o", "\u001b[?2004h> "]
[99.034948, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[99.035009, "o", "\u001b[?2004h> "]
[99.035099, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[99.035149, "o", "\u001b[?2004h> "]
[99.035166, "o", "  \r\n\u001b[?2004l\r"]
[99.035217, "o", "\u001b[?2004h> "]
[99.03531, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[99.035358, "o", "\u001b[?2004h> "]
[99.035462, "o", "    const curr = queue.shift();\r\n\u001b[?2004l\r"]
[99.035511, "o", "\u001b[?2004h> "]
[99.035683, "o", "    for (const neighbor of (adj.get(curr) || [])) {\r\n\u001b[?2004l\r"]
[99.035734, "o", "\u001b[?2004h> "]
[99.03585, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r"]
[99.035873, "o", "\u001b[?2004h"]
[99.035884, "o", "> "]
[99.036001, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r"]
[99.036051, "o", "\u001b[?2004h> "]
[99.03615, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[99.036172, "o", "\u001b[?2004h"]
[99.036264, "o", ">       }\r\n\u001b[?2004l\r\u001b[?2004h"]
[99.036284, "o", "> "]
[99.03634, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[99.036358, "o", "> "]
[99.03642, "o", "  }\r\n\u001b[?2004l\r"]
[99.036537, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[99.036632, "o", "\u001b[?2004h> "]
[99.036737, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r\u001b[?2004h"]
[99.036798, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[99.036902, "o", "// Check if puzzle is solved\r\n\u001b[?2004l\r"]
[99.03697, "o", "\u001b[?2004h> "]
[99.037096, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[99.037118, "o", "\u001b[?2004h"]
[99.037139, "o", "> "]
[99.037273, "o", "  // Check all counts match\r\n\u001b[?2004l\r\u001b[?2004h> "]
[99.037439, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[99.03753, "o", "\u001b[?2004h> "]
[99.037604, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[99.03767, "o", "\u001b[?2004h> "]
[99.037864, "o", "    if ((counts.get(island.id) || 0) !== island.value) return false;\r\n\u001b[?2004l\r"]
[99.037887, "o", "\u001b[?2004h"]
[99.037899, "o", "> "]
[99.037982, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h>   \r\n"]
[99.038, "o", "\u001b[?2004l\r"]
[99.038058, "o", "\u001b[?2004h> "]
[99.038127, "o", "  // Check no crossings\r\n\u001b[?2004l\r"]
[99.038174, "o", "\u001b[?2004h> "]
[99.038267, "o", "  const bridgeList = [];\r\n\u001b[?2004l\r"]
[99.03835, "o", "\u001b[?2004h> "]
[99.038442, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[99.038506, "o", "\u001b[?2004h> "]
[99.038596, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[99.038645, "o", "\u001b[?2004h> "]
[99.038735, "o", "    bridgeList.push(key);\r\n\u001b[?2004l\r"]
[99.03878, "o", "\u001b[?2004h> "]
[99.038798, "o", "  }\r\n\u001b[?2004l\r"]
[99.038844, "o", "\u001b[?2004h> "]
[99.038862, "o", "  \r\n\u001b[?2004l\r"]
[99.038909, "o", "\u001b[?2004h> "]
[99.039059, "o", "  for (let i = 0; i < bridgeList.length; i++) {\r\n\u001b[?2004l\r"]
[99.039106, "o", "\u001b[?2004h> "]
[99.039311, "o", "    const [x1, y1, x2, y2] = bridgeList[i].split(',').map(Number);\r\n\u001b[?2004l\r"]
[99.039358, "o", "\u001b[?2004h> "]
[99.03945, "o", "    const isH = y1 === y2;\r\n\u001b[?2004l\r"]
[99.039499, "o", "\u001b[?2004h> "]
[99.039683, "o", "    for (let j = i + 1; j < bridgeList.length; j++) {\r\n\u001b[?2004l\r"]
[99.039762, "o", "\u001b[?2004h> "]
[99.039948, "o", "      const [ax1, ay1, ax2, ay2] = bridgeList[j].split(',').map(Number);\r\n\u001b[?2004l\r"]
[99.040014, "o", "\u001b[?2004h> "]
[99.040107, "o", "      const isH2 = ay1 === ay2;\r\n\u001b[?2004l\r"]
[99.040194, "o", "\u001b[?2004h> "]
[99.040277, "o", "      if (isH === isH2) continue;\r\n\u001b[?2004l\r"]
[99.040336, "o", "\u001b[?2004h>       \r\n"]
[99.040414, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[99.04048, "o", "      if (isH) {\r\n\u001b[?2004l\r"]
[99.040545, "o", "\u001b[?2004h> "]
[99.040738, "o", "        const hMinX = Math.min(x1, x2), hMaxX = Math.max(x1, x2), hY = y1;\r\n\u001b[?2004l\r"]
[99.04076, "o", "\u001b[?2004h"]
[99.04083, "o", "> "]
[99.04103, "o", "        const vX = ax1, vMinY = Math.min(ay1, ay2), vMaxY = Math.max(ay1, ay2);\r\n\u001b[?2004l\r"]
[99.041081, "o", "\u001b[?2004h> "]
[99.041313, "o", "        if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) return false;\r\n\u001b[?2004l\r"]
[99.041368, "o", "\u001b[?2004h> "]
[99.041422, "o", "      } else {\r\n\u001b[?2004l\r"]
[99.041469, "o", "\u001b[?2004h> "]
[99.041705, "o", "        const hMinX = Math.min(ax1, ax2), hMaxX = Math.max(ax1, ax2), hY = ay1;\r\n\u001b[?2004l\r"]
[99.041727, "o", "\u001b[?2004h"]
[99.041793, "o", "> "]
[99.041982, "o", "        const vX = x1, vMinY = Math.min(y1, y2), vMaxY = Math.max(y1, y2);\r\n\u001b[?2004l\r"]
[99.042032, "o", "\u001b[?2004h> "]
[99.042267, "o", "        if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) return false;\r\n\u001b[?2004l\r"]
[99.042317, "o", "\u001b[?2004h> "]
[99.042361, "o", "      }\r\n\u001b[?2004l\r"]
[99.042379, "o", "\u001b[?2004h"]
[99.042392, "o", "> "]
[99.042452, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[99.042469, "o", "> "]
[99.042484, "o", "  }\r\n\u001b[?2004l\r"]
[99.042539, "o", "\u001b[?2004h>   \r\n"]
[99.042556, "o", "\u001b[?2004l\r"]
[99.042607, "o", "\u001b[?2004h> "]
[99.04269, "o", "  // Check connectivity\r\n\u001b[?2004l\r"]
[99.042738, "o", "\u001b[?2004h> "]
[99.042885, "o", "  return checkConnectivity(islands, bridges);\r\n\u001b[?2004l\r"]
[99.042903, "o", "\u001b[?2004h"]
[99.042917, "o", "> "]
[99.042984, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[99.042999, "o", "LOGIC\r\n"]
