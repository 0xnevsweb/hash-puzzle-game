[292.270006, "i", "     toggleBridge(selectedIsland, currentIsland);\n          setSelectedIsland(null);\n        }\n        return;\n      }\n\n      if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {\n        e.preventDefault();\n        let bestIsland = null;\n        let bestDist = Infinity;\n\n        for (const island of islands) {\n          if (island.id === cursorIslandId) continue;\n\n          let valid = false;\n          // Prefer same-axis islands first\n          if (e.key === 'ArrowRight' && island.x > currentIsland.x) valid = true;\n          if (e.key === 'ArrowLeft' && island.x < currentIsland.x) valid = true;\n          if (e.key === 'ArrowDown' && island.y > currentIsland.y) valid = true;\n          if (e.key === 'ArrowUp' && island.y < currentIsland.y) valid = true;\n\n          if (valid) {\n            // Prioritize same row/col\n            let dist;\n            if ((e.key === 'ArrowRight' || e.key === 'ArrowLeft') && island.y === currentIsland.y) {\n              dist = Math.abs(island.x - currentIslan"]
