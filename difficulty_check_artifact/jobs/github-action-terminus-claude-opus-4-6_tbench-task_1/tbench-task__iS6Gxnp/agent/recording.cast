[139.202937, "i", "cat > src/index.css << 'EOF'\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml, body {\n  background-color: #000;\n  color: #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  overflow: hidden;\n}\n\n.controls {\n  position: absolute;\n  top: 610px;\n  left: 0;\n  padding: 10px;\n  display: flex;\n  gap: 15px;\n  align-items: center;\n}\n\nselect, button {\n  background: #000;\n  color: #0f0;\n  border: 1px solid #0f0;\n  font-family: 'Courier New', Courier, monospace;\n  font-size: 14px;\n  padding: 4px 8px;\n  cursor: pointer;\n}\n\nselect:hover, button:hover {\n  background: #0f0;\n  color: #000;\n}\n\n.error-message {\n  color: #f00;\n  font-size: 14px;\n  margin-left: 15px;\n}\n\n.victory-banner {\n  color: #0f0;\n  font-size: 24px;\n  font-weight: bold;\n  margin-left: 15px;\n  text-shadow: 0 0 10px #0f0;\n  animation: blink 1s infinite;\n}\n\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.5; }\n}\nEOF\n"]
