[?2004l[?2004hroot@93b5f974abb4:/app# cat > src/utils/hashiLogic.js << 'LOGIC'
[?2004l[?2004h> // Create canonical bridge key: smaller coord first
[?2004l[?2004h> export function makeBridgeKey(island1, island2) {
[?2004l[?2004h>   const x1 = island1.x, y1 = island1.y;
[?2004l[?2004h>   const x2 = island2.x, y2 = island2.y;
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col, no island between)
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no island between them
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>     if (from.x === to.x && island.x === from.x) {
[?2004l[?2004h>       const minY = Math.min(from.y, to.y);
[?2004l[?2004h>       const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>       if (island.y > minY && island.y < maxY) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (from.y === to.y && island.y === from.y) {
[?2004l[?2004h>       const minX = Math.min(from.x, to.x);
[?2004l[?2004h>       const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>       if (island.x > minX && island.x < maxX) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if a bridge between two points would cross any existing bridge
[?2004l[?2004h> export function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   const isHorizontal = from.y === to.y;
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     // Find the islands for this bridge
[?2004l[?2004h>     const bridgeIsHorizontal = y1 === y2;
[?2004l[?2004h>     
[?2004l[?2004h>     // Only perpendicular bridges can cross
[?2004l[?2004h>     if (isHorizontal === bridgeIsHorizontal) continue;
[?2004l[?2004h>     
[?2004l[?2004h>     if (isHorizontal) {
[?2004l[?2004h>       // New bridge is horizontal (from.y === to.y), existing is vertical (x1===x2)
[?2004l[?2004h>       const newMinX = Math.min(from.x, to.x);
[?2004l[?2004h>       const newMaxX = Math.max(from.x, to.x);
[?2004l[?2004h>       const newY = from.y;
[?2004l[?2004h>       const existX = x1;
[?2004l[?2004h>       const existMinY = Math.min(y1, y2);
[?2004l[?2004h>       const existMaxY = Math.max(y1, y2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (existX > newMinX && existX < newMaxX && newY > existMinY && newY < existMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // New bridge is vertical (from.x === to.x), existing is horizontal (y1===y2)
[?2004l[?2004h>       const newMinY = Math.min(from.y, to.y);
[?2004l[?2004h>       const newMaxY = Math.max(from.y, to.y);
[?2004l[?2004h>       const newX = from.x;
[?2004l[?2004h>       const existY = y1;
[?2004l[?2004h>       const existMinX = Math.min(x1, x2);
[?2004l[?2004h>       const existMaxX = Math.max(x1, x2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (newX > existMinX && newX < existMaxX && existY > newMinY && existY < newMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts for each island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if ((island.x === x1 && island.y === y1) || (island.x === x2 && island.y === y2)) {
[?2004l[?2004h>         counts.set(island.id, (counts.get(island.id) || 0) + count);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // canAddBridge: check if adding delta bridges is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = makeBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check max 2
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing (only if adding new bridge where none existed)
[?2004l[?2004h>   if (current === 0 && delta > 0) {
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency from bridges
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     let id1 = null, id2 = null;
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.x === x1 && island.y === y1) id1 = island.id;
[?2004l[?2004h>       if (island.x === x2 && island.y === y2) id2 = island.id;
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     if (id1 !== null && id2 !== null) {
[?2004l[?2004h>       adj.get(id1).push(id2);
[?2004l[?2004h>       adj.get(id2).push(id1);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h>   
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const curr = queue.shift();
[?2004l[?2004h>     for (const neighbor of (adj.get(curr) || [])) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if puzzle is solved
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all counts match
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     if ((counts.get(island.id) || 0) !== island.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no crossings
[?2004l[?2004h>   const bridgeList = [];
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     bridgeList.push(key);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (let i = 0; i < bridgeList.length; i++) {
[?2004l[?2004h>     const [x1, y1, x2, y2] = bridgeList[i].split(',').map(Number);
[?2004l[?2004h>     const isH = y1 === y2;
[?2004l[?2004h>     for (let j = i + 1; j < bridgeList.length; j++) {
[?2004l[?2004h>       const [ax1, ay1, ax2, ay2] = bridgeList[j].split(',').map(Number);
[?2004l[?2004h>       const isH2 = ay1 === ay2;
[?2004l[?2004h>       if (isH === isH2) continue;
[?2004l[?2004h>       
[?2004l[?2004h>       if (isH) {
[?2004l[?2004h>         const hMinX = Math.min(x1, x2), hMaxX = Math.max(x1, x2), hY = y1;
[?2004l[?2004h>         const vX = ax1, vMinY = Math.min(ay1, ay2), vMaxY = Math.max(ay1, ay2);
[?2004l[?2004h>         if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) return false;
[?2004l[?2004h>       } else {
[?2004l[?2004h>         const hMinX = Math.min(ax1, ax2), hMaxX = Math.max(ax1, ax2), hY = ay1;
[?2004l[?2004h>         const vX = x1, vMinY = Math.min(y1, y2), vMaxY = Math.max(y1, y2);
[?2004l[?2004h>         if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> LOGIC
[?2004l[?2004hroot@93b5f974abb4:/app# cat > src/data/puzzles.js << 'EOF'
[?2004l[?2004h> export const puzzles = [
[?2004l[?2004h>   {
[?2004l[?2004h>     id: 1,
[?2004l[?2004h>     name: "Easy",
[?2004l[?2004h>     islands: [
[?2004l[?2004h>       { id: 0, x: 2, y: 2, value: 2 },
[?2004l[?2004h>       { id: 1, x: 6, y: 2, value: 2 },
[?2004l[?2004h>       { id: 2, x: 2, y: 6, value: 2 },
