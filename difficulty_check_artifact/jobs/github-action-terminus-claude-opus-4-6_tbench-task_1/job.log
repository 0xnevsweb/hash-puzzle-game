Sending keys: ['cat > /app/src/App.jsx << \'ENDOFFILE\'\nimport React, { useState, useEffect, useCallback } from \'react\';\nimport { puzzles } from \'./data/puzzles\';\nimport {\n  makeBridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory\n} from \'./utils/hashiLogic\';\n\nconst GRID_SIZE = 40;\nconst SVG_WIDTH = 800;\nconst SVG_HEIGHT = 600;\nconst ISLAND_RADIUS = 16;\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [cursorIslandId, setCursorIslandId] = useState(0);\n  const [errorMessage, setErrorMessage] = useState(null);\n  const [victory, setVictory] = useState(false);\n  const [kbSelected, setKbSelected] = useState(false);\n\n  const puzzle = puzzles[puzzleIndex];\n  const islands = puzzle.islands;\n\n  // Reset everything when puzzle changes\n  const handlePuzzleChange = (e) => {\n    const idx = parseInt(e.target.value, 10);\n    setPuzzleIndex(idx);\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n    setKbSelected(false);\n  };\n\n  const handleReset = () => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIslandId(0);\n    setErrorMessage(null);\n    setVictory(false);\n    setKbSelected(false);\n  };\n\n  // Toggle bridge between two islands (none -> single -> double -> none)\n  const toggleBridge = useCallback((fromIsland, toIsland) => {\n    const key = makeBridgeKey(fromIsland, toIsland);\n    const current = bridges.get(key) || 0;\n\n    if (current === 2) {\n      // Remove bridge (double -> none)\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setSelectedIsland(null);\n      setErrorMessage(null);\n      setVictory(isVictory(islands, newBridges));\n      return;\n    }\n\n    // Try to add one bridge\n    const delta = 1;\n    const result = canAddBridge(islands, bridges, fromIsland, toIsland, delta);\n\n    if (!result.valid) {\n      setErrorMessage(result.error);\n      setSelectedIsland(null);\n      return;\n    }\n\n    const newBridges = new Map(bridges);\n    newBridges.set(key, current + 1);\n    setBridges(newBridges);\n    setSelectedIsland(null);\n    setErrorMessage(null);\n    setVictory(isVictory(islands, newBridges));\n  }, [bridges, islands]);\n\n  // Handle island click\n  const handleIslandClick = useCallback((island) => {\n    if (victory) return;\n\n    setCursorIslandId(island.id);\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island.id);\n      setKbSelected(false);\n    } else if (selectedIsland === island.id) {\n      // Deselect\n      setSelectedIsland(null);\n    } else {\n      const fromIsland = islands.find(i => i.id === selectedIsland);\n      toggleBridge(fromIsland, island);\n    }\n  }, [selectedIsland, islands, toggleBridge, victory]);\n\n  // Handle bridge right-click or ctrl-click removal\n  const handleBridgeRemove = useCallback((e, key) => {\n    e.preventDefault();\n    e.stopPropagation();\n    if (victory) return;\n\n    const newBridges = new Map(bridges);\n    newBridges.delete(key);\n    setBridges(newBridges);\n    setSelectedIsland(null);\n    setErrorMessage(null);\n    setVictory(isVictory(islands, newBridges));\n  }, [bridges, islands, victory]);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      if (victory) return;\n\n      const currentIsland = islands.find(i => i.id === cursorIslandId);\n      if (!currentIsland) return;\n\n      if (e.key === \'Escape\') {\n        setSelectedIsland(null);\n        setKbSelected(false);\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        if (!kbSelected) {\n          setKbSelected(true);\n          setSelectedIsland(cursorIslandId);\n        } else {\n          if (selectedIsland !== null && selectedIsland !== cursorIslandId) {\n            const fromIsland = islands.find(i => i.id === selectedIsland);\n            const toIsland = islands.find(i => i.id === cursorIslandId);\n            toggleBridge(fromIsland, toIsland);\n            setKbSelected(false);\n          } else {\n            setSelectedIsland(null);\n            setKbSelected(false);\n          }\n        }\n        return;\n      }\n\n      if ([\'ArrowUp\', \'ArrowDown\', \'ArrowLeft\', \'ArrowRight\'].includes(e.key)) {\n        e.preventDefault();\n        let bestIsland = null;\n        let bestDist = Infinity;\n\n        for (const isl of islands) {\n          if (isl.id === cursorIslandId) continue;\n\n          let valid = false;\n          let dist = 0;\n\n          if (e.key === \'ArrowUp\' && isl.y < currentIsland.y) {\n            valid = true;\n            dist = Math.abs(isl.x - currentIsland.x) * 1000 + (currentIsland.y - isl.y);\n          } else if (e.key === \'ArrowDown\' && isl.y > currentIsland.y) {\n            valid = true;\n            dist = Math.abs(isl.x - currentIsland.x) * 1000 + (isl.y - currentIsland.y);\n          } else if (e.key === \'ArrowLeft\' && isl.x < currentIsland.x) {\n            valid = true;\n            dist = Math.abs(isl.y - currentIsland.y) * 1000 + (currentIsland.x - isl.x);\n          } else if (e.key === \'ArrowRight\' && isl.x > currentIsland.x) {\n            valid = true;\n            dist = Math.abs(isl.y - currentIsland.y) * 1000 + (isl.x - currentIsland.x);\n          }\n\n          if (valid && dist < bestDist) {\n            bestDist = dist;\n            bestIsland = isl;\n          }\n        }\n\n        if (bestIsland) {\n          setCursorIslandId(bestIsland.id);\n        }\n      }\n    };\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [cursorIslandId, selectedIsland, kbSelected, islands, toggleBridge, victory]);\n\n  // Render bridges\n  const renderBridges = () => {\n    const elements = [];\n    for (const [key, count] of bridges) {\n      if (count === 0) continue;\n      const parts = key.split(\',\').map(Number);\n      const [x1, y1, x2, y2] = parts;\n      const px1 = x1 * GRID_SIZE;\n      const py1 = y1 * GRID_SIZE;\n      const px2 = x2 * GRID_SIZE;\n      const py2 = y2 * GRID_SIZE;\n\n      const isHorizontal = y1 === y2;\n      const offset = 4;\n\n      const handleContext = (e) => handleBridgeRemove(e, key);\n      const handleClick = (e) => {\n        if (e.ctrlKey) {\n          handleBridgeRemove(e, key);\n        }\n      };\n\n      if (count === 1) {\n        elements.push(\n          <line\n            key={key}\n            x1={px1}\n            y1={py1}\n            x2={px2}\n            y2={py2}\n            stroke="#0f0"\n            strokeWidth="3"\n            style={{ cursor: \'pointer\' }}\n            onContextMenu={handleContext}\n            onClick={handleClick}\n          />\n        );\n      } else if (count === 2) {\n        const dx = isHorizontal ? 0 : offset;\n        const dy = isHorizontal ? offset : 0;\n\n        elements.push(\n          <line\n            key={key + \'-a\'}\n            x1={px1 - dx}\n            y1={py1 - dy}\n            x2={px2 - dx}\n            y2={py2 - dy}\n            stroke="#0f0"\n            strokeWidth="3"\n            style={{ cursor: \'pointer\' }}\n            onContextMenu={handleContext}\n            onClick={handleClick}\n          />\n        );\n        elements.push(\n          <line\n            key={key + \'-b\'}\n            x1={px1 + dx}\n            y1={py1 + dy}\n            x2={px2 + dx}\n            y2={py2 + dy}\n            stroke="#0f0"\n            strokeWidth="3"\n            style={{ cursor: \'pointer\' }}\n            onContextMenu={handleContext}\n            onClick={handleClick}\n          />\n        );\n      }\n    }\n    return elements;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map(island => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland === island.id;\n\n      return (\n        <g key={island.id} onClick={() => handleIslandClick(island)} style={{ cursor: \'pointer\' }}>\n          <circle\n            cx={px}\n            cy={py}\n            r={ISLAND_RADIUS}\n            fill="black"\n            stroke={isSelected ? \'#ff0\' : \'#0f0\'}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px}\n            y={py}\n            textAnchor="middle"\n            dominantBaseline="central"\n            fill="#0f0"\n            fontSize="14"\n            fontFamily="monospace"\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render cursor (rect, not circle)\n  const renderCursor = () => {\n    const island = islands.find(i => i.id === cursorIslandId);\n    if (!island) return null;\n    const px = island.x * GRID_SIZE;\n    const py = island.y * GRID_SIZE;\n    const size = ISLAND_RADIUS + 6;\n\n    return (\n      <rect\n        x={px - size}\n        y={py - size}\n        width={size * 2}\n        height={size * 2}\n        fill="none"\n        stroke="#0ff"\n        strokeWidth="2"\n        strokeDasharray="4 2"\n        pointerEvents="none"\n      />\n    );\n  };\n\n  return (\n    <div>\n      <svg\n        width={SVG_WIDTH}\n        height={SVG_HEIGHT}\n        style={{ display: \'block\', position: \'absolute\', top: 0, left: 0, background: \'black\' }}\n      >\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n      <div style={{\n        position: \'absolute\',\n        top: SVG_HEIGHT + \'px\',\n        left: 0,\n        padding: \'8px\',\n        display: \'flex\',\n        gap: \'12px\',\n        alignItems: \'center\'\n      }}>\n        <select\n          value={puzzleIndex}\n          onChange={handlePuzzleChange}\n          style={{\n            background: \'black\',\n            color: \'#0f0\',\n            border: \'1px solid #0f0\',\n            fontFamily: \'monospace\',\n            padding: \'4px\'\n          }}\n        >\n          {puzzles.map((p, idx) => (\n            <option key={p.id} value={idx}>{p.name}</option>\n          ))}\n        </select>\n        <button\n          onClick={handleReset}\n          style={{\n            background: \'black\',\n            color: \'#0f0\',\n            border: \'1px solid #0f0\',\n            fontFamily: \'monospace\',\n            padding: \'4px 8px\',\n            cursor: \'pointer\'\n          }}\n        >\n          Reset\n        </button>\n        {errorMessage && (\n          <span className="error-message" style={{ color: \'#f00\', fontFamily: \'monospace\' }}>\n            {errorMessage}\n          </span>\n        )}\n        {victory && (\n          <span className="victory-banner" style={{ color: \'#0f0\', fontFamily: \'monospace\', fontSize: \'20px\', fontWeight: \'bold\' }}>\n            SOLVED!\n          </span>\n        )}\n      </div>\n    </div>\n  );\n}\n\nexport default App;\nENDOFFILE\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
