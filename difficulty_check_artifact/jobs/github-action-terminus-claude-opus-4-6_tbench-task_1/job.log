Sending keys: ['cat > /app/src/utils/hashiLogic.js << \'EOF\'\n// Utility to create a canonical bridge key from two islands\n// Key format: "x1,y1,x2,y2" where (x1,y1) sorts before (x2,y2)\nexport function makeBridgeKey(a, b) {\n  if (a.x < b.x || (a.x === b.x && a.y < b.y)) {\n    return `${a.x},${a.y},${b.x},${b.y}`;\n  }\n  return `${b.x},${b.y},${a.x},${a.y}`;\n}\n\n// Check if two islands are on the same row or column (adjacent axis)\nfunction areAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\n// Check if there\'s any island between a and b on the same line\nfunction hasIslandBetween(islands, a, b) {\n  if (a.x === b.x) {\n    // vertical\n    const minY = Math.min(a.y, b.y);\n    const maxY = Math.max(a.y, b.y);\n    return islands.some(isl =>\n      isl.id !== a.id && isl.id !== b.id &&\n      isl.x === a.x && isl.y > minY && isl.y < maxY\n    );\n  } else if (a.y === b.y) {\n    // horizontal\n    const minX = Math.min(a.x, b.x);\n    const maxX = Math.max(a.x, b.x);\n    return islands.some(isl =>\n      isl.id !== a.id && isl.id !== b.id &&\n      isl.y === a.y && isl.x > minX && isl.x < maxX\n    );\n  }\n  return false;\n}\n\n// Check if two line segments cross (not just touch)\nfunction segmentsCross(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2) {\n  // Only check perpendicular segments (one horizontal, one vertical)\n  const aHoriz = ay1 === ay2;\n  const aVert = ax1 === ax2;\n  const bHoriz = by1 === by2;\n  const bVert = bx1 === bx2;\n\n  if (aHoriz && bVert) {\n    const aMinX = Math.min(ax1, ax2);\n    const aMaxX = Math.max(ax1, ax2);\n    const bMinY = Math.min(by1, by2);\n    const bMaxY = Math.max(by1, by2);\n    // Strictly between (not at endpoints)\n    return bx1 > aMinX && bx1 < aMaxX && ay1 > bMinY && ay1 < bMaxY;\n  }\n\n  if (aVert && bHoriz) {\n    const bMinX = Math.min(bx1, bx2);\n    const bMaxX = Math.max(bx1, bx2);\n    const aMinY = Math.min(ay1, ay2);\n    const aMaxY = Math.max(ay1, ay2);\n    return ax1 > bMinX && ax1 < bMaxX && by1 > aMinY && by1 < aMaxY;\n  }\n\n  // Parallel segments don\'t cross in Hashi\n  return false;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nfunction wouldCross(islands, bridges, from, to) {\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const [ex1, ey1, ex2, ey2] = parts;\n    if (segmentsCross(from.x, from.y, to.x, to.y, ex1, ey1, ex2, ey2)) {\n      return true;\n    }\n  }\n  return false;\n}\n\n// Compute the current bridge count for each island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) {\n    counts.set(isl.id, 0);\n  }\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const [x1, y1, x2, y2] = parts;\n    // Find islands at these positions\n    const islA = islands.find(i => i.x === x1 && i.y === y1);\n    const islB = islands.find(i => i.x === x2 && i.y === y2);\n    if (islA) counts.set(islA.id, (counts.get(islA.id) || 0) + count);\n    if (islB) counts.set(islB.id, (counts.get(islB.id) || 0) + count);\n  }\n  return counts;\n}\n\n// Check if adding delta bridges between from and to is valid\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Same island\n  if (from.id === to.id) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n\n  // Not aligned (not on same row or column)\n  if (!areAligned(from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n\n  // Island between them\n  if (hasIslandBetween(islands, from, to)) {\n    return { valid: false, error: "Cannot connect non-adjacent islands" };\n  }\n\n  const key = makeBridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const newCount = current + delta;\n\n  // Max 2 bridges\n  if (newCount > 2) {\n    return { valid: false, error: "Max 2 bridges per pair" };\n  }\n\n  // Check island capacity\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) || 0;\n  const toCount = counts.get(to.id) || 0;\n\n  if (fromCount + delta > from.value) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n  if (toCount + delta > to.value) {\n    return { valid: false, error: "Island would exceed its number" };\n  }\n\n  // Check crossing\n  if (delta > 0 && current === 0) {\n    // Only check crossing when creating a new bridge (not adding to existing)\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: "Bridges would cross" };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\n// Check connectivity: all islands with at least one bridge are connected\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  // Build adjacency list based on bridges\n  const adj = new Map();\n  for (const isl of islands) {\n    adj.set(isl.id, []);\n  }\n\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    const [x1, y1, x2, y2] = parts;\n    const islA = islands.find(i => i.x === x1 && i.y === y1);\n    const islB = islands.find(i => i.x === x2 && i.y === y2);\n    if (islA && islB) {\n      adj.get(islA.id).push(islB.id);\n      adj.get(islB.id).push(islA.id);\n    }\n  }\n\n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n\n  while (queue.length > 0) {\n    const curr = queue.shift();\n    for (const neighbor of adj.get(curr)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  return visited.size === islands.length;\n}\n\n// Check if the puzzle is solved\nexport function isVictory(islands, bridges) {\n  // Check all island counts match their values\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) || 0) !== isl.value) {\n      return false;\n    }\n  }\n\n  // Check no bridges cross\n  const bridgeSegments = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(\',\').map(Number);\n    bridgeSegments.push(parts);\n  }\n  for (let i = 0; i < bridgeSegments.length; i++) {\n    for (let j = i + 1; j < bridgeSegments.length; j++) {\n      const [ax1, ay1, ax2, ay2] = bridgeSegments[i];\n      const [bx1, by1, bx2, by2] = bridgeSegments[j];\n      if (segmentsCross(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2)) {\n        return false;\n      }\n    }\n  }\n\n  // Check connectivity\n  return checkConnectivity(islands, bridges);\n}\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
