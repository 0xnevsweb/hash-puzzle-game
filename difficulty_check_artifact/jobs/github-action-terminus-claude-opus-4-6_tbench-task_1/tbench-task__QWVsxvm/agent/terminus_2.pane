[?2004l[?2004h> // Utility to create a canonical bridge key from two islands
[?2004l[?2004h> // Key format: "x1,y1,x2,y2" where (x1,y1) sorts before (x2,y2)
[?2004l[?2004h> export function makeBridgeKey(a, b) {
[?2004l[?2004h>   if (a.x < b.x || (a.x === b.x && a.y < b.y)) {
[?2004l[?2004h>     return `${a.x},${a.y},${b.x},${b.y}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${b.x},${b.y},${a.x},${a.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are on the same row or column (adjacent axis)
[?2004l[?2004h> function areAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if there's any island between a and b on the same line
[?2004l[?2004h> function hasIslandBetween(islands, a, b) {
[?2004l[?2004h>   if (a.x === b.x) {
[?2004l[?2004h>     // vertical
[?2004l[?2004h>     const minY = Math.min(a.y, b.y);
[?2004l[?2004h>     const maxY = Math.max(a.y, b.y);
[?2004l[?2004h>     return islands.some(isl =>
[?2004l[?2004h>       isl.id !== a.id && isl.id !== b.id &&
[?2004l[?2004h>       isl.x === a.x && isl.y > minY && isl.y < maxY
[?2004l[?2004h>     );
[?2004l[?2004h>   } else if (a.y === b.y) {
[?2004l[?2004h>     // horizontal
[?2004l[?2004h>     const minX = Math.min(a.x, b.x);
[?2004l[?2004h>     const maxX = Math.max(a.x, b.x);
[?2004l[?2004h>     return islands.some(isl =>
[?2004l[?2004h>       isl.id !== a.id && isl.id !== b.id &&
[?2004l[?2004h>       isl.y === a.y && isl.x > minX && isl.x < maxX
[?2004l[?2004h>     );
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two line segments cross (not just touch)
[?2004l[?2004h> function segmentsCross(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2) {
[?2004l[?2004h>   // Only check perpendicular segments (one horizontal, one vertical)
[?2004l[?2004h>   const aHoriz = ay1 === ay2;
[?2004l[?2004h>   const aVert = ax1 === ax2;
[?2004l[?2004h>   const bHoriz = by1 === by2;
[?2004l[?2004h>   const bVert = bx1 === bx2;
[?2004l[?2004h> 
[?2004l[?2004h>   if (aHoriz && bVert) {
[?2004l[?2004h>     const aMinX = Math.min(ax1, ax2);
[?2004l[?2004h>     const aMaxX = Math.max(ax1, ax2);
[?2004l[?2004h>     const bMinY = Math.min(by1, by2);
[?2004l[?2004h>     const bMaxY = Math.max(by1, by2);
[?2004l[?2004h>     // Strictly between (not at endpoints)
[?2004l[?2004h>     return bx1 > aMinX && bx1 < aMaxX && ay1 > bMinY && ay1 < bMaxY;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   if (aVert && bHoriz) {
[?2004l[?2004h>     const bMinX = Math.min(bx1, bx2);
[?2004l[?2004h>     const bMaxX = Math.max(bx1, bx2);
[?2004l[?2004h>     const aMinY = Math.min(ay1, ay2);
[?2004l[?2004h>     const aMaxY = Math.max(ay1, ay2);
[?2004l[?2004h>     return ax1 > bMinX && ax1 < bMaxX && by1 > aMinY && by1 < aMaxY;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Parallel segments don't cross in Hashi
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding a bridge between from and to would cross any existing bridge
[?2004l[?2004h> function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const [ex1, ey1, ex2, ey2] = parts;
[?2004l[?2004h>     if (segmentsCross(from.x, from.y, to.x, to.y, ex1, ey1, ex2, ey2)) {
[?2004l[?2004h>       return true;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004lr[?2004h> 
[?2004le[?2004h> // Compute the current bridge count for each island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     counts.set(isl.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const [x1, y1, x2, y2] = parts;
[?2004l[?2004h>     // Find islands at these positions
[?2004l[?2004h>     const islA = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const islB = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (islA) counts.set(islA.id, (counts.get(islA.id) || 0) + count);
[?2004l[?2004h>     if (islB) counts.set(islB.id, (counts.get(islB.id) || 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges between from and to is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Same island
[?2004l[?2004h>   if (from.id === to.id) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Not aligned (not on same row or column)
[?2004l[?2004h>   if (!areAligned(from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Island between them
[?2004l[?2004h>   if (hasIslandBetween(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = makeBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   // Max 2 bridges
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>   if (fromCount + delta > from.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   if (toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check crossing
[?2004l[?2004h>   if (delta > 0 && current === 0) {
[?2004l[?2004h>     // Only check crossing when creating a new bridge (not adding to existing)
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check connectivity: all islands with at least one bridge are connected
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   // Build adjacency list based on bridges
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     adj.set(isl.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     const [x1, y1, x2, y2] = parts;
[?2004l[?2004h>     const islA = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const islB = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (islA && islB) {
[?2004l[?2004h>       adj.get(islA.id).push(islB.id);
[?2004l[?2004h>       adj.get(islB.id).push(islA.id);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h> 
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const curr = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(curr)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if the puzzle is solved
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all island counts match their values
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) || 0) !== isl.value) {
[?2004l[?2004h>       return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check no bridges cross
[?2004l[?2004h>   const bridgeSegments = [];
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const parts = key.split(',').map(Number);
[?2004l[?2004h>     bridgeSegments.push(parts);
[?2004l[?2004h>   }
[?2004l[?2004h>   for (let i = 0; i < bridgeSegments.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < bridgeSegments.length; j++) {
[?2004l[?2004h>       const [ax1, ay1, ax2, ay2] = bridgeSegments[i];
[?2004l[?2004h>       const [bx1, by1, bx2, by2] = bridgeSegments[j];
[?2004l[?2004h>       if (segmentsCross(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2)) {
[?2004l[?2004h>         return false;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check connectivity
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> EOF
