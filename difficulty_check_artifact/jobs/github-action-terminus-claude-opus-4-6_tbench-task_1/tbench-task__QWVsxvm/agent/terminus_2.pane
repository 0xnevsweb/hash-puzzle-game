[?2004l[?2004h> import React, { useState, useEffect, useCallback, useRef } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles';
[?2004l[?2004h> import {
[?2004l[?2004h>   makeBridgeKey,
[?2004l[?2004h>   canAddBridge,
