[82.372917, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.373046, "o", "  const key = makeBridgeKey(from, to);\r\n\u001b[?2004l\r"]
[82.373129, "o", "\u001b[?2004h> "]
[82.373223, "o", "  const current = bridges.get(key) || 0;\r\n\u001b[?2004l\r"]
[82.37329, "o", "\u001b[?2004h> "]
[82.373369, "o", "  const newCount = current + delta;\r\n\u001b[?2004l\r"]
[82.373419, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[82.373493, "o", "\u001b[?2004h> "]
[82.373573, "o", "  // Max 2 bridges\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.373653, "o", "  if (newCount > 2) {\r\n\u001b[?2004l\r"]
[82.3737, "o", "\u001b[?2004h> "]
