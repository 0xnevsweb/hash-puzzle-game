[82.357843, "o", "// Check if two line segments cross (not just touch)\r\n\u001b[?2004l\r"]
[82.35792, "o", "\u001b[?2004h> "]
[82.358265, "o", "function segmentsCross(ax1, ay1, ax2, ay2, bx1, by1, bx2, by2) {\r\n\u001b[?2004l\r"]
[82.358287, "o", "\u001b[?2004h> "]
[82.358687, "o", "  // Only check perpendicular segments (one horizontal, one vertical)\r\n\u001b[?2004l\r"]
[82.358722, "o", "\u001b[?2004h> "]
[82.358917, "o", "  const aHoriz = ay1 === ay2;\r\n\u001b[?2004l\r"]
[82.358936, "o", "\u001b[?2004h"]
[82.358946, "o", "> "]
[82.359129, "o", "  const aVert = ax1 === ax2;\r\n\u001b[?2004l\r"]
[82.359144, "o", "\u001b[?2004h"]
[82.359153, "o", "> "]
[82.359354, "o", "  const bHoriz = by1 === by2;\r\n\u001b[?2004l\r"]
[82.359377, "o", "\u001b[?2004h"]
[82.359387, "o", "> "]
