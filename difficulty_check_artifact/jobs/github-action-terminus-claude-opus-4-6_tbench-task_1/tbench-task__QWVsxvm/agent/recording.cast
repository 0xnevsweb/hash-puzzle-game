[82.347323, "i", "islB = islands.find(i => i.x === x2 && i.y === y2);\n    if (islA && islB) {\n      adj.get(islA.id).push(islB.id);\n      adj.get(islB.id).push(islA.id);\n    }\n  }\n\n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n\n  while (queue.length > 0) {\n    const curr = queue.shift();\n    for (const neighbor of adj.get(curr)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  return visited.size === islands.length;\n}\n\n// Check if the puzzle is solved\nexport function isVictory(islands, bridges) {\n  // Check all island counts match their values\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) || 0) !== isl.value) {\n      return false;\n    }\n  }\n\n  // Check no bridges cross\n  const bridgeSegments = [];\n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const parts = key.split(',').map(Number);\n    "]
