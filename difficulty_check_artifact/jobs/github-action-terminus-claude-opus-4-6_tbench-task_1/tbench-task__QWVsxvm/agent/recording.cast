[82.374411, "o", "\u001b[?2004h> "]
[82.374555, "o", "  const fromCount = counts.get(from.id) || 0;\r\n\u001b[?2004l\r"]
[82.374605, "o", "\u001b[?2004h> "]
[82.374742, "o", "  const toCount = counts.get(to.id) || 0;\r\n\u001b[?2004l\r"]
[82.374793, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[82.374826, "o", "\u001b[?2004h"]
[82.374875, "o", "> "]
[82.374978, "o", "  if (fromCount + delta > from.value) {\r\n\u001b[?2004l\r"]
[82.375011, "o", "\u001b[?2004h"]
[82.375056, "o", "> "]
[82.375262, "o", "    return { valid: false, error: \"Island would exceed its number\" };\r\n\u001b[?2004l\r"]
