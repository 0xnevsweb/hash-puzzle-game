[82.372217, "o", "\u001b[?2004h> "]
[82.372305, "o", "  // Island between them\r\n\u001b[?2004l\r"]
[82.372322, "o", "\u001b[?2004h"]
[82.372377, "o", "> "]
[82.372487, "o", "  if (hasIslandBetween(islands, from, to)) {\r\n\u001b[?2004l\r"]
[82.37254, "o", "\u001b[?2004h> "]
[82.372749, "o", "    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\r\n\u001b[?2004l\r"]
[82.372788, "o", "\u001b[?2004h"]
[82.372807, "o", ">   }\r\n\u001b[?2004l\r"]
