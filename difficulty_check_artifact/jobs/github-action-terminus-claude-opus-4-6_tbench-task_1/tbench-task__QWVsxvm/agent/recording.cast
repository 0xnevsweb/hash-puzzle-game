[82.364214, "o", "> "]
[82.364633, "o", "// Check if adding a bridge between from and to would cross any existing bridge\r\n\u001b[?2004l\r"]
[82.364653, "o", "\u001b[?2004h"]
[82.364713, "o", "> "]
[82.364972, "o", "function wouldCross(islands, bridges, from, to) {\r\n\u001b[?2004l\r"]
[82.365021, "o", "\u001b[?2004h> "]
[82.365262, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[82.365343, "o", "\u001b[?2004h> "]
[82.365496, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[82.365564, "o", "\u001b[?2004h> "]
[82.365795, "o", "    const parts = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[82.365872, "o", "\u001b[?2004h> "]
[82.366086, "o", "    const [ex1, ey1, ex2, ey2] = parts;\r\n\u001b[?2004l\r"]
[82.366142, "o", "\u001b[?2004h> "]
[82.366526, "o", "    if (segmentsCross(from.x, from.y, to.x, to.y, ex1, ey1, ex2, ey2)) {\r\n\u001b[?2004l\r"]
[82.366613, "o", "\u001b[?2004h> "]
[82.366695, "o", "      return true;\r\n\u001b[?2004l\r"]
[82.36672, "o", "\u001b[?2004h"]
[82.366809, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.366876, "o", ">   }\r\n\u001b[?2004l\r"]
