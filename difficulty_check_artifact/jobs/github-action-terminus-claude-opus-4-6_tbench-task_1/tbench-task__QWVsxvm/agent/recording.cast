[82.367116, "o", "\u001b[?2004h> \r\n\u001b[?2004l\re"]
[82.367207, "o", "\u001b[?2004h> "]
[82.367542, "o", "// Compute the current bridge count for each island\r\n\u001b[?2004l\r"]
[82.367619, "o", "\u001b[?2004h> "]
[82.367754, "o", "export function computeCurrentCounts(islands, bridges) {\r\n\u001b[?2004l\r"]
[82.367806, "o", "\u001b[?2004h> "]
[82.367893, "o", "  const counts = new Map();\r\n\u001b[?2004l\r"]
[82.367961, "o", "\u001b[?2004h> "]
[82.368042, "o", "  for (const isl of islands) {\r\n\u001b[?2004l\r"]
[82.368127, "o", "\u001b[?2004h> "]
[82.368187, "o", "    counts.set(isl.id, 0);\r\n\u001b[?2004l\r"]
[82.36824, "o", "\u001b[?2004h"]
[82.368302, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.368438, "o", "  for (const [key, count] of bridges) {\r\n\u001b[?2004l\r"]
[82.36851, "o", "\u001b[?2004h"]
[82.368567, "o", "> "]
[82.368624, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[82.368684, "o", "\u001b[?2004h> "]
[82.368789, "o", "    const parts = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[82.36885, "o", "\u001b[?2004h"]
[82.368871, "o", "> "]
[82.368965, "o", "    const [x1, y1, x2, y2] = parts;\r\n\u001b[?2004l\r"]
[82.368989, "o", "\u001b[?2004h> "]
[82.369126, "o", "    // Find islands at these positions\r\n\u001b[?2004l\r"]
[82.369145, "o", "\u001b[?2004h"]
[82.369227, "o", "> "]
[82.369366, "o", "    const islA = islands.find(i => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[82.369386, "o", "\u001b[?2004h"]
[82.369399, "o", "> "]
[82.369589, "o", "    const islB = islands.find(i => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[82.369637, "o", "\u001b[?2004h> "]
[82.369841, "o", "    if (islA) counts.set(islA.id, (counts.get(islA.id) || 0) + count);\r\n\u001b[?2004l\r"]
[82.369887, "o", "\u001b[?2004h> "]
[82.37009, "o", "    if (islB) counts.set(islB.id, (counts.get(islB.id) || 0) + count);\r\n\u001b[?2004l\r"]
[82.370162, "o", "\u001b[?2004h"]
[82.370223, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.37024, "o", "  return counts;\r\n"]
