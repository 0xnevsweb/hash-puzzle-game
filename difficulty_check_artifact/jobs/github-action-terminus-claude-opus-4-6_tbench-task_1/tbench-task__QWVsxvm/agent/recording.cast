[82.377348, "o", "\u001b[?2004h> "]
[82.377562, "o", "// Check connectivity: all islands with at least one bridge are connected\r\n\u001b[?2004l\r"]
[82.377605, "o", "\u001b[?2004h> "]
[82.377795, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[82.377843, "o", "\u001b[?2004h> "]
