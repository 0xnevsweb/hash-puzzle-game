[82.371102, "o", "\u001b[?2004h> "]
[82.371351, "o", "    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\r\n\u001b[?2004l\r"]
[82.371408, "o", "\u001b[?2004h> "]
[82.37143, "o", "  }\r\n\u001b[?2004l\r"]
