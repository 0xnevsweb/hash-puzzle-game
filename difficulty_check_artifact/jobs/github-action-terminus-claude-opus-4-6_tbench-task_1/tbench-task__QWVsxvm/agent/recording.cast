[82.359608, "o", "\r\n\u001b[?2004l\r"]
[82.359619, "o", "\u001b[?2004h"]
[82.359681, "o", "> "]
[82.359795, "o", "  if (aHoriz && bVert) {\r\n\u001b[?2004l\r"]
[82.359818, "o", "\u001b[?2004h> "]
[82.360068, "o", "    const aMinX = Math.min(ax1, ax2);\r\n\u001b[?2004l\r"]
[82.360144, "o", "\u001b[?2004h> "]
[82.360352, "o", "    const aMaxX = Math.max(ax1, ax2);\r\n\u001b[?2004l\r"]
[82.360464, "o", "\u001b[?2004h> "]
[82.360609, "o", "    const bMinY = Math.min(by1, by2);\r\n\u001b[?2004l\r"]
[82.360671, "o", "\u001b[?2004h"]
[82.360733, "o", "> "]
[82.360887, "o", "    const bMaxY = Math.max(by1, by2);\r\n\u001b[?2004l\r"]
[82.360956, "o", "\u001b[?2004h> "]
[82.361193, "o", "    // Strictly between (not at endpoints)\r\n\u001b[?2004l\r"]
[82.361245, "o", "\u001b[?2004h> "]
[82.361609, "o", "    return bx1 > aMinX && bx1 < aMaxX && ay1 > bMinY && ay1 < bMaxY;\r\n\u001b[?2004l\r"]
[82.361628, "o", "\u001b[?2004h"]
[82.36164, "o", "> "]
[82.361712, "o", "  }\r\n\u001b[?2004l\r"]
[82.361772, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.361909, "o", "  if (aVert && bHoriz) {\r\n\u001b[?2004l\r"]
[82.361931, "o", "\u001b[?2004h> "]
[82.362151, "o", "    const bMinX = Math.min(bx1, bx2);\r\n\u001b[?2004l\r"]
[82.362175, "o", "\u001b[?2004h"]
[82.362188, "o", "> "]
[82.362406, "o", "    const bMaxX = Math.max(bx1, bx2);\r\n\u001b[?2004l\r"]
[82.362474, "o", "\u001b[?2004h> "]
[82.362666, "o", "    const aMinY = Math.min(ay1, ay2);\r\n\u001b[?2004l\r"]
[82.362684, "o", "\u001b[?2004h"]
[82.362697, "o", "> "]
[82.36294, "o", "    const aMaxY = Math.max(ay1, ay2);\r\n\u001b[?2004l\r"]
[82.363001, "o", "\u001b[?2004h> "]
[82.363404, "o", "    return ax1 > bMinX && ax1 < bMaxX && by1 > aMinY && by1 < aMaxY;\r\n\u001b[?2004l\r"]
[82.363468, "o", "\u001b[?2004h"]
[82.363527, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[82.363599, "o", "\u001b[?2004h> "]
