[82.373939, "o", "\u001b[?2004h> "]
[82.373975, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.374025, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
