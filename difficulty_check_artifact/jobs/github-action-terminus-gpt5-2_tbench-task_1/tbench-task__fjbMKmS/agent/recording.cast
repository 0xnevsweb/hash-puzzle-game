[58.488803, "o", "\u001b[?2004h> "]
[58.488945, "o", "  for (const [key, n] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[58.488961, "o", "\u001b[?2004h"]
[58.488973, "o", "> "]
[58.489069, "o", "    if (!n) continue;\r\n\u001b[?2004l\r"]
[58.489143, "o", "\u001b[?2004h> "]
[58.489326, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[58.490018, "o", "\u001b[?2004h"]
[58.490145, "o", "> "]
[58.490193, "o", "    const a = byCoord.get(`${x1},${y1}`);\r\n"]
[58.490248, "o", "\u001b[?2004l\r"]
[58.490315, "o", "\u001b[?2004h"]
[58.49033, "o", "> "]
[58.490485, "o", "    const b = byCoord.get(`${x2},${y2}`);"]
