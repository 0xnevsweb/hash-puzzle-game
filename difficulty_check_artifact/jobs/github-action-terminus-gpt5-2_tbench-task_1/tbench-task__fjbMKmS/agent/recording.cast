[58.578769, "i", "amily: 'monospace' }}\n        >\n          Reset\n        </button>\n        <div style={{ fontSize: 12 }}>\n          {checkConnectivity(islands, bridges) ? 'Connected' : 'Not connected'}\n        </div>\n      </div>\n\n      {error ? <div className=\"error-message\" style={{ paddingLeft: 8, paddingBottom: 6 }}>\n        {error}\n      </div> : null}\n\n      {victory ? <div className=\"victory-banner\" style={{ paddingLeft: 8, paddingBottom: 6 }}>\n        SOLVED!\n      </div> : null}\n\n      <svg\n        width={SVG_W}\n        height={SVG_H}\n        style={{ display: 'block' }}\n      >\n        {/* Bridges */}\n        {bridgeLines}\n\n        {/* Cursor (non-circle) */}\n        {cursorIsland ? (\n          <rect\n            x={cursorX - 18}\n            y={cursorY - 18}\n            width={36}\n            height={36}\n            fill=\"none\"\n            stroke={selectedId != null ? '#0f0' : '#0f0'}\n            strokeWidth={2}\n            strokeDasharray={selectedId != null ? '0' : '6 4'}\n          />\n        ) : null}\n\n        {/*"]
[58.578781, "i", " Islands */}\n        {islands.map((isl) => {\n          const cx = px(isl.x);\n          const cy = px(isl.y);\n          const isSelected = selectedId === isl.id;\n          const cur = counts.get(isl.id) ?? 0;\n\n          return (\n            <g key={isl.id}>\n              <circle\n                cx={cx}\n                cy={cy}\n                r={16}\n                fill=\"black\"\n                stroke={isSelected ? '#0f0' : '#0f0'}\n                strokeWidth={2}\n                onClick={() => handleIslandClick(isl)}\n              />\n              <text\n                x={cx}\n                y={cy + 5}\n                textAnchor=\"middle\"\n                fontFamily=\"monospace\"\n                fontSize=\"14\"\n                fill=\"#0f0\"\n                style={{ userSelect: 'none', pointerEvents: 'none' }}\n              >\n                {isl.value}\n              </text>\n              {/* tiny current count indicator */}\n              <text\n                x={cx}\n                y={cy + 28}\n                textAnchor"]
