[58.482061, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[58.482084, "o", "> "]
[58.482317, "o", "  if (!from || !to) return { valid: false, error: 'Invalid islands' };\r\n\u001b[?2004l\r"]
[58.482347, "o", "\u001b[?2004h> "]
[58.482706, "o", "  if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };\r\n\u001b[?2004l\r"]
[58.482729, "o", "\u001b[?2004h> "]
[58.483076, "o", "  if (!areAdjacent(islands, from, to)) return { valid: false, error: 'Cannot connect non-adjacent islands' };\r\n\u001b[?2004l\r"]
