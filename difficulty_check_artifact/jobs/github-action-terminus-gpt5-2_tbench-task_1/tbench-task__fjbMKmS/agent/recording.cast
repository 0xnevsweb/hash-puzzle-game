[58.485844, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[58.485901, "o", "> "]
[58.486031, "o", "  // Capacity check: islands cannot exceed required value\r\n\u001b[?2004l\r"]
[58.486093, "o", "\u001b[?2004h> "]
[58.486246, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[58.4863, "o", "\u001b[?2004h> "]
[58.48644, "o", "  const fromCount = counts.get(from.id) ?? 0;\r\n\u001b[?2004l\r"]
[58.48649, "o", "\u001b[?2004h> "]
