[58.578536, "i", "ddEventListener('keydown', onKeyDown);\n    return () => window.removeEventListener('keydown', onKeyDown);\n  }, []);\n\n  function resetAll() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n    setVictory(false);\n    setCursorId(0);\n  }\n\n  function onChangePuzzle(e) {\n    const nextKey = e.target.value;\n    // Reset everything in the same update sequence (bridges + selection/error/victory/cursor)\n    setPuzzleKey(nextKey);\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n    setVictory(false);\n    setCursorId(0);\n  }\n\n  function handleIslandClick(island) {\n    if (selectedId == null) {\n      setSelectedId(island.id);\n      setCursorId(island.id);\n      setError(null);\n      return;\n    }\n\n    if (selectedId === island.id) {\n      // Clicking same island again just keeps selection (or could deselect). We'll deselect.\n      setSelectedId(null);\n      setError(null);\n      setCursorId(0);\n      return;\n    }\n\n    const from = getIslandById(islands, selectedId);\n    c"]
