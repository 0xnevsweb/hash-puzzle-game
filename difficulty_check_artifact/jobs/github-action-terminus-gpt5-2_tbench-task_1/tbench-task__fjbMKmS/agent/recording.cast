[58.495523, "o", "\u001b[?2004h"]
[58.495577, "o", "> "]
[58.495879, "o", "      const [bx1, by1, bx2, by2] = keyB.split(',').map(Number);\r\n\u001b[?2004l\r"]
[58.495935, "o", "\u001b[?2004h"]
[58.49597, "o", "> "]
[58.496141, "o", "      const b1 = { x: bx1, y: by1 };\r\n\u001b[?2004l\r"]
[58.497115, "o", "\u001b[?2004h> "]
[58.497778, "o", "      const b2 = { x: bx2, y: by2 };\r\n\u001b[?2004l\r\u001b[?2004h>       if (segmentsCross(a1, a2, b1, b2)) return false;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[58.49791, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n"]
