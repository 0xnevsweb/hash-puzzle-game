[58.498027, "o", "\u001b[?2004h"]
[58.498094, "o", "> "]
[58.498263, "o", "  for (const isl of islands) {\r\n\u001b[?2004l\r"]
[58.498336, "o", "\u001b[?2004h"]
[58.498393, "o", "> "]
[58.498648, "o", "    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n\u001b[?2004l\r"]
[58.498728, "o", "\u001b[?2004h"]
[58.498776, "o", "> "]
[58.498793, "o", "  }\r\n\u001b[?2004l\r"]
[58.498865, "o", "\u001b[?2004h"]
