[58.498956, "o", "\u001b[?2004h"]
[58.499004, "o", "> "]
[58.499249, "o", "  if (!checkConnectivity(islands, bridges)) return false;\r\n\u001b[?2004l\r"]
[58.499327, "o", "\u001b[?2004h"]
[58.499341, "o", "> \r\n"]
[58.499406, "o", "\u001b[?2004l\r"]
[58.499453, "o", "\u001b[?2004h"]
[58.499499, "o", "> "]
