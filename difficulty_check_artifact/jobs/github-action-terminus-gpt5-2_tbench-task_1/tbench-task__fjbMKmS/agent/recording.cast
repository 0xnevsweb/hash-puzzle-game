[58.484805, "o", "\u001b[?2004h> "]
[58.484925, "o", "  // Crossing check only needed if we are increasing above existing.\r\n\u001b[?2004l\r"]
[58.484957, "o", "\u001b[?2004h"]
[58.48497, "o", "> "]
[58.485096, "o", "  if (delta > 0 && next > existing) {\r\n\u001b[?2004l\r"]
[58.485128, "o", "\u001b[?2004h"]
[58.485139, "o", "> "]
