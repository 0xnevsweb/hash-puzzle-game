[85.795063, "o", "y}`, isl);\r\n\r\n  const adj = new Map();\r\n  for (const isl of islands) adj.set(isl.id, []);\r\n\r\n  for (const [key, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n    const a = byCoord.get(`${x1},${y1}`);\r\n    const b = byCoord.get(`${x2},${y2}`);\r\n    if (!a || !b) continue;\r\n    adj.get(a.id).push(b.id);\r\n    adj.get(b.id).push(a.id);\r\n  }\r\n\r\n  const seen = new Set();\r\n  const stack = [islands[0].id];\r\n  seen.add(islands[0].id);\r\n  while (stack.length) {\r\n    const cur = stack.pop();\r\n    for (const nb of adj.get(cur) || []) {\r\n      if (!seen.has(nb)) {\r\n        seen.add(nb);\r\n        stack.push(nb);\r\n      }\r\n    }\r\n  }\r\n\r\n  return seen.size === islands.length;\r\n}\r\n\r\nexport function isVictory(islands, bridges) {\r\n  // no crossings\r\n  for (const [keyA, nA] of bridges.entries()) {\r\n    if (!nA) continue;\r\n    const [ax1, ay1, ax2, ay2] = keyA.split(',').map(Number);\r\n    const a1 = { x: ax1, y: ay1 };\r\n    const a2 = { x: ax2, y: ay2 };\r\n\r\n    for (c"]
