[58.494635, "o", "> \r\n"]
[58.494647, "o", "\u001b[?2004l\r"]
[58.494774, "o", "\u001b[?2004h> "]
[58.494944, "o", "    for (const [keyB, nB] of bridges.entries()) {\r\n\u001b[?2004l\r"]
