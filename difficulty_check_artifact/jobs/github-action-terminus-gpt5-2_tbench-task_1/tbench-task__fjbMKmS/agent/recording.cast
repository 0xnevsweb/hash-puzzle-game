[58.484019, "o", "\u001b[?2004h"]
[58.484041, "o", "> "]
[58.484334, "o", "  if (next > 2) return { valid: false, error: 'Max 2 bridges per pair' };\r\n\u001b[?2004l\r"]
[58.484355, "o", "\u001b[?2004h> "]
[58.484605, "o", "  if (next < 0) return { valid: false, error: 'Invalid bridge count' };\r\n\u001b[?2004l\r"]
[58.484625, "o", "\u001b[?2004h"]
