[58.490626, "o", "\u001b[?2004h"]
[58.490721, "o", "> "]
[58.49087, "o", "    if (!a || !b) continue;"]
[58.493791, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     adj.get(a.id).push(b.id);\r\n\u001b[?2004l\r\u001b[?2004h>     adj.get(b.id).push(a.id);\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   const seen = new Set();\r\n\u001b[?2004l\r\u001b[?2004h>   const stack = [islands[0].id];\r\n\u001b[?2004l\r\u001b[?2004h>   seen.add(islands[0].id);\r\n\u001b[?2004l\r\u001b[?2004h>   while (stack.length) {\r\n\u001b[?2004l\r\u001b[?2004h>     const cur = stack.pop();\r\n\u001b[?2004l\r\u001b[?2004h>     for (const nb of adj.get(cur) || []) {\r\n\u001b[?2004l\r\u001b[?2004h>       if (!seen.has(nb)) {\r\n\u001b[?2004l\r\u001b[?2004h>         seen.add(nb);\r\n\u001b[?2004l\r\u001b[?2004h>         stack.push(nb);\r\n\u001b[?2004l\r\u001b[?2004h>       }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   return seen.size === islands.length;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r\u001b[?2004h>   // no crossings\r\n\u001b[?2004l\r\u001b[?2004h>   for (const [keyA, nA] of bridges.entries()) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!nA) continue;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[58.494312, "o", "    const [ax1, ay1, ax2, ay2] = keyA.split(',').map(Number);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[58.494444, "o", "    const a1 = { x: ax1, y: ay1 };\r\n\u001b[?2004l\r\u001b[?2004h"]
[58.494467, "o", "> "]
