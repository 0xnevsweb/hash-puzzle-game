[85.793739, "o", ".p2)) return false;\r\n  if (isEndpoint(ip, v.p1, v.p2)) return false;\r\n\r\n  return true;\r\n}\r\n\r\nexport function bridgesWouldCross(islands, bridges, from, to) {\r\n  const a1 = { x: from.x, y: from.y };\r\n  const a2 = { x: to.x, y: to.y };\r\n  for (const [key, count] of bridges.entries()) {\r\n    if (!count) continue;\r\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n    const b1 = { x: x1, y: y1 };\r\n    const b2 = { x: x2, y: y2 };\r\n\r\n    // If same pair, ignore (adding within same segment never \"crosses\" itself).\r\n    const same = (a1.x === b1.x && a1.y === b1.y && a2.x === b2.x && a2.y === b2.y) ||\r\n      (a1.x === b2.x && a1.y === b2.y && a2.x === b1.x && a2.y === b1.y);\r\n    if (same) continue;\r\n\r\n    // Sharing endpoints is allowed.\r\n    const sharesEndpoint =\r\n      (a1.x === b1.x && a1.y === b1.y) ||\r\n      (a1.x === b2.x && a1.y === b2.y) ||\r\n      (a2.x === b1.x && a2.y === b1.y) ||\r\n      (a2.x === b2.x && a2.y === b2.y);\r\n    if (sharesEndpoint) continue;\r\n\r\n    if (segmentsCross(a1, a2, b1, b2)) "]
[85.794675, "o", "return true;\r\n  }\r\n  return false;\r\n}\r\n\r\nexport function computeCurrentCounts(islands, bridges) {\r\n  const counts = new Map();\r\n  for (const isl of islands) counts.set(isl.id, 0);\r\n\r\n  for (const [key, n] of bridges.entries()) {\r\n    if (!n) continue;\r\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\r\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\r\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\r\n    if (!a || !b) continue;\r\n\r\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\r\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\r\n  }\r\n\r\n  return counts;\r\n}\r\n\r\nexport function canAddBridge(islands, bridges, from, to, delta) {\r\n  if (!from || !to) return { valid: false, error: 'Invalid islands' };\r\n  if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };\r\n  if (!areAdjacent(islands, from, to)) return { valid: false, error: 'Cannot connect non-adjacent islands' };\r\n\r\n  const key = makeBridgeKey(from, to);\r\n  const existing = bridges.get(key) ?"]
