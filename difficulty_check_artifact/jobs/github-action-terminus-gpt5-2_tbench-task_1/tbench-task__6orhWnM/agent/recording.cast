[167.967212, "o", "export function areAdjacent(islands, a, b) {\r\n\u001b[?2004l\r"]
[167.967297, "o", "\u001b[?2004h> "]
[167.967355, "o", "  if (!a || !b) return false;\r\n\u001b[?2004l\r"]
[167.967436, "o", "\u001b[?2004h> "]
