[58.668611, "i", "onnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    // any positive bridge count implies connectivity edge\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const start = islands[0].id;\n  const seen = new Set([start]);\n  const q = [start];\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // delta is usually +1; can be negative if desired, but UI uses removal separately\n  if (!areAdjacent(island"]
