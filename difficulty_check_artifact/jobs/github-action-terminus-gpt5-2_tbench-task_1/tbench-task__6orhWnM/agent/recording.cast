[167.970849, "o", "function segmentsCross(segA, segB) {\r\n\u001b[?2004l\r"]
[167.970973, "o", "\u001b[?2004h> "]
[167.971145, "o", "  // Only perpendicular crossings count; intersections at endpoints do not.\r\n\u001b[?2004l\r"]
[167.971207, "o", "\u001b[?2004h> "]
