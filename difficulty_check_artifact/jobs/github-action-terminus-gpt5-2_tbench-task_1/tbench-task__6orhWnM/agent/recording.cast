[167.959163, "i", "cat > src/utils/hashiLogic.js <<'EOF'\n// Hashi (Bridges) game logic utilities\n\nexport const ERROR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\nexport const ERROR_MAX_2 = 'Max 2 bridges per pair';\nexport const ERROR_EXCEED = 'Island would exceed its number';\nexport const ERROR_CROSS = 'Bridges would cross';\n\nexport function canonicalBridgeKey(a, b) {\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\n  const second = first === p1 ? p2 : p1;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nfunction buildCoordMap(islands) {\n  const m = new Map();\n  for (const isl of islands) m.set(`${isl.x},${isl.y}`, isl);\n  return m;\n}\n\nexport function areAdjacent(islands, a, b) {\n  if (!a || !b) return false;\n  if (a.id === b.id) return false;\n  if (a.x !== b.x && a.y !== b.y) return false;\n\n  const coordMap"]
[167.959206, "i", " = buildCoordMap(islands);\n\n  if (a.x === b.x) {\n    const x = a.x;\n    const [yMin, yMax] = a.y < b.y ? [a.y, b.y] : [b.y, a.y];\n    for (let y = yMin + 1; y <= yMax - 1; y++) {\n      if (coordMap.has(`${x},${y}`)) return false;\n    }\n    return true;\n  }\n\n  const y = a.y;\n  const [xMin, xMax] = a.x < b.x ? [a.x, b.x] : [b.x, a.x];\n  for (let x = xMin + 1; x <= xMax - 1; x++) {\n    if (coordMap.has(`${x},${y}`)) return false;\n  }\n  return true;\n}\n\nfunction isHorizontal(seg) {\n  return seg.y1 === seg.y2;\n}\n\nfunction segmentsCross(segA, segB) {\n  // Only perpendicular crossings count; intersections at endpoints do not.\n  const aH = isHorizontal(segA);\n  const bH = isHorizontal(segB);\n  if (aH === bH) return false;\n\n  const h = aH ? segA : segB;\n  const v = aH ? segB : segA;\n\n  const hx1 = Math.min(h.x1, h.x2);\n  const hx2 = Math.max(h.x1, h.x2);\n  const hy = h.y1;\n\n  const vy1 = Math.min(v.y1, v.y2);\n  const vy2 = Math.max(v.y1, v.y2);\n  const vx = v.x1;\n\n  return vx > hx1 && vx < hx2 && hy > vy1 && hy < vy2;\n"]
[167.959311, "i", "}\n\nexport function bridgesCross(bridges) {\n  const segs = [];\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    segs.push(parseKey(key));\n  }\n  for (let i = 0; i < segs.length; i++) {\n    for (let j = i + 1; j < segs.length; j++) {\n      if (segmentsCross(segs[i], segs[j])) return true;\n    }\n  }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n\n  return counts;\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n\n  const adj = new Map();\n  for (const isl of islands)"]
[167.959328, "i", " adj.set(isl.id, []);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const start = islands[0].id;\n  const seen = new Set([start]);\n  const q = [start];\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) || []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: ERROR_NON_ADJACENT };\n  }\n\n  const key = canonicalBridgeKey(from, to);\n  const cur = bridges.get(key) ?? 0;\n  const next = cur + delta;\n\n  if (next > 2) return { valid: false, error: ERROR_MAX_2 };\n\n  const counts = compu"]
[167.959369, "i", "teCurrentCounts(islands, bridges);\n  const fromNext = (counts.get(from.id) ?? 0) + delta;\n  const toNext = (counts.get(to.id) ?? 0) + delta;\n\n  if (fromNext > from.value || toNext > to.value) {\n    return { valid: false, error: ERROR_EXCEED };\n  }\n\n  const tmp = new Map(bridges);\n  if (next <= 0) tmp.delete(key);\n  else tmp.set(key, next);\n\n  if (bridgesCross(tmp)) {\n    return { valid: false, error: ERROR_CROSS };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function isVictory(islands, bridges) {\n  if (bridgesCross(bridges)) return false;\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"]
[167.959523, "o", "cat > src/utils/hashiLogic.js <<'EOF'"]
