[167.97147, "o", "  const bH = isHorizontal(segB);\r\n\u001b[?2004l\r"]
[167.971587, "o", "\u001b[?2004h"]
[167.971706, "o", ">   if (aH === bH) return false;\r\n\u001b[?2004l\r"]
[167.971728, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.971831, "o", "  const h = aH ? segA : segB;\r\n\u001b[?2004l\r"]
[167.971903, "o", "\u001b[?2004h> "]
[167.971989, "o", "  const v = aH ? segB : segA;\r\n\u001b[?2004l\r"]
[167.972074, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.972204, "o", "  const hx1 = Math.min(h.x1, h.x2);\r\n\u001b[?2004l\r"]
[167.972287, "o", "\u001b[?2004h> "]
[167.972372, "o", "  const hx2 = Math.max(h.x1, h.x2);\r\n\u001b[?2004l\r"]
[167.972437, "o", "\u001b[?2004h> "]
