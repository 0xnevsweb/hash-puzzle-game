[109.809403, "o", "\u001b[?2004l\r\u001b[?2004h>   const key = canonicalBridgeKey(from, to);\r\n\u001b[?2004l\r\u001b[?2004h>   const cur = bridges.get(key) ?? 0;\r\n\u001b[?2004l\r\u001b[?2004h>   const next = cur + delta;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   if (next > 2) return { valid: false, error: ERROR_MAX_2 };\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r\u001b[?2004h>   const fromNext = (counts.get(from.id) ?? 0) + delta;\r\n\u001b[?2004l\r\u001b[?2004h>   const toNext = (counts.get(to.id) ?? 0) + delta;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   if (fromNext > from.value || toNext > to.value) {\r\n\u001b[?2004l\r\u001b[?2004h>     return { valid: false, error: ERROR_EXCEED };\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
