[167.964426, "o", "  const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\r\n\u001b[?2004l\r"]
[167.964553, "o", "\u001b[?2004h> "]
[167.964771, "o", "  const second = first === p1 ? p2 : p1;\r\n\u001b[?2004l\r"]
[167.96479, "o", "\u001b[?2004h"]
[167.964799, "o", "> "]
[167.965141, "o", "  return `${first.x},${first.y},${second.x},${second.y}`;\r\n\u001b[?2004l\r"]
[167.965257, "o", "\u001b[?2004h> "]
[167.965332, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[167.965407, "o", "> "]
