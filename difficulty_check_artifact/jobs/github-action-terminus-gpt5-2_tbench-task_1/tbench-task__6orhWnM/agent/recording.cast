[109.786351, "o", "export const ERROR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\r\n\u001b[?2004l\r\u001b[?2004h> export const ERROR_MAX_2 = 'Max 2 bridges per pair';\r\n\u001b[?2004l\r\u001b[?2004h> export const ERROR_EXCEED = 'Island would exceed its number';\r\n\u001b[?2004l\r\u001b[?2004h> export const ERROR_CROSS = 'Bridges would cross';\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> export function canonicalBridgeKey(a, b) {\r\n\u001b[?2004l\r\u001b[?2004h>   const p1 = { x: a.x, y: a.y };\r\n\u001b[?2004l\r\u001b[?2004h>   const p2 = { x: b.x, y: b.y };\r\n\u001b[?2004l\r\u001b[?2004h>   const first = p1.x < p2.x || (p1.x === p2.x && p1.y <= p2.y) ? p1 : p2;\r\n\u001b[?2004l\r\u001b[?2004h>   const second = first === p1 ? p2 : p1;\r\n\u001b[?2004l\r\u001b[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[109.786371, "i", "teCurrentCounts(islands, bridges);\n  const fromNext = (counts.get(from.id) ?? 0) + delta;\n  const toNext = (counts.get(to.id) ?? 0) + delta;\n\n  if (fromNext > from.value || toNext > to.value) {\n    return { valid: false, error: ERROR_EXCEED };\n  }\n\n  const tmp = new Map(bridges);\n  if (next <= 0) tmp.delete(key);\n  else tmp.set(key, next);\n\n  if (bridgesCross(tmp)) {\n    return { valid: false, error: ERROR_CROSS };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function isVictory(islands, bridges) {\n  if (bridgesCross(bridges)) return false;\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"]
