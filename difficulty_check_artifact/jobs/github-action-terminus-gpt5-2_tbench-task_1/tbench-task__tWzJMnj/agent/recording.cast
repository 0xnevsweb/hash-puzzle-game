[70.567233, "i", "cat > /app/src/utils/hashiLogic.js <<'EOF'\nexport const ERROR_NON_ADJACENT = \"Cannot connect non-adjacent islands\";\nexport const ERROR_MAX_PAIR = \"Max 2 bridges per pair\";\nexport const ERROR_EXCEED = \"Island would exceed its number\";\nexport const ERROR_CROSS = \"Bridges would cross\";\n\nexport function canonicalKey(a, b) {\n  // a,b are {x,y} in grid units\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n  const swap = p1.x > p2.x || (p1.x === p2.x && p1.y > p2.y);\n  const s = swap ? [p2, p1] : [p1, p2];\n  return `${s[0].x},${s[0].y},${s[1].x},${s[1].y}`;\n}\n\nexport function parseKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nfunction isHorizontal(seg) {\n  return seg.y1 === seg.y2;\n}\n\nfunction isVertical(seg) {\n  return seg.x1 === seg.x2;\n}\n\nfunction normSeg(seg) {\n  // return with (x1,y1) <= (x2,y2) along axis\n  if (isHorizontal(seg)) {\n    const swap = seg.x1 > seg.x2;\n    return swap\n      ? { x1: seg.x2, y1: seg.y2, x2: seg.x1, y2: seg.y1 }\n  "]
[70.567411, "i", "    : seg;\n  }\n  if (isVertical(seg)) {\n    const swap = seg.y1 > seg.y2;\n    return swap\n      ? { x1: seg.x2, y1: seg.y2, x2: seg.x1, y2: seg.y1 }\n      : seg;\n  }\n  return seg;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nfunction between(v, a, b) {\n  const lo = Math.min(a, b);\n  const hi = Math.max(a, b);\n  return v > lo && v < hi;\n}\n\nexport function bridgesCross(existingKey, newKey) {\n  if (existingKey === newKey) return false;\n  const e = normSeg(parseKey(existingKey));\n  const n = normSeg(parseKey(newKey));\n\n  // Only orthogo"]
[70.567481, "o", "cat > /app/src/utils/hashiLogic.js <<'EOF'\r\n"]
[70.5675, "i", "nal crossings matter; colinear overlaps are prevented by adjacency.\n  const eH = isHorizontal(e);\n  const eV = isVertical(e);\n  const nH = isHorizontal(n);\n  const nV = isVertical(n);\n  if (!((eH && nV) || (eV && nH))) return false;\n\n  const h = eH ? e : n;\n  const v = eV ? e : n;\n\n  // Proper crossing at an interior point (not at endpoints)\n  const cx = v.x1;\n  const cy = h.y1;\n\n  const hX1 = Math.min(h.x1, h.x2);\n  const hX2 = Math.max(h.x1, h.x2);\n  const vY1 = Math.min(v.y1, v.y2);\n  const vY2 = Math.max(v.y1, v.y2);\n\n  const intersects = cx >= hX1 && cx <= hX2 && cy >= vY1 && cy <= vY2;\n  if (!intersects) return false;\n\n  // exclude touching at endpoints\n  const hEndpoint = (cx === h.x1 && cy === h.y1) || (cx === h.x2 && cy === h.y2);\n  const vEndpoint = (cx === v.x1 && cy === v.y1) || (cx === v.x2 && cy === v.y2);\n  if (hEndpoint || vEndpoint) return false;\n\n  // also ensure it's strictly inside both segments\n  if (!between(cx, h.x1, h.x2)) return false;\n  if (!between(cy, v.y1, v.y2)) return false;\n\n  "]
[70.56751, "o", "\u001b[?2004l\r\u001b[?2004h"]
[70.567521, "i", "return true;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to) return { valid: false, error: ERROR_NON_ADJACENT };\n  if (from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  const sameRow = from.y === to.y;\n  const sameCol = from.x === to.x;\n  if (!sameRow && !sameCol) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  // must be adjacent with no island between\n  if (sameRow) {\n    const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === from.y && between(i.x, from.x, to.x));\n    if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };\n  } else {\n    const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === from.x && between(i.y, from.y, to.y));\n    if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };\n  }\n\n  const key = canonicalKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = current + delta;\n\n  if (next < 0) return { valid: false, error: ERROR_MAX_PAIR };"]
[70.567533, "i", "\n  if (next > 2) return { valid: false, error: ERROR_MAX_PAIR };\n\n  // check island counts do not exceed\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) ?? 0;\n  const toCount = counts.get(to.id) ?? 0;\n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: ERROR_EXCEED };\n  }\n\n  // check crossing if adding (delta>0). Removing never introduces crossing.\n  if (delta > 0) {\n    for (const [k, nBr] of bridges.entries()) {\n      if (!nBr) continue;\n      if (bridgesCross(k, key)) return { valid: false, error: ERROR_CROSS };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length <= 1) return true;\n\n  const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));\n  const adj = new Map(islands.map((i) => [i.id, []]));\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseKey(key);\n    const a "]
[70.56762, "i", "= posToId.get(`${x1},${y1}`);\n    const b = posToId.get(`${x2},${y2}`);\n    if (a === undefined || b === undefined) continue;\n    adj.get(a).push(b);\n    adj.get(b).push(a);\n  }\n\n  const start = islands[0].id;\n  const seen = new Set([start]);\n  const q = [start];\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) ?? []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // no crossings\n  const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);\n  for (let i = 0; i < keys.length; i++) {\n    for (let j = i + 1; j < keys.length; j++) {\n      if (bridgesCross(keys[i], keys[j])) return false;\n    }\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"]
