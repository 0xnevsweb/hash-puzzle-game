[81.368656, "o", "     1\texport const ERROR_NON_ADJACENT = \"Cannot connect non-adjacent islands\";\r\n     2\texport const ERROR_MAX_PAIR = \"Max 2 bridges per pair\";\r\n     3\texport const ERROR_EXCEED = \"Island would exceed its number\";\r\n"]
[81.368682, "o", "     4\texport const ERROR_CROSS = \"Bridges would cross\";\r\n     5\t\r\n     6\texport function canonicalKey(a, b) {\r\n     7\t  // a,b are {x,y} in grid units\r\n     8\t  const p1 = { x: a.x, y: a.y };\r\n     9\t  const p2 = { x: b.x, y: b.y };\r\n    10\t  const swap = p1.x > p2.x || (p1.x === p2.x && p1.y > p2.y);\r\n"]
[81.369539, "o", "    11\t  const s = swap ? [p2, p1] : [p1, p2];\r\n    12\t  return `${s[0].x},${s[0].y},${s[1].x},${s[1].y}`;\r\n    13\t}\r\n    14\t\r\n    15\texport function parseKey(key) {\r\n    16\t  const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n    17\t  return { x1, y1, x2, y2 };\r\n    18\t}\r\n    19\t\r\n    20\tfunction isHorizontal(seg) {\r\n    21\t  return seg.y1 === seg.y2;\r\n    22\t}\r\n    23\t\r\n    24\tfunction isVertical(seg) {\r\n    25\t  return seg.x1 === seg.x2;\r\n    26\t}\r\n    27\t\r\n    28\tfunction normSeg(seg) {\r\n    29\t  // return with (x1,y1) <= (x2,y2) along axis\r\n    30\t  if (isHorizontal(seg)) {\r\n    31\t    const swap = seg.x1 > seg.x2;"]
[81.370768, "o", "\r\n    32\t    return swap\r\n    33\t      ? { x1: seg.x2, y1: seg.y2, x2: seg.x1, y2: seg.y1 }\r\n    34\t      : seg;\r\n    35\t  }\r\n    36\t  if (isVertical(seg)) {\r\n    37\t    const swap = seg.y1 > seg.y2;\r\n    38\t    return swap\r\n    39\t      ? { x1: seg.x2, y1: seg.y2, x2: seg.x1, y2: seg.y1 }\r\n    40\t      : seg;\r\n    41\t  }\r\n    42\t  return seg;\r\n    43\t}\r\n    44\t\r\n    45\texport function computeCurrentCounts(islands, bridges) {\r\n    46\t  const counts = new Map();\r\n    47\t  for (const isl of islands) counts.set(isl.id, 0);\r\n    48\t\r\n    49\t  for (const [key, n] of bridges.entries()) {\r\n    50\t    if (!n) continue;\r\n    51\t    const { x1, y1, x2, y2 } = parseKey(key);\r\n    52\t    const a = islands.find((i) => i.x === x1 && i.y === y1);\r\n    53\t    const b = islands.find((i) => i.x === x2 && i.y === y2);\r\n    54\t    if (!a || !b) continue;\r\n    55\t    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\r\n    56\t    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\r\n    57\t  }\r\n    58\t  return counts;\r\n    59\t}\r\n    60\t\r\n  "]
[81.370892, "o", "  61\tfunction between(v, a, b) {\r\n    62\t  const lo = Math.min(a, b);\r\n    63\t  const hi = Math.max(a, b);\r\n    64\t  return v > lo && v < hi;\r\n    65\t}\r\n    66\t\r\n    67\texport function bridgesCross(existingKey, newKey) {\r\n    68\t  if (existingKey === newKey) return false;\r\n    69\t  const e = normSeg(parseKey(existingKey));\r\n    70\t  const n = normSeg(parseKey(newKey));\r\n    71\t\r\n    72\t  // Only orthogonal crossings matter; colinear overlaps are prevented by adjacency.\r\n    73\t  const eH = isHorizontal(e);\r\n    74\t  const eV = isVertical(e);\r\n    75\t  const nH = isHorizontal(n);\r\n    76\t  const nV = isVertical(n);\r\n    77\t  if (!((eH && nV) || (eV && nH))) return false;\r\n    78\t\r\n    79\t  const h = eH ? e : n;\r\n    80\t  const v = eV ? e : n;\r\n    81\t\r\n    82\t  // Proper crossing at an interior point (not at endpoints)\r\n    83\t  const cx = v.x1;\r\n    84\t  const cy = h.y1;\r\n    85\t\r\n    86\t  const hX1 = Math.min(h.x1, h.x2);\r\n    87\t  const hX2 = Math.max(h.x1, h.x2);\r\n    88\t  const vY1 = Math.min(v.y1, v.y2);"]
[81.370975, "o", "\r\n    89\t  const vY2 = Math.max(v.y1, v.y2);\r\n    90\t\r\n    91\t  const intersects = cx >= hX1 && cx <= hX2 && cy >= vY1 && cy <= vY2;\r\n    92\t  if (!intersects) return false;\r\n    93\t\r\n    94\t  // exclude touching at endpoints\r\n    95\t  const hEndpoint = (cx === h.x1 && cy === h.y1) || (cx === h.x2 && cy === h.y2);\r\n    96\t  const vEndpoint = (cx === v.x1 && cy === v.y1) || (cx === v.x2 && cy === v.y2);\r\n    97\t  if (hEndpoint || vEndpoint) return false;\r\n    98\t\r\n    99\t  // also ensure it's strictly inside both segments\r\n   100\t  if (!between(cx, h.x1, h.x2)) return false;\r\n   101\t  if (!between(cy, v.y1, v.y2)) return false;\r\n   102\t\r\n   103\t  return true;\r\n   104\t}\r\n   105\t\r\n   106\texport function canAddBridge(islands, bridges, from, to, delta) {\r\n   107\t  if (!from || !to) return { valid: false, error: ERROR_NON_ADJACENT };\r\n   108\t  if (from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };\r\n   109\t\r\n   110\t  const sameRow = from.y === to.y;\r\n   111\t  const sameCol = from.x === to.x;\r\n   "]
[81.371043, "o", "112\t  if (!sameRow && !sameCol) return { valid: false, error: ERROR_NON_ADJACENT };\r\n   113\t\r\n   114\t  // must be adjacent with no island between\r\n   115\t  if (sameRow) {\r\n   116\t    const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === from.y && between(i.x, from.x, to.x));\r\n   117\t    if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };\r\n   118\t  } else {\r\n   119\t    const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === from.x && between(i.y, from.y, to.y));\r\n   120\t    if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\u001b[?2004hroot@87e9000a9ae9:/app# "]
