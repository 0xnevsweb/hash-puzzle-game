[70.709255, "i", "key + ':a'} x1={px1 - dx} y1={py1 - dy} x2={px2 - dx} y2={py2 - dy} />,\n              <line key={key + ':b'} x1={px1 + dx} y1={py1 + dy} x2={px2 + dx} y2={py2 + dy} />,\n            ];\n          })}\n        </g>\n\n        {/* cursor (not a circle) */}\n        {(() => {\n          const c = islandAt(islands, cursorId);\n          if (!c) return null;\n          const px = c.x * GRID;\n          const py = c.y * GRID;\n          const selected = selectedId === c.id;\n          return (\n            <rect\n              x={px - 18}\n              y={py - 18}\n              width={36}\n              height={36}\n              fill=\"none\"\n              stroke={selected ? '#0f0' : '#0f0'}\n              strokeWidth={selected ? 4 : 2}\n              strokeDasharray={selected ? '0' : '6 4'}\n            />\n          );\n        })()}\n\n        {/* islands */}\n        <g>\n          {islands.map((isl) => {\n            const px = isl.x * GRID;\n            const py = isl.y * GRID;\n            const isSelected = selectedId === isl.id;\n     "]
[70.709265, "i", "       return (\n              <g key={isl.id}>\n                <circle\n                  cx={px}\n                  cy={py}\n                  r={16}\n                  fill=\"black\"\n                  stroke=\"#0f0\"\n                  strokeWidth={isSelected ? 4 : 2}\n                  onClick={(e) => handleIslandClick(e, isl)}\n                  onContextMenu={(e) => handleIslandClick(e, isl)}\n                  style={{ cursor: 'pointer' }}\n                />\n                <text\n                  x={px}\n                  y={py + 5}\n                  textAnchor=\"middle\"\n                  fontFamily=\"monospace\"\n                  fontSize=\"16\"\n                  fill=\"#0f0\"\n                  style={{ userSelect: 'none', pointerEvents: 'none' }}\n                >\n                  {isl.value}\n                </text>\n              </g>\n            );\n          })}\n        </g>\n      </svg>\n    </div>\n  );\n}\n\nexport default App;\nEOF\n"]
