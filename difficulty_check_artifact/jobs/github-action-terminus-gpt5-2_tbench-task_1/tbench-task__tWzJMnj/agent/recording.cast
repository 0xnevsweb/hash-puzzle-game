[70.588781, "o", "export function bridgesCross(existingKey, newKey) {\r\n\u001b[?2004l\r"]
[70.588865, "o", "\u001b[?2004h"]
[70.588949, "o", "> "]
[70.589275, "o", "  if (existingKey === newKey) return false;\r\n\u001b[?2004l\r"]
[70.589358, "o", "\u001b[?2004h"]
[70.589445, "o", "> "]
[70.589704, "o", "  const e = normSeg(parseKey(existingKey));\r\n\u001b[?2004l\r"]
[70.589737, "o", "\u001b[?2004h"]
[70.589831, "o", "> "]
[70.589977, "o", "  const n = normSeg(parseKey(newKey));\r\n\u001b[?2004l\r"]
[70.590018, "o", "\u001b[?2004h> "]
[70.590088, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[70.59033, "o", "  // Only orthogonal crossings matter; colinear overlaps are prevented by adjacency.\r\n\u001b[?2004l\r"]
[70.590403, "o", "\u001b[?2004h> "]
[70.590476, "o", "  const eH = isHorizontal(e);\r\n\u001b[?2004l\r"]
[70.590544, "o", "\u001b[?2004h"]
[70.590616, "o", ">   const eV = isVertical(e);\r\n\u001b[?2004l\r"]
[70.590658, "o", "\u001b[?2004h"]
[70.590734, "o", "> "]
[70.590804, "o", "  const nH = isHorizontal(n);\r\n\u001b[?2004l\r\u001b[?2004h"]
[70.590905, "o", "> "]
[70.590987, "o", "  const nV = isVertical(n);\r\n\u001b[?2004l\r"]
[70.591071, "o", "\u001b[?2004h> "]
[70.591163, "o", "  if (!((eH && nV) || (eV && nH))) return false;\r\n\u001b[?2004l\r"]
[70.59121, "o", "\u001b[?2004h> "]
[70.594989, "o", "\r\n\u001b[?2004l\r"]
[70.595083, "o", "\u001b[?2004h"]
[70.595102, "o", "> "]
[70.595267, "o", "  const h = eH ? e : n;\r\n\u001b[?2004l\r"]
[70.595352, "o", "\u001b[?2004h> "]
[70.595425, "o", "  const v = eV ? e : n;\r\n\u001b[?2004l\r"]
[70.595506, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[70.595522, "o", "\u001b[?2004h"]
[70.595534, "o", "> "]
[70.595794, "o", "  // Proper crossing at an interior point (not at endpoints)\r\n\u001b[?2004l\r"]
[70.595871, "o", "\u001b[?2004h> "]
[70.595949, "o", "  const cx = v.x1;\r\n\u001b[?2004l\r"]
[70.59605, "o", "\u001b[?2004h> "]
[70.596068, "o", "  const cy = h.y1;\r\n\u001b[?2004l\r"]
[70.596169, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[70.596325, "o", "  const hX1 = Math.min(h.x1, h.x2);\r\n\u001b[?2004l\r"]
[70.596405, "o", "\u001b[?2004h> "]
[70.596516, "o", "  const hX2 = Math.max(h.x1, h.x2);\r\n\u001b[?2004l\r"]
[70.596595, "o", "\u001b[?2004h> "]
[70.596707, "o", "  const vY1 = Math.min(v.y1, v.y2);\r\n\u001b[?2004l\r"]
[70.596788, "o", "\u001b[?2004h> "]
[70.596934, "o", "  const vY2 = Math.max(v.y1, v.y2);\r\n\u001b[?2004l\r"]
[70.597016, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[70.597033, "o", "> "]
[70.597291, "o", "  const intersects = cx >= hX1 && cx <= hX2 && cy >= vY1 && cy <= vY2;\r\n\u001b[?2004l\r"]
[70.597314, "o", "\u001b[?2004h"]
[70.597325, "o", "> "]
[70.597466, "o", "  if (!intersects) return false;\r\n\u001b[?2004l\r"]
[70.597552, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[70.597709, "o", "  // exclude touching at endpoints\r\n\u001b[?2004l\r"]
[70.597791, "o", "\u001b[?2004h> "]
[70.598112, "o", "  const hEndpoint = (cx === h.x1 && cy === h.y1) || (cx === h.x2 && cy === h.y2);\r\n\u001b[?2004l\r"]
[70.598268, "o", "\u001b[?2004h> "]
[70.598492, "o", "  const vEndpoint = (cx === v.x1 && cy === v.y1) || (cx === v.x2 && cy === v.y2);\r\n\u001b[?2004l\r"]
[70.598579, "o", "\u001b[?2004h> "]
[70.59872, "o", "  if (hEndpoint || vEndpoint) return false;\r\n\u001b[?2004l\r"]
[70.598791, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[70.59882, "o", "> "]
[70.59902, "o", "  // also ensure it's strictly inside both segments\r\n\u001b[?2004l\r"]
[70.599049, "o", "\u001b[?2004h"]
[70.599106, "o", "> "]
[70.599253, "o", "  if (!between(cx, h.x1, h.x2)) return false;\r\n\u001b[?2004l\r"]
[70.599319, "o", "\u001b[?2004h> "]
[70.599489, "o", "  if (!between(cy, v.y1, v.y2)) return false;\r\n\u001b[?2004l\r"]
[70.599516, "o", "\u001b[?2004h"]
[70.599532, "o", "> "]
[70.599544, "o", "\r\n\u001b[?2004l\r"]
[70.599622, "o", "\u001b[?2004h> "]
[70.599666, "o", "  return true;\r\n\u001b[?2004l\r"]
