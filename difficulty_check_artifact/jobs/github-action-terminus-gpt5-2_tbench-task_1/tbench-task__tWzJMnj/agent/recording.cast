[70.582094, "o", "\u001b[?2004h"]
[70.582138, "o", "> "]
[70.582539, "o", "  for (const [key, n] of bridges.entries()) {\r\n"]
[70.582562, "o", "\u001b[?2004l\r"]
[70.582623, "o", "\u001b[?2004h"]
[70.582675, "o", "> "]
[70.582834, "o", "    if (!n) continue;\r\n\u001b[?2004l\r"]
[70.582887, "o", "\u001b[?2004h"]
[70.582936, "o", "> "]
[70.583307, "o", "    const { x1, y1, x2, y2 } = parseKey(key);\r\n\u001b[?2004l\r"]
[70.583383, "o", "\u001b[?2004h> "]
[70.583844, "o", "    const a = islands.find((i) => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[70.583911, "o", "\u001b[?2004h> "]
[70.584368, "o", "    const b = islands.find((i) => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[70.584395, "o", "\u001b[?2004h"]
[70.584407, "o", "> "]
[70.584619, "o", "    if (!a || !b) continue;\r\n\u001b[?2004l\r"]
[70.584667, "o", "\u001b[?2004h"]
[70.584736, "o", "> "]
[70.585119, "o", "    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\r\n\u001b[?2004l\r"]
[70.585182, "o", "\u001b[?2004h> "]
[70.58555, "o", "    counts.set(b.id, (counts.get(b.id) ?? 0) + n);"]
