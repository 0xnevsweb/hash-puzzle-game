[70.708888, "i", " && isl.x === from.x && isl.y > from.y) {\n      if (!best || isl.y < best.y) best = isl;\n    }\n  }\n  return best ? best.id : fromId;\n}\n\nfunction orderedPairsFromBridges(bridges) {\n  const out = [];\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const seg = parseKey(key);\n    out.push({ key, n, ...seg });\n  }\n  return out;\n}\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const puzzle = puzzles[puzzleIndex];\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [kbMode, setKbMode] = useState(false); // when true, next Enter toggles against cursor target\n  const [cursorId, setCursorId] = useState(islands[0]?.id ?? 0);\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  // reset when puzzle changes\n  useEffect(() => {\n    setBridges(new Map());\n    setSelectedId(null);\n    setKbMode(false);\n    setCursorId(puzzles[puzzleIndex].islands[0"]
[70.708918, "o", "cat > /app/src/App.jsx <<'EOF'"]
[70.708933, "i", "]?.id ?? 0);\n    setError(null);\n  }, [puzzleIndex]);\n\n  // keep cursorId valid if islands change\n  useEffect(() => {\n    if (!islands.some((i) => i.id === cursorId)) {\n      setCursorId(islands[0]?.id ?? 0);\n    }\n  }, [cursorId, islands]);\n\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function clearErrorOnValid(valid) {\n    if (valid) setError(null);\n  }\n\n  function applyToggle(from, to) {\n    const key = canonicalKey(from, to);\n    const current = bridges.get(key) ?? 0;\n    const next = (current + 1) % 3; // none -> 1 -> 2 -> none\n    const delta = next - current;\n\n    if (delta === 0) {\n      setSelectedId(null);\n      setKbMode(false);\n      return;\n    }\n\n    // for wraparound 2 -> 0 delta=-2, validate removal in two steps not needed; just set to 0.\n    if (next === 0) {\n      const nb = new Map(bridges);\n      nb.delete(key);\n      setBridges(nb);\n      clearErrorOnValid(true);\n      setSelectedId(null);\n      setKbMode(false);\n      return;\n    }\n\n    const res "]
[70.70904, "i", "= canAddBridge(islands, bridges, from, to, delta);\n    if (!res.valid) {\n      setError(res.error);\n      setSelectedId(null);\n      setKbMode(false);\n      return;\n    }\n\n    const nb = new Map(bridges);\n    nb.set(key, next);\n    setBridges(nb);\n    clearErrorOnValid(true);\n    setSelectedId(null);\n    setKbMode(false);\n  }\n\n  function removeBridge(from, to) {\n    const key = canonicalKey(from, to);\n    if (!(bridges.get(key) > 0)) return;\n    const nb = new Map(bridges);\n    nb.delete(key);\n    setBridges(nb);\n    clearErrorOnValid(true);\n    setSelectedId(null);\n    setKbMode(false);\n  }\n\n  function handleIslandClick(e, isl) {\n    e.preventDefault();\n\n    // right click / ctrl click removes bridge to selected if exists, else no-op\n    if (e.type === 'contextmenu' || e.button === 2 || e.ctrlKey) {\n      if (selectedId != null && selectedId !== isl.id) {\n        const from = islandAt(islands, selectedId);\n        if (from) removeBridge(from, isl);\n      }\n      return;\n    }\n\n    if (selectedId == null) {\n "]
[70.709152, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[70.709188, "i", "     setSelectedId(isl.id);\n      setCursorId(isl.id);\n      setKbMode(false);\n      return;\n    }\n\n    if (selectedId === isl.id) {\n      // clicking same island just keeps selection\n      setCursorId(isl.id);\n      return;\n    }\n\n    const from = islandAt(islands, selectedId);\n    applyToggle(from, isl);\n    setCursorId(isl.id);\n  }\n\n  useEffect(() => {\n    function onKeyDown(e) {\n      const k = e.key;\n      if (['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Enter', 'Escape'].includes(k)) {\n        e.preventDefault();\n      } else {\n        return;\n      }\n\n      if (k === 'Escape') {\n        setSelectedId(null);\n        setKbMode(false);\n        setError(null);\n        return;\n      }\n\n      if (k.startsWith('Arrow')) {\n        const dir =\n          k === 'ArrowLeft'\n            ? 'left'\n            : k === 'ArrowRight'\n              ? 'right'\n              : k === 'ArrowUp'\n                ? 'up'\n                : 'down';\n        setCursorId((cur) => findNextIsland(islands, cur, dir));\n        retu"]
[70.709208, "i", "rn;\n      }\n\n      if (k === 'Enter') {\n        if (selectedId == null) {\n          setSelectedId(cursorId);\n          setKbMode(true);\n          return;\n        }\n\n        // if selected exists, toggle between selected and cursor if different\n        if (selectedId === cursorId) return;\n        const from = islandAt(islands, selectedId);\n        const to = islandAt(islands, cursorId);\n        applyToggle(from, to);\n        return;\n      }\n    }\n\n    window.addEventListener('keydown', onKeyDown);\n    return () => window.removeEventListener('keydown', onKeyDown);\n  }, [cursorId, islands, selectedId, bridges]);\n\n  const lines = useMemo(() => orderedPairsFromBridges(bridges), [bridges]);\n\n  return (\n    <div style={{ position: 'relative' }}>\n      <div style={{ padding: '8px 8px 0 8px' }}>\n        <label>\n          Puzzle:{' '}\n          <select\n            value={puzzleIndex}\n            onChange={(e) => setPuzzleIndex(Number(e.target.value))}\n            style={{\n              background: 'black',\n            "]
[70.709227, "i", "  color: '#0f0',\n              border: '1px solid #0f0',\n              fontFamily: 'monospace',\n            }}\n          >\n            <option value={0}>Easy</option>\n            <option value={1}>Medium</option>\n            <option value={2}>Hard</option>\n          </select>\n        </label>\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setSelectedId(null);\n            setKbMode(false);\n            setError(null);\n          }}\n          style={{\n            marginLeft: 8,\n            background: 'black',\n            color: '#0f0',\n            border: '1px solid #0f0',\n            fontFamily: 'monospace',\n            cursor: 'pointer',\n          }}\n        >\n          Reset\n        </button>\n        {error ? (\n          <div className=\"error-message\" style={{ marginTop: 8, color: '#0f0' }}>\n            {error}\n          </div>\n        ) : null}\n        {victory ? (\n          <div className=\"victory-banner\" style={{ marginTop: 8, fontWeight: 'bold' }}>\n            SO"]
