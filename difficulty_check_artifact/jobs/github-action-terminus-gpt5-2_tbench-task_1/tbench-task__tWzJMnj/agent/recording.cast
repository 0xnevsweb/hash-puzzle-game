[70.600129, "o", "export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[70.600214, "o", "\u001b[?2004h> "]
[70.60046, "o", "  if (!from || !to) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\u001b[?2004l\r"]
[70.60048, "o", "\u001b[?2004h"]
[70.600538, "o", "> "]
[70.600825, "o", "  if (from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\u001b[?2004l\r"]
[70.600919, "o", "\u001b[?2004h"]
[70.600982, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[70.601071, "o", "  const sameRow = from.y === to.y;\r\n\u001b[?2004l\r"]
[70.60114, "o", "\u001b[?2004h> "]
[70.601265, "o", "  const sameCol = from.x === to.x;\r\n\u001b[?2004l\r"]
[70.601341, "o", "\u001b[?2004h> "]
[70.601647, "o", "  if (!sameRow && !sameCol) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\u001b[?2004l\r"]
[70.601744, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[70.601926, "o", "  // must be adjacent with no island between\r\n\u001b[?2004l\r"]
[70.601979, "o", "\u001b[?2004h> "]
[70.602073, "o", "  if (sameRow) {\r\n\u001b[?2004l\r"]
[70.602136, "o", "\u001b[?2004h> "]
[70.602574, "o", "    const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === from.y && between(i.x, from.x, to.x));\r\n\u001b[?2004l\r"]
[70.602666, "o", "\u001b[?2004h> "]
[70.602972, "o", "    if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\u001b[?2004l\r"]
[70.603104, "o", "\u001b[?2004h>   } else {\r\n\u001b[?2004l\r"]
[70.603221, "o", "\u001b[?2004h> "]
[70.603566, "o", "    const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === from.x && between(i.y, from.y, to.y));\r\n\u001b[?2004l\r"]
[70.603643, "o", "\u001b[?2004h> "]
[70.603897, "o", "    if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };\r\n\u001b[?2004l\r"]
[70.603949, "o", "\u001b[?2004h> "]
[70.604027, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[70.604047, "o", "> \r\n\u001b[?2004l\r"]
[70.604163, "o", "\u001b[?2004h> "]
[70.60428, "o", "  const key = canonicalKey(from, to);\r\n\u001b[?2004l\r"]
[70.604345, "o", "\u001b[?2004h> "]
[70.604502, "o", "  const current = bridges.get(key) ?? 0;\r\n\u001b[?2004l\r"]
[70.60455, "o", "\u001b[?2004h> "]
[70.604698, "o", "  const next = current + delta;\r\n\u001b[?2004l\r"]
[70.604745, "o", "\u001b[?2004h> "]
[70.604807, "o", "\r\n\u001b[?2004l\r"]
[70.604896, "o", "\u001b[?2004h> "]
[70.605059, "o", "  if (next < 0) return { valid: false, error: ERROR_MAX_PAIR };\r\n\u001b[?2004l\r"]
[70.605106, "o", "\u001b[?2004h> "]
[70.605383, "o", "  if (next > 2) return { valid: false, error: ERROR_MAX_PAIR };\r\n\u001b[?2004l\r"]
[70.605458, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[70.605476, "o", "> "]
[70.605652, "o", "  // check island counts do not exceed\r\n\u001b[?2004l\r"]
[70.605714, "o", "\u001b[?2004h"]
[70.605755, "o", "> "]
[70.605924, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[70.605995, "o", "\u001b[?2004h> "]
[70.60618, "o", "  const fromCount = counts.get(from.id) ?? 0;\r\n\u001b[?2004l\r"]
[70.606208, "o", "\u001b[?2004h"]
[70.606219, "o", "> "]
[70.606389, "o", "  const toCount = counts.get(to.id) ?? 0;\r\n\u001b[?2004l\r"]
[70.606417, "o", "\u001b[?2004h"]
[70.606428, "o", "> "]
[70.606722, "o", "  if (fromCount + delta > from.value || toCount + delta > to.value) {\r\n\u001b[?2004l\r"]
[70.606752, "o", "\u001b[?2004h"]
[70.606764, "o", "> "]
[70.606996, "o", "    return { valid: false, error: ERROR_EXCEED };\r\n\u001b[?2004l\r"]
[70.607026, "o", "\u001b[?2004h"]
[70.607038, "o", "> "]
[70.607137, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[70.60723, "o", "> "]
[70.607528, "o", "  // check crossing if adding (delta>0). Removing never introduces crossing.\r\n\u001b[?2004l\r"]
[70.607564, "o", "\u001b[?2004h"]
[70.607578, "o", "> "]
[70.60768, "o", "  if (delta > 0) {\r\n\u001b[?2004l\r"]
[70.607834, "o", "\u001b[?2004h> "]
