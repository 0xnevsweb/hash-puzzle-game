[70.586468, "o", "> "]
[70.586706, "o", "function between(v, a, b) {\r\n\u001b[?2004l\r"]
[70.586782, "o", "\u001b[?2004h"]
[70.586824, "o", "> "]
[70.587063, "o", "  const lo = Math.min(a, b);\r\n"]
[70.587085, "o", "\u001b[?2004l\r"]
[70.587188, "o", "\u001b[?2004h"]
[70.587263, "o", "> "]
[70.587521, "o", "  const hi = Math.max(a, b);\r\n\u001b[?2004l\r"]
[70.587607, "o", "\u001b[?2004h"]
[70.587686, "o", "> "]
[70.587898, "o", "  return v > lo && v < hi;\r\n"]
[70.58798, "o", "\u001b[?2004l\r"]
[70.588052, "o", "\u001b[?2004h> "]
