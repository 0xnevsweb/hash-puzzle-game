[?2004l[?2004h> import React, { useEffect, useMemo, useRef, useState } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles';
[?2004l[?2004h> import {
[?2004l[?2004h>   canAddBridge,
[?2004l[?2004h>   canonicalKey,
[?2004l[?2004h>   isVictory,
[?2004l[?2004h>   parseKey,
[?2004l[?2004h>   ERROR_CROSS,
[?2004l[?2004h>   ERROR_EXCEED,
[?2004l[?2004h>   ERROR_MAX_PAIR,
[?2004l[?2004h>   ERROR_NON_ADJACENT,
[?2004l[?2004h> } from './utils/hashiLogic';
[?2004l[?2004h> 
[?2004l[?2004h> const GRID = 40;
[?2004l[?2004h> const W = 800;
[?2004l[?2004h> const H = 600;
