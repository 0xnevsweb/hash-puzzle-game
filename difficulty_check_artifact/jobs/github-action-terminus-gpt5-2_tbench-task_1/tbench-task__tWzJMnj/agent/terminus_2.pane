[?2004l[?2004h> export const ERROR_NON_ADJACENT = "Cannot connect non-adjacent islands";
[?2004l[?2004h> export const ERROR_MAX_PAIR = "Max 2 bridges per pair";
[?2004l[?2004h> export const ERROR_EXCEED = "Island would exceed its number";
[?2004l[?2004h> export const ERROR_CROSS = "Bridges would cross";
[?2004l[?2004h> 
[?2004ll[?2004h> export function canonicalKey(a, b) {
[?2004l[?2004h>   // a,b are {x,y} in grid units
[?2004l[?2004h>   const p1 = { x: a.x, y: a.y };
[?2004l[?2004h>   const p2 = { x: b.x, y: b.y };
[?2004l[?2004h>   const swap = p1.x > p2.x || (p1.x === p2.x && p1.y > p2.y);
[?2004l[?2004h>   const s = swap ? [p2, p1] : [p1, p2];
[?2004l[?2004h>   return `${s[0].x},${s[0].y},${s[1].x},${s[1].y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isHorizontal(seg) {
[?2004l[?2004h>   return seg.y1 === seg.y2;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isVertical(seg) {
[?2004l[?2004h>   return seg.x1 === seg.x2;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function normSeg(seg) {
[?2004l[?2004h>   // return with (x1,y1) <= (x2,y2) along axis
[?2004l[?2004h>   if (isHorizontal(seg)) {
[?2004l[?2004h>     const swap = seg.x1 > seg.x2;
[?2004l[?2004h>     return swap
[?2004l[?2004h>       ? { x1: seg.x2, y1: seg.y2, x2: seg.x1, y2: seg.y1 }
[?2004l[?2004h>       : seg;
[?2004l[?2004h>   }
[?2004l[?2004h>   if (isVertical(seg)) {
[?2004l[?2004h>     const swap = seg.y1 > seg.y2;
[?2004l[?2004h>     return swap
[?2004l[?2004h>       ? { x1: seg.x2, y1: seg.y2, x2: seg.x1, y2: seg.y1 }
[?2004l[?2004h>       : seg;
[?2004l[?2004h>   }
[?2004l[?2004h>   return seg;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(v, a, b) {
[?2004l[?2004h>   const lo = Math.min(a, b);
[?2004l[?2004h>   const hi = Math.max(a, b);
[?2004l[?2004h>   return v > lo && v < hi;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesCross(existingKey, newKey) {
[?2004l[?2004h>   if (existingKey === newKey) return false;
[?2004l[?2004h>   const e = normSeg(parseKey(existingKey));
[?2004l[?2004h>   const n = normSeg(parseKey(newKey));
[?2004l[?2004h> 
[?2004l[?2004h>   // Only orthogonal crossings matter; colinear overlaps are prevented by adjacency.
[?2004l[?2004h>   const eH = isHorizontal(e);
[?2004l[?2004h>   const eV = isVertical(e);
[?2004l[?2004h>   const nH = isHorizontal(n);
[?2004l[?2004h>   const nV = isVertical(n);
[?2004l[?2004h>   if (!((eH && nV) || (eV && nH))) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const h = eH ? e : n;
[?2004l[?2004h>   const v = eV ? e : n;
[?2004l[?2004h> 
[?2004l[?2004h>   // Proper crossing at an interior point (not at endpoints)
[?2004l[?2004h>   const cx = v.x1;
[?2004l[?2004h>   const cy = h.y1;
[?2004l[?2004h> 
[?2004l[?2004h>   const hX1 = Math.min(h.x1, h.x2);
[?2004l[?2004h>   const hX2 = Math.max(h.x1, h.x2);
[?2004l[?2004h>   const vY1 = Math.min(v.y1, v.y2);
[?2004l[?2004h>   const vY2 = Math.max(v.y1, v.y2);
[?2004l[?2004h> 
[?2004l[?2004h>   const intersects = cx >= hX1 && cx <= hX2 && cy >= vY1 && cy <= vY2;
[?2004l[?2004h>   if (!intersects) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // exclude touching at endpoints
[?2004l[?2004h>   const hEndpoint = (cx === h.x1 && cy === h.y1) || (cx === h.x2 && cy === h.y2);
[?2004l[?2004h>   const vEndpoint = (cx === v.x1 && cy === v.y1) || (cx === v.x2 && cy === v.y2);
[?2004l[?2004h>   if (hEndpoint || vEndpoint) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // also ensure it's strictly inside both segments
[?2004l[?2004h>   if (!between(cx, h.x1, h.x2)) return false;
[?2004l[?2004h>   if (!between(cy, v.y1, v.y2)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h> 
[?2004l[?2004h>   const sameRow = from.y === to.y;
[?2004l[?2004h>   const sameCol = from.x === to.x;
[?2004l[?2004h>   if (!sameRow && !sameCol) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h> 
[?2004l[?2004h>   // must be adjacent with no island between
[?2004l[?2004h>   if (sameRow) {
[?2004l[?2004h>     const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.y === from.y && between(i.x, from.x, to.x));
[?2004l[?2004h>     if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h>   } else {
[?2004l[?2004h>     const blocked = islands.some((i) => i.id !== from.id && i.id !== to.id && i.x === from.x && between(i.y, from.y, to.y));
[?2004l[?2004h>     if (blocked) return { valid: false, error: ERROR_NON_ADJACENT };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: false, error: ERROR_MAX_PAIR };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERROR_MAX_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   // check island counts do not exceed
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) ?? 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) ?? 0;
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERROR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // check crossing if adding (delta>0). Removing never introduces crossing.
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     for (const [k, nBr] of bridges.entries()) {
[?2004l[?2004h>       if (!nBr) continue;
[?2004l[?2004h>       if (bridgesCross(k, key)) return { valid: false, error: ERROR_CROSS };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length <= 1) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const posToId = new Map(islands.map((i) => [`${i.x},${i.y}`, i.id]));
[?2004l[?2004h>   const adj = new Map(islands.map((i) => [i.id, []]));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = posToId.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = posToId.get(`${x2},${y2}`);
[?2004l[?2004h>     if (a === undefined || b === undefined) continue;
[?2004l[?2004h>     adj.get(a).push(b);
[?2004l[?2004h>     adj.get(b).push(a);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   const q = [start];
[?2004l[?2004h>   while (q.length) {
[?2004l[?2004h>     const cur = q.shift();
[?2004l[?2004h>     for (const nxt of adj.get(cur) ?? []) {
[?2004l[?2004h>       if (!seen.has(nxt)) {
[?2004l[?2004h>         seen.add(nxt);
[?2004l[?2004h>         q.push(nxt);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // no crossings
[?2004l[?2004h>   const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       if (bridgesCross(keys[i], keys[j])) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
