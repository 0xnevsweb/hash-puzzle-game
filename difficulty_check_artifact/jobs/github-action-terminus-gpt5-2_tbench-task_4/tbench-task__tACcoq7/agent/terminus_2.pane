[?2004l[?2004hroot@19bf34d6591d:/app# cat > src/App.jsx <<'EOF'
[?2004l[?2004h> import React, { useEffect, useMemo, useRef, useState } from 'react';
[?2004l[?2004h> import { puzzles } from './data/puzzles.js';
[?2004l[?2004h> import {
[?2004l[?2004h>   canonicalBridgeKey,
[?2004l[?2004h>   canAddBridge,
[?2004l[?2004h>   computeCurrentCounts,
[?2004l[?2004h>   isVictory
[?2004l[?2004h> } from './utils/hashiLogic.js';
[?2004l[?2004h> 
[?2004l[?2004h> const GRID = 40;
[?2004l[?2004h> const SVG_W = 800;
[?2004l[?2004h> const SVG_H = 600;
[?2004l[?2004h> 
[?2004l[?2004h> function islandById(islands, id) {
[?2004l[?2004h>   return islands.find((i) => i.id === id) || null;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l [?2004h> function bridgeKeyToEndpoints(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function findNextIsland(islands, fromId, dir) {
[?2004l[?2004h>   const from = islandById(islands, fromId);
[?2004l[?2004h>   if (!from) return fromId;
[?2004l[?2004h> 
[?2004l[?2004h>   let best = null;
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     if (dir === 'left' && isl.y === from.y && isl.x < from.x) {
[?2004l[?2004h>       const dist = from.x - isl.x;
[?2004l[?2004h>       if (!best || dist < best.dist) best = { id: isl.id, dist };
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'right' && isl.y === from.y && isl.x > from.x) {
[?2004l[?2004h>       const dist = isl.x - from.x;
[?2004l[?2004h>       if (!best || dist < best.dist) best = { id: isl.id, dist };
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'up' && isl.x === from.x && isl.y < from.y) {
[?2004l[?2004h>       const dist = from.y - isl.y;
[?2004l[?2004h>       if (!best || dist < best.dist) best = { id: isl.id, dist };
[?2004l[?2004h>     }
[?2004l[?2004h>     if (dir === 'down' && isl.x === from.x && isl.y > from.y) {
[?2004l[?2004h>       const dist = isl.y - from.y;
[?2004l[?2004h>       if (!best || dist < best.dist) best = { id: isl.id, dist };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return best ? best.id : fromId;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function applyToggleBridge(islands, bridges, from, to) {
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = (current + 1) % 3; // 0->1->2->0
[?2004l[?2004h> 
[?2004l[?2004h>   // We'll validate only when increasing (0->1,1->2). For 2->0 always allow.
[?2004l[?2004h>   if (next === 0) {
[?2004l[?2004h>     const nextMap = new Map(bridges);
[?2004l[?2004h>     nextMap.delete(key);
[?2004l[?2004h>     return { ok: true, bridges: nextMap, error: null };
[?2004l[?2004h>   }
[?2004l[?2004h> 
