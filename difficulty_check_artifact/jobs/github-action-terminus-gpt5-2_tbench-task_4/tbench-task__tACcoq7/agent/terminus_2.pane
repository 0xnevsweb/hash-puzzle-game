[?2004l[?2004h> export const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> export const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';
[?2004l[?2004h> export const ERR_EXCEED = 'Island would exceed its number';
[?2004l[?2004h> export const ERR_CROSS = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> function isAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(from, to) {
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;
[?2004l[?2004h>   const second = first === a ? b : a;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function between(v, a, b) {
[?2004l[?2004h>   return v > Math.min(a, b) && v < Math.max(a, b);
[?2004l [?2004h> }
[?2004l[?2004h> 
[?2004la[?2004h> function hasBlockingIsland(islands, a, b) {
[?2004l[?2004h>   if (!isAligned(a, b)) return true;
[?2004l[?2004h>   if (a.x === b.x) {
[?2004l[?2004h>     const x = a.x;
[?2004l[?2004h>     return islands.some((p) => p.id !== a.id && p.id !== b.id && p.x === x && between(p.y, a.y, b.y));
[?2004l[?2004h>   }
[?2004l[?2004h>   const y = a.y;
[?2004l[?2004h>   return islands.some((p) => p.id !== a.id && p.id !== b.id && p.y === y && between(p.x, a.x, b.x));
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, a, b) {
[?2004l[?2004h>   if (!a || !b) return false;
[?2004l[?2004h>   if (a.id === b.id) return false;
[?2004l[?2004h>   if (!isAligned(a, b)) return false;
[?2004l[?2004h>   return !hasBlockingIsland(islands, a, b);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentCrosses(segA, segB) {
[?2004l[?2004h>   // Only consider crossing of perpendicular interior points (not sharing endpoints).
[?2004l[?2004h>   const a = segA;
[?2004l[?2004h>   const b = segB;
[?2004l[?2004h> 
[?2004l[?2004h>   const aVert = a.x1 === a.x2;
[?2004l[?2004h>   const bVert = b.x1 === b.x2;
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const v = aVert ? a : b;
[?2004l[?2004h>   const h = aVert ? b : a;
[?2004l[?2004h> 
[?2004l[?2004h>   const ix = v.x1;
[?2004l[?2004h>   const iy = h.y1;
[?2004l[?2004h> 
[?2004lC[?2004h>   const vMinY = Math.min(v.y1, v.y2);
[?2004l[?2004h>   const vMaxY = Math.max(v.y1, v.y2);
[?2004l[?2004h>   const hMinX = Math.min(h.x1, h.x2);
[?2004l[?2004h>   const hMaxX = Math.max(h.x1, h.x2);
[?2004l[?2004h> 
[?2004l[?2004h>   // intersection must be strictly inside both segments (not at endpoints)
[?2004l[?2004h>   const vInterior = iy > vMinY && iy < vMaxY;
[?2004l[?2004h>   const hInterior = ix > hMinX && ix < hMaxX;
[?2004l[?2004h>   if (!vInterior || !hInterior) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // exclude if intersection equals any endpoint (extra safety)
[?2004l[?2004h>   const endpoints = [
[?2004l[?2004h>     `${a.x1},${a.y1}`,
[?2004l[?2004h>     `${a.x2},${a.y2}`,
[?2004l[?2004h>     `${b.x1},${b.y1}`,
[?2004l[?2004h>     `${b.x2},${b.y2}`
[?2004l[?2004h>   ];
[?2004l[?2004h>   if (endpoints.includes(`${ix},${iy}`)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesWouldCross(bridges, from, to) {
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>   const newSeg = { x1, y1, x2, y2 };
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [k, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     if (k === key) continue;
[?2004l[?2004h>     const seg = parseKey(k);
[?2004l[?2004h> 
[?2004l[?2004h>     // sharing endpoints never counts as crossing
[?2004l[?2004h>     const sharesEndpoint =
[?2004l[?2004h>       (seg.x1 === x1 && seg.y1 === y1) ||
[?2004l[?2004h>       (seg.x2 === x1 && seg.y2 === y1) ||
[?2004l[?2004h>       (seg.x1 === x2 && seg.y1 === y2) ||
[?2004l[?2004h>       (seg.x2 === x2 && seg.y2 === y2) ||
[?2004l[?2004h>       (seg.x1 === x1 && seg.y1 === y1) ||
[?2004l[?2004h>       (seg.x2 === x2 && seg.y2 === y2);
[?2004l[?2004h> 
[?2004l[?2004h>     if (sharesEndpoint) continue;
[?2004l[?2004h>     if (segmentCrosses(newSeg, seg)) return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = islands.find((p) => p.x === x1 && p.y === y1);
[?2004l[?2004h>     const b = islands.find((p) => p.x === x2 && p.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERR_NON_ADJACENT };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: true, error: null };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PER_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   if (next > 0 && bridgesWouldCross(bridges, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERR_CROSS };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (!islands.length) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = islands.find((p) => p.x === x1 && p.y === y1);
[?2004l[?2004h>     const b = islands.find((p) => p.x === x2 && p.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   const stack = [start];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     for (const nb of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(nb)) {
[?2004l[?2004h>         seen.add(nb);
[?2004l[?2004h>         stack.push(nb);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return seen.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Ensure no crossings (defensive)
[?2004l[?2004h>   const keys = [...bridges.entries()].filter(([, n]) => n > 0).map(([k]) => k);
[?2004l[?2004h>   for (let i = 0; i < keys.length; i++) {
[?2004l[?2004h>     const a = parseKey(keys[i]);
[?2004l[?2004h>     for (let j = i + 1; j < keys.length; j++) {
[?2004l[?2004h>       const b = parseKey(keys[j]);
[?2004l[?2004h>       if (segmentCrosses(a, b)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
