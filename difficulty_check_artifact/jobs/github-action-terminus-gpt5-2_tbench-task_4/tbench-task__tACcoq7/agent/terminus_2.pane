[?2004l[?2004h>           const to = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>           if (from && to) removeBridgeBetween(from, to);
[?2004l[?2004h>         }}
[?2004l[?2004h>         onClick={(e) => {
[?2004l[?2004h>           if (e.ctrlKey) {
[?2004l[?2004h>             e.preventDefault();
[?2004l[?2004h>             const from = islands.find((i) => i.x === x1 && i.y === y1);
