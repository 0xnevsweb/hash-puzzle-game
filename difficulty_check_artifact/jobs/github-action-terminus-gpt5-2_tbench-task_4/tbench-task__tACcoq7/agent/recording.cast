[64.273597, "i", "cat > src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useRef, useState } from 'react';\nimport { puzzles } from './data/puzzles.js';\nimport {\n  canonicalBridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory\n} from './utils/hashiLogic.js';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction islandById(islands, id) {\n  return islands.find((i) => i.id === id) || null;\n}\n\nfunction bridgeKeyToEndpoints(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nfunction findNextIsland(islands, fromId, dir) {\n  const from = islandById(islands, fromId);\n  if (!from) return fromId;\n\n  let best = null;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\n      const dist = from.x - isl.x;\n      if (!best || dist < best.dist) best = { id: isl.id, dist };\n    }\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\n      const dist = isl.x - from.x;\n      if (!best ||"]
[64.273729, "i", " dist < best.dist) best = { id: isl.id, dist };\n    }\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\n      const dist = from.y - isl.y;\n      if (!best || dist < best.dist) best = { id: isl.id, dist };\n    }\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\n      const dist = isl.y - from.y;\n      if (!best || dist < best.dist) best = { id: isl.id, dist };\n    }\n  }\n\n  return best ? best.id : fromId;\n}\n\nfunction applyToggleBridge(islands, bridges, from, to) {\n  const key = canonicalBridgeKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = (current + 1) % 3; // 0->1->2->0\n\n  // We'll validate only when increasing (0->1,1->2). For 2->0 always allow.\n  if (next === 0) {\n    const nextMap = new Map(bridges);\n    nextMap.delete(key);\n    return { ok: true, bridges: nextMap, error: null };\n  }\n\n  const delta = next - current;\n  const res = canAddBridge(islands, bridges, from, to, delta);\n  if (!res.valid) return { ok: false, bridges, error: res.error };\n\n  const nextM"]
[64.273776, "o", "cat > src/App.jsx <<'EOF'"]
[64.273817, "i", "ap = new Map(bridges);\n  nextMap.set(key, next);\n  return { ok: true, bridges: nextMap, error: null };\n}\n\nexport default function App() {\n  const [puzzleIdx, setPuzzleIdx] = useState(0);\n  const puzzle = puzzles[puzzleIdx];\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [mouseSelectedId, setMouseSelectedId] = useState(null);\n\n  const [cursorId, setCursorId] = useState(islands[0]?.id ?? 0);\n  const [kbdSelectedId, setKbdSelectedId] = useState(null);\n\n  const [error, setError] = useState(null);\n\n  const rootRef = useRef(null);\n\n  useEffect(() => {\n    // When puzzle changes, fully reset bridges & selection.\n    setBridges(new Map());\n    setMouseSelectedId(null);\n    setKbdSelectedId(null);\n    setError(null);\n    setCursorId(puzzles[puzzleIdx].islands[0]?.id ?? 0);\n  }, [puzzleIdx]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n"]
[64.273858, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[64.273897, "i", "\n  function clearErrorOnValidMove() {\n    if (error) setError(null);\n  }\n\n  function onIslandClick(isl) {\n    if (victory) return;\n\n    if (mouseSelectedId === null) {\n      setMouseSelectedId(isl.id);\n      return;\n    }\n\n    if (mouseSelectedId === isl.id) {\n      setMouseSelectedId(null);\n      return;\n    }\n\n    const from = islandById(islands, mouseSelectedId);\n    const to = isl;\n    if (!from || !to) {\n      setMouseSelectedId(null);\n      return;\n    }\n\n    const res = applyToggleBridge(islands, bridges, from, to);\n    if (!res.ok) {\n      setError(res.error);\n    } else {\n      clearErrorOnValidMove();\n      setBridges(res.bridges);\n    }\n\n    setMouseSelectedId(null);\n  }\n\n  function removeBridgeBetween(from, to) {\n    if (victory) return;\n    const key = canonicalBridgeKey(from, to);\n    if (!(bridges.get(key) > 0)) return;\n\n    const next = new Map(bridges);\n    next.delete(key);\n    setBridges(next);\n    clearErrorOnValidMove();\n  }\n\n  function onKeyDown(e) {\n    const k = e.key;\n    if (k === 'A"]
[64.273935, "o", "> "]
[64.273973, "i", "rrowLeft' || k === 'ArrowRight' || k === 'ArrowUp' || k === 'ArrowDown') {\n      e.preventDefault();\n      const dir =\n        k === 'ArrowLeft'\n          ? 'left'\n          : k === 'ArrowRight'\n            ? 'right'\n            : k === 'ArrowUp'\n              ? 'up'\n              : 'down';\n      setCursorId((cur) => findNextIsland(islands, cur, dir));\n      return;\n    }\n\n    if (k === 'Escape') {\n      e.preventDefault();\n      setKbdSelectedId(null);\n      return;\n    }\n\n    if (k === 'Enter') {\n      e.preventDefault();\n      if (victory) return;\n\n      if (kbdSelectedId === null) {\n        setKbdSelectedId(cursorId);\n        return;\n      }\n\n      if (kbdSelectedId === cursorId) {\n        setKbdSelectedId(null);\n        return;\n      }\n\n      const from = islandById(islands, kbdSelectedId);\n      const to = islandById(islands, cursorId);\n      const res = applyToggleBridge(islands, bridges, from, to);\n      if (!res.ok) {\n        setError(res.error);\n      } else {\n        clearErrorOnValidMove();\n      "]
[64.274019, "i", "  setBridges(res.bridges);\n      }\n      setKbdSelectedId(null);\n    }\n  }\n\n  const selectedId = mouseSelectedId ?? kbdSelectedId;\n\n  const bridgeLines = [];\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = bridgeKeyToEndpoints(key);\n    const a = { x: x1, y: y1 };\n    const b = { x: x2, y: y2 };\n\n    const px1 = a.x * GRID;\n    const py1 = a.y * GRID;\n    const px2 = b.x * GRID;\n    const py2 = b.y * GRID;\n\n    const isHoriz = py1 === py2;\n    const offset = 4;\n\n    const mkLine = (dx, dy, idx) => (\n      <line\n        key={`${key}-${idx}`}\n        x1={px1 + dx}\n        y1={py1 + dy}\n        x2={px2 + dx}\n        y2={py2 + dy}\n        stroke=\"#0f0\"\n        strokeWidth={3}\n        shapeRendering=\"crispEdges\"\n        onContextMenu={(e) => {\n          e.preventDefault();\n          const from = islands.find((i) => i.x === x1 && i.y === y1);\n          const to = islands.find((i) => i.x === x2 && i.y === y2);\n          if (from && to) removeBridgeBetween(from, to);"]
[64.27406, "i", "\n        }}\n        onClick={(e) => {\n          if (e.ctrlKey) {\n            e.preventDefault();\n            const from = islands.find((i) => i.x === x1 && i.y === y1);\n            const to = islands.find((i) => i.x === x2 && i.y === y2);\n            if (from && to) removeBridgeBetween(from, to);\n          }\n        }}\n      />\n    );\n\n    if (n === 1) {\n      bridgeLines.push(mkLine(0, 0, 0));\n    } else if (n === 2) {\n      if (isHoriz) {\n        bridgeLines.push(mkLine(0, -offset, 0));\n        bridgeLines.push(mkLine(0, +offset, 1));\n      } else {\n        bridgeLines.push(mkLine(-offset, 0, 0));\n        bridgeLines.push(mkLine(+offset, 0, 1));\n      }\n    }\n  }\n\n  const cursorIsland = islandById(islands, cursorId);\n  const cursorPx = cursorIsland ? { x: cursorIsland.x * GRID, y: cursorIsland.y * GRID } : { x: 0, y: 0 };\n\n  return (\n    <div\n      ref={rootRef}\n      tabIndex={0}\n      onKeyDown={onKeyDown}\n      style={{ outline: 'none' }}\n    >\n      <div style={{ padding: 8 }}>\n        <label>\n         "]
[64.274109, "i", " Puzzle:{' '}\n          <select\n            value={puzzleIdx}\n            onChange={(e) => setPuzzleIdx(Number(e.target.value))}\n            style={{ background: 'black', color: '#0f0', border: '1px solid #0f0', fontFamily: 'monospace' }}\n          >\n            <option value={0}>Easy</option>\n            <option value={1}>Medium</option>\n            <option value={2}>Hard</option>\n          </select>\n        </label>{' '}\n        <button\n          onClick={() => {\n            setBridges(new Map());\n            setMouseSelectedId(null);\n            setKbdSelectedId(null);\n            setError(null);\n          }}\n          style={{ background: 'black', color: '#0f0', border: '1px solid #0f0', fontFamily: 'monospace' }}\n        >\n          Reset\n        </button>\n      </div>\n\n      {error ? <div className=\"error-message\" style={{ padding: '0 8px 8px 8px' }}>{error}</div> : null}\n      {victory ? <div className=\"victory-banner\" style={{ padding: '0 8px 8px 8px' }}>SOLVED!</div> : null}\n\n      <svg\n        width"]
[64.274145, "i", "={SVG_W}\n        height={SVG_H}\n        style={{ position: 'absolute', left: 0, top: 0 }}\n        onContextMenu={(e) => e.preventDefault()}\n      >\n        {/* Bridges first so islands draw on top */}\n        {bridgeLines}\n\n        {/* Keyboard cursor (not a circle) */}\n        {cursorIsland ? (\n          <rect\n            x={cursorPx.x - 18}\n            y={cursorPx.y - 18}\n            width={36}\n            height={36}\n            fill=\"none\"\n            stroke={kbdSelectedId !== null ? '#0f0' : '#0a0'}\n            strokeWidth={2}\n            strokeDasharray={kbdSelectedId !== null ? '0' : '4 3'}\n          />\n        ) : null}\n\n        {islands.map((isl) => {\n          const cx = isl.x * GRID;\n          const cy = isl.y * GRID;\n          const isSelected = selectedId === isl.id;\n          const cur = counts.get(isl.id) ?? 0;\n          const satisfied = cur === isl.value;\n\n          return (\n            <g key={isl.id}>\n              <circle\n                cx={cx}\n                cy={cy}\n                r={1"]
[64.274185, "i", "6}\n                fill=\"black\"\n                stroke={isSelected ? '#9f9' : '#0f0'}\n                strokeWidth={2}\n                onClick={() => onIslandClick(isl)}\n              />\n              <text\n                x={cx}\n                y={cy + 5}\n                textAnchor=\"middle\"\n                fontFamily=\"monospace\"\n                fontSize={16}\n                fill={satisfied ? '#9f9' : '#0f0'}\n                style={{ userSelect: 'none' }}\n                onClick={() => onIslandClick(isl)}\n              >\n                {isl.value}\n              </text>\n              <text\n                x={cx}\n                y={cy + 26}\n                textAnchor=\"middle\"\n                fontFamily=\"monospace\"\n                fontSize={10}\n                fill=\"#0a0\"\n                style={{ userSelect: 'none' }}\n              >\n                {cur}/{isl.value}\n              </text>\n            </g>\n          );\n        })}\n      </svg>\n    </div>\n  );\n}\nEOF\n"]
