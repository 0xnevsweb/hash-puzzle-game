[98.79335, "i", "\n    setCursorId(0);\n  }\n\n  function removeBridgeByKey(key) {\n    if (!(bridges.get(key) > 0)) return;\n    const nb = new Map(bridges);\n    nb.delete(key);\n    setBridges(nb);\n    setSelectedId(null);\n    setError(null);\n    setCursorId(0);\n  }\n\n  function applyToggle(from, to) {\n    const key = canonicalKey(from, to);\n    const current = bridges.get(key) ?? 0;\n    const next = (current + 1) % 3; // none -> single -> double -> none\n    const delta = next - current;\n\n    const { valid, error: err } = canAddBridge(islands, bridges, from, to, delta);\n    if (!valid) {\n      // clear selection on error so the next click starts a fresh A->B pair\n      setSelectedId(null);\n      setError(err);\n      return;\n    }\n\n    const nb = new Map(bridges);\n    if (next === 0) nb.delete(key);\n    else nb.set(key, next);\n\n    setBridges(nb);\n    setSelectedId(null);\n    setError(null); // remove error-message immediately on next valid toggle\n    setCursorId(0);\n  }\n\n  function onIslandClick(id) {\n    const isl = islandAt(islan"]
