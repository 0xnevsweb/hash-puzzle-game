[98.79302, "i", "xport default function App() {\n  const [puzzleKey, setPuzzleKey] = useState('Easy');\n  const islands = PUZZLES[puzzleKey].islands;\n\n  const nav = useMemo(() => buildNeighborsByDirection(islands), [islands]);\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [cursorId, setCursorId] = useState(0);\n  const [error, setError] = useState(null);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  // cursor parked on island id 0 from page load and after any puzzle change\n  useEffect(() => {\n    setCursorId(0);\n  }, [puzzleKey]);\n\n  function resetAll() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n    setCursorId(0);\n  }\n\n  function changePuzzle(nextKey) {\n    setPuzzleKey(nextKey);\n    // fully reset in the same update batch\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);"]
