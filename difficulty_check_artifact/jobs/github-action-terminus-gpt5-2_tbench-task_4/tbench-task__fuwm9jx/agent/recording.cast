[56.304768, "i", "}\n      }\n      if (a.x === b.x) {\n        if (b.y < a.y) {\n          if (!cand.up || b.y > cand.up.y) cand.up = b;\n        } else if (b.y > a.y) {\n          if (!cand.down || b.y < cand.down.y) cand.down = b;\n        }\n      }\n    }\n    result.set(a.id, {\n      left: cand.left ? cand.left.id : null,\n      right: cand.right ? cand.right.id : null,\n      up: cand.up ? cand.up.id : null,\n      down: cand.down ? cand.down.id : null\n    });\n  }\n\n  return { byId, neighbors: result };\n}\n\nfunction bridgeLinesForKey(key, count) {\n  // returns array of {x1,y1,x2,y2, offset}\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  const horizontal = y1 === y2;\n\n  if (count === 1) {\n    return [{ x1, y1, x2, y2, dx: 0, dy: 0 }];\n  }\n  if (count === 2) {\n    // offset in pixels; parallel lines separated by 6px\n    const sep = 6;\n    if (horizontal) {\n      return [\n        { x1, y1, x2, y2, dx: 0, dy: -sep / 2 },\n        { x1, y1, x2, y2, dx: 0, dy: sep / 2 }\n      ];\n    }\n    return [\n      { x1, y1, x2, y2, dx: -sep /"]
[56.304953, "o", "cat > src/App.jsx <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.304982, "i", " 2, dy: 0 },\n      { x1, y1, x2, y2, dx: sep / 2, dy: 0 }\n    ];\n  }\n  return [];\n}\n\nexport default function App() {\n  const [puzzleKey, setPuzzleKey] = useState('Easy');\n  const islands = PUZZLES[puzzleKey].islands;\n\n  const [{ byId, neighbors }] = useState(() => buildNeighborsByDirection(PUZZLES.Easy.islands));\n  // recompute per puzzle\n  const nav = useMemo(() => buildNeighborsByDirection(islands), [islands]);\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null);\n  const [cursorId, setCursorId] = useState(0);\n  const [error, setError] = useState(null);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const victory = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  // keep cursor parked on id 0 from load and after puzzle changes\n  useEffect(() => {\n    setCursorId(0);\n  }, [puzzleKey]);\n\n  function resetAll() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setError(null);\n   "]
