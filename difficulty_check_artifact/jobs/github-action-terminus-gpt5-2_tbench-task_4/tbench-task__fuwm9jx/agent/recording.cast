[98.792508, "i", "cat > src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useState } from 'react';\nimport { PUZZLES, PUZZLE_OPTIONS } from './data/puzzles';\nimport { canAddBridge, canonicalKey, computeCurrentCounts, isVictory } from './utils/hashiLogic';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction px(n) {\n  return n * GRID;\n}\n\nfunction islandAt(islands, id) {\n  return islands.find((i) => i.id === id) || null;\n}\n\nfunction buildNeighborsByDirection(islands) {\n  // For keyboard navigation: for each island, find nearest island in each dir.\n  const result = new Map();\n\n  for (const a of islands) {\n    const cand = { left: null, right: null, up: null, down: null };\n    for (const b of islands) {\n      if (a.id === b.id) continue;\n      if (a.y === b.y) {\n        if (b.x < a.x) {\n          if (!cand.left || b.x > cand.left.x) cand.left = b;\n        } else if (b.x > a.x) {\n          if (!cand.right || b.x < cand.right.x) cand.right = b;\n        }\n      }\n      if (a.x === b.x) {\n        if (b.y < a.y) {\n   "]
[98.792712, "i", "       if (!cand.up || b.y > cand.up.y) cand.up = b;\n        } else if (b.y > a.y) {\n          if (!cand.down || b.y < cand.down.y) cand.down = b;\n        }\n      }\n    }\n    result.set(a.id, {\n      left: cand.left ? cand.left.id : null,\n      right: cand.right ? cand.right.id : null,\n      up: cand.up ? cand.up.id : null,\n      down: cand.down ? cand.down.id : null\n    });\n  }\n\n  return { neighbors: result };\n}\n\nfunction bridgeLinesForKey(key, count) {\n  // returns array of {x1,y1,x2,y2, dx,dy} where dx/dy are pixel offsets for parallel lines\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  const horizontal = y1 === y2;\n\n  if (count === 1) return [{ x1, y1, x2, y2, dx: 0, dy: 0 }];\n\n  if (count === 2) {\n    const sep = 6;\n    if (horizontal) {\n      return [\n        { x1, y1, x2, y2, dx: 0, dy: -sep / 2 },\n        { x1, y1, x2, y2, dx: 0, dy: sep / 2 }\n      ];\n    }\n    return [\n      { x1, y1, x2, y2, dx: -sep / 2, dy: 0 },\n      { x1, y1, x2, y2, dx: sep / 2, dy: 0 }\n    ];\n  }\n\n  return [];\n}\n\ne"]
