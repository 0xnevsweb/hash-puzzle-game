[98.793424, "i", "${key}:${idx}`;\n\n      bridgeLineEls.push(\n        <line\n          key={lineKey}\n          x1={x1}\n          y1={y1}\n          x2={x2}\n          y2={y2}\n          stroke=\"#0f0\"\n          strokeWidth={4}\n          strokeLinecap=\"round\"\n          onClick={(e) => {\n            if (e.ctrlKey) {\n              e.preventDefault();\n              removeBridgeByKey(key);\n            }\n          }}\n          onContextMenu={(e) => {\n            e.preventDefault();\n            removeBridgeByKey(key);\n          }}\n        />\n      );\n    }\n  }\n\n  return (\n    <div style={{ position: 'relative', width: SVG_W, height: SVG_H, margin: 0, padding: 0 }}>\n      {/* SVG anchored at viewport top-left */}\n      <svg width={SVG_W} height={SVG_H} style={{ display: 'block', background: 'black' }}>\n        {bridgeLineEls}\n\n        {/* Cursor (not a circle) */}\n        {(() => {\n          const c = islandAt(islands, cursorId);\n          if (!c) return null;\n          const size = islandRadius * 2 + 10;\n          return (\n            <rec"]
