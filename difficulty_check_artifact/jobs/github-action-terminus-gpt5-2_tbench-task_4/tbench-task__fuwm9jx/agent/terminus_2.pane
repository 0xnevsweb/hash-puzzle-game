[?2004l[?2004hroot@666a35584647:/app# cat > src/utils/hashiLogic.js <<'EOF'
[?2004l[?2004h> // Hashi (Bridges) logic utilities
[?2004l[?2004h> 
[?2004l[?2004h> export const ERR_NON_ADJACENT = 'Cannot connect non-adjacent islands';
[?2004l[?2004h> export const ERR_MAX_PER_PAIR = 'Max 2 bridges per pair';
[?2004l[?2004h> export const ERR_EXCEED_ISLAND = 'Island would exceed its number';
[?2004l[?2004h> export const ERR_CROSSING = 'Bridges would cross';
[?2004l[?2004h> 
[?2004l[?2004h> export function isOrthogonal(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalKey(from, to) {
[?2004l[?2004h>   // key is in grid units: "x1,y1,x2,y2" sorted by (x, then y)
[?2004l[?2004h>   const a = { x: from.x, y: from.y };
[?2004l[?2004h>   const b = { x: to.x, y: to.y };
[?2004l[?2004h>   const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;
[?2004l[?2004h>   const second = first === a ? b : a;
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004lr[?2004h> export function parseKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function buildCoordToIsland(islands) {
[?2004l[?2004h>   const m = new Map();
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     m.set(`${isl.x},${isl.y}`, isl);
[?2004l[?2004h>   }
[?2004l[?2004h>   return m;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (!from || !to) return false;
[?2004l[?2004h>   if (from.id === to.id) return false;
[?2004l[?2004h>   if (!isOrthogonal(from, to)) return false;
[?2004l[?2004h> 
[?2004ls[?2004h>   const coordToIsland = buildCoordToIsland(islands);
[?2004l[?2004h> 
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const x = from.x;
[?2004l[?2004h>     const yMin = Math.min(from.y, to.y);
[?2004l[?2004h>     const yMax = Math.max(from.y, to.y);
[?2004l[?2004h>     for (let y = yMin + 1; y <= yMax - 1; y++) {
[?2004l[?2004h>       if (coordToIsland.has(`${x},${y}`)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>     return true;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004lc[?2004h>   // from.y === to.y
[?2004l[?2004h>   const y = from.y;
[?2004l[?2004h>   const xMin = Math.min(from.x, to.x);
[?2004l[?2004h>   const xMax = Math.max(from.x, to.x);
[?2004l[?2004h>   for (let x = xMin + 1; x <= xMax - 1; x++) {
[?2004l[?2004h>     if (coordToIsland.has(`${x},${y}`)) return false;
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004lco[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(segA, segB) {
[?2004l[?2004h>   // seg: {x1,y1,x2,y2} in grid units, axis-aligned
[?2004l[?2004h>   // Only count crossing when one horizontal and one vertical intersect at interior points.
[?2004l[?2004h>   const aVert = segA.x1 === segA.x2;
[?2004l[?2004h>   const bVert = segB.x1 === segB.x2;
[?2004l[?2004h>   if (aVert === bVert) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const v = aVert ? segA : segB;
[?2004l[?2004h>   const h = aVert ? segB : segA;
[?2004l[?2004h> 
[?2004l[?2004h>   const vx = v.x1;
[?2004l[?2004h>   const vyMin = Math.min(v.y1, v.y2);
[?2004l[?2004h>   const vyMax = Math.max(v.y1, v.y2);
[?2004l[?2004h> 
[?2004l[?2004h>   const hy = h.y1;
[?2004l[?2004h>   const hxMin = Math.min(h.x1, h.x2);
[?2004l[?2004h>   const hxMax = Math.max(h.x1, h.x2);
[?2004l[?2004h> 
[?2004l[?2004h>   // intersection point
[?2004l[?2004h>   const ix = vx;
[?2004l[?2004h>   const iy = hy;
[?2004l[?2004h> 
[?2004l[?2004h>   // must be strictly inside both segments, not at endpoints
[?2004l[?2004h>   const vInside = iy > vyMin && iy < vyMax;
[?2004l[?2004h>   const hInside = ix > hxMin && ix < hxMax;
[?2004l[?2004h>   return vInside && hInside;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function wouldCrossExisting(bridges, newKey) {
[?2004l[?2004h>   const newSeg = parseKey(newKey);
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     if (key === newKey) continue;
[?2004l[?2004h>     const seg = parseKey(key);
[?2004l[?2004h>     if (segmentsCross(seg, newSeg)) return true;
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   const coordToIsland = buildCoordToIsland(islands);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = coordToIsland.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = coordToIsland.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: ERR_NON_ADJACENT };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };
[?2004l[?2004h> 
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: ERR_NON_ADJACENT };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: false, error: 'Bridge count cannot be negative' };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERR_MAX_PER_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   // Crossing check only matters when adding (delta > 0) and next > 0
[?2004l[?2004h>   if (delta > 0 && next > 0) {
[?2004l[?2004h>     const temp = new Map(bridges);
[?2004l[?2004h>     temp.set(key, next);
[?2004l[?2004h>     if (wouldCrossExisting(temp, key)) {
[?2004l[?2004h>       return { valid: false, error: ERR_CROSSING };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Island capacity check
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = (counts.get(from.id) ?? 0) + delta;
[?2004l[?2004h>   const toCount = (counts.get(to.id) ?? 0) + delta;
[?2004l[?2004h>   if (fromCount > from.value || toCount > to.value) {
[?2004l[?2004h>     return { valid: false, error: ERR_EXCEED_ISLAND };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const coordToIsland = buildCoordToIsland(islands);
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>     if (!n) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseKey(key);
[?2004l[?2004h>     const a = coordToIsland.get(`${x1},${y1}`);
[?2004l[?2004h>     const b = coordToIsland.get(`${x2},${y2}`);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const startId = islands[0].id;
[?2004l[?2004h>   const visited = new Set([startId]);
[?2004l[?2004h>   const q = [startId];
[?2004l[?2004h>   while (q.length) {
[?2004l[?2004h>     const cur = q.shift();
[?2004l[?2004h>     for (const nb of adj.get(cur) ?? []) {
[?2004l[?2004h>       if (!visited.has(nb)) {
[?2004l[?2004h>         visited.add(nb);
[?2004l[?2004h>         q.push(nb);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // ensure no crossings
[?2004l[?2004h>   for (const [keyA, nA] of bridges.entries()) {
[?2004l[?2004h>     if (!nA) continue;
[?2004l[?2004h>     const segA = parseKey(keyA);
[?2004l[?2004h>     for (const [keyB, nB] of bridges.entries()) {
[?2004l[?2004h>       if (!nB) continue;
[?2004l[?2004h>       if (keyA === keyB) continue;
[?2004l[?2004h>       const segB = parseKey(keyB);
[?2004l[?2004h>       if (segmentsCross(segA, segB)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> EOF
[?2004l[?2004hroot@666a35584647:/app# cat > src/App.jsx <<'EOF'
[?2004l[?2004h> import React, { useEffect, useMemo, useState } from 'react';
[?2004l[?2004h> import { PUZZLES, PUZZLE_OPTIONS } from './data/puzzles';
[?2004l[?2004h> import {
[?2004l[?2004h>   canAddBridge,
[?2004l[?2004h>   canonicalKey,
[?2004l[?2004h>   computeCurrentCounts,
[?2004l[?2004h>   isVictory
[?2004l[?2004h> } from './utils/hashiLogic';
[?2004l[?2004h> 
[?2004l[?2004h> const GRID = 40;
[?2004l[?2004h> const SVG_W = 800;
[?2004l[?2004h> const SVG_H = 600;
