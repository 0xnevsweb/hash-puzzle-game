[89.363917, "o", "\u001b[?2004h> "]
[89.364004, "o", "  const adj = new Map();\r\n\u001b[?2004l\r"]
[89.364023, "o", "\u001b[?2004h"]
[89.364086, "o", "> "]
[89.364182, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[89.364206, "o", "\u001b[?2004h> "]
[89.364331, "o", "    adj.set(island.id, []);\r\n\u001b[?2004l\r"]
[89.364411, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.364459, "o", "  \r\n\u001b[?2004l\r\u001b[?2004h"]
[89.364478, "o", "> "]
[89.36465, "o", "  for (const [key, count] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[89.364713, "o", "\u001b[?2004h> "]
[89.364814, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[89.364878, "o", "\u001b[?2004h> "]
[89.365058, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[89.365103, "o", "\u001b[?2004h> "]
[89.365297, "o", "    const islandA = islands.find(i => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[89.365385, "o", "\u001b[?2004h"]
[89.365466, "o", "> "]
[89.365589, "o", "    const islandB = islands.find(i => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[89.365658, "o", "\u001b[?2004h> "]
[89.365746, "o", "    if (islandA && islandB) {\r\n\u001b[?2004l\r"]
[89.365836, "o", "\u001b[?2004h> "]
[89.365945, "o", "      adj.get(islandA.id).push(islandB.id);\r\n\u001b[?2004l\r"]
[89.366021, "o", "\u001b[?2004h> "]
[89.366139, "o", "      adj.get(islandB.id).push(islandA.id);\r\n\u001b[?2004l\r"]
[89.366203, "o", "\u001b[?2004h> "]
[89.366302, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.366374, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h>   \r\n\u001b[?2004l\r\u001b[?2004h"]
[89.366426, "o", "> "]
[89.366494, "o", "  // BFS from first island\r\n\u001b[?2004l\r"]
[89.366556, "o", "\u001b[?2004h> "]
[89.36663, "o", "  const visited = new Set();\r\n\u001b[?2004l\r"]
[89.366692, "o", "\u001b[?2004h> "]
[89.366781, "o", "  const queue = [islands[0].id];\r\n\u001b[?2004l\r"]
[89.366833, "o", "\u001b[?2004h> "]
[89.36693, "o", "  visited.add(islands[0].id);\r\n\u001b[?2004l\r"]
[89.366995, "o", "\u001b[?2004h>   \r\n\u001b[?2004l\r"]
[89.36705, "o", "\u001b[?2004h> "]
[89.367145, "o", "  while (queue.length > 0) {\r\n\u001b[?2004l\r"]
[89.367207, "o", "\u001b[?2004h> "]
[89.367302, "o", "    const current = queue.shift();\r\n\u001b[?2004l\r"]
[89.367412, "o", "\u001b[?2004h> "]
[89.367493, "o", "    for (const neighbor of adj.get(current)) {\r\n\u001b[?2004l\r"]
[89.367589, "o", "\u001b[?2004h> "]
[89.367661, "o", "      if (!visited.has(neighbor)) {\r\n\u001b[?2004l\r"]
[89.367717, "o", "\u001b[?2004h> "]
[89.367805, "o", "        visited.add(neighbor);\r\n\u001b[?2004l\r"]
[89.367866, "o", "\u001b[?2004h> "]
[89.367957, "o", "        queue.push(neighbor);\r\n\u001b[?2004l\r"]
[89.368021, "o", "\u001b[?2004h>       }\r\n\u001b[?2004l\r"]
[89.368121, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.368188, "o", ">   }\r\n"]
[89.368286, "o", "\u001b[?2004l\r\u001b[?2004h>   "]
[89.368382, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.368441, "o", "  return visited.size === islands.length;\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.368571, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[89.36867, "o", "> "]
[89.368733, "o", "// Check if puzzle is solved\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.368845, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[89.368949, "o", "\u001b[?2004h> "]
[89.369045, "o", "  // Check all counts match\r\n\u001b[?2004l\r"]
[89.369109, "o", "\u001b[?2004h> "]
[89.369212, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[89.369274, "o", "\u001b[?2004h> "]
[89.369399, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[89.36946, "o", "\u001b[?2004h> "]
[89.369664, "o", "    if ((counts.get(island.id) || 0) !== island.value) return false;\r\n\u001b[?2004l\r"]
[89.369692, "o", "\u001b[?2004h> "]
[89.369748, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.369763, "o", "> "]
[89.369803, "o", "  \r\n\u001b[?2004l\r"]
[89.369819, "o", "\u001b[?2004h"]
[89.369832, "o", "> "]
[89.369952, "o", "  // Check no bridges cross\r\n\u001b[?2004l\r"]
[89.370011, "o", "\u001b[?2004h> "]
[89.370096, "o", "  const bridgeList = [];\r\n\u001b[?2004l\r"]
[89.37019, "o", "\u001b[?2004h> "]
[89.370294, "o", "  for (const [key, count] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[89.370385, "o", "\u001b[?2004h"]
[89.37043, "o", ">     if (count === 0) continue;"]
[89.370516, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.370676, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[89.370713, "o", "\u001b[?2004h> "]
[89.370854, "o", "    bridgeList.push({ x1, y1, x2, y2 });\r\n\u001b[?2004l\r"]
[89.370878, "o", "\u001b[?2004h> "]
[89.37089, "o", "  }\r\n\u001b[?2004l\r"]
[89.370925, "o", "\u001b[?2004h"]
[89.370945, "o", "> "]
[89.370959, "o", "  \r\n\u001b[?2004l\r"]
[89.370972, "o", "\u001b[?2004h"]
[89.370999, "o", "> "]
[89.371265, "o", "  for (let i = 0; i < bridgeList.length; i++) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.371379, "o", "    for (let j = i + 1; j < bridgeList.length; j++) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.371406, "o", "> "]
[89.371478, "o", "      const a = bridgeList[i];\r\n\u001b[?2004l\r"]
[89.371553, "o", "\u001b[?2004h"]
[89.371614, "o", "> "]
[89.371687, "o", "      const b = bridgeList[j];\r\n\u001b[?2004l\r"]
[89.371743, "o", "\u001b[?2004h> "]
[89.371807, "o", "      const aHoriz = a.y1 === a.y2;\r\n\u001b[?2004l\r"]
[89.371824, "o", "\u001b[?2004h"]
[89.371917, "o", "> "]
[89.371976, "o", "      const bHoriz = b.y1 === b.y2;\r\n\u001b[?2004l\r"]
[89.372046, "o", "\u001b[?2004h> "]
[89.372179, "o", "      if (aHoriz === bHoriz) continue;\r\n\u001b[?2004l\r"]
