[89.353043, "o", "\u001b[?2004h> "]
[89.353159, "o", "      const vX = x1;\r\n\u001b[?2004l\r"]
[89.353266, "o", "\u001b[?2004h> "]
[89.353465, "o", "      const vMinY = Math.min(y1, y2);\r\n\u001b[?2004l\r"]
[89.353511, "o", "\u001b[?2004h> "]
[89.35375, "o", "      const vMaxY = Math.max(y1, y2);\r\n\u001b[?2004l\r"]
[89.353768, "o", "\u001b[?2004h"]
[89.353796, "o", "> "]
[89.353863, "o", "      \r\n\u001b[?2004l\r"]
[89.35388, "o", "\u001b[?2004h"]
[89.353895, "o", "> "]
[89.354291, "o", "      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\r\n\u001b[?2004l\r"]
[89.354345, "o", "\u001b[?2004h> "]
[89.354475, "o", "        return true;\r\n\u001b[?2004l\r"]
