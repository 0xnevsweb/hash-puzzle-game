[89.358581, "o", "// Compute current bridge counts per island\r\n\u001b[?2004l\r"]
[89.358637, "o", "\u001b[?2004h> "]
[89.358987, "o", "export function computeCurrentCounts(islands, bridges) {\r\n\u001b[?2004l\r"]
[89.359086, "o", "\u001b[?2004h> "]
[89.359222, "o", "  const counts = new Map();\r\n\u001b[?2004l\r"]
[89.359283, "o", "\u001b[?2004h> "]
[89.359483, "o", "  for (const island of islands) {\r\n\u001b[?2004l\r"]
[89.359544, "o", "\u001b[?2004h> "]
[89.359722, "o", "    counts.set(island.id, 0);\r\n\u001b[?2004l\r"]
[89.359806, "o", "\u001b[?2004h> "]
[89.359827, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[89.359839, "o", "> "]
[89.359853, "o", "  \r\n\u001b[?2004l\r"]
[89.359935, "o", "\u001b[?2004h> "]
[89.360222, "o", "  for (const [key, count] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[89.360316, "o", "\u001b[?2004h> "]
[89.360478, "o", "    if (count === 0) continue;\r\n\u001b[?2004l\r"]
[89.360526, "o", "\u001b[?2004h> "]
[89.360875, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
