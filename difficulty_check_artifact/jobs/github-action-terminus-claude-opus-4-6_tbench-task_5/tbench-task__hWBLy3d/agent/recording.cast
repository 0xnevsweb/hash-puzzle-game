[89.355118, "o", "\u001b[?2004h> "]
[89.35536, "o", "      // Existing is horizontal (y1 === y2)\r\n\u001b[?2004l\r"]
[89.355406, "o", "\u001b[?2004h> "]
[89.355679, "o", "      const vMinY = Math.min(from.y, to.y);\r\n\u001b[?2004l\r"]
[89.35573, "o", "\u001b[?2004h> "]
[89.355981, "o", "      const vMaxY = Math.max(from.y, to.y);\r\n\u001b[?2004l\r"]
[89.356027, "o", "\u001b[?2004h> "]
[89.356189, "o", "      const vX = from.x;\r\n\u001b[?2004l\r"]
[89.356235, "o", "\u001b[?2004h> "]
[89.356365, "o", "      const hY = y1;\r\n\u001b[?2004l\r"]
[89.356391, "o", "\u001b[?2004h"]
[89.356458, "o", "> "]
[89.356654, "o", "      const hMinX = Math.min(x1, x2);\r\n\u001b[?2004l\r"]
[89.356753, "o", "\u001b[?2004h> "]
[89.356937, "o", "      const hMaxX = Math.max(x1, x2);\r\n\u001b[?2004l\r"]
[89.356957, "o", "\u001b[?2004h"]
[89.357038, "o", ">       \r\n\u001b[?2004l\r"]
[89.357111, "o", "\u001b[?2004h> "]
[89.357497, "o", "      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\r\n\u001b[?2004l\r"]
