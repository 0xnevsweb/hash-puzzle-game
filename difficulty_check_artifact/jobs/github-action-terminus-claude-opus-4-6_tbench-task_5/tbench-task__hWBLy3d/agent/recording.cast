[89.352185, "o", "> "]
[89.352444, "o", "      const hMinX = Math.min(from.x, to.x);\r\n\u001b[?2004l\r"]
[89.352464, "o", "\u001b[?2004h"]
[89.352475, "o", "> "]
[89.352765, "o", "      const hMaxX = Math.max(from.x, to.x);\r\n\u001b[?2004l\r"]
[89.352851, "o", "\u001b[?2004h> "]
