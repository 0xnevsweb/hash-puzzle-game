[89.361, "o", "> "]
[89.361245, "o", "    // Find which islands these coords belong to\r\n\u001b[?2004l\r"]
[89.361338, "o", "\u001b[?2004h> "]
[89.361648, "o", "    const islandA = islands.find(i => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r"]
[89.361708, "o", "\u001b[?2004h"]
[89.361727, "o", "> "]
[89.361967, "o", "    const islandB = islands.find(i => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r"]
[89.362067, "o", "\u001b[?2004h> "]
[89.362268, "o", "    if (islandA) counts.set(islandA.id, (counts.get(islandA.id) || 0) + count);\r\n\u001b[?2004l\r"]
[89.362332, "o", "\u001b[?2004h> "]
[89.362577, "o", "    if (islandB) counts.set(islandB.id, (counts.get(islandB.id) || 0) + count);\r\n\u001b[?2004l\r"]
[89.362655, "o", "\u001b[?2004h> "]
[89.362714, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[89.362763, "o", "  return counts;\r\n"]
