[89.362936, "o", "\u001b[?2004h> "]
[89.363087, "o", "// Check if all islands are connected via bridges\r\n\u001b[?2004l\r"]
[89.363145, "o", "\u001b[?2004h> "]
[89.363293, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[89.363369, "o", "\u001b[?2004h> "]
[89.363487, "o", "  if (islands.length === 0) return true;\r\n\u001b[?2004l\r"]
[89.363595, "o", "\u001b[?2004h> "]
