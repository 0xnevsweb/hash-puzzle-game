[?2004l[?2004h>       const a = bridgeList[i];
[?2004l[?2004h>       const b = bridgeList[j];
[?2004l[?2004h>       const aHoriz = a.y1 === a.y2;
[?2004l[?2004h>       const bHoriz = b.y1 === b.y2;
[?2004l[?2004h>       if (aHoriz === bHoriz) continue;
[?2004l[?2004h>       
[?2004l[?2004h>       if (aHoriz) {
[?2004l[?2004h>         const hMinX = Math.min(a.x1, a.x2);
[?2004l[?2004h>         const hMaxX = Math.max(a.x1, a.x2);
