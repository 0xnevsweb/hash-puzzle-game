[?2004l[?2004h>         const hY = b.y1;
[?2004l[?2004h>         const vX = a.x1;
[?2004l[?2004h>         const vMinY = Math.min(a.y1, a.y2);
[?2004l[?2004h>         const vMaxY = Math.max(a.y1, a.y2);
