[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const islandA = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const islandB = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (islandA && islandB) {
[?2004l[?2004h>       adj.get(islandA.id).push(islandB.id);
[?2004l[?2004h>       adj.get(islandB.id).push(islandA.id);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
