[?2004l[?2004h>           ))}
[?2004l[?2004h>         </select>
[?2004l[?2004h>         <button onClick={handleReset}
[?2004l[?2004h>           style={{ background: 'black', color: '#0f0', border: '1px solid #0f0', fontFamily: 'monospace', padding: '4px 8px', cursor: 'pointer' }}>
[?2004l[?2004h>           Reset
[?2004l[?2004h>         </button>
