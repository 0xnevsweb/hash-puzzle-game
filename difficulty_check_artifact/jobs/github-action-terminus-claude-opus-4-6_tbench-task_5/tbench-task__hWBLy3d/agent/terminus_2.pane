[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     // Find which islands these coords belong to
[?2004l[?2004h>     const islandA = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const islandB = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (islandA) counts.set(islandA.id, (counts.get(islandA.id) || 0) + count);
[?2004l[?2004h>     if (islandB) counts.set(islandB.id, (counts.get(islandB.id) || 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected via bridges
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency list
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const island of islands) {
