onst renderIslands = () => {\n    return islands.map(island => {\n      const px = island.x * GRID;\n      const py = island.y * GRID;\n      const isSelected = selectedIsland && selectedIsland.id === island.id;\n\n      return (\n        <g key={island.id}\n          onClick={(e) => handleIslandClick(island, e)}\n          onContextMenu={(e) => handleIslandRightClick(island, e)}\n          style={{ cursor: \'pointer\' }}>\n          <circle cx={px} cy={py} r={16}\n            fill="black" stroke={isSelected ? \'#ff0\' : \'#0f0\'} strokeWidth="2" />\n          <text x={px} y={py} textAnchor="middle" dominantBaseline="central"\n            fill="#0f0" fontSize="14" fontFamily="monospace">\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render cursor as rect (NOT circle)\n  const renderCursor = () => {\n    const island = islands.find(i => i.id === cursorIslandId);\n    if (!island) return null;\n    const px = island.x * GRID;\n    const py = island.y * GRID;\n    return (\n      <rect x={px - 22} y={py - 22} width={44} height={44}\n        fill="none" stroke="#0f0" strokeWidth="1.5"\n        strokeDasharray="5 3" />\n    );\n  };\n\n  return (\n    <div style={{ margin: 0, padding: 0, position: \'relative\' }}>\n      <svg width={800} height={600} style={{ display: \'block\', position: \'absolute\', top: 0, left: 0 }}>\n        <rect width={800} height={600} fill="black" />\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n      <div style={{ position: \'relative\', zIndex: 10, padding: \'5px 10px\', display: \'flex\', gap: \'10px\', alignItems: \'center\' }}>\n        <select value={puzzleIndex} onChange={handlePuzzleChange}\n          style={{ background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\', padding: \'2px 4px\' }}>\n          {puzzles.map((p, i) => (\n            <option key={p.id} value={i}>{p.name}</option>\n          ))}\n   