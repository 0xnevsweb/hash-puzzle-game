Sending keys: ['cat > /app/src/App.jsx << \'ENDOFFILE\'\nimport React, { useState, useEffect, useCallback, useRef } from \'react\';\nimport { puzzles } from \'./data/puzzles\';\nimport { bridgeKey, canAddBridge, computeCurrentCounts, isVictory } from \'./utils/hashiLogic\';\n\nconst GRID_SIZE = 40;\nconst ISLAND_RADIUS = 16;\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [cursorIndex, setCursorIndex] = useState(0);\n  const [error, setError] = useState(null);\n  const [victory, setVictory] = useState(false);\n  const [keyboardMode, setKeyboardMode] = useState(false);\n  const svgRef = useRef(null);\n\n  const currentPuzzle = puzzles[puzzleIndex];\n  const islands = currentPuzzle.islands;\n\n  // Reset when puzzle changes\n  const resetGame = useCallback(() => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setCursorIndex(0);\n    setError(null);\n    setVictory(false);\n  }, []);\n\n  useEffect(() => {\n    resetGame();\n  }, [puzzleIndex, resetGame]);\n\n  // Check victory after bridge changes\n  useEffect(() => {\n    if (bridges.size > 0 && isVictory(islands, bridges)) {\n      setVictory(true);\n    } else {\n      setVictory(false);\n    }\n  }, [bridges, islands]);\n\n  const handlePuzzleChange = (e) => {\n    setPuzzleIndex(Number(e.target.value));\n  };\n\n  const handleReset = () => {\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setError(null);\n    setVictory(false);\n  };\n\n  const toggleBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const currentCount = bridges.get(key) || 0;\n\n    if (currentCount === 0) {\n      // Try to add single\n      const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        setError(result.error);\n        return;\n      }\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 1);\n      setBridges(newBridges);\n    } else if (currentCount === 1) {\n      // Try to add second\n      const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        // If can\'t add second, cycle to none\n        setError(null);\n        const newBridges = new Map(bridges);\n        newBridges.delete(key);\n        setBridges(newBridges);\n        return;\n      }\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 2);\n      setBridges(newBridges);\n    } else {\n      // currentCount === 2, cycle to none\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n    }\n  }, [bridges, islands]);\n\n  const removeBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const currentCount = bridges.get(key) || 0;\n    if (currentCount > 0) {\n      setError(null);\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n    }\n  }, [bridges]);\n\n  const handleIslandClick = useCallback((island, e) => {\n    if (e.button === 2 || e.ctrlKey) {\n      // Right-click or Ctrl+click: remove bridge if selected\n      if (selectedIsland !== null) {\n        removeBridge(selectedIsland, island);\n        setSelectedIsland(null);\n      }\n      return;\n    }\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island);\n      setError(null);\n    } else {\n      if (selectedIsland.id === island.id) {\n        setSelectedIsland(null);\n        return;\n      }\n      toggleBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    }\n  }, [selectedIsland, toggleBridge, removeBridge]);\n\n  const handleContextMenu = useCallback((e) => {\n    e.preventDefault();\n  }, []);\n\n  // Find nearest island in a direction from current cursor position\n  const findNextIsland = useCallback((direction) => {\n    const current = islands[cursorIndex];\n    let candidates = [];\n\n    for (let i = 0; i < islands.length; i++) {\n      if (i === cursorIndex) continue;\n      const other = islands[i];\n      switch (direction) {\n        case \'ArrowUp\':\n          if (other.y < current.y) candidates.push(i);\n          break;\n        case \'ArrowDown\':\n          if (other.y > current.y) candidates.push(i);\n          break;\n        case \'ArrowLeft\':\n          if (other.x < current.x) candidates.push(i);\n          break;\n        case \'ArrowRight\':\n          if (other.x > current.x) candidates.push(i);\n          break;\n      }\n    }\n\n    if (candidates.length === 0) return cursorIndex;\n\n    // Sort by distance (manhattan)\n    candidates.sort((a, b) => {\n      const da = Math.abs(islands[a].x - current.x) + Math.abs(islands[a].y - current.y);\n      const db = Math.abs(islands[b].x - current.x) + Math.abs(islands[b].y - current.y);\n      return da - db;\n    });\n\n    return candidates[0];\n  }, [cursorIndex, islands]);\n\n  // Keyboard handling\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      if (e.key === \'ArrowUp\' || e.key === \'ArrowDown\' || e.key === \'ArrowLeft\' || e.key === \'ArrowRight\') {\n        e.preventDefault();\n        setKeyboardMode(true);\n        const next = findNextIsland(e.key);\n        setCursorIndex(next);\n      } else if (e.key === \'Enter\') {\n        e.preventDefault();\n        setKeyboardMode(true);\n        const cursorIsland = islands[cursorIndex];\n        if (selectedIsland === null) {\n          setSelectedIsland(cursorIsland);\n          setError(null);\n        } else {\n          if (selectedIsland.id === cursorIsland.id) {\n            setSelectedIsland(null);\n            return;\n          }\n          toggleBridge(selectedIsland, cursorIsland);\n          setSelectedIsland(null);\n        }\n      } else if (e.key === \'Escape\') {\n        e.preventDefault();\n        setSelectedIsland(null);\n        setError(null);\n      }\n    };\n\n    window.addEventListener(\'keydown\', handleKeyDown);\n    return () => window.removeEventListener(\'keydown\', handleKeyDown);\n  }, [cursorIndex, selectedIsland, islands, findNextIsland, toggleBridge]);\n\n  // Render bridges as lines\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges.entries()) {\n      if (count === 0) continue;\n      const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n      const px1 = x1 * GRID_SIZE;\n      const py1 = y1 * GRID_SIZE;\n      const px2 = x2 * GRID_SIZE;\n      const py2 = y2 * GRID_SIZE;\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={px1} y1={py1}\n            x2={px2} y2={py2}\n            stroke="#0f0"\n            strokeWidth="2"\n          />\n        );\n      } else if (count === 2) {\n        const isHorizontal = y1 === y2;\n        const offset = 4;\n        if (isHorizontal) {\n          lines.push(\n            <line\n              key={key + \'-a\'}\n              x1={px1} y1={py1 - offset}\n              x2={px2} y2={py2 - offset}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'-b\'}\n              x1={px1} y1={py1 + offset}\n              x2={px2} y2={py2 + offset}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n        } else {\n          lines.push(\n            <line\n              key={key + \'-a\'}\n              x1={px1 - offset} y1={py1}\n              x2={px2 - offset} y2={py2}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n          lines.push(\n            <line\n              key={key + \'-b\'}\n              x1={px1 + offset} y1={py1}\n              x2={px2 + offset} y2={py2}\n              stroke="#0f0"\n              strokeWidth="2"\n            />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands as circles\n  const renderIslands = () => {\n    return islands.map((island) => {\n      const px = island.x * GRID_SIZE;\n      const py = island.y * GRID_SIZE;\n      const isSelected = selectedIsland && selectedIsland.id === island.id;\n\n      return (\n        <g key={island.id} onClick={(e) => handleIslandClick(island, e)}\n           onContextMenu={(e) => {\n             e.preventDefault();\n             if (selectedIsland !== null) {\n               removeBridge(selectedIsland, island);\n               setSelectedIsland(null);\n             }\n           }}\n           style={{ cursor: \'pointer\' }}>\n          <circle\n            cx={px}\n            cy={py}\n            r={ISLAND_RADIUS}\n            fill="black"\n            stroke={isSelected ? \'#ff0\' : \'#0f0\'}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px}\n            y={py}\n            textAnchor="middle"\n            dominantBaseline="central"\n            fill="#0f0"\n            fontSize="14"\n            fontFamily="monospace"\n          >\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render keyboard cursor (NOT a circle - use rect)\n  const renderCursor = () => {\n    if (!keyboardMode) return null;\n    const island = islands[cursorIndex];\n    if (!island) return null;\n    const px = island.x * GRID_SIZE;\n    const py = island.y * GRID_SIZE;\n    const size = ISLAND_RADIUS + 6;\n\n    return (\n      <rect\n        x={px - size}\n        y={py - size}\n        width={size * 2}\n        height={size * 2}\n        fill="none"\n        stroke="#0ff"\n        strokeWidth="2"\n        strokeDasharray="4 2"\n      />\n    );\n  };\n\n  return (\n    <div onContextMenu={handleContextMenu} style={{ margin: 0, padding: 0 }}>\n      <div style={{ padding: \'8px\', display: \'flex\', gap: \'12px\', alignItems: \'center\' }}>\n        <select value={puzzleIndex} onChange={handlePuzzleChange}\n          style={{ background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\', padding: \'4px\' }}>\n          {puzzles.map((p, i) => (\n            <option key={p.id} value={i}>{p.name}</option>\n          ))}\n        </select>\n        <button onClick={handleReset}\n          style={{ background: \'black\', color: \'#0f0\', border: \'1px solid #0f0\', fontFamily: \'monospace\', padding: \'4px 8px\', cursor: \'pointer\' }}>\n          Reset\n        </button>\n        {error && <span className="error-message" style={{ color: \'#f00\', fontFamily: \'monospace\' }}>{error}</span>}\n        {victory && <span className="victory-banner" style={{ color: \'#0f0\', fontFamily: \'monospace\', fontSize: \'20px\', fontWeight: \'bold\' }}>SOLVED!</span>}\n      </div>\n      <svg ref={svgRef} width="800" height="600" style={{ display: \'block\' }}>\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n    </div>\n  );\n}\n\nexport default App;\nENDOFFILE\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
