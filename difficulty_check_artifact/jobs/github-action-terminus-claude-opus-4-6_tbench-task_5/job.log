n      setErrorMsg(null);\n      setBridges(newBridges);\n      setVictory(isVictory(islands, newBridges));\n    } else {\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setErrorMsg(null);\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges, islands]);\n\n  // Remove bridge entirely\n  const removeBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const currentCount = bridges.get(key) || 0;\n    if (currentCount > 0) {\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setErrorMsg(null);\n      setBridges(newBridges);\n      setVictory(false);\n    }\n  }, [bridges]);\n\n  // Handle island click (left click)\n  const handleIslandClick = useCallback((island, e) => {\n    // Ctrl+click removes bridge\n    if (e.ctrlKey) {\n      if (selectedIsland !== null && selectedIsland.id !== island.id) {\n        removeBridge(selectedIsland, island);\n        setSelectedIsland(null);\n      } else {\n        setSelectedIsland(island);\n        setCursorIslandId(island.id);\n      }\n      return;\n    }\n\n    if (selectedIsland === null) {\n      setSelectedIsland(island);\n      setCursorIslandId(island.id);\n      setErrorMsg(null);\n    } else if (selectedIsland.id === island.id) {\n      setSelectedIsland(null);\n    } else {\n      toggleBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    }\n  }, [selectedIsland, toggleBridge, removeBridge]);\n\n  // Handle right-click on island\n  const handleIslandRightClick = useCallback((island, e) => {\n    e.preventDefault();\n    if (selectedIsland !== null && selectedIsland.id !== island.id) {\n      removeBridge(selectedIsland, island);\n      setSelectedIsland(null);\n    } else {\n      setSelectedIsland(island);\n      setCursorIslandId(island.id);\n    }\n  }, [selectedIsland, removeBridge]);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      const currentIsland = islands.find(i => i.id === cursorIslandId);\n      if (!currentIsland) return;\n\n      if (e.key === \'Escape\') {\n        setSelectedIsland(null);\n        setErrorMsg(null);\n        return;\n      }\n\n      if (e.key === \'Enter\') {\n        e.preventDefault();\n        if (selectedIsland === null) {\n          setSelectedIsland(currentIsland);\n          setErrorMsg(null);\n        } else if (selectedIsland.id === currentIsland.id) {\n          setSelectedIsland(null);\n        } else {\n          toggleBridge(selectedIsland, currentIsland);\n          setSelectedIsland(null);\n        }\n        return;\n      }\n\n      if ([\'ArrowUp\', \'ArrowDown\', \'ArrowLeft\', \'ArrowRight\'].includes(e.key)) {\n        e.preventDefault();\n        let nextIsland = null;\n        let bestDist = Infinity;\n\n        for (const island of islands) {\n          if (island.id === currentIsland.id) continue;\n\n          let valid = false;\n          let dist = 0;\n\n          if (e.key === \'ArrowRight\' && island.x > currentIsland.x) {\n            dist = Math.abs(island.x - currentIsland.x) + Math.abs(island.y - currentIsland.y) * 0.01;\n            valid = true;\n          } else if (e.key === \'ArrowLeft\' && island.x < currentIsland.x) {\n            dist = Math.abs(island.x - currentIsland.x) + Math.abs(island.y - currentIsland.y) * 0.01;\n            valid = true;\n          } else if (e.key === \'ArrowDown\' && island.y > currentIsland.y) {\n            dist = Math.abs(island.y - currentIsland.y) + Math.abs(island.x - currentIsland.x) * 0.01;\n            valid = true;\n          } else if (e.key === \'ArrowUp\' && island.y < currentIsland.y) {\n            dist = Math.abs(island.y - currentIsland.y) + Math.abs(island.x - currentIsland.x) * 0.01;\n            valid = true;\n          }\n\n          if (valid && dist < bestDist) {\n            bestDist = dist;\n            nextIsland = island;\n          }\n        }\n\n      