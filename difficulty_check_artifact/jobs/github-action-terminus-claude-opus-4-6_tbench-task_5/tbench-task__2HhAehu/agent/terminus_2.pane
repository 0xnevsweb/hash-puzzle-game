[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     adj.set(island.id, []);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     let id1 = null, id2 = null;
