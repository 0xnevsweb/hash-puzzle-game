[?2004l[?2004h> // Generate canonical bridge key: smaller endpoint first
[?2004l[?2004h> export function bridgeKey(island1, island2) {
[?2004l[?2004h>   const x1 = island1.x, y1 = island1.y;
[?2004l[?2004h>   const x2 = island2.x, y2 = island2.y;
[?2004l[?2004h>   if (x1 < x2 || (x1 === x2 && y1 < y2)) {
[?2004l[?2004h>     return `${x1},${y1},${x2},${y2}`;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${x2},${y2},${x1},${y1}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row or column with no island in between)
[?2004l[?2004h> function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check no island between them
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.x === from.x && island.y > minY && island.y < maxY) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   } else {
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if (island.id === from.id || island.id === to.id) continue;
[?2004l[?2004h>       if (island.y === from.y && island.x > minX && island.x < maxX) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding a bridge between from and to would cross any existing bridge
[?2004l[?2004h> function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   // A bridge from->to is horizontal or vertical
[?2004l[?2004h>   const isHorizontal = from.y === to.y;
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const bridgeIsHorizontal = (y1 === y2);
[?2004l[?2004h>     
[?2004l[?2004h>     // Parallel bridges can't cross
[?2004l[?2004h>     if (isHorizontal === bridgeIsHorizontal) continue;
[?2004l[?2004h>     
[?2004l[?2004h>     // Perpendicular bridges: check intersection
[?2004l[?2004h>     if (isHorizontal) {
[?2004l[?2004h>       // from-to is horizontal, existing is vertical
[?2004l[?2004h>       const hMinX = Math.min(from.x, to.x);
[?2004l[?2004h>       const hMaxX = Math.max(from.x, to.x);
[?2004l[?2004h>       const hY = from.y;
[?2004l[?2004h>       const vX = x1; // x1 === x2 for vertical
[?2004l[?2004h>       const vMinY = Math.min(y1, y2);
[?2004l[?2004h>       const vMaxY = Math.max(y1, y2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // from-to is vertical, existing is horizontal
[?2004l[?2004h>       const vMinY = Math.min(from.y, to.y);
[?2004l[?2004h>       const vMaxY = Math.max(from.y, to.y);
[?2004l[?2004h>       const vX = from.x;
[?2004l[?2004h>       const hY = y1; // y1 === y2 for horizontal
[?2004l[?2004h>       const hMinX = Math.min(x1, x2);
[?2004l[?2004h>       const hMaxX = Math.max(x1, x2);
[?2004l[?2004h>       
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts for each island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const island of islands) {
[?2004l[?2004h>     counts.set(island.id, 0);
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   for (const [key, count] of bridges) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     
[?2004l[?2004h>     for (const island of islands) {
[?2004l[?2004h>       if ((island.x === x1 && island.y === y1) || (island.x === x2 && island.y === y2)) {
[?2004l[?2004h>         counts.set(island.id, (counts.get(island.id) || 0) + count);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if adding delta bridges is valid
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   const key = bridgeKey(from, to);
[?2004l[?2004h>   const currentCount = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = currentCount + delta;
[?2004l[?2004h>   
[?2004l[?2004h>   // Check max 2
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) || 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) || 0;
[?2004l[?2004h>   
[?2004l[?2004h>   if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   // Check crossing (only if adding, not removing)
[?2004l[?2004h>   if (delta > 0 && currentCount === 0) {
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected via bridges
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h>   
[?2004l[?2004h>   // Build adjacency from bridges
