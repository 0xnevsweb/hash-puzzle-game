[?2004l// Generate canonical bridge key: smaller endpoint first
export function bridgeKey(island1, island2) {
  const x1 = island1.x, y1 = island1.y;
  const x2 = island2.x, y2 = island2.y;
  if (x1 < x2 || (x1 === x2 && y1 < y2)) {
    return `${x1},${y1},${x2},${y2}`;
  }
  return `${x2},${y2},${x1},${y1}`;
}

// Check if two islands are adjacent (same row or column with no island in between)
function areAdjacent(islands, from, to) {
  if (from.x !== to.x && from.y !== to.y) return false;
  if (from.x === to.x && from.y === to.y) return false;
  
  // Check no island between them
