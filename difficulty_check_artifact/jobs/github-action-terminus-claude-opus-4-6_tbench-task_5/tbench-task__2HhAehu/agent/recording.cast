[87.211514, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Generate canonical bridge key: smaller endpoint first\nexport function bridgeKey(island1, island2) {\n  const x1 = island1.x, y1 = island1.y;\n  const x2 = island2.x, y2 = island2.y;\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\n    return `${x1},${y1},${x2},${y2}`;\n  }\n  return `${x2},${y2},${x1},${y1}`;\n}\n\n// Check if two islands are adjacent (same row or column with no island in between)\nfunction areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n  \n  // Check no island between them\n  if (from.x === to.x) {\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.x === from.x && island.y > minY && island.y < maxY) return false;\n    }\n  } else {\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    for"]
[87.215011, "i", " (const island of islands) {\n      if (island.id === from.id || island.id === to.id) continue;\n      if (island.y === from.y && island.x > minX && island.x < maxX) return false;\n    }\n  }\n  return true;\n}\n\n// Check if adding a bridge between from and to would cross any existing bridge\nfunction wouldCross(islands, bridges, from, to) {\n  // A bridge from->to is horizontal or vertical\n  const isHorizontal = from.y === to.y;\n  \n  for (const [key, count] of bridges) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const bridgeIsHorizontal = (y1 === y2);\n    \n    // Parallel bridges can't cross\n    if (isHorizontal === bridgeIsHorizontal) continue;\n    \n    // Perpendicular bridges: check intersection\n    if (isHorizontal) {\n      // from-to is horizontal, existing is vertical\n      const hMinX = Math.min(from.x, to.x);\n      const hMaxX = Math.max(from.x, to.x);\n      const hY = from.y;\n      const vX = x1; // x1 === x2 for vertical\n      const vMinY = Math.min(y1, y2);"]
