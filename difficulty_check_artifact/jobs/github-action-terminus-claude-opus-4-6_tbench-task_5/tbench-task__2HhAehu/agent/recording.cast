[230.521077, "i", "ventDefault();\n    document.addEventListener('contextmenu', handler);\n    return () => document.removeEventListener('contextmenu', handler);\n  }, []);\n\n  // Render bridges as SVG lines\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges) {\n      if (count === 0) continue;\n      const [x1, y1, x2, y2] = key.split(',').map(Number);\n      const px1 = x1 * GRID;\n      const py1 = y1 * GRID;\n      const px2 = x2 * GRID;\n      const py2 = y2 * GRID;\n\n      if (count === 1) {\n        lines.push(\n          <line key={key} x1={px1} y1={py1} x2={px2} y2={py2}\n            stroke=\"#0f0\" strokeWidth=\"2\" />\n        );\n      } else if (count === 2) {\n        const isHoriz = (y1 === y2);\n        const offset = 4;\n        if (isHoriz) {\n          lines.push(\n            <line key={key + '-a'} x1={px1} y1={py1 - offset} x2={px2} y2={py2 - offset}\n              stroke=\"#0f0\" strokeWidth=\"2\" />\n          );\n          lines.push(\n            <line key={key + '-b'} x1={px1} y1={py1 + offset"]
[230.521089, "i", "} x2={px2} y2={py2 + offset}\n              stroke=\"#0f0\" strokeWidth=\"2\" />\n          );\n        } else {\n          lines.push(\n            <line key={key + '-a'} x1={px1 - offset} y1={py1} x2={px2 - offset} y2={py2}\n              stroke=\"#0f0\" strokeWidth=\"2\" />\n          );\n          lines.push(\n            <line key={key + '-b'} x1={px1 + offset} y1={py1} x2={px2 + offset} y2={py2}\n              stroke=\"#0f0\" strokeWidth=\"2\" />\n          );\n        }\n      }\n    }\n    return lines;\n  };\n\n  // Render islands as circles\n  const renderIslands = () => {\n    return islands.map(island => {\n      const px = island.x * GRID;\n      const py = island.y * GRID;\n      const isSelected = selectedIsland && selectedIsland.id === island.id;\n\n      return (\n        <g key={island.id}\n          onClick={(e) => handleIslandClick(island, e)}\n          onContextMenu={(e) => handleIslandRightClick(island, e)}\n          style={{ cursor: 'pointer' }}>\n          <circle cx={px} cy={py} r={16}\n            fill=\"black\" stroke={isSel"]
[230.521097, "i", "ected ? '#ff0' : '#0f0'} strokeWidth=\"2\" />\n          <text x={px} y={py} textAnchor=\"middle\" dominantBaseline=\"central\"\n            fill=\"#0f0\" fontSize=\"14\" fontFamily=\"monospace\">\n            {island.value}\n          </text>\n        </g>\n      );\n    });\n  };\n\n  // Render cursor as rect (NOT circle)\n  const renderCursor = () => {\n    const island = islands.find(i => i.id === cursorIslandId);\n    if (!island) return null;\n    const px = island.x * GRID;\n    const py = island.y * GRID;\n    return (\n      <rect x={px - 22} y={py - 22} width={44} height={44}\n        fill=\"none\" stroke=\"#0f0\" strokeWidth=\"1.5\"\n        strokeDasharray=\"5 3\" />\n    );\n  };\n\n  return (\n    <div style={{ margin: 0, padding: 0, position: 'relative' }}>\n      <svg width={800} height={600} style={{ display: 'block', position: 'absolute', top: 0, left: 0 }}>\n        <rect width={800} height={600} fill=\"black\" />\n        {renderBridges()}\n        {renderIslands()}\n        {renderCursor()}\n      </svg>\n      <div style={{ position: 'rela"]
