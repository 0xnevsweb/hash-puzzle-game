[230.520884, "i", "false);\n  };\n\n  // Toggle bridge between two islands: none -> single -> double -> none\n  const toggleBridge = useCallback((fromIsland, toIsland) => {\n    const key = bridgeKey(fromIsland, toIsland);\n    const currentCount = bridges.get(key) || 0;\n\n    if (currentCount === 0) {\n      const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        setErrorMsg(result.error);\n        return;\n      }\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 1);\n      setErrorMsg(null);\n      setBridges(newBridges);\n      setVictory(isVictory(islands, newBridges));\n    } else if (currentCount === 1) {\n      const result = canAddBridge(islands, bridges, fromIsland, toIsland, 1);\n      if (!result.valid) {\n        setErrorMsg(result.error);\n        return;\n      }\n      const newBridges = new Map(bridges);\n      newBridges.set(key, 2);\n      setErrorMsg(null);\n      setBridges(newBridges);\n      setVictory(isVictory(islands, newBridges));\n    } else {\n      const "]
