[230.521053, "i", ".key === 'Enter') {\n        e.preventDefault();\n        if (selectedIsland === null) {\n          setSelectedIsland(currentIsland);\n          setErrorMsg(null);\n        } else if (selectedIsland.id === currentIsland.id) {\n          setSelectedIsland(null);\n        } else {\n          toggleBridge(selectedIsland, currentIsland);\n          setSelectedIsland(null);\n        }\n        return;\n      }\n\n      if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {\n        e.preventDefault();\n        let nextIsland = null;\n        let bestDist = Infinity;\n\n        for (const island of islands) {\n          if (island.id === currentIsland.id) continue;\n\n          let valid = false;\n          let dist = 0;\n\n          if (e.key === 'ArrowRight' && island.x > currentIsland.x) {\n            dist = Math.abs(island.x - currentIsland.x) + Math.abs(island.y - currentIsland.y) * 0.01;\n            valid = true;\n          } else if (e.key === 'ArrowLeft' && island.x < currentIsland.x) {\n            dist = Math.ab"]
