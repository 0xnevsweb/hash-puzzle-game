[360.777581, "o", "// Generate canonical bridge key: smaller endpoint first\r\nexport function bridgeKey(island1, island2) {\r\n  const x1 = island1.x, y1 = island1.y;\r\n  const x2 = island2.x, y2 = island2.y;\r\n  if (x1 < x2 || (x1 === x2 && y1 < y2)) {\r\n    return `${x1},${y1},${x2},${y2}`;\r\n  }\r\n  return `${x2},${y2},${x1},${y1}`;\r\n}\r\n\r\n// Check if two islands are adjacent (same row or column with no island in between)\r\nfunction areAdjacent(islands, from, to) {\r\n  if (from.x !== to.x && from.y !== to.y) return false;\r\n  if (from.x === to.x && from.y === to.y) return false;\r\n  \r\n  // Check no island between them\r\n  if (from.x === to.x) {\r\n    const minY = Math.min(from.y, to.y);\r\n    const maxY = Math.max(from.y, to.y);\r\n    for (const island of islands) {\r\n"]
