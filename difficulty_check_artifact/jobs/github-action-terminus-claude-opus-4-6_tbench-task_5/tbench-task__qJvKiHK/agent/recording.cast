[125.431276, "i", "cat > /app/src/App.jsx << 'ENDOFFILE'\nimport React, { useState, useEffect, useCallback } from 'react';\nimport { puzzles } from './data/puzzles.js';\nimport {\n  bridgeKey,\n  canAddBridge,\n  computeCurrentCounts,\n  isVictory,\n  areAdjacent\n} from './utils/hashiLogic.js';\n\nconst GRID = 40;\nconst WIDTH = 800;\nconst HEIGHT = 600;\n\nfunction App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const [bridges, setBridges] = useState(new Map());\n  const [selectedIsland, setSelectedIsland] = useState(null);\n  const [error, setError] = useState(null);\n  const [victory, setVictory] = useState(false);\n  const [cursorIslandId, setCursorIslandId] = useState(0);\n  const [kbSelected, setKbSelected] = useState(false);\n\n  const puzzle = puzzles[puzzleIndex];\n  const islands = puzzle.islands;\n\n  // Reset state when puzzle changes\n  const resetPuzzle = useCallback((newIndex) => {\n    setPuzzleIndex(newIndex);\n    setBridges(new Map());\n    setSelectedIsland(null);\n    setError(null);\n    setVictory(false);\n    setCursorI"]
[125.431448, "i", "slandId(0);\n    setKbSelected(false);\n  }, []);\n\n  // Handle clicking an island (mouse)\n  const handleIslandClick = useCallback((island) => {\n    if (victory) return;\n\n    if (selectedIsland === null) {\n      // First selection\n      setSelectedIsland(island.id);\n      setError(null);\n    } else if (selectedIsland === island.id) {\n      // Deselect same island\n      setSelectedIsland(null);\n    } else {\n      // Second selection - try to toggle bridge\n      const from = islands.find(i => i.id === selectedIsland);\n      const to = island;\n      toggleBridge(from, to);\n    }\n  }, [selectedIsland, islands, bridges, victory]);\n\n  const toggleBridge = useCallback((from, to) => {\n    const key = bridgeKey(from, to);\n    const current = bridges.get(key) || 0;\n\n    if (current === 2) {\n      // Cycle to 0 (remove)\n      const newBridges = new Map(bridges);\n      newBridges.delete(key);\n      setBridges(newBridges);\n      setSelectedIsland(null);\n      setError(null);\n      setVictory(false);\n    } else {\n      // Try"]
[125.431589, "i", " to add\n      const delta = 1;\n      const result = canAddBridge(islands, bridges, from, to, delta);\n      if (result.valid) {\n        const newBridges = new Map(bridges);\n        newBridges.set(key, current + 1);\n        setBridges(newBridges);\n        setSelectedIsland(null);\n        setError(null);\n        // Check victory\n        if (isVictory(islands, newBridges)) {\n          setVictory(true);\n        }\n      } else {\n        setError(result.error);\n        setSelectedIsland(null);\n      }\n    }\n  }, [bridges, islands]);\n\n  // Handle right-click or ctrl+click on a bridge line to remove it\n  const handleBridgeRemove = useCallback((e, key) => {\n    e.preventDefault();\n    e.stopPropagation();\n    const newBridges = new Map(bridges);\n    newBridges.delete(key);\n    setBridges(newBridges);\n    setError(null);\n    setVictory(false);\n  }, [bridges]);\n\n  // Keyboard navigation\n  useEffect(() => {\n    const handleKeyDown = (e) => {\n      const currentIslands = puzzles[puzzleIndex].islands;\n      const cursorIsla"]
