[125.433797, "i", ") => Math.abs(a.x - cursorIsland.x) - Math.abs(b.x - cursorIsland.x) || b.y - a.y);\n          }\n          if (allCandidates && allCandidates.length > 0) {\n            setCursorIslandId(allCandidates[0].id);\n          }\n        }\n      }\n    };\n\n    window.addEventListener('keydown', handleKeyDown);\n    return () => window.removeEventListener('keydown', handleKeyDown);\n  }, [cursorIslandId, kbSelected, selectedIsland, puzzleIndex]);\n\n  // Render bridges\n  const renderBridges = () => {\n    const lines = [];\n    for (const [key, count] of bridges.entries()) {\n      if (count === 0) continue;\n      const [x1, y1, x2, y2] = key.split(',').map(Number);\n      const px1 = x1 * GRID;\n      const py1 = y1 * GRID;\n      const px2 = x2 * GRID;\n      const py2 = y2 * GRID;\n\n      const isHorizontal = y1 === y2;\n      const offset = 4;\n\n      if (count === 1) {\n        lines.push(\n          <line\n            key={key}\n            x1={px1} y1={py1} x2={px2} y2={py2}\n            stroke=\"#0f0\"\n            strokeWidth=\"2\"\n    "]
[125.433814, "i", "        style={{ cursor: 'pointer' }}\n            onClick={(e) => {\n              if (e.ctrlKey || e.metaKey) {\n                handleBridgeRemove(e, key);\n              }\n            }}\n            onContextMenu={(e) => handleBridgeRemove(e, key)}\n          />\n        );\n      } else if (count === 2) {\n        const dx = isHorizontal ? 0 : offset;\n        const dy = isHorizontal ? offset : 0;\n        lines.push(\n          <line\n            key={key + '_a'}\n            x1={px1 - dx} y1={py1 - dy} x2={px2 - dx} y2={py2 - dy}\n            stroke=\"#0f0\"\n            strokeWidth=\"2\"\n            style={{ cursor: 'pointer' }}\n            onClick={(e) => {\n              if (e.ctrlKey || e.metaKey) {\n                handleBridgeRemove(e, key);\n              }\n            }}\n            onContextMenu={(e) => handleBridgeRemove(e, key)}\n          />\n        );\n        lines.push(\n          <line\n            key={key + '_b'}\n            x1={px1 + dx} y1={py1 + dy} x2={px2 + dx} y2={py2 + dy}\n            stroke=\"#0f0\"\n    "]
[125.433827, "i", "        strokeWidth=\"2\"\n            style={{ cursor: 'pointer' }}\n            onClick={(e) => {\n              if (e.ctrlKey || e.metaKey) {\n                handleBridgeRemove(e, key);\n              }\n            }}\n            onContextMenu={(e) => handleBridgeRemove(e, key)}\n          />\n        );\n      }\n    }\n    return lines;\n  };\n\n  // Render islands\n  const renderIslands = () => {\n    return islands.map(island => {\n      const px = island.x * GRID;\n      const py = island.y * GRID;\n      const isSelected = selectedIsland === island.id;\n\n      return (\n        <g key={island.id} onClick={() => handleIslandClick(island)} style={{ cursor: 'pointer' }}>\n          <circle\n            cx={px}\n            cy={py}\n            r={16}\n            fill=\"black\"\n            stroke={isSelected ? '#ff0' : '#0f0'}\n            strokeWidth={isSelected ? 3 : 2}\n          />\n          <text\n            x={px}\n            y={py}\n            textAnchor=\"middle\"\n            dominantBaseline=\"central\"\n            fill=\"#0f0\"\n"]
