[78.313526, "i", "cat > /app/src/utils/hashiLogic.js << 'EOF'\n// Utility: create canonical bridge key from two islands (grid coords)\nexport function bridgeKey(island1, island2) {\n  const [a, b] = [island1, island2].sort((p, q) => p.x - q.x || p.y - q.y);\n  return `${a.x},${a.y},${b.x},${b.y}`;\n}\n\n// Check if two islands are adjacent (same row/col, no island between them)\nexport function areAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n  if (from.x === to.x && from.y === to.y) return false;\n\n  if (from.x === to.x) {\n    // Vertical\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    return !islands.some(i =>\n      i.id !== from.id && i.id !== to.id &&\n      i.x === from.x && i.y > minY && i.y < maxY\n    );\n  } else {\n    // Horizontal\n    const minX = Math.min(from.x, to.x);\n    const maxX = Math.max(from.x, to.x);\n    return !islands.some(i =>\n      i.id !== from.id && i.id !== to.id &&\n      i.y === from.y && i.x > minX && i.x < maxX\n    );\n  }\n}\n\n// Ch"]
[78.313583, "i", "eck if a bridge between from and to would cross any existing bridge\nexport function wouldCross(islands, bridges, from, to) {\n  // A bridge from->to is either horizontal or vertical\n  const isHorizontal = from.y === to.y;\n\n  for (const [key, count] of bridges.entries()) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n\n    // Skip if this is the same bridge\n    const thisKey = bridgeKey(from, to);\n    if (key === thisKey) continue;\n\n    const existingIsHorizontal = y1 === y2;\n\n    // Parallel bridges cannot cross in grid-based Hashi\n    if (isHorizontal === existingIsHorizontal) continue;\n\n    // Perpendicular: check intersection\n    if (isHorizontal) {\n      // New bridge is horizontal, existing is vertical\n      const hMinX = Math.min(from.x, to.x);\n      const hMaxX = Math.max(from.x, to.x);\n      const hY = from.y;\n      const vX = x1; // vertical bridge x\n      const vMinY = Math.min(y1, y2);\n      const vMaxY = Math.max(y1, y2);\n\n      if (vX > hMinX && vX < hMaxX"]
[78.313598, "i", " && hY > vMinY && hY < vMaxY) {\n        return true;\n      }\n    } else {\n      // New bridge is vertical, existing is horizontal\n      const vMinY = Math.min(from.y, to.y);\n      const vMaxY = Math.max(from.y, to.y);\n      const vX = from.x;\n      const hY = y1; // horizontal bridge y\n      const hMinX = Math.min(x1, x2);\n      const hMaxX = Math.max(x1, x2);\n\n      if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\n// Validate if a bridge can be added\n// delta is the amount to add (usually 1 for cycling up)\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  // Degenerate case\n  if (from.id === to.id) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n\n  // Check adjacency\n  if (!areAdjacent(islands, from, to)) {\n    return { valid: false, error: \"Cannot connect non-adjacent islands\" };\n  }\n\n  const key = bridgeKey(from, to);\n  const current = bridges.get(key) || 0;\n  const newCount = current + d"]
[78.313614, "i", "elta;\n\n  // Check max bridges\n  if (newCount > 2) {\n    return { valid: false, error: \"Max 2 bridges per pair\" };\n  }\n\n  // Check island capacity\n  const fromCounts = computeCurrentCounts(islands, bridges);\n  const fromCurrent = fromCounts.get(from.id) || 0;\n  const toCurrent = fromCounts.get(to.id) || 0;\n\n  if (fromCurrent + delta > from.value) {\n    return { valid: false, error: \"Island would exceed its number\" };\n  }\n  if (toCurrent + delta > to.value) {\n    return { valid: false, error: \"Island would exceed its number\" };\n  }\n\n  // Check crossing\n  if (delta > 0 && current === 0) {\n    // Only check crossing when adding a new bridge (not incrementing existing)\n    if (wouldCross(islands, bridges, from, to)) {\n      return { valid: false, error: \"Bridges would cross\" };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\n// Compute current bridge counts for each island\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  islands.forEach(i => counts.set(i.id, 0));\n\n  for ("]
[78.313625, "i", "const [key, count] of bridges.entries()) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    if (island1) counts.set(island1.id, (counts.get(island1.id) || 0) + count);\n    if (island2) counts.set(island2.id, (counts.get(island2.id) || 0) + count);\n  }\n\n  return counts;\n}\n\n// Check if all islands are connected via bridges\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  if (islands.length === 1) return true;\n\n  // Build adjacency from bridges\n  const adj = new Map();\n  islands.forEach(i => adj.set(i.id, []));\n\n  for (const [key, count] of bridges.entries()) {\n    if (count === 0) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const island1 = islands.find(i => i.x === x1 && i.y === y1);\n    const island2 = islands.find(i => i.x === x2 && i.y === y2);\n    if (island1 && i"]
[78.313635, "i", "sland2) {\n      adj.get(island1.id).push(island2.id);\n      adj.get(island2.id).push(island1.id);\n    }\n  }\n\n  // BFS from first island\n  const visited = new Set();\n  const queue = [islands[0].id];\n  visited.add(islands[0].id);\n\n  while (queue.length > 0) {\n    const curr = queue.shift();\n    for (const neighbor of adj.get(curr)) {\n      if (!visited.has(neighbor)) {\n        visited.add(neighbor);\n        queue.push(neighbor);\n      }\n    }\n  }\n\n  return visited.size === islands.length;\n}\n\n// Check if the puzzle is solved\nexport function isVictory(islands, bridges) {\n  // Check all counts match\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const island of islands) {\n    if ((counts.get(island.id) || 0) !== island.value) return false;\n  }\n\n  // Check connectivity\n  if (!checkConnectivity(islands, bridges)) return false;\n\n  return true;\n}\nEOF\n"]
