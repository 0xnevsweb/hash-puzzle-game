[?2004l[?2004h>   const [victory, setVictory] = useState(false);
[?2004l[?2004h>   const [cursorIslandId, setCursorIslandId] = useState(0);
[?2004l[?2004h>   const [kbSelected, setKbSelected] = useState(false);
[?2004l[?2004h> 
[?2004l[?2004h>   const puzzle = puzzles[puzzleIndex];
[?2004l[?2004h>   const islands = puzzle.islands;
[?2004l[?2004h> 
[?2004l[?2004h>   // Reset state when puzzle changes
[?2004l[?2004h>   const resetPuzzle = useCallback((newIndex) => {
[?2004l[?2004h>     setPuzzleIndex(newIndex);
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedIsland(null);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>     setCursorIslandId(0);
[?2004l[?2004h>     setKbSelected(false);
[?2004l[?2004h>   }, []);
[?2004l[?2004h> 
[?2004l[?2004h>   // Handle clicking an island (mouse)
[?2004l[?2004h>   const handleIslandClick = useCallback((island) => {
[?2004l[?2004h>     if (victory) return;
[?2004l[?2004h> 
[?2004l[?2004h>     if (selectedIsland === null) {
[?2004l[?2004h>       setSelectedIsland(island.id);
[?2004l[?2004h>       setError(null);
[?2004l[?2004h>     } else if (selectedIsland === island.id) {
[?2004l[?2004h>       setSelectedIsland(null);
[?2004l[?2004h>     } else {
[?2004l[?2004h>       const from = islands.find(i => i.id === selectedIsland);
[?2004l[?2004h>       const to = island;
[?2004l[?2004h>       const key = bridgeKey(from, to);
[?2004l[?2004h>       const current = bridges.get(key) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>       if (current === 2) {
[?2004l[?2004h>         const newBridges = new Map(bridges);
[?2004l[?2004h>         newBridges.delete(key);
[?2004l[?2004h>         setBridges(newBridges);
[?2004l[?2004h>         setSelectedIsland(null);
[?2004l[?2004h>         setError(null);
[?2004l[?2004h>         setVictory(false);
[?2004l[?2004h>       } else {
[?2004l[?2004h>         const delta = 1;
[?2004l[?2004h>         const result = canAddBridge(islands, bridges, from, to, delta);
[?2004l[?2004h>         if (result.valid) {
[?2004l[?2004h>           const newBridges = new Map(bridges);
[?2004l[?2004h>           newBridges.set(key, current + 1);
[?2004l[?2004h>           setBridges(newBridges);
[?2004l[?2004h>           setSelectedIsland(null);
[?2004l[?2004h>           setError(null);
[?2004l[?2004h>           if (isVictory(islands, newBridges)) {
[?2004l[?2004h>             setVictory(true);
[?2004l[?2004h>           }
[?2004l[?2004h>         } else {
[?2004l[?2004h>           setError(result.error);
[?2004l[?2004h>           setSelectedIsland(null);
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }, [selectedIsland, islands, bridges, victory]);
[?2004l[?2004h> 
[?2004l[?2004h>   // Handle right-click or ctrl+click on a bridge line to remove it
[?2004l[?2004h>   const handleBridgeRemove = useCallback((e, key) => {
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h>     e.stopPropagation();
[?2004l[?2004h>     const newBridges = new Map(bridges);
[?2004l[?2004h>     newBridges.delete(key);
[?2004l[?2004h>     setBridges(newBridges);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setVictory(false);
[?2004l[?2004h>     setSelectedIsland(null);
[?2004l[?2004h>   }, [bridges]);
[?2004l[?2004h> 
[?2004l[?2004h>   // Keyboard navigation
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     const handleKeyDown = (e) => {
[?2004l[?2004h>       const currentIslands = puzzles[puzzleIndex].islands;
[?2004l[?2004h>       const cursorIsland = currentIslands.find(i => i.id === cursorIslandId);
[?2004l[?2004h>       if (!cursorIsland) return;
[?2004l[?2004h> 
[?2004ls[?2004h>       if (e.key === 'Escape') {
[?2004l[?2004h>         setKbSelected(false);
[?2004l[?2004h>         setSelectedIsland(null);
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       if (e.key === 'Enter') {
[?2004l[?2004h>         e.preventDefault();
[?2004l[?2004h>         if (!kbSelected) {
[?2004l[?2004h>           setKbSelected(true);
[?2004l[?2004h>           setSelectedIsland(cursorIsland.id);
[?2004l[?2004h>           setError(null);
[?2004l[?2004h>         } else {
[?2004l[?2004h>           if (selectedIsland !== null && selectedIsland !== cursorIsland.id) {
[?2004l[?2004h>             const from = currentIslands.find(i => i.id === selectedIsland);
[?2004l[?2004h>             const to = cursorIsland;
[?2004ll[?2004h>             setBridges(prevBridges => {
[?2004l[?2004h>               const key = bridgeKey(from, to);
[?2004l[?2004h>               const current = prevBridges.get(key) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>               if (current === 2) {
[?2004l[?2004h>                 const newBridges = new Map(prevBridges);
[?2004l[?2004h>                 newBridges.delete(key);
[?2004l[?2004h>                 setError(null);
[?2004l[?2004h>                 setVictory(false);
[?2004l[?2004h>                 setSelectedIsland(null);
[?2004l[?2004h>                 setKbSelected(false);
[?2004l[?2004h>                 return newBridges;
[?2004l[?2004h>               } else {
[?2004l[?2004h>                 const delta = 1;
[?2004l[?2004h>                 const result = canAddBridge(currentIslands, prevBridges, from, to, delta);
[?2004l[?2004h>                 if (result.valid) {
[?2004l[?2004h>                   const newBridges = new Map(prevBridges);
[?2004l[?2004h>                   newBridges.set(key, current + 1);
[?2004l[?2004h>                   setError(null);
[?2004l[?2004h>                   setSelectedIsland(null);
[?2004l[?2004h>                   setKbSelected(false);
[?2004l[?2004h>                   if (isVictory(currentIslands, newBridges)) {
[?2004l[?2004h>                     setVictory(true);
[?2004l[?2004h>                   }
[?2004l[?2004h>                   return newBridges;
[?2004l[?2004h>                 } else {
[?2004l[?2004h>                   setError(result.error);
[?2004l[?2004h>                   setSelectedIsland(null);
[?2004l[?2004h>                   setKbSelected(false);
[?2004l[?2004h>                   return prevBridges;
[?2004l[?2004h>                 }
[?2004l[?2004h>               }
[?2004l[?2004h>             });
[?2004l[?2004h>           } else if (selectedIsland === cursorIsland.id) {
[?2004l[?2004h>             setKbSelected(false);
[?2004l[?2004h>             setSelectedIsland(null);
[?2004l[?2004h>           }
[?2004l[?2004h>         }
[?2004l[?2004h>         return;
[?2004l[?2004h>       }
[?2004l[?2004h> 
[?2004l[?2004h>       if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
[?2004l[?2004h>         e.preventDefault();
[?2004l[?2004h>         let candidates = null;
[?2004l[?2004h>         if (e.key === 'ArrowRight') {
[?2004l[?2004h>           candidates = currentIslands.filter(i => i.x > cursorIsland.x && i.y === cursorIsland.y)
[?2004l[?2004h>             .sort((a, b) => a.x - b.x);
[?2004l[?2004h>         } else if (e.key === 'ArrowLeft') {
[?2004l[?2004h>           candidates = currentIslands.filter(i => i.x < cursorIsland.x && i.y === cursorIsland.y)
[?2004l[?2004h>             .sort((a, b) => b.x - a.x);
[?2004l[?2004h>         } else if (e.key === 'ArrowDown') {
[?2004l[?2004h>           candidates = currentIslands.filter(i => i.y > cursorIsland.y && i.x === cursorIsland.x)
[?2004l[?2004h>             .sort((a, b) => a.y - b.y);
[?2004l[?2004h>         } else if (e.key === 'ArrowUp') {
[?2004l[?2004h>           candidates = currentIslands.filter(i => i.y < cursorIsland.y && i.x === cursorIsland.x)
[?2004l[?2004h>             .sort((a, b) => b.y - a.y);
[?2004l[?2004h>         }
[?2004l [?2004h> 
[?2004l[?2004h>         if (candidates && candidates.length > 0) {
[?2004l[?2004h>           setCursorIslandId(candidates[0].id);
[?2004l[?2004h>         } else {
[?2004l[?2004h>           // Find nearest island in general direction
[?2004l[?2004h>           let allCandidates = null;
[?2004l[?2004h>           if (e.key === 'ArrowRight') {
[?2004l[?2004h>             allCandidates = currentIslands.filter(i => i.x > cursorIsland.x)
[?2004l[?2004h>               .sort((a, b) => {
[?2004l[?2004h>                 const da = Math.abs(a.y - cursorIsland.y) * 100 + (a.x - cursorIsland.x);
[?2004l[?2004h>                 const db = Math.abs(b.y - cursorIsland.y) * 100 + (b.x - cursorIsland.x);
[?2004l[?2004h>                 return da - db;
[?2004l[?2004h>               });
[?2004l[?2004h>           } else if (e.key === 'ArrowLeft') {
[?2004l[?2004h>             allCandidates = currentIslands.filter(i => i.x < cursorIsland.x)
[?2004l[?2004h>               .sort((a, b) => {
[?2004l[?2004h>                 const da = Math.abs(a.y - cursorIsland.y) * 100 + (cursorIsland.x - a.x);
[?2004l[?2004h>                 const db = Math.abs(b.y - cursorIsland.y) * 100 + (cursorIsland.x - b.x);
[?2004l[?2004h>                 return da - db;
[?2004l[?2004h>               });
[?2004l [?2004h>           } else if (e.key === 'ArrowDown') {
[?2004l[?2004h>             allCandidates = currentIslands.filter(i => i.y > cursorIsland.y)
[?2004l[?2004h>               .sort((a, b) => {
[?2004l[?2004h>                 const da = Math.abs(a.x - cursorIsland.x) * 100 + (a.y - cursorIsland.y);
[?2004l[?2004h>                 const db = Math.abs(b.x - cursorIsland.x) * 100 + (b.y - cursorIsland.y);
[?2004l[?2004h>                 return da - db;
[?2004l[?2004h>               });
[?2004l[?2004h>           } else if (e.key === 'ArrowUp') {
[?2004l[?2004h>             allCandidates = currentIslands.filter(i => i.y < cursorIsland.y)
[?2004l[?2004h>               .sort((a, b) => {
[?2004l[?2004h>                 const da = Math.abs(a.x - cursorIsland.x) * 100 + (cursorIsland.y - a.y);
[?2004l[?2004h>                 const db = Math.abs(b.x - cursorIsland.x) * 100 + (cursorIsland.y - b.y);
[?2004l[?2004h>                 return da - db;
[?2004l[?2004h>               });
[?2004l[?2004h>           }
[?2004l[?2004h>           if (allCandidates && allCandidates.length > 0) {
[?2004l[?2004h>             setCursorIslandId(allCandidates[0].id);
[?2004l[?2004h>           }
[?2004l[?2004h>         }
[?2004l[?2004h>       }
[?2004l[?2004h>     };
[?2004l[?2004h> 
[?2004le[?2004h>     window.addEventListener('keydown', handleKeyDown);
[?2004l[?2004h>     return () => window.removeEventListener('keydown', handleKeyDown);
[?2004l[?2004h>   }, [cursorIslandId, kbSelected, selectedIsland, puzzleIndex]);
[?2004l[?2004h> 
[?2004l[?2004h>   // Render bridges
[?2004l[?2004h>   const renderBridges = () => {
[?2004l[?2004h>     const lines = [];
[?2004l[?2004h>     for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>       if (count === 0) continue;
[?2004l[?2004h>       const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>       const px1 = x1 * GRID;
[?2004l[?2004h>       const py1 = y1 * GRID;
[?2004l[?2004h>       const px2 = x2 * GRID;
[?2004l[?2004h>       const py2 = y2 * GRID;
[?2004l[?2004h> 
[?2004l[?2004h>       const isHorizontal = y1 === y2;
[?2004l[?2004h>       const offset = 4;
[?2004l[?2004h> 
[?2004l[?2004h>       if (count === 1) {
[?2004l[?2004h>         lines.push(
[?2004l[?2004h>           <line
[?2004l[?2004h>             key={key}
[?2004l[?2004h>             x1={px1} y1={py1} x2={px2} y2={py2}
[?2004l[?2004h>             stroke="#0f0"
[?2004l[?2004h>             strokeWidth="2"
[?2004l[?2004h>             style={{ cursor: 'pointer' }}
[?2004l[?2004h>             onClick={(e) => {
[?2004l[?2004h>               if (e.ctrlKey || e.metaKey) {
[?2004l[?2004h>                 handleBridgeRemove(e, key);
[?2004l[?2004h>               }
[?2004l[?2004h>             }}
[?2004l[?2004h>             onContextMenu={(e) => handleBridgeRemove(e, key)}
[?2004l[?2004h>           />
[?2004l[?2004h>         );
[?2004l[?2004h>       } else if (count === 2) {
[?2004l[?2004h>         const dx = isHorizontal ? 0 : offset;
[?2004l[?2004h>         const dy = isHorizontal ? offset : 0;
[?2004l[?2004h>         lines.push(
[?2004l[?2004h>           <line
[?2004l[?2004h>             key={key + '_a'}
[?2004l[?2004h>             x1={px1 - dx} y1={py1 - dy} x2={px2 - dx} y2={py2 - dy}
[?2004l[?2004h>             stroke="#0f0"
[?2004l[?2004h>             strokeWidth="2"
[?2004l[?2004h>             style={{ cursor: 'pointer' }}
[?2004l[?2004h>             onClick={(e) => {
[?2004l[?2004h>               if (e.ctrlKey || e.metaKey) {
[?2004l[?2004h>                 handleBridgeRemove(e, key);
[?2004l[?2004h>               }
[?2004l[?2004h>             }}
[?2004l[?2004h>             onContextMenu={(e) => handleBridgeRemove(e, key)}
[?2004l[?2004h>           />
[?2004l[?2004h>         );
[?2004l[?2004h>         lines.push(
[?2004l[?2004h>           <line
[?2004l[?2004h>             key={key + '_b'}
[?2004l[?2004h>             x1={px1 + dx} y1={py1 + dy} x2={px2 + dx} y2={py2 + dy}
[?2004l[?2004h>             stroke="#0f0"
[?2004l[?2004h>             strokeWidth="2"
[?2004l[?2004h>             style={{ cursor: 'pointer' }}
[?2004l[?2004h>             onClick={(e) => {
[?2004l[?2004h>               if (e.ctrlKey || e.metaKey) {
[?2004l[?2004h>                 handleBridgeRemove(e, key);
[?2004l[?2004h>               }
[?2004l[?2004h>             }}
[?2004l[?2004h>             onContextMenu={(e) => handleBridgeRemove(e, key)}
[?2004l[?2004h>           />
[?2004l[?2004h>         );
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>     return lines;
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   // Render islands
[?2004l[?2004h>   const renderIslands = () => {
[?2004l[?2004h>     return islands.map(island => {
[?2004l[?2004h>       const px = island.x * GRID;
[?2004l[?2004h>       const py = island.y * GRID;
[?2004l[?2004h>       const isSelected = selectedIsland === island.id;
[?2004l[?2004h> 
[?2004l[?2004h>       return (
[?2004l[?2004h>         <g key={island.id} onClick={() => handleIslandClick(island)} style={{ cursor: 'pointer' }}>
[?2004l[?2004h>           <circle
[?2004l[?2004h>             cx={px}
[?2004l[?2004h>             cy={py}
[?2004l[?2004h>             r={16}
[?2004l[?2004h>             fill="black"
[?2004l[?2004h>             stroke={isSelected ? '#ff0' : '#0f0'}
[?2004l[?2004h>             strokeWidth={isSelected ? 3 : 2}
[?2004l[?2004h>           />
[?2004l[?2004h>           <text
[?2004l[?2004h>             x={px}
[?2004l[?2004h>             y={py}
[?2004l[?2004h>             textAnchor="middle"
[?2004l[?2004h>             dominantBaseline="central"
[?2004l[?2004h>             fill="#0f0"
[?2004l[?2004h>             fontSize="14"
[?2004l[?2004h>             fontFamily="monospace"
[?2004l[?2004h>           >
[?2004l[?2004h>             {island.value}
[?2004l[?2004h>           </text>
[?2004l[?2004h>         </g>
[?2004l[?2004h>       );
[?2004l[?2004h>     });
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   // Render keyboard cursor (rect, not circle)
[?2004l[?2004h>   const renderCursor = () => {
[?2004l[?2004h>     const cursorIsland = islands.find(i => i.id === cursorIslandId);
[?2004l[?2004h>     if (!cursorIsland) return null;
[?2004l[?2004h>     const px = cursorIsland.x * GRID;
[?2004l[?2004h>     const py = cursorIsland.y * GRID;
[?2004l[?2004h>     return (
[?2004l[?2004h>       <rect
[?2004l[?2004h>         x={px - 20}
[?2004l[?2004h>         y={py - 20}
[?2004l[?2004h>         width={40}
[?2004l[?2004h>         height={40}
[?2004l[?2004h>         fill="none"
[?2004l[?2004h>         stroke={kbSelected ? '#ff0' : '#0ff'}
[?2004l[?2004h>         strokeWidth={2}
[?2004l[?2004h>         strokeDasharray="4 2"
[?2004l[?2004h>         pointerEvents="none"
[?2004l[?2004h>       />
[?2004l[?2004h>     );
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   return (
[?2004l[?2004h>     <div style={{ margin: 0, padding: 0 }}>
[?2004l[?2004h>       <svg
[?2004l[?2004h>         width={WIDTH}
[?2004l[?2004h>         height={HEIGHT}
[?2004l[?2004h>         style={{ display: 'block', position: 'absolute', top: 0, left: 0 }}
[?2004l[?2004h>       >
[?2004l[?2004h>         {renderBridges()}
[?2004l[?2004h>         {renderIslands()}
[?2004l[?2004h>         {renderCursor()}
[?2004l[?2004h>       </svg>
[?2004l[?2004h>       <div style={{
[?2004l[?2004h>         position: 'absolute',
[?2004l[?2004h>         top: HEIGHT + 5,
[?2004l[?2004h>         left: 0,
[?2004l[?2004h>         padding: '5px',
[?2004l[?2004h>         display: 'flex',
[?2004l[?2004h>         alignItems: 'center',
[?2004l[?2004h>         gap: '10px'
[?2004l[?2004h>       }}>
[?2004l[?2004h>         <select
[?2004l[?2004h>           value={puzzleIndex}
[?2004l[?2004h>           onChange={(e) => resetPuzzle(Number(e.target.value))}
[?2004l[?2004h>           style={{
[?2004l[?2004h>             background: 'black',
[?2004l[?2004h>             color: '#0f0',
[?2004l[?2004h>             border: '1px solid #0f0',
[?2004l[?2004h>             fontFamily: 'monospace',
[?2004l[?2004h>             padding: '4px'
[?2004l[?2004h>           }}
[?2004l[?2004h>         >
[?2004l[?2004h>           {puzzles.map((p, idx) => (
[?2004l[?2004h>             <option key={p.id} value={idx}>{p.name}</option>
[?2004l[?2004h>           ))}
[?2004l[?2004h>         </select>
[?2004l[?2004h>         <button
[?2004l[?2004h>           onClick={() => {
[?2004l[?2004h>             setBridges(new Map());
[?2004l[?2004h>             setSelectedIsland(null);
[?2004l[?2004h>             setError(null);
[?2004l[?2004h>             setVictory(false);
[?2004l[?2004h>             setCursorIslandId(0);
[?2004l[?2004h>             setKbSelected(false);
[?2004l[?2004h>           }}
[?2004l[?2004h>           style={{
[?2004l[?2004h>             background: 'black',
[?2004l[?2004h>             color: '#0f0',
[?2004l[?2004h>             border: '1px solid #0f0',
[?2004l[?2004h>             fontFamily: 'monospace',
[?2004l[?2004h>             padding: '4px 8px',
[?2004l[?2004h>             cursor: 'pointer'
[?2004l[?2004h>           }}
[?2004l[?2004h>         >
[?2004l[?2004h>           Reset
[?2004l[?2004h>         </button>
[?2004l[?2004h>         {error && <span className="error-message" style={{ color: '#f00', fontFamily: 'monospace' }}>{error}</span>}
[?2004l[?2004h>         {victory && <span className="victory-banner" style={{ color: '#0f0', fontFamily: 'monospace', fontSize: '20px', fontWeight: 'bold' }}>SOLVED!</span>}
[?2004l[?2004h>       </div>
[?2004l[?2004h>     </div>
[?2004l[?2004h>   );
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default App;
