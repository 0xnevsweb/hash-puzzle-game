[?2004l[?2004h> // Utility: create canonical bridge key from two islands (grid coords)
[?2004l[?2004h> export function bridgeKey(island1, island2) {
[?2004l[?2004h>   const [a, b] = [island1, island2].sort((p, q) => p.x - q.x || p.y - q.y);
[?2004l[?2004h>   return `${a.x},${a.y},${b.x},${b.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if two islands are adjacent (same row/col, no island between them)
[?2004l[?2004h> export function areAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.x !== to.x && from.y !== to.y) return false;
[?2004l[?2004h>   if (from.x === to.x && from.y === to.y) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   if (from.x === to.x) {
[?2004l[?2004h>     // Vertical
[?2004l[?2004h>     const minY = Math.min(from.y, to.y);
[?2004l[?2004h>     const maxY = Math.max(from.y, to.y);
[?2004l[?2004h>     return !islands.some(i =>
[?2004l[?2004h>       i.id !== from.id && i.id !== to.id &&
[?2004l[?2004h>       i.x === from.x && i.y > minY && i.y < maxY
[?2004l[?2004h>     );
[?2004l[?2004h>   } else {
[?2004l[?2004h>     // Horizontal
[?2004l[?2004h>     const minX = Math.min(from.x, to.x);
[?2004l[?2004h>     const maxX = Math.max(from.x, to.x);
[?2004l[?2004h>     return !islands.some(i =>
[?2004l[?2004h>       i.id !== from.id && i.id !== to.id &&
[?2004l[?2004h>       i.y === from.y && i.x > minX && i.x < maxX
[?2004l[?2004h>     );
[?2004l[?2004h>   }
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if a bridge between from and to would cross any existing bridge
[?2004l[?2004h> export function wouldCross(islands, bridges, from, to) {
[?2004l[?2004h>   // A bridge from->to is either horizontal or vertical
[?2004l[?2004h>   const isHorizontal = from.y === to.y;
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h> 
[?2004l[?2004h>     // Skip if this is the same bridge
[?2004l[?2004h>     const thisKey = bridgeKey(from, to);
[?2004l[?2004h>     if (key === thisKey) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     const existingIsHorizontal = y1 === y2;
[?2004l[?2004h> 
[?2004l[?2004h>     // Parallel bridges cannot cross in grid-based Hashi
[?2004l[?2004h>     if (isHorizontal === existingIsHorizontal) continue;
[?2004l counts match
  const counts = computeCurrentCo[?2004h> 
[?2004lu[?2004h>     // Perpendicular: check intersection
[?2004l[?2004h>     if (isHorizontal) {
[?2004l[?2004h>       // New bridge is horizontal, existing is vertical
[?2004l[?2004h>       const hMinX = Math.min(from.x, to.x);
[?2004l[?2004h>       const hMaxX = Math.max(from.x, to.x);
[?2004l[?2004h>       const hY = from.y;
[?2004l[?2004h>       const vX = x1; // vertical bridge x
[?2004l[?2004h>       const vMinY = Math.min(y1, y2);
[?2004l[?2004h>       const vMaxY = Math.max(y1, y2);
[?2004l[?2004h> 
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     } else {
[?2004l[?2004h>       // New bridge is vertical, existing is horizontal
[?2004l[?2004h>       const vMinY = Math.min(from.y, to.y);
[?2004l[?2004h>       const vMaxY = Math.max(from.y, to.y);
[?2004l[?2004h>       const vX = from.x;
[?2004l[?2004h>       const hY = y1; // horizontal bridge y
[?2004l[?2004h>       const hMinX = Math.min(x1, x2);
[?2004l[?2004h>       const hMaxX = Math.max(x1, x2);
[?2004l[?2004h> 
[?2004l[?2004h>       if (vX > hMinX && vX < hMaxX && hY > vMinY && hY < vMaxY) {
[?2004l[?2004h>         return true;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Validate if a bridge can be added
[?2004l[?2004h> // delta is the amount to add (usually 1 for cycling up)
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   // Degenerate case
[?2004l[?2004h>   if (from.id === to.id) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check adjacency
[?2004l[?2004h>   if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: "Cannot connect non-adjacent islands" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = bridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) || 0;
[?2004l[?2004h>   const newCount = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   // Check max bridges
[?2004l[?2004h>   if (newCount > 2) {
[?2004l[?2004h>     return { valid: false, error: "Max 2 bridges per pair" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check island capacity
[?2004l[?2004h>   const fromCounts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCurrent = fromCounts.get(from.id) || 0;
[?2004l[?2004h>   const toCurrent = fromCounts.get(to.id) || 0;
[?2004l[?2004h> 
[?2004l[?2004h>   if (fromCurrent + delta > from.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h>   if (toCurrent + delta > to.value) {
[?2004l[?2004h>     return { valid: false, error: "Island would exceed its number" };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Check crossing
[?2004l[?2004h>   if (delta > 0 && current === 0) {
[?2004l[?2004h>     // Only check crossing when adding a new bridge (not incrementing existing)
[?2004l[?2004h>     if (wouldCross(islands, bridges, from, to)) {
[?2004l[?2004h>       return { valid: false, error: "Bridges would cross" };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Compute current bridge counts for each island
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   islands.forEach(i => counts.set(i.id, 0));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const island1 = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const island2 = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (island1) counts.set(island1.id, (counts.get(island1.id) || 0) + count);
[?2004l[?2004h>     if (island2) counts.set(island2.id, (counts.get(island2.id) || 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if all islands are connected via bridges
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   if (islands.length === 1) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   // Build adjacency from bridges
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   islands.forEach(i => adj.set(i.id, []));
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (count === 0) continue;
[?2004l[?2004h>     const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>     const island1 = islands.find(i => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const island2 = islands.find(i => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (island1 && island2) {
[?2004l[?2004h>       adj.get(island1.id).push(island2.id);
[?2004l[?2004h>       adj.get(island2.id).push(island1.id);
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // BFS from first island
[?2004l[?2004h>   const visited = new Set();
[?2004l[?2004h>   const queue = [islands[0].id];
[?2004l[?2004h>   visited.add(islands[0].id);
[?2004l[?2004h> 
[?2004l[?2004h>   while (queue.length > 0) {
[?2004l[?2004h>     const curr = queue.shift();
[?2004l[?2004h>     for (const neighbor of adj.get(curr)) {
[?2004l[?2004h>       if (!visited.has(neighbor)) {
[?2004l[?2004h>         visited.add(neighbor);
[?2004l[?2004h>         queue.push(neighbor);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return visited.size === islands.length;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Check if the puzzle is solved
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // Check all counts match
