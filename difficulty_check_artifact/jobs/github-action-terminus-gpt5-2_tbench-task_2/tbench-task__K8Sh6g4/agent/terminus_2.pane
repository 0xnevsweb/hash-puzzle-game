[?2004l[?2004h>         if (target) setCursorId(target.id);
[?2004l[?2004h>       };
[?2004l[?2004h> 
[?2004l[?2004h>       if (e.key === 'ArrowLeft') move('left');
[?2004l[?2004h>       else if (e.key === 'ArrowRight') move('right');
[?2004l[?2004h>       else if (e.key === 'ArrowUp') move('up');
[?2004l[?2004h>       else if (e.key === 'ArrowDown') move('down');
[?2004l[?2004h>       else if (e.key === 'Enter') {
[?2004l[?2004h>         // Enter selects or toggles, analogous to click
[?2004l[?2004h>         const id = cursorId;
