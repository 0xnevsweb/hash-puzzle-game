[?2004l[?2004h>           return;
[?2004l[?2004h>         }
[?2004l[?2004h> 
[?2004l[?2004h>         // For keyboard we also want the descriptive "non-adjacent" error for non-adjacent
[?2004l[?2004h>         if (!areAdjacent(islands, from, to)) {
[?2004l[?2004h>           setError('Cannot connect non-adjacent islands');
[?2004l[?2004h>           setSelectedId(null);
