[?2004l[?2004h> 
[?2004l[?2004h>         applyToggle(from, to);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     window.addEventListener('keydown', onKeyDown);
