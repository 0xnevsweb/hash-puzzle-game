[?2004l[?2004hroot@edf4ce9dc4d4:/app# cat > src/utils/hashiLogic.js <<'EOF'
[?2004l[?2004h> // Hashi (Bridges) game logic utilities
[?2004l[?2004h> 
[?2004l[?2004h> export function canonicalBridgeKey(a, b) {
[?2004l[?2004h>   // key is based on grid coordinates (x,y) not ids
[?2004l[?2004h>   const p1 = { x: a.x, y: a.y };
[?2004l[?2004h>   const p2 = { x: b.x, y: b.y };
[?2004l[?2004h> 
[?2004l[?2004h>   let first = p1;
[?2004l[?2004h>   let second = p2;
[?2004l[?2004h>   if (p2.x < p1.x || (p2.x === p1.x && p2.y < p1.y)) {
[?2004l[?2004h>     first = p2;
[?2004l[?2004h>     second = p1;
[?2004l[?2004h>   }
[?2004l[?2004h>   return `${first.x},${first.y},${second.x},${second.y}`;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function parseBridgeKey(key) {
[?2004l[?2004h>   const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));
[?2004l[?2004h>   return { x1, y1, x2, y2 };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l.[?2004h> export function isAxisAligned(a, b) {
[?2004l[?2004h>   return a.x === b.x || a.y === b.y;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function areAdjacent(islands, a, b) {
[?2004l[?2004h>   if (!isAxisAligned(a, b)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   if (a.x === b.x) {
[?2004l[?2004h>     const x = a.x;
[?2004l[?2004h>     const yMin = Math.min(a.y, b.y);
[?2004l[?2004h>     const yMax = Math.max(a.y, b.y);
[?2004l[?2004h>     // adjacent if no island strictly between them on the same column
[?2004l[?2004h>     return !islands.some((i) => i.id !== a.id && i.id !== b.id && i.x === x && i.y > yMin && i.y < yMax);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const y = a.y;
[?2004l[?2004h>   const xMin = Math.min(a.x, b.x);
[?2004l[?2004h>   const xMax = Math.max(a.x, b.x);
[?2004l[?2004h>   return !islands.some((i) => i.id !== a.id && i.id !== b.id && i.y === y && i.x > xMin && i.x < xMax);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function rangesOverlap(a1, a2, b1, b2) {
[?2004l[?2004h>   const minA = Math.min(a1, a2);
[?2004l[?2004h>   const maxA = Math.max(a1, a2);
[?2004l[?2004h>   const minB = Math.min(b1, b2);
[?2004l[?2004h>   const maxB = Math.max(b1, b2);
[?2004l[?2004h>   return Math.max(minA, minB) < Math.min(maxA, maxB);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function bridgesWouldCross(islands, bridges, a, b) {
[?2004l[?2004h>   if (!isAxisAligned(a, b)) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   const newIsVertical = a.x === b.x;
[?2004l[?2004h>   const newX1 = a.x;
[?2004l[?2004h>   const newY1 = a.y;
[?2004l[?2004h>   const newX2 = b.x;
[?2004l[?2004h>   const newY2 = b.y;
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const existingVertical = x1 === x2;
[?2004l[?2004h> 
[?2004l[?2004h>     // Same orientation can overlap/duplicate but not "cross" in Hashi terms.
[?2004l[?2004h>     if (existingVertical === newIsVertical) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     // Check proper intersection (not at endpoints).
[?2004l[?2004h>     // vertical segment at x = xv, y in (yvMin, yvMax)
[?2004l[?2004h>     // horizontal segment at y = yh, x in (xhMin, xhMax)
[?2004l[?2004h>     let xv, yv1, yv2, yh, xh1, xh2;
[?2004l[?2004h>     if (existingVertical) {
[?2004l[?2004h>       xv = x1;
[?2004l[?2004h>       yv1 = y1;
[?2004l[?2004h>       yv2 = y2;
[?2004l[?2004h>       yh = newY1;
[?2004l[?2004h>       xh1 = newX1;
[?2004l[?2004h>       xh2 = newX2;
[?2004l[?2004h>     } else {
[?2004l[?2004h>       xv = newX1;
[?2004l[?2004h>       yv1 = newY1;
[?2004l[?2004h>       yv2 = newY2;
[?2004l[?2004h>       yh = y1;
[?2004l[?2004h>       xh1 = x1;
[?2004l[?2004h>       xh2 = x2;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     // intersection at (xv, yh)
[?2004l[?2004h>     const vMin = Math.min(yv1, yv2);
[?2004l[?2004h>     const vMax = Math.max(yv1, yv2);
[?2004l[?2004h>     const hMin = Math.min(xh1, xh2);
[?2004l[?2004h>     const hMax = Math.max(xh1, xh2);
[?2004l[?2004h> 
[?2004l[?2004h>     const intersects = xv > hMin && xv < hMax && yh > vMin && yh < vMax;
[?2004l[?2004h>     if (!intersects) continue;
[?2004l[?2004h> 
[?2004l[?2004h>     // If intersection point is an island coordinate, allow (it means meeting at island).
[?2004l[?2004h>     const intersectionIsIsland = islands.some((i) => i.x === xv && i.y === yh);
[?2004l[?2004h>     if (!intersectionIsIsland) return true;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return false;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function computeCurrentCounts(islands, bridges) {
[?2004l[?2004h>   const counts = new Map();
[?2004l[?2004h>   for (const isl of islands) counts.set(isl.id, 0);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + count);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + count);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function canAddBridge(islands, bridges, from, to, delta) {
[?2004l[?2004h>   if (!from || !to) return { valid: false, error: 'Invalid islands' };
[?2004l[?2004h>   if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };
[?2004l[?2004h>   if (!isAxisAligned(from, to) || !areAdjacent(islands, from, to)) {
[?2004l[?2004h>     return { valid: false, error: 'Cannot connect non-adjacent islands' };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>   const current = bridges.get(key) ?? 0;
[?2004l[?2004h>   const next = current + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next > 2) return { valid: false, error: 'Max 2 bridges per pair' };
[?2004l[?2004h>   if (next < 0) return { valid: false, error: 'Invalid bridge count' };
[?2004l[?2004h> 
[?2004l[?2004h>   // Crossing check is for adding (delta > 0) only
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     const temp = new Map(bridges);
[?2004l[?2004h>     temp.set(key, next);
[?2004l[?2004h>     if (bridgesWouldCross(islands, temp, from, to)) {
[?2004l[?2004h>       return { valid: false, error: 'Bridges would cross' };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // Island capacity check
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) ?? 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) ?? 0;
[?2004l[?2004h> 
[?2004l[?2004h>   if (delta > 0) {
[?2004l[?2004h>     if (fromCount + delta > from.value || toCount + delta > to.value) {
[?2004l[?2004h>       return { valid: false, error: 'Island would exceed its number' };
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h> 
[?2004l[?2004h>   const adj = new Map();
[?2004l[?2004h>   for (const isl of islands) adj.set(isl.id, []);
[?2004l[?2004h> 
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     adj.get(a.id).push(b.id);
[?2004l[?2004h>     adj.get(b.id).push(a.id);
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   const start = islands[0].id;
[?2004l[?2004h>   const seen = new Set([start]);
[?2004l[?2004h>   const stack = [start];
[?2004l[?2004h>   while (stack.length) {
[?2004l[?2004h>     const cur = stack.pop();
[?2004l[?2004h>     for (const n of adj.get(cur) || []) {
[?2004l[?2004h>       if (!seen.has(n)) {
[?2004l[?2004h>         seen.add(n);
[?2004l[?2004h>         stack.push(n);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return islands.every((i) => seen.has(i.id));
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function isVictory(islands, bridges) {
[?2004l[?2004h>   // counts satisfied
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // no crossings
[?2004l[?2004h>   for (const [key, count] of bridges.entries()) {
[?2004l[?2004h>     if (!count) continue;
[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     if (bridgesWouldCross(islands, bridges, a, b)) return false;
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   // connected
[?2004l[?2004h>   return checkConnectivity(islands, bridges);
[?2004l[?2004h> }
[?2004l[?2004h> EOF
