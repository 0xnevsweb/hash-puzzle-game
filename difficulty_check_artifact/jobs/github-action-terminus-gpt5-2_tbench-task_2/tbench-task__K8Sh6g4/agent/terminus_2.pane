[?2004limport React, { useEffect, useMemo, useState } from 'react';
import { PUZZLES, PUZZLE_OPTIONS } from './data/puzzles';
import {
  areAdjacent,
  canAddBridge,
  canonicalBridgeKey,
  computeCurrentCounts,
  isVictory,
  parseBridgeKey
} from './utils/hashiLogic';

const GRID = 40;
const SVG_W = 800;
const SVG_H = 600;

function islandById(islands, id) {
  return islands.find((i) => i.id === id) || null;
}

function findIslandAt(islands, x, y) {
  return islands.find((i) => i.x === x && i.y === y) || null;
}

function islandsInDirection(islands, from, dir) {
  // Return nearest island strictly in direction if exists.
  // dir: 'left'|'right'|'up'|'down'
  let best = null;
  for (const isl of islands) {
    if (isl.id === from.id) continue;
    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {
      if (!best || isl.x > best.x) best = isl;
    }
    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {
      if (!best || isl.x < best.x) best = isl;
    }
    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {
      if (!best || isl.y > best.y) best = isl;
    }
    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {
      if (!best || isl.y < best.y) best = isl;
    }
  }
  return best;
}

function bridgeLinesForKey(key, count) {
  // returns [{x1,y1,x2,y2, offset:{dx,dy}, index}]
  const { x1, y1, x2, y2 } = parseBridgeKey(key);
  const vertical = x1 === x2;

  if (count === 1) {
    return [{ x1, y1, x2, y2, dx: 0, dy: 0, idx: 0 }];
  }

  if (count === 2) {
    // offset by 4px perpendicular in pixel space => 4/GRID in grid units
    const off = 4 / GRID;
    if (vertical) {
      return [
        { x1: x1 - off, y1, x2: x2 - off, y2, dx: -off, dy: 0, idx: 0 },
        { x1: x1 + off, y1, x2: x2 + off, y2, dx: off, dy: 0, idx: 1 }
      ];
    }
    return [
      { x1, y1: y1 - off, x2, y2: y2 - off, dx: 0, dy: -off, idx: 0 },
      { x1, y1: y1 + off, x2, y2: y2 + off, dx: 0, dy: off, idx: 1 }
    ];
  }

  return [];
}

export default function App() {
  const [puzzleKey, setPuzzleKey] = useState('Easy');
  const islands = useMemo(() => PUZZLES[puzzleKey].islands, [puzzleKey]);

  const [bridges, setBridges] = useState(() => new Map());
  const [selectedId, setSelectedId] = useState(null); // first click/enter selection
  const [cursorId, setCursorId] = useState(0);
  const [error, setError] = useState(null);
  const [victory, setVictory] = useState(false);

  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);

  // Park cursor on id=0 after any puzzle change (and reset everything)
  useEffect(() => {
    setCursorId(0);
    setSelectedId(null);
    setError(null);
    setVictory(false);
    setBridges(new Map());
  }, [puzzleKey]);

  // Keep cursor parked on id=0 after any puzzle change AND after any puzzle change was already handled.
  // (Requirement: after any puzzle change; also after any puzzle change selection etc.)

  useEffect(() => {
    setVictory(isVictory(islands, bridges));
  }, [islands, bridges]);

  function clearAfterValidMove() {
    setError(null);
  }

  function resetAll() {
    setBridges(new Map());
    setSelectedId(null);
    setCursorId(0);
    setError(null);
    setVictory(false);
  }

  function applyToggle(from, to) {
    const key = canonicalBridgeKey(from, to);
    const current = bridges.get(key) ?? 0;
    const next = current === 0 ? 1 : current === 1 ? 2 : 0;

    // Validate as delta steps if adding. For removal (next=0) always allowed.
    if (next === 0) {
      const nb = new Map(bridges);
      nb.delete(key);
      setBridges(nb);
      clearAfterValidMove();
      setSelectedId(null);
      setCursorId(0);
      return;
    }

    const delta = next - current;
    const check = canAddBridge(islands, bridges, from, to, delta);
    if (!check.valid) {
      // When second click produces an error, also reset the in-progress selection now.
      setError(check.error || 'Invalid move');
      setSelectedId(null);
      return;
    }

    const nb = new Map(bridges);
    nb.set(key, next);
    setBridges(nb);
    clearAfterValidMove();
    setSelectedId(null);
    setCursorId(0);
  }

  function onIslandActivate(id) {
    const island = islandById(islands, id);
    if (!island) return;

    // first click selects only
    if (selectedId == null) {
      setSelectedId(id);
      setError(null);
      return;
    }

    // second click against different island performs toggle
    if (selectedId === id) {
      // treat as reselect (no toggle)
      setSelectedId(id);
      setError(null);
      return;
    }

    const from = islandById(islands, selectedId);
    const to = island;
    if (!from || !to) {
      setSelectedId(null);
      return;
    }

    applyToggle(from, to);
  }

  function removeBridgeByKey(key) {
    if (!(bridges.get(key) > 0)) return;
    const nb = new Map(bridges);
    nb.delete(key);
    setBridges(nb);
    setError(null);
    setSelectedId(null);
    setCursorId(0);
  }

  function onBridgeLineContextMenu(e, key) {
    e.preventDefault();
    removeBridgeByKey(key);
  }

  function onBridgeLineClick(e, key) {
    if (e.ctrlKey) {
      removeBridgeByKey(key);
    }
  }

  // keyboard controls on window/document (not focused element)
  useEffect(() => {
    function onKeyDown(e) {
      if (e.key === 'Escape') {
        setSelectedId(null);
        setError(null);
        return;
      }

      const cur = islandById(islands, cursorId) || islands[0];
      if (!cur) return;

      const move = (dir) => {
        const target = islandsInDirection(islands, cur, dir);
        if (target) setCursorId(target.id);
      };

      if (e.key === 'ArrowLeft') move('left');
      else if (e.key === 'ArrowRight') move('right');
      else if (e.key === 'ArrowUp') move('up');
      else if (e.key === 'ArrowDown') move('down');
      else if (e.key === 'Enter') {
        // Enter selects or toggles, analogous to click
        const id = cursorId;
        if (selectedId == null) {
          setSelectedId(id);
          setError(null);
          return;
        }
        if (selectedId === id) {
          setSelectedId(id);
          setError(null);
          return;
        }

        const from = islandById(islands, selectedId);
        const to = islandById(islands, id);
        if (!from || !to) {
          setSelectedId(null);
          return;
        }

        // For keyboard we also want the descriptive "non-adjacent" error for non-adjacent
        if (!areAdjacent(islands, from, to)) {
          setError('Cannot connect non-adjacent islands');
          setSelectedId(null);
          return;
        }

        applyToggle(from, to);
      }
    }

    window.addEventListener('keydown', onKeyDown);
    return () => window.removeEventListener('keydown', onKeyDown);
  }, [islands, cursorId, selectedId, bridges]);

  const bridgeRenderList = useMemo(() => {
    const items = [];
    for (const [key, count] of bridges.entries()) {
      if (!count) continue;
      const lines = bridgeLinesForKey(key, count);
      for (const ln of lines) items.push({ key, count, ...ln });
    }
    return items;
[?2004hroot@edf4ce9dc4d4:/app# sed -n '1,260p' src/utils/hashiLogic.js
[?2004l// Hashi (Bridges) game logic utilities

export function canonicalBridgeKey(a, b) {
  // key is based on grid coordinates (x,y) not ids
  const p1 = { x: a.x, y: a.y };
  const p2 = { x: b.x, y: b.y };

  let first = p1;
  let second = p2;
  if (p2.x < p1.x || (p2.x === p1.x && p2.y < p1.y)) {
    first = p2;
    second = p1;
  }
  return `${first.x},${first.y},${second.x},${second.y}`;
}

export function parseBridgeKey(key) {
  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));
  return { x1, y1, x2, y2 };
}

export function isAxisAligned(a, b) {
  return a.x === b.x || a.y === b.y;
}

export function areAdjacent(islands, a, b) {
  if (!isAxisAligned(a, b)) return false;

  if (a.x === b.x) {
    const x = a.x;
    const yMin = Math.min(a.y, b.y);
    const yMax = Math.max(a.y, b.y);
    // adjacent if no island strictly between them on the same column
    return !islands.some((i) => i.id !== a.id && i.id !== b.id && i.x === x && i.y > yMin && i.y < yMax);
  }

  const y = a.y;
  const xMin = Math.min(a.x, b.x);
  const xMax = Math.max(a.x, b.x);
  return !islands.some((i) => i.id !== a.id && i.id !== b.id && i.y === y && i.x > xMin && i.x < xMax);
}

function rangesOverlap(a1, a2, b1, b2) {
  const minA = Math.min(a1, a2);
  const maxA = Math.max(a1, a2);
  const minB = Math.min(b1, b2);
  const maxB = Math.max(b1, b2);
  return Math.max(minA, minB) < Math.min(maxA, maxB);
}

export function bridgesWouldCross(islands, bridges, a, b) {
  if (!isAxisAligned(a, b)) return false;

  const newIsVertical = a.x === b.x;
  const newX1 = a.x;
  const newY1 = a.y;
  const newX2 = b.x;
  const newY2 = b.y;

  for (const [key, count] of bridges.entries()) {
    if (!count) continue;
    const { x1, y1, x2, y2 } = parseBridgeKey(key);
    const existingVertical = x1 === x2;

    // Same orientation can overlap/duplicate but not "cross" in Hashi terms.
    if (existingVertical === newIsVertical) continue;

    // Check proper intersection (not at endpoints).
    // vertical segment at x = xv, y in (yvMin, yvMax)
    // horizontal segment at y = yh, x in (xhMin, xhMax)
    let xv, yv1, yv2, yh, xh1, xh2;
    if (existingVertical) {
      xv = x1;
      yv1 = y1;
      yv2 = y2;
      yh = newY1;
      xh1 = newX1;
      xh2 = newX2;
    } else {
      xv = newX1;
      yv1 = newY1;
      yv2 = newY2;
      yh = y1;
      xh1 = x1;
      xh2 = x2;
    }

    // intersection at (xv, yh)
    const vMin = Math.min(yv1, yv2);
    const vMax = Math.max(yv1, yv2);
    const hMin = Math.min(xh1, xh2);
    const hMax = Math.max(xh1, xh2);

    const intersects = xv > hMin && xv < hMax && yh > vMin && yh < vMax;
    if (!intersects) continue;

    // If intersection point is an island coordinate, allow (it means meeting at island).
    const intersectionIsIsland = islands.some((i) => i.x === xv && i.y === yh);
    if (!intersectionIsIsland) return true;
  }

  return false;
}

export function computeCurrentCounts(islands, bridges) {
  const counts = new Map();
  for (const isl of islands) counts.set(isl.id, 0);

  for (const [key, count] of bridges.entries()) {
    if (!count) continue;
    const { x1, y1, x2, y2 } = parseBridgeKey(key);
    const a = islands.find((i) => i.x === x1 && i.y === y1);
    const b = islands.find((i) => i.x === x2 && i.y === y2);
    if (!a || !b) continue;
    counts.set(a.id, (counts.get(a.id) ?? 0) + count);
    counts.set(b.id, (counts.get(b.id) ?? 0) + count);
  }
  return counts;
}

export function canAddBridge(islands, bridges, from, to, delta) {
  if (!from || !to) return { valid: false, error: 'Invalid islands' };
  if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };
  if (!isAxisAligned(from, to) || !areAdjacent(islands, from, to)) {
    return { valid: false, error: 'Cannot connect non-adjacent islands' };
  }

  const key = canonicalBridgeKey(from, to);
  const current = bridges.get(key) ?? 0;
  const next = current + delta;

  if (next > 2) return { valid: false, error: 'Max 2 bridges per pair' };
  if (next < 0) return { valid: false, error: 'Invalid bridge count' };

  // Crossing check is for adding (delta > 0) only
  if (delta > 0) {
    const temp = new Map(bridges);
    temp.set(key, next);
    if (bridgesWouldCross(islands, temp, from, to)) {
      return { valid: false, error: 'Bridges would cross' };
    }
  }

  // Island capacity check
  const counts = computeCurrentCounts(islands, bridges);
  const fromCount = counts.get(from.id) ?? 0;
  const toCount = counts.get(to.id) ?? 0;

  if (delta > 0) {
    if (fromCount + delta > from.value || toCount + delta > to.value) {
      return { valid: false, error: 'Island would exceed its number' };
    }
  }

  return { valid: true, error: null };
}

export function checkConnectivity(islands, bridges) {
  if (islands.length === 0) return true;

  const adj = new Map();
  for (const isl of islands) adj.set(isl.id, []);

  for (const [key, count] of bridges.entries()) {
    if (!count) continue;
    const { x1, y1, x2, y2 } = parseBridgeKey(key);
    const a = islands.find((i) => i.x === x1 && i.y === y1);
    const b = islands.find((i) => i.x === x2 && i.y === y2);
    if (!a || !b) continue;
    adj.get(a.id).push(b.id);
    adj.get(b.id).push(a.id);
  }

  const start = islands[0].id;
  const seen = new Set([start]);
  const stack = [start];
  while (stack.length) {
    const cur = stack.pop();
    for (const n of adj.get(cur) || []) {
      if (!seen.has(n)) {
        seen.add(n);
        stack.push(n);
      }
    }
  }

  return islands.every((i) => seen.has(i.id));
}

export function isVictory(islands, bridges) {
  // counts satisfied
  const counts = computeCurrentCounts(islands, bridges);
  for (const isl of islands) {
    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;
  }

  // no crossings
  for (const [key, count] of bridges.entries()) {
    if (!count) continue;
    const { x1, y1, x2, y2 } = parseBridgeKey(key);
    const a = islands.find((i) => i.x === x1 && i.y === y1);
    const b = islands.find((i) => i.x === x2 && i.y === y2);
    if (!a || !b) continue;
    if (bridgesWouldCross(islands, bridges, a, b)) return false;
  }

  // connected
  return checkConnectivity(islands, bridges);
}
