[190.067692, "o", "export const PUZZLES = {\r\n  Easy: {\r\n    name: 'Easy',\r\n    islands: [\r\n      { id: 0, x: 2, y: 2, value: 2 },\r\n      { id: 1, x: 6, y: 2, value: 2 },\r\n      { id: 2, x: 2, y: 6, value: 2 },\r\n      { id: 3, x: 6, y: 6, value: 2 }\r\n    ]\r\n  },\r\n  Medium: {\r\n    name: 'Medium',\r\n"]
