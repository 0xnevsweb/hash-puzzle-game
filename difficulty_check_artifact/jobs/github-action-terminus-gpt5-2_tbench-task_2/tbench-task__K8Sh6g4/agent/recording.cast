[121.453565, "i", "nction clearAfterValidMove() {\n    setError(null);\n  }\n\n  function resetAll() {\n    setBridges(new Map());\n    setSelectedId(null);\n    setCursorId(0);\n    setError(null);\n    setVictory(false);\n  }\n\n  function applyToggle(from, to) {\n    const key = canonicalBridgeKey(from, to);\n    const current = bridges.get(key) ?? 0;\n    const next = current === 0 ? 1 : current === 1 ? 2 : 0;\n\n    // Validate as delta steps if adding. For removal (next=0) always allowed.\n    if (next === 0) {\n      const nb = new Map(bridges);\n      nb.delete(key);\n      setBridges(nb);\n      clearAfterValidMove();\n      setSelectedId(null);\n      setCursorId(0);\n      return;\n    }\n\n    const delta = next - current;\n    const check = canAddBridge(islands, bridges, from, to, delta);\n    if (!check.valid) {\n      // When second click produces an error, also reset the in-progress selection now.\n      setError(check.error || 'Invalid move');\n      setSelectedId(null);\n      return;\n    }\n\n    const nb = new Map(bridges);\n    nb.set(key, nex"]
