[121.453093, "i", "cat > src/App.jsx <<'EOF'\nimport React, { useEffect, useMemo, useState } from 'react';\nimport { PUZZLES, PUZZLE_OPTIONS } from './data/puzzles';\nimport {\n  areAdjacent,\n  canAddBridge,\n  canonicalBridgeKey,\n  computeCurrentCounts,\n  isVictory,\n  parseBridgeKey\n} from './utils/hashiLogic';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction islandById(islands, id) {\n  return islands.find((i) => i.id === id) || null;\n}\n\nfunction findIslandAt(islands, x, y) {\n  return islands.find((i) => i.x === x && i.y === y) || null;\n}\n\nfunction islandsInDirection(islands, from, dir) {\n  // Return nearest island strictly in direction if exists.\n  // dir: 'left'|'right'|'up'|'down'\n  let best = null;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\n      if (!best || isl.x > best.x) best = isl;\n    }\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\n      if (!best || isl.x < best.x) best = isl;\n    }\n    if (dir =="]
[121.45323, "i", "= 'up' && isl.x === from.x && isl.y < from.y) {\n      if (!best || isl.y > best.y) best = isl;\n    }\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\n      if (!best || isl.y < best.y) best = isl;\n    }\n  }\n  return best;\n}\n\nfunction bridgeLinesForKey(key, count) {\n  // returns [{x1,y1,x2,y2, offset:{dx,dy}, index}]\n  const { x1, y1, x2, y2 } = parseBridgeKey(key);\n  const vertical = x1 === x2;\n\n  if (count === 1) {\n    return [{ x1, y1, x2, y2, dx: 0, dy: 0, idx: 0 }];\n  }\n\n  if (count === 2) {\n    // offset by 4px perpendicular in pixel space => 4/GRID in grid units\n    const off = 4 / GRID;\n    if (vertical) {\n      return [\n        { x1: x1 - off, y1, x2: x2 - off, y2, dx: -off, dy: 0, idx: 0 },\n        { x1: x1 + off, y1, x2: x2 + off, y2, dx: off, dy: 0, idx: 1 }\n      ];\n    }\n    return [\n      { x1, y1: y1 - off, x2, y2: y2 - off, dx: 0, dy: -off, idx: 0 },\n      { x1, y1: y1 + off, x2, y2: y2 + off, dx: 0, dy: off, idx: 1 }\n    ];\n  }\n\n  return [];\n}\n\nexport default function App() {\n "]
[121.453396, "o", "cat > src/App.jsx <<'EOF'\r\n"]
[121.453499, "i", " const [puzzleKey, setPuzzleKey] = useState('Easy');\n  const islands = useMemo(() => PUZZLES[puzzleKey].islands, [puzzleKey]);\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedId, setSelectedId] = useState(null); // first click/enter selection\n  const [cursorId, setCursorId] = useState(0);\n  const [error, setError] = useState(null);\n  const [victory, setVictory] = useState(false);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n\n  // Park cursor on id=0 after any puzzle change (and reset everything)\n  useEffect(() => {\n    setCursorId(0);\n    setSelectedId(null);\n    setError(null);\n    setVictory(false);\n    setBridges(new Map());\n  }, [puzzleKey]);\n\n  // Keep cursor parked on id=0 after any puzzle change AND after any puzzle change was already handled.\n  // (Requirement: after any puzzle change; also after any puzzle change selection etc.)\n\n  useEffect(() => {\n    setVictory(isVictory(islands, bridges));\n  }, [islands, bridges]);\n\n  fu"]
