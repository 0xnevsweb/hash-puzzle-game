[190.182369, "o", "s');\r\n          setSelectedId(null);\r\n          return;\r\n        }\r\n\r\n        applyToggle(from, to);\r\n      }\r\n    }\r\n\r\n    window.addEventListener('keydown', onKeyDown);\r\n    return () => window.removeEventListener('keydown', onKeyDown);\r\n  }, [islands, cursorId, selectedId, bridges]);\r\n\r\n  const bridgeRenderList = useMemo(() => {\r\n    const items = [];\r\n    for (const [key, count] of bridges.entries()) {\r\n      if (!count) continue;\r\n      const lines = bridgeLinesForKey(key, count);\r\n      for (const ln of lines) items.push({ key, count, ...ln });\r\n    }\r\n    return items;\r\n"]
