[190.181169, "o", "import React, { useEffect, useMemo, useState } from 'react';\r\nimport { PUZZLES, PUZZLE_OPTIONS } from './data/puzzles';\r\nimport {\r\n  areAdjacent,\r\n  canAddBridge,\r\n  canonicalBridgeKey,\r\n  computeCurrentCounts,\r\n  isVictory,\r\n  parseBridgeKey\r\n} from './utils/hashiLogic';\r\n\r\nconst GRID = 40;"]
[190.18129, "o", "\r\nconst SVG_W = 800;\r\nconst SVG_H = 600;\r\n\r\nfunction islandById(islands, id) {\r\n  return islands.find((i) => i.id === id) || null;\r\n}\r\n\r\nfunction findIslandAt(islands, x, y) {\r\n  return islands.find((i) => i.x === x && i.y === y) || null;\r\n"]
[190.181309, "o", "}\r\n\r\nfunction islandsInDirection(islands, from, dir) {\r\n  // Return nearest island strictly in direction if exists.\r\n  // dir: 'left'|'right'|'up'|'down'\r\n"]
[190.181616, "o", "  let best = null;\r\n  for (const isl of islands) {\r\n    if (isl.id === from.id) continue;\r\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\r\n      if (!best || isl.x > best.x) best = isl;\r\n    }\r\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\r\n      if (!best || isl.x < best.x) best = isl;\r\n    }\r\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\r\n      if (!best || isl.y > best.y) best = isl;\r\n    }\r\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\r\n      if (!best || isl.y < best.y) best = isl;\r\n    }\r\n  }\r\n  return best;\r\n}\r\n\r\nfunction bridgeLinesForKey(key, count) {\r\n  // returns [{x1,y1,x2,y2, offset:{dx,dy}, index}]\r\n  const { x1, y1, x2, y2 } = parseBridgeKey(key);\r\n  const vertical = x1 === x2;\r\n\r\n  if (count === 1) {\r\n    return [{ x1, y1, x2, y2, dx: 0, dy: 0, idx: 0 }];\r\n  }\r\n\r\n  if (count === 2) {\r\n    // offset by 4px perpendicular in pixel space => 4/GRID in grid units\r\n    const off = 4 / GRID;\r\n    if (vertical) {\r\n      return [\r\n   "]
[190.181804, "o", "     { x1: x1 - off, y1, x2: x2 - off, y2, dx: -off, dy: 0, idx: 0 },\r\n        { x1: x1 + off, y1, x2: x2 + off, y2, dx: off, dy: 0, idx: 1 }\r\n      ];\r\n    }\r\n    return [\r\n      { x1, y1: y1 - off, x2, y2: y2 - off, dx: 0, dy: -off, idx: 0 },\r\n      { x1, y1: y1 + off, x2, y2: y2 + off, dx: 0, dy: off, idx: 1 }\r\n    ];\r\n  }\r\n\r\n  return [];\r\n}\r\n\r\nexport default function App() {\r\n  const [puzzleKey, setPuzzleKey] = useState('Easy');\r\n  const islands = useMemo(() => PUZZLES[puzzleKey].islands, [puzzleKey]);\r\n\r\n  const [bridges, setBridges] = useState(() => new Map());\r\n  const [selectedId, setSelectedId] = useState(null); // first click/enter selection\r\n  const [cursorId, setCursorId] = useState(0);\r\n  const [error, setError] = useState(null);\r\n  const [victory, setVictory] = useState(false);\r\n\r\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\r\n\r\n  // Park cursor on id=0 after any puzzle change (and reset everything)\r\n  useEffect(() => {\r\n    setCursorId(0);\r\n    setS"]
[190.181856, "o", "electedId(null);\r\n    setError(null);\r\n    setVictory(false);\r\n    setBridges(new Map());\r\n  }, [puzzleKey]);\r\n\r\n  // Keep cursor parked on id=0 after any puzzle change AND after any puzzle change was already handled.\r\n  // (Requirement: after any puzzle change; also after any puzzle change selection etc.)\r\n\r\n  useEffect(() => {\r\n    setVictory(isVictory(islands, bridges));\r\n  }, [islands, bridges]);\r\n\r\n  function clearAfterValidMove() {\r\n    setError(null);\r\n  }\r\n\r\n  function resetAll() {\r\n    setBridges(new Map());\r\n    setSelectedId(null);\r\n    setCursorId(0);\r\n    setError(null);\r\n    setVictory(false);\r\n  }\r\n\r\n  function applyToggle(from, to) {\r\n    const key = canonicalBridgeKey(from, to);\r\n    const current = bridges.get(key) ?? 0;\r\n    const next = current === 0 ? 1 : current === 1 ? 2 : 0;\r\n\r\n    // Validate as delta steps if adding. For removal (next=0) always allowed.\r\n    if (next === 0) {\r\n      const nb = new Map(bridges);\r\n      nb.delete(key);\r\n      setBridges(nb);\r\n      clearAfterValidMove("]
[190.182049, "o", ");\r\n      setSelectedId(null);\r\n      setCursorId(0);\r\n      return;\r\n    }\r\n\r\n    const delta = next - current;\r\n    const check = canAddBridge(islands, bridges, from, to, delta);\r\n    if (!check.valid) {\r\n      // When second click produces an error, also reset the in-progress selection now.\r\n      setError(check.error || 'Invalid move');\r\n      setSelectedId(null);\r\n      return;\r\n    }\r\n\r\n    const nb = new Map(bridges);\r\n    nb.set(key, next);\r\n    setBridges(nb);\r\n    clearAfterValidMove();\r\n    setSelectedId(null);\r\n    setCursorId(0);\r\n  }\r\n\r\n  function onIslandActivate(id) {\r\n    const island = islandById(islands, id);\r\n    if (!island) return;\r\n\r\n    // first click selects only\r\n    if (selectedId == null) {\r\n      setSelectedId(id);\r\n      setError(null);\r\n      return;\r\n    }\r\n\r\n    // second click against different island performs toggle\r\n    if (selectedId === id) {\r\n      // treat as reselect (no toggle)\r\n      setSelectedId(id);\r\n      setError(null);\r\n      return;\r\n    }\r\n\r\n    const from = "]
[190.182325, "o", "islandById(islands, selectedId);\r\n    const to = island;\r\n    if (!from || !to) {\r\n      setSelectedId(null);\r\n      return;\r\n    }\r\n\r\n    applyToggle(from, to);\r\n  }\r\n\r\n  function removeBridgeByKey(key) {\r\n    if (!(bridges.get(key) > 0)) return;\r\n    const nb = new Map(bridges);\r\n    nb.delete(key);\r\n    setBridges(nb);\r\n    setError(null);\r\n    setSelectedId(null);\r\n    setCursorId(0);\r\n  }\r\n\r\n  function onBridgeLineContextMenu(e, key) {\r\n    e.preventDefault();\r\n    removeBridgeByKey(key);\r\n  }\r\n\r\n  function onBridgeLineClick(e, key) {\r\n    if (e.ctrlKey) {\r\n      removeBridgeByKey(key);\r\n    }\r\n  }\r\n\r\n  // keyboard controls on window/document (not focused element)\r\n  useEffect(() => {\r\n    function onKeyDown(e) {\r\n      if (e.key === 'Escape') {\r\n        setSelectedId(null);\r\n        setError(null);\r\n        return;\r\n      }\r\n\r\n      const cur = islandById(islands, cursorId) || islands[0];\r\n      if (!cur) return;\r\n\r\n      const move = (dir) => {\r\n        const target = islandsInDirection(islands, cur, d"]
