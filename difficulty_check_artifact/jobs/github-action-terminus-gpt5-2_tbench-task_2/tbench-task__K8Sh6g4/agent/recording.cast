[121.595919, "i", "cat > src/index.css <<'EOF'\n:root {\n  color-scheme: dark;\n}\n\nhtml,\nbody {\n  margin: 0;\n  padding: 0;\n  background: #000;\n  color: #00ff66;\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n}\n\n.app {\n  margin: 0;\n  padding: 0;\n}\n\n.hud {\n  position: fixed;\n  top: 0;\n  left: 0;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  padding: 8px 10px;\n  background: rgba(0, 0, 0, 0.8);\n  border-bottom: 1px solid rgba(0, 255, 102, 0.35);\n  z-index: 10;\n}\n\nselect,\nbutton {\n  background: #000;\n  color: #00ff66;\n  border: 1px solid rgba(0, 255, 102, 0.5);\n  font: inherit;\n  padding: 4px 8px;\n}\n\nbutton {\n  cursor: pointer;\n}\n\n.error-message {\n  margin-left: 10px;\n  color: #00ff66;\n  border: 1px solid rgba(0, 255, 102, 0.5);\n  padding: 4px 8px;\n}\n\n.victory-banner {\n  margin-left: 10px;\n  color: #00ff66;\n  border: 1px solid rgba(0, 255, 102, 0.9);\n  padding: 4px 8px;\n  font-weight: 700;\n}\n\n.board {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 800px;\n"]
[121.596051, "i", "  height: 600px;\n  background: #000;\n}\n\n.bridge {\n  stroke: #00ff66;\n  stroke-width: 4;\n  stroke-linecap: round;\n}\n\n.island {\n  fill: #000;\n  stroke: #00ff66;\n  stroke-width: 2;\n}\n\n.island-selected {\n  stroke-width: 4;\n}\n\n.island-text {\n  fill: #00ff66;\n  font-size: 16px;\n  pointer-events: none;\n}\n\n.island-subtext {\n  fill: rgba(0, 255, 102, 0.8);\n  font-size: 10px;\n  pointer-events: none;\n}\n\n.island-group {\n  cursor: pointer;\n}\n\n.cursor {\n  fill: none;\n  stroke: rgba(0, 255, 102, 0.8);\n  stroke-width: 2;\n  stroke-dasharray: 4 3;\n  pointer-events: none;\n}\n\n.cursor-selected {\n  stroke-width: 3;\n}\nEOF\n"]
