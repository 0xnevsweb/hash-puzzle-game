[121.258939, "o", "for (const isl of islands) {\r\n\u001b[?2004l\r\u001b[?2004h>     if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   // no crossings\r\n\u001b[?2004l\r\u001b[?2004h>   for (const [key, count] of bridges.entries()) {\r\n\u001b[?2004l\r\u001b[?2004h>     if (!count) continue;\r\n\u001b[?2004l\r\u001b[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);\r\n\u001b[?2004l\r\u001b[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);\r\n\u001b[?2004l\r\u001b[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);\r\n\u001b[?2004l\r\u001b[?2004h>     if (!a || !b) continue;\r\n\u001b[?2004l\r\u001b[?2004h>     if (bridgesWouldCross(islands, bridges, a, b)) return false;\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   // connected\r\n\u001b[?2004l\r\u001b[?2004h>   return checkConnectivity(islands, bridges);\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
