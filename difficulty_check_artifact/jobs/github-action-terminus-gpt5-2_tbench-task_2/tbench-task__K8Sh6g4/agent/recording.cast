[121.217151, "i", "cat > src/utils/hashiLogic.js <<'EOF'\n// Hashi (Bridges) game logic utilities\n\nexport function canonicalBridgeKey(a, b) {\n  // key is based on grid coordinates (x,y) not ids\n  const p1 = { x: a.x, y: a.y };\n  const p2 = { x: b.x, y: b.y };\n\n  let first = p1;\n  let second = p2;\n  if (p2.x < p1.x || (p2.x === p1.x && p2.y < p1.y)) {\n    first = p2;\n    second = p1;\n  }\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map((n) => Number(n));\n  return { x1, y1, x2, y2 };\n}\n\nexport function isAxisAligned(a, b) {\n  return a.x === b.x || a.y === b.y;\n}\n\nexport function areAdjacent(islands, a, b) {\n  if (!isAxisAligned(a, b)) return false;\n\n  if (a.x === b.x) {\n    const x = a.x;\n    const yMin = Math.min(a.y, b.y);\n    const yMax = Math.max(a.y, b.y);\n    // adjacent if no island strictly between them on the same column\n    return !islands.some((i) => i.id !== a.id && i.id !== b.id && i.x === x && i.y > yMin && i.y < yMax);\n  "]
[121.217198, "i", "}\n\n  const y = a.y;\n  const xMin = Math.min(a.x, b.x);\n  const xMax = Math.max(a.x, b.x);\n  return !islands.some((i) => i.id !== a.id && i.id !== b.id && i.y === y && i.x > xMin && i.x < xMax);\n}\n\nfunction rangesOverlap(a1, a2, b1, b2) {\n  const minA = Math.min(a1, a2);\n  const maxA = Math.max(a1, a2);\n  const minB = Math.min(b1, b2);\n  const maxB = Math.max(b1, b2);\n  return Math.max(minA, minB) < Math.min(maxA, maxB);\n}\n\nexport function bridgesWouldCross(islands, bridges, a, b) {\n  if (!isAxisAligned(a, b)) return false;\n\n  const newIsVertical = a.x === b.x;\n  const newX1 = a.x;\n  const newY1 = a.y;\n  const newX2 = b.x;\n  const newY2 = b.y;\n\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const existingVertical = x1 === x2;\n\n    // Same orientation can overlap/duplicate but not \"cross\" in Hashi terms.\n    if (existingVertical === newIsVertical) continue;\n\n    // Check proper intersection (not at endpoints).\n    // vertical s"]
[121.217207, "i", "egment at x = xv, y in (yvMin, yvMax)\n    // horizontal segment at y = yh, x in (xhMin, xhMax)\n    let xv, yv1, yv2, yh, xh1, xh2;\n    if (existingVertical) {\n      xv = x1;\n      yv1 = y1;\n      yv2 = y2;\n      yh = newY1;\n      xh1 = newX1;\n      xh2 = newX2;\n    } else {\n      xv = newX1;\n      yv1 = newY1;\n      yv2 = newY2;\n      yh = y1;\n      xh1 = x1;\n      xh2 = x2;\n    }\n\n    // intersection at (xv, yh)\n    const vMin = Math.min(yv1, yv2);\n    const vMax = Math.max(yv1, yv2);\n    const hMin = Math.min(xh1, xh2);\n    const hMax = Math.max(xh1, xh2);\n\n    const intersects = xv > hMin && xv < hMax && yh > vMin && yh < vMax;\n    if (!intersects) continue;\n\n    // If intersection point is an island coordinate, allow (it means meeting at island).\n    const intersectionIsIsland = islands.some((i) => i.x === xv && i.y === yh);\n    if (!intersectionIsIsland) return true;\n  }\n\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) c"]
[121.217215, "i", "ounts.set(isl.id, 0);\n\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + count);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + count);\n  }\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to) return { valid: false, error: 'Invalid islands' };\n  if (from.id === to.id) return { valid: false, error: 'Cannot connect island to itself' };\n  if (!isAxisAligned(from, to) || !areAdjacent(islands, from, to)) {\n    return { valid: false, error: 'Cannot connect non-adjacent islands' };\n  }\n\n  const key = canonicalBridgeKey(from, to);\n  const current = bridges.get(key) ?? 0;\n  const next = current + delta;\n\n  if (next > 2) return { valid: false, error: 'Max 2 bridges per pair' };\n  if (next < 0) ret"]
[121.217226, "i", "urn { valid: false, error: 'Invalid bridge count' };\n\n  // Crossing check is for adding (delta > 0) only\n  if (delta > 0) {\n    const temp = new Map(bridges);\n    temp.set(key, next);\n    if (bridgesWouldCross(islands, temp, from, to)) {\n      return { valid: false, error: 'Bridges would cross' };\n    }\n  }\n\n  // Island capacity check\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) ?? 0;\n  const toCount = counts.get(to.id) ?? 0;\n\n  if (delta > 0) {\n    if (fromCount + delta > from.value || toCount + delta > to.value) {\n      return { valid: false, error: 'Island would exceed its number' };\n    }\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = islands.fin"]
[121.217235, "i", "d((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const start = islands[0].id;\n  const seen = new Set([start]);\n  const stack = [start];\n  while (stack.length) {\n    const cur = stack.pop();\n    for (const n of adj.get(cur) || []) {\n      if (!seen.has(n)) {\n        seen.add(n);\n        stack.push(n);\n      }\n    }\n  }\n\n  return islands.every((i) => seen.has(i.id));\n}\n\nexport function isVictory(islands, bridges) {\n  // counts satisfied\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  // no crossings\n  for (const [key, count] of bridges.entries()) {\n    if (!count) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) "]
[121.219749, "i", "continue;\n    if (bridgesWouldCross(islands, bridges, a, b)) return false;\n  }\n\n  // connected\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"]
