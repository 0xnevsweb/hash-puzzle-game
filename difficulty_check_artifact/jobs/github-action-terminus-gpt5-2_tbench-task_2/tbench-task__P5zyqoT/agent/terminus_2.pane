[?2004l[?2004h>       </div>
[?2004l[?2004h> 
[?2004l[?2004h>       {error ? <div className="error-message">{error}</div> : null}
[?2004l[?2004h>       {!error && victory ? <div className="victory-banner">SOLVED!</div> : null}
[?2004l[?2004h> 
[?2004l[?2004h>       <svg width={SVG_W} height={SVG_H} style={{ position: 'fixed', left: 0, top: 0, zIndex: 1 }}>
