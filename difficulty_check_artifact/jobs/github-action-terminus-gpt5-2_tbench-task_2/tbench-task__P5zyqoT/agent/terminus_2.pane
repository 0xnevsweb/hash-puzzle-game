[?2004l[?2004h>               <text x={cx} y={cy + 28} textAnchor="middle" fontSize={10} fill="#00ff66">
[?2004l[?2004h>                 {curCount}/{isl.value}
[?2004l[?2004h>               </text>
[?2004l[?2004h>             </g>
