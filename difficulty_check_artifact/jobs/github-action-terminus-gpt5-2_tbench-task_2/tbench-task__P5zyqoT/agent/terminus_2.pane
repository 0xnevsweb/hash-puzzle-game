[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const removeBridge = (from, to) => {
[?2004l[?2004h>     const key = canonicalBridgeKey(from, to);
[?2004l[?2004h>     const cur = bridges.get(key) ?? 0;
[?2004l[?2004h>     if (!cur) return true;
[?2004l[?2004h>     setError(null);
[?2004l  [?2004h>     setBridges((prev) => {
[?2004l[?2004h>       const next = new Map(prev);
[?2004l[?2004h>       next.delete(key);
[?2004l[?2004h>       return next;
[?2004l[?2004h>     });
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>     setCursorId(0);
[?2004l[?2004h>     return true;
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const onIslandClick = (isl) => {
[?2004l[?2004h>     if (selectedId === null) {
[?2004l[?2004h>       setSelectedId(isl.id);
[?2004l[?2004h>       setCursorId(isl.id);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h>     if (selectedId === isl.id) return;
[?2004l[?2004h>     const from = islandsById.get(selectedId);
[?2004l[?2004h>     const to = isl;
[?2004l[?2004h>     cycleBridge(from, to);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const onIslandRemoveGesture = (e, isl) => {
[?2004l[?2004h>     e.preventDefault();
[?2004l[?2004h>     if (selectedId === null) return;
[?2004l[?2004h>     if (selectedId === isl.id) return;
[?2004l[?2004h>     const from = islandsById.get(selectedId);
[?2004l[?2004h>     removeBridge(from, isl);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const keyHandlerRef = useRef(null);
[?2004l[?2004h>   keyHandlerRef.current = (e) => {
[?2004l[?2004h>     if (e.key === 'Escape') {
[?2004l[?2004h>       setSelectedId(null);
[?2004l[?2004h>       return;
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004lu[?2004h>     const cur = islandsById.get(cursorId) ?? islands[0];
[?2004l[?2004h>     if (!cur) return;
[?2004l[?2004h>     const neighbors = getNeighbors(islands, cur);
[?2004l[?2004h> 
[?2004l[?2004h>     const moveCursor = (dir) => {
[?2004l[?2004h>       const next = neighbors[dir];
[?2004l[?2004h>       if (!next) return;
[?2004l[?2004h>       setCursorId(next.id);
[?2004l[?2004h>     };
[?2004l[?2004h> 
[?2004l[?2004h>     if (e.key === 'ArrowLeft') moveCursor('left');
[?2004l[?2004h>     else if (e.key === 'ArrowRight') moveCursor('right');
[?2004l[?2004h>     else if (e.key === 'ArrowUp') moveCursor('up');
[?2004l[?2004h>     else if (e.key === 'ArrowDown') moveCursor('down');
[?2004l[?2004h>     else if (e.key === 'Enter') {
[?2004l[?2004h>       if (selectedId === null) {
[?2004l[?2004h>         setSelectedId(cursorId);
[?2004l[?2004h>       } else {
[?2004l[?2004h>         const from = islandsById.get(selectedId);
[?2004l[?2004h>         const to = islandsById.get(cursorId);
[?2004l[?2004h>         if (from && to && from.id !== to.id) cycleBridge(from, to);
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     const onKeyDown = (e) => keyHandlerRef.current?.(e);
[?2004l[?2004h>     window.addEventListener('keydown', onKeyDown);
[?2004l[?2004h>     return () => window.removeEventListener('keydown', onKeyDown);
[?2004l[?2004h>   }, []);
[?2004l[?2004h> 
[?2004l[?2004h>   useEffect(() => {
[?2004l[?2004h>     setCursorId(0);
[?2004l[?2004h>   }, [puzzleKey]);
[?2004l[?2004h> 
[?2004l[?2004h>   const renderedBridges = useMemo(() => {
[?2004l[?2004h>     const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));
[?2004l[?2004h>     const lines = [];
[?2004l[?2004h>     for (const [key, n] of bridges.entries()) {
[?2004l[?2004h>       const [x1, y1, x2, y2] = key.split(',').map(Number);
[?2004l[?2004h>       const a = byCoord.get(`${x1},${y1}`);
