[?2004l[?2004h>         ))}
[?2004l[?2004h> 
[?2004l[?2004h>         <rect
[?2004l[?2004h>           x={cursorPx.x - 16}
[?2004l[?2004h>           y={cursorPx.y - 16}
[?2004l[?2004h>           width={32}
[?2004l[?2004h>           height={32}
[?2004l[?2004h>           fill="none"
[?2004l[?2004h>           stroke="#00ff66"
[?2004l[?2004h>           strokeWidth={2}
[?2004l[?2004h>           strokeDasharray={selectionMode ? '4 2' : '2 2'}
[?2004l[?2004h>         />
[?2004l[?2004h> 
