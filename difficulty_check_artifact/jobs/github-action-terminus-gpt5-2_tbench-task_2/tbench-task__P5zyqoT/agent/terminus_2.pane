[?2004l[?2004h>     return m;
[?2004l[?2004h>   }, [islands]);
[?2004l[?2004h> 
[?2004l[?2004h>   const cursorIsland = islandsById.get(cursorId) ?? islands[0];
[?2004l[?2004h> 
[?2004l[?2004h>   const resetAllStateForPuzzle = (nextPuzzleKey) => {
[?2004l[?2004h>     setPuzzleKey(nextPuzzleKey);
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setCursorId(0);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const resetBridgesOnly = () => {
[?2004l[?2004h>     setBridges(new Map());
[?2004l[?2004h>     setSelectedId(null);
[?2004l[?2004h>     setError(null);
[?2004l[?2004h>     setCursorId(0);
[?2004l[?2004h>   };
[?2004l[?2004h> 
[?2004l[?2004h>   const applyBridgeDelta = (from, to, delta) => {
