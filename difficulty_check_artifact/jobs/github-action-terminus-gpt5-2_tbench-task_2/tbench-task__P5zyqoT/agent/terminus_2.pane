[?2004l[?2004h>     { x1, y1: y1 - offset, x2, y2: y2 - offset },
[?2004l[?2004h>     { x1, y1: y1 + offset, x2, y2: y2 + offset },
[?2004l[?2004h>   ];
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export default function App() {
[?2004l[?2004h>   const [puzzleKey, setPuzzleKey] = useState('Easy');
[?2004l[?2004h>   const islands = puzzles[puzzleKey].islands;
[?2004l[?2004h> 
