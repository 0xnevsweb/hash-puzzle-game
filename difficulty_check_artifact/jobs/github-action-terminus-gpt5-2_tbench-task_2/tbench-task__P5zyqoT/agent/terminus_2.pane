[?2004l[?2004h>     <>
[?2004l[?2004h>       <div className="ui-bar">
[?2004l[?2004h>         <label>
[?2004l[?2004h>           Puzzle:{' '}
[?2004l[?2004h>           <select value={puzzleKey} onChange={(e) => resetAllStateForPuzzle(e.target.value)}>
[?2004l[?2004h>             {puzzleOptions.map((opt) => (
[?2004l[?2004h>               <option key={opt.key} value={opt.key}>
[?2004l[?2004h>                 {opt.label}
