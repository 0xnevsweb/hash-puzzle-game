[?2004l[?2004h>       if (isl.y < from.y) {
[?2004l[?2004h>         if (!candidates.up || isl.y > candidates.up.y) candidates.up = isl;
[?2004l[?2004h>       } else if (isl.y > from.y) {
[?2004l[?2004h>         if (!candidates.down || isl.y < candidates.down.y) candidates.down = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return candidates;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function bridgeLinesForPair(from, to, count) {
[?2004l[?2004h>   if (!count) return [];
[?2004l[?2004h>   const x1 = from.x * CELL;
