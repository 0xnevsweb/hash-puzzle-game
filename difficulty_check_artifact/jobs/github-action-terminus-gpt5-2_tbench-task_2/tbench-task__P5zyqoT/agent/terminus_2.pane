[?2004l[?2004h> const SVG_H = 600;
[?2004l[?2004h> 
[?2004l[?2004h> function getNeighbors(islands, from) {
[?2004l[?2004h>   const candidates = { left: null, right: null, up: null, down: null };
[?2004l[?2004h>   for (const isl of islands) {
[?2004l[?2004h>     if (isl.id === from.id) continue;
[?2004l[?2004h>     if (isl.y === from.y) {
[?2004l[?2004h>       if (isl.x < from.x) {
[?2004l[?2004h>         if (!candidates.left || isl.x > candidates.left.x) candidates.left = isl;
[?2004l[?2004h>       } else if (isl.x > from.x) {
[?2004l[?2004h>         if (!candidates.right || isl.x < candidates.right.x) candidates.right = isl;
[?2004l[?2004h>       }
[?2004l[?2004h>     }
