[134.053103, "i", "cat > src/utils/hashiLogic.js <<'EOF'\nconst ERROR_NON_ADJ = 'Cannot connect non-adjacent islands';\nconst ERROR_MAX2 = 'Max 2 bridges per pair';\nconst ERROR_EXCEED = 'Island would exceed its number';\nconst ERROR_CROSS = 'Bridges would cross';\n\nexport function canonicalBridgeKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;\n  const second = first === a ? b : a;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nfunction between(v, a, b) {\n  const min = Math.min(a, b);\n  const max = Math.max(a, b);\n  return v > min && v < max;\n}\n\nfunction isAdjacent(islands, from, to) {\n  if (from.x !== to.x && from.y !== to.y) return false;\n\n  if (from.x === to.x) {\n    const x = from.x;\n    const minY = Math.min(from.y, to.y);\n    const maxY = Math.max(from.y, to.y);\n    for (const isl of islands) {\n      if (isl.x === x && isl.y > minY && isl.y < maxY) return false;\n    }\n    return true;\n  }\n\n  const y = from.y;\n"]
[134.053515, "i", "  const minX = Math.min(from.x, to.x);\n  const maxX = Math.max(from.x, to.x);\n  for (const isl of islands) {\n    if (isl.y === y && isl.x > minX && isl.x < maxX) return false;\n  }\n  return true;\n}\n\nfunction wouldCrossExisting(bridges, from, to) {\n  const ax = from.x,\n    ay = from.y,\n    bx = to.x,\n    by = to.y;\n  const candVert = ax === bx;\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n\n    const sharesEndpoint =\n      (x1 === ax && y1 === ay) ||\n      (x2 === ax && y2 === ay) ||\n      (x1 === bx && y1 === by) ||\n      (x2 === bx && y2 === by);\n    if (sharesEndpoint) continue;\n\n    const exVert = x1 === x2;\n    if (candVert === exVert) continue;\n\n    const vx = candVert ? ax : x1;\n    const vy1 = candVert ? ay : y1;\n    const vy2 = candVert ? by : y2;\n\n    const hy = candVert ? y1 : ay;\n    const hx1 = candVert ? x1 : ax;\n    const hx2 = candVert ? x2 : bx;\n\n    if (between(vx, hx1, hx2) && between(hy, vy1, vy2)) return true;\n "]
[134.053912, "o", "cat > src/utils/hashiLogic.js <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> const ERROR_NON_ADJ = 'Cannot connect non-adjacent islands';\r\n\u001b[?2004l\r\u001b[?2004h> const ERROR_MAX2 = 'Max 2 bridges per pair';\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.053947, "i", " }\n  return false;\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!from || !to || from.id === to.id) return { valid: false, error: ERROR_NON_ADJ };\n  if (!isAdjacent(islands, from, to)) return { valid: false, error: ERROR_NON_ADJ };\n\n  const key = canonicalBridgeKey(from, to);\n  const cur = bridges.get(key) ?? 0;\n  const next = cur + delta;\n\n  if (next < 0) return { valid: true, error: null };\n  if (next > 2) return { valid: false, error: ERROR_MAX2 };\n"]
[134.054435, "i", "\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) ?? 0;\n  const toCount = counts.get(to.id) ?? 0;\n  if (fromCount + delta > from.value || toCount + delta > to.value) {\n    return { valid: false, error: ERROR_EXCEED };\n  }\n\n  if (delta > 0 && wouldCrossExisting(bridges, from, to)) {\n    return { valid: false, error: ERROR_CROSS };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\n\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, new Set());\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a.id).add(b.id);\n    adj.get(b.id).add(a.id);\n  }\n\n  const startId = islands[0].id;\n  const seen = ne"]
