[81.294096, "o", "+      if (isl.x === x && isl.y > minY && isl.y < maxY) return false;\r\n\u001b[?2004l\r"]
[81.294264, "o", "\u001b[?2004h> "]
[81.294297, "o", "+    }\r\n\u001b[?2004l\r\u001b[?2004h> +    return true;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.294487, "o", "+  }\r\n\u001b[?2004l\r\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> +  const y = from.y;\r\n\u001b[?2004l\r"]
[81.29466, "o", "\u001b[?2004h> +  const minX = Math.min(from.x, to.x);\r\n\u001b[?2004l\r"]
[81.294802, "o", "\u001b[?2004h> "]
[81.294951, "o", "+  const maxX = Math.max(from.x, to.x);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.295115, "o", "+  for (const isl of islands) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.295235, "o", "+    if (isl.y === y && isl.x > minX && isl.x < maxX) return false;\r\n\u001b[?2004l\r"]
[81.295257, "o", "\u001b[?2004h> "]
[81.295393, "o", "+  }\r\n\u001b[?2004l\r\u001b[?2004h> +  return true;\r\n\u001b[?2004l\r"]
[81.295424, "o", "\u001b[?2004h> "]
