[134.05451, "i", "w Set([startId]);\n  const q = [startId];\n  while (q.length) {\n    const cur = q.shift();\n    for (const nxt of adj.get(cur) ?? []) {\n      if (!seen.has(nxt)) {\n        seen.add(nxt);\n        q.push(nxt);\n      }\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // crossing check among existing bridges\n  const segs = [];\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const [x1, y1, x2, y2] = key.split(',').map(Number);\n    segs.push({ x1, y1, x2, y2 });\n  }\n  for (let i = 0; i < segs.length; i++) {\n    for (let j = i + 1; j < segs.length; j++) {\n      const a = segs[i];\n      const b = segs[j];\n      const aVert = a.x1 === a.x2;\n      const bVert = b.x1 === b.x2;\n      if (aVert === bVert) continue;\n\n      const aEndpoints = new Set([`${a.x1},${a.y1}`, `${a.x2},${a.y2}`]);\n      if (aEndpoints.has(`${b.x1},${b.y1}`) || aEndpoints.has(`${b.x2},${b.y2}`)) continue;\n\n      const vx = aVert ? a.x1 : b.x1;\n      const vy1 = aVert ? a.y1 : b"]
