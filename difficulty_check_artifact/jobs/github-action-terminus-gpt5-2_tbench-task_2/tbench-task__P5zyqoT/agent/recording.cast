[134.075792, "o", "\u001b[?2004h"]
[134.075807, "o", "> \r\n"]
[134.075819, "o", "\u001b[?2004l\r"]
[134.075833, "o", "\u001b[?2004h"]
[134.075903, "o", "> "]
[134.076095, "o", "  if (delta > 0 && wouldCrossExisting(bridges, from, to)) {\r\n\u001b[?2004l\r"]
[134.076144, "o", "\u001b[?2004h> "]
[134.076339, "o", "    return { valid: false, error: ERROR_CROSS };\r\n\u001b[?2004l\r"]
[134.076387, "o", "\u001b[?2004h> "]
[134.076417, "o", "  }\r\n\u001b[?2004l\r"]
[134.076538, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.076784, "o", "  return { valid: true, error: null };\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[134.07688, "o", "> "]
[134.077002, "o", "export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[134.07702, "o", "\u001b[?2004h"]
[134.077037, "o", "> "]
[134.077203, "o", "  if (islands.length === 0) return true;\r\n\u001b[?2004l\r"]
[134.077224, "o", "\u001b[?2004h"]
[134.077238, "o", "> "]
[134.077464, "o", "  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\r\n\u001b[?2004l\r"]
[134.077482, "o", "\u001b[?2004h"]
[134.077495, "o", "> \r\n"]
[134.077509, "o", "\u001b[?2004l\r"]
[134.077597, "o", "\u001b[?2004h> "]
[134.077647, "o", "  const adj = new Map();\r\n"]
[134.077695, "o", "\u001b[?2004l\r"]
[134.07774, "o", "\u001b[?2004h> "]
[134.077919, "o", "  for (const isl of islands) adj.set(isl.id, new Set());\r\n\u001b[?2004l\r"]
[134.078021, "o", "\u001b[?2004h> "]
[134.078107, "o", "  for (const [key, n] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[134.078187, "o", "\u001b[?2004h> "]
[134.078252, "o", "    if (!n) continue;\r\n\u001b[?2004l\r"]
[134.078357, "o", "\u001b[?2004h> "]
[134.078503, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[134.078586, "o", "\u001b[?2004h> "]
[134.078688, "o", "    const a = byCoord.get(`${x1},${y1}`);\r\n\u001b[?2004l\r"]
[134.078795, "o", "\u001b[?2004h> "]
[134.078875, "o", "    const b = byCoord.get(`${x2},${y2}`);\r\n\u001b[?2004l\r"]
[134.078938, "o", "\u001b[?2004h> "]
[134.079047, "o", "    if (!a || !b) continue;\r\n\u001b[?2004l\r"]
[134.079151, "o", "\u001b[?2004h> "]
[134.079224, "o", "    adj.get(a.id).add(b.id);\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.079243, "o", "> "]
[134.079357, "o", "    adj.get(b.id).add(a.id);\r\n\u001b[?2004l\r"]
[134.079376, "o", "\u001b[?2004h> "]
[134.079498, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.07954, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.079625, "o", "  const startId = islands[0].id;\r\n\u001b[?2004l\r"]
[134.079684, "o", "\u001b[?2004h> "]
[134.079803, "o", "  const seen = new Set([startId]);\r\n\u001b[?2004l\r"]
[134.079866, "o", "\u001b[?2004h> "]
[134.079922, "o", "  const q = [startId];\r\n\u001b[?2004l\r"]
[134.08001, "o", "\u001b[?2004h> "]
[134.08009, "o", "  while (q.length) {\r\n\u001b[?2004l\r"]
[134.080134, "o", "\u001b[?2004h> "]
[134.080227, "o", "    const cur = q.shift();\r\n\u001b[?2004l\r"]
[134.08033, "o", "\u001b[?2004h> "]
[134.080458, "o", "    for (const nxt of adj.get(cur) ?? []) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.080548, "o", "> "]
[134.080615, "o", "      if (!seen.has(nxt)) {\r\n\u001b[?2004l\r"]
[134.080659, "o", "\u001b[?2004h> "]
[134.080725, "o", "        seen.add(nxt);\r\n\u001b[?2004l\r"]
[134.0808, "o", "\u001b[?2004h"]
[134.080875, "o", "> "]
[134.080924, "o", "        q.push(nxt);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.080981, "o", "      }\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.081031, "o", ">     }\r\n\u001b[?2004l\r"]
[134.081082, "o", "\u001b[?2004h> "]
[134.081111, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.081245, "o", "  return seen.size === islands.length;\r\n\u001b[?2004l\r"]
[134.081262, "o", "\u001b[?2004h"]
[134.081274, "o", "> "]
[134.081289, "o", "}\r\n\u001b[?2004l\r"]
[134.081372, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[134.081414, "o", "> "]
[134.081582, "o", "export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r"]
[134.081679, "o", "\u001b[?2004h> "]
[134.081744, "o", "  // crossing check among existing bridges\r\n\u001b[?2004l\r"]
[134.081808, "o", "\u001b[?2004h> "]
[134.081857, "o", "  const segs = [];\r\n\u001b[?2004l\r"]
[134.081915, "o", "\u001b[?2004h> "]
[134.082062, "o", "  for (const [key, n] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[134.082146, "o", "\u001b[?2004h> "]
[134.08222, "o", "    if (!n) continue;\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.082314, "o", "> "]
[134.082448, "o", "    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[134.082536, "o", "\u001b[?2004h> "]
[134.082601, "o", "    segs.push({ x1, y1, x2, y2 });\r\n\u001b[?2004l\r"]
[134.082661, "o", "\u001b[?2004h"]
[134.082693, "o", ">   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.082708, "o", "> "]
[134.082888, "o", "  for (let i = 0; i < segs.length; i++) {\r\n\u001b[?2004l\r"]
[134.08291, "o", "\u001b[?2004h"]
[134.082923, "o", "> "]
[134.08309, "o", "    for (let j = i + 1; j < segs.length; j++) {\r\n\u001b[?2004l\r"]
[134.083107, "o", "\u001b[?2004h"]
[134.083122, "o", "> "]
[134.08322, "o", "      const a = segs[i];\r\n\u001b[?2004l\r"]
[134.083247, "o", "\u001b[?2004h"]
[134.083319, "o", "> "]
[134.083359, "o", "      const b = segs[j];\r\n"]
[134.083375, "o", "\u001b[?2004l\r"]
[134.083425, "o", "\u001b[?2004h> "]
[134.083586, "o", "      const aVert = a.x1 === a.x2;\r\n\u001b[?2004l\r"]
[134.083604, "o", "\u001b[?2004h"]
[134.083618, "o", "> "]
[134.08375, "o", "      const bVert = b.x1 === b.x2;\r\n\u001b[?2004l\r"]
[134.083766, "o", "\u001b[?2004h"]
[134.083779, "o", "> "]
[134.08392, "o", "      if (aVert === bVert) continue;\r\n\u001b[?2004l\r"]
[134.083941, "o", "\u001b[?2004h"]
[134.083955, "o", "> \r\n"]
[134.083969, "o", "\u001b[?2004l\r"]
[134.084044, "o", "\u001b[?2004h> "]
[134.084313, "o", "      const aEndpoints = new Set([`${a.x1},${a.y1}`, `${a.x2},${a.y2}`]);\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.084433, "o", "> "]
[134.084653, "o", "      if (aEndpoints.has(`${b.x1},${b.y1}`) || aEndpoints.has(`${b.x2},${b.y2}`)) continue;\r\n\u001b[?2004l\r"]
[134.084674, "o", "\u001b[?2004h"]
[134.084698, "o", "> \r\n"]
[134.084709, "o", "\u001b[?2004l\r"]
[134.084724, "o", "\u001b[?2004h"]
[134.084738, "o", "> "]
[134.08489, "o", "      const vx = aVert ? a.x1 : b.x1;\r\n\u001b[?2004l\r"]
[134.084979, "o", "\u001b[?2004h> "]
[134.085139, "o", "      const vy1 = aVert ? a.y1 : b.y1;\r\n\u001b[?2004l\r"]
[134.085171, "o", "\u001b[?2004h> "]
[134.085339, "o", "      const vy2 = aVert ? a.y2 : b.y2;\r\n\u001b[?2004l\r"]
[134.085458, "o", "\u001b[?2004h> "]
[134.085625, "o", "      const hy = aVert ? b.y1 : a.y1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.085777, "o", "      const hx1 = aVert ? b.x1 : a.x1;\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.085909, "o", "> "]
[134.08605, "o", "      const hx2 = aVert ? b.x2 : a.x2;\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.08626, "o", "      if (between(vx, hx1, hx2) && between(hy, vy1, vy2)) return false;\r\n\u001b[?2004l\r"]
[134.086379, "o", "\u001b[?2004h> "]
[134.086574, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[134.086602, "o", "\u001b[?2004h> "]
[134.08673, "o", "  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.08689, "o", "  for (const isl of islands) {\r\n\u001b[?2004l\r\u001b[?2004h"]
[134.086943, "o", "> "]
[134.087191, "o", "    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n\u001b[?2004l\r"]
[134.087334, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[134.087544, "o", "  return checkConnectivity(islands, bridges);\r\n\u001b[?2004l\r"]
[134.08765, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> export const ERROR_STRINGS = {\r\n\u001b[?2004l\r"]
[134.087698, "o", "\u001b[?2004h> "]
[134.087749, "o", "  ERROR_NON_ADJ,\r\n\u001b[?2004l\r"]
[134.087808, "o", "\u001b[?2004h> "]
[134.087858, "o", "  ERROR_MAX2,\r\n\u001b[?2004l\r"]
[134.087922, "o", "\u001b[?2004h> "]
[134.08797, "o", "  ERROR_EXCEED,\r\n\u001b[?2004l\r"]
[134.088027, "o", "\u001b[?2004h> "]
[134.088077, "o", "  ERROR_CROSS,\r\n\u001b[?2004l\r"]
[134.088158, "o", "\u001b[?2004h> };\r\n\u001b[?2004l\r"]
[134.088232, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
