[81.295446, "o", "\u001b[?2004l\r"]
[81.295623, "o", "\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.295793, "o", "+export function canAddBridge(islands, bridges, from, to, delta) {\r\n\u001b[?2004l\r"]
[81.295823, "o", "\u001b[?2004h"]
[81.295838, "o", "> "]
[81.296289, "o", "+  if (!from || !to || from.id === to.id) return { valid: false, error: ERROR_NON_ADJ };\r\n\u001b[?2004l\r"]
[81.296319, "o", "\u001b[?2004h> "]
[81.296628, "o", "+  if (!isAdjacent(islands, from, to)) return { valid: false, error: ERROR_NON_ADJ };\r\n\u001b[?2004l\r"]
[81.296774, "o", "\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.296916, "o", "+  const key = canonicalBridgeKey(from, to);\r\n\u001b[?2004l\r"]
[81.297077, "o", "\u001b[?2004h> "]
[81.297099, "o", "+  const cur = bridges.get(key) ?? 0;\r\n\u001b[?2004l\r"]
[81.297232, "o", "\u001b[?2004h> "]
[81.297374, "o", "+  const next = cur + delta;\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.297455, "o", "> "]
[81.297606, "o", "+  if (next < 0) return { valid: true, error: null };\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.297809, "o", "+  if (next > 2) return { valid: false, error: ERROR_MAX2 };\r\n\u001b[?2004l\r"]
[81.297856, "o", "\u001b[?2004h> "]
[81.297871, "o", "+\r\n\u001b[?2004l\r"]
[81.298012, "o", "\u001b[?2004h"]
[81.298092, "o", "> "]
[81.298201, "o", "+  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.29835, "o", "+  const fromCount = counts.get(from.id) ?? 0;\r\n\u001b[?2004l\r"]
[81.298407, "o", "\u001b[?2004h> "]
[81.298568, "o", "+  const toCount = counts.get(to.id) ?? 0;\r\n\u001b[?2004l\r"]
[81.2987, "o", "\u001b[?2004h> "]
[81.298897, "o", "+  if (fromCount + delta > from.value || toCount + delta > to.value) {\r\n\u001b[?2004l\r"]
[81.298924, "o", "\u001b[?2004h> "]
[81.299146, "o", "+    return { valid: false, error: ERROR_EXCEED };\r\n\u001b[?2004l\r"]
[81.299166, "o", "\u001b[?2004h> "]
[81.299182, "o", "+  }\r\n\u001b[?2004l\r"]
[81.299336, "o", "\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.299565, "o", "+  if (delta > 0 && wouldCrossExisting(islands, bridges, from, to)) {\r\n\u001b[?2004l\r"]
[81.299593, "o", "\u001b[?2004h> "]
[81.299796, "o", "+    return { valid: false, error: ERROR_CROSS };\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.29982, "o", "> "]
[81.299941, "o", "+  }\r\n\u001b[?2004l\r"]
[81.299975, "o", "\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.300092, "o", "+  return { valid: true, error: null };\r\n\u001b[?2004l\r"]
[81.300239, "o", "\u001b[?2004h> +}\r\n\u001b[?2004l\r\u001b[?2004h> +\r\n\u001b[?2004l\r"]
[81.300267, "o", "\u001b[?2004h> "]
[81.300513, "o", "+export function checkConnectivity(islands, bridges) {\r\n\u001b[?2004l\r"]
[81.300624, "o", "\u001b[?2004h> "]
[81.300748, "o", "+  if (islands.length === 0) return true;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.300958, "o", "+  const byCoord = new Map(islands.map((i) => [`${i.x},${i.y}`, i]));\r\n\u001b[?2004l\r"]
[81.300984, "o", "\u001b[?2004h> "]
[81.300997, "o", "+\r\n\u001b[?2004l\r"]
[81.301155, "o", "\u001b[?2004h> +  const adj = new Map();\r\n\u001b[?2004l\r"]
[81.301299, "o", "\u001b[?2004h> "]
[81.301396, "o", "+  for (const i of islands) adj.set(i.id, new Set());\r\n\u001b[?2004l\r"]
[81.301482, "o", "\u001b[?2004h> "]
[81.301614, "o", "+  for (const [key, n] of bridges.entries()) {\r\n\u001b[?2004l\r"]
[81.301805, "o", "\u001b[?2004h> "]
[81.301863, "o", "+    if (!n) continue;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.302068, "o", "+    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[81.302177, "o", "\u001b[?2004h> "]
[81.302236, "o", "+    const a = byCoord.get(`${x1},${y1}`);\r\n\u001b[?2004l\r"]
[81.302297, "o", "\u001b[?2004h> "]
[81.302494, "o", "+    const b = byCoord.get(`${x2},${y2}`);\r\n\u001b[?2004l\r"]
[81.302604, "o", "\u001b[?2004h> "]
[81.302667, "o", "+    if (!a || !b) continue;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.302771, "o", "+    adj.get(a.id).add(b.id);\r\n\u001b[?2004l\r"]
[81.302846, "o", "\u001b[?2004h> "]
[81.302924, "o", "+    adj.get(b.id).add(a.id);\r\n\u001b[?2004l\r"]
[81.303059, "o", "\u001b[?2004h> "]
[81.303173, "o", "+  }\r\n\u001b[?2004l\r\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.303201, "o", "> "]
[81.303326, "o", "+  const startId = islands[0].id;\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.303427, "o", "+  const seen = new Set([startId]);\r\n\u001b[?2004l\r"]
[81.303521, "o", "\u001b[?2004h> "]
[81.303624, "o", "+  const q = [startId];\r\n\u001b[?2004l\r"]
[81.303786, "o", "\u001b[?2004h> "]
[81.303916, "o", "+  while (q.length) {\r\n\u001b[?2004l\r\u001b[?2004h> +    const cur = q.shift();\r\n\u001b[?2004l\r"]
[81.30403, "o", "\u001b[?2004h> "]
[81.304059, "o", "+    for (const nxt of adj.get(cur) ?? []) {\r\n\u001b[?2004l\r"]
[81.304137, "o", "\u001b[?2004h> "]
[81.304246, "o", "+      if (!seen.has(nxt)) {\r\n\u001b[?2004l\r"]
[81.304306, "o", "\u001b[?2004h> "]
[81.304382, "o", "+        seen.add(nxt);\r\n\u001b[?2004l\r"]
[81.304517, "o", "\u001b[?2004h> "]
[81.304547, "o", "+        q.push(nxt);\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.304634, "o", "> "]
[81.304767, "o", "+      }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.304853, "o", "+    }\r\n\u001b[?2004l\r\u001b[?2004h> +  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.304969, "o", "+  return seen.size === islands.length;\r\n\u001b[?2004l\r"]
[81.305911, "o", "\u001b[?2004h> +}\r\n\u001b[?2004l\r\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.306168, "o", "> +export function isVictory(islands, bridges) {\r\n\u001b[?2004l\r\u001b[?2004h> +  // Ensure no crossings\r\n\u001b[?2004l\r\u001b[?2004h> +  for (const islA of islands) {\r\n\u001b[?2004l\r\u001b[?2004h> +    // noop, crossing validated through explicit scan below\r\n\u001b[?2004l\r\u001b[?2004h> +  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.306406, "o", "+  // brute-force crossing check among existing bridges\r\n\u001b[?2004l\r\u001b[?2004h> +  const segments = [];\r\n\u001b[?2004l\r"]
[81.306591, "o", "\u001b[?2004h> +  for (const [key, n] of bridges.entries()) {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.306663, "o", "+    if (!n) continue;\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.306683, "o", "> "]
[81.306946, "o", "+    const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n\u001b[?2004l\r"]
[81.306977, "o", "\u001b[?2004h> "]
[81.307202, "o", "+    segments.push({ x1, y1, x2, y2 });\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.307312, "o", "> +  }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.307415, "o", "+  for (let i = 0; i < segments.length; i++) {\r\n\u001b[?2004l\r"]
[81.307445, "o", "\u001b[?2004h"]
[81.307459, "o", "> "]
[81.307721, "o", "+    for (let j = i + 1; j < segments.length; j++) {\r\n\u001b[?2004l\r"]
[81.307863, "o", "\u001b[?2004h> "]
[81.307984, "o", "+      const a = segments[i];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.308089, "o", "+      const b = segments[j];\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.308185, "o", "+      const aVert = a.x1 === a.x2;\r\n\u001b[?2004l\r"]
[81.308294, "o", "\u001b[?2004h> "]
[81.308445, "o", "+      const bVert = b.x1 === b.x2;\r\n\u001b[?2004l\r"]
[81.308608, "o", "\u001b[?2004h> "]
[81.30873, "o", "+      if (aVert === bVert) continue;\r\n\u001b[?2004l\r\u001b[?2004h> +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.308861, "o", "+      // check share endpoint\r\n\u001b[?2004l\r"]
[81.308971, "o", "\u001b[?2004h> "]
[81.309127, "o", "+      const aEndpoints = new Set([`${a.x1},${a.y1}`, `${a.x2},${a.y2}`]);\r\n\u001b[?2004l\r"]
[81.309151, "o", "\u001b[?2004h> "]
[81.309479, "o", "+      if (aEndpoints.has(`${b.x1},${b.y1}`) || aEndpoints.has(`${b.x2},${b.y2}`)) continue;\r\n\u001b[?2004l\r"]
[81.309507, "o", "\u001b[?2004h> "]
[81.309614, "o", "+\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.309645, "o", "> "]
[81.309815, "o", "+      const vx = aVert ? a.x1 : b.x1;\r\n\u001b[?2004l\r"]
[81.30984, "o", "\u001b[?2004h> "]
[81.309933, "o", "+      const vy1 = aVert ? a.y1 : b.y1;\r\n\u001b[?2004l\r"]
[81.309989, "o", "\u001b[?2004h> "]
[81.310161, "o", "+      const vy2 = aVert ? a.y2 : b.y2;\r\n\u001b[?2004l\r"]
[81.310188, "o", "\u001b[?2004h> "]
[81.310339, "o", "+      const hy = aVert ? b.y1 : a.y1;\r\n\u001b[?2004l\r"]
[81.310364, "o", "\u001b[?2004h"]
[81.310387, "o", "> "]
[81.310551, "o", "+      const hx1 = aVert ? b.x1 : a.x1;\r\n\u001b[?2004l\r"]
[81.310578, "o", "\u001b[?2004h"]
[81.310593, "o", "> "]
[81.310738, "o", "+      const hx2 = aVert ? b.x2 : a.x2;\r\n\u001b[?2004l\r"]
[81.310766, "o", "\u001b[?2004h"]
[81.310781, "o", "> "]
[81.311028, "o", "+      if (between(vx, hx1, hx2) && between(hy, vy1, vy2)) return false;\r\n\u001b[?2004l\r"]
[81.311054, "o", "\u001b[?2004h> "]
[81.311181, "o", "+    }\r\n\u001b[?2004l\r"]
[81.311211, "o", "\u001b[?2004h> +  }\r\n\u001b[?2004l\r\u001b[?2004h"]
[81.311224, "o", "> "]
[81.311239, "o", "+\r\n\u001b[?2004l\r"]
[81.311353, "o", "\u001b[?2004h> "]
[81.311491, "o", "+  const counts = computeCurrentCounts(islands, bridges);\r\n\u001b[?2004l\r"]
[81.311581, "o", "\u001b[?2004h> "]
[81.311693, "o", "+  for (const isl of islands) {\r\n\u001b[?2004l\r"]
[81.311797, "o", "\u001b[?2004h> "]
[81.311946, "o", "+    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\r\n\u001b[?2004l\r"]
[81.311972, "o", "\u001b[?2004h> "]
[81.312084, "o", "+  }"]
[81.312141, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[81.312293, "o", "+  return checkConnectivity(islands, bridges);\r\n\u001b[?2004l\r"]
[81.312375, "o", "\u001b[?2004h> "]
[81.312449, "o", "+}"]
[81.312495, "o", "\r\n\u001b[?2004l\r"]
