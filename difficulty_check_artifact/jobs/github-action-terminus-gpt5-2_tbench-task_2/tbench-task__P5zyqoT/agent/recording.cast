[134.182817, "i", "cat > src/index.css <<'EOF'\nhtml,\nbody {\n  margin: 0;\n  padding: 0;\n  background: #000;\n  color: #00ff66;\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',\n    'Courier New', monospace;\n}\n\n#root {\n  margin: 0;\n  padding: 0;\n}\n\nbutton,\nselect {\n  background: #000;\n  color: #00ff66;\n  border: 1px solid #00ff66;\n  font: inherit;\n}\n\nbutton {\n  cursor: pointer;\n}\n\n.ui-bar {\n  position: fixed;\n  left: 0;\n  top: 0;\n  padding: 8px;\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  background: rgba(0, 0, 0, 0.85);\n  z-index: 2;\n}\n\n.error-message {\n  position: fixed;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  color: #00ff66;\n  background: rgba(0, 0, 0, 0.85);\n  z-index: 2;\n}\n\n.victory-banner {\n  position: fixed;\n  left: 0;\n  top: 44px;\n  padding: 8px;\n  border: 1px solid #00ff66;\n  background: rgba(0, 0, 0, 0.85);\n  z-index: 2;\n}\nEOF\n"]
