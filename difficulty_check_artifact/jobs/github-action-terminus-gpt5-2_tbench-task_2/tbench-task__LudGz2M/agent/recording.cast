[88.90591, "o", "        ref={svgRef}\r\n        tabIndex={0}\r\n        width={SVG_W}\r\n        height={SVG_H}\r\n        style={{ display: 'block', outline: 'none' }}\r\n        onKeyDown={onKeyDown}\r\n      >\r\n        {/* Bridges */}\r\n        {bridgeEntries.flatMap(([key, n]) => {\r\n          const lines = bridgeLinesForKey(key, n);\r\n          return lines.map((ln, idx) => (\r\n            <line\r\n              key={`${key}-${idx}`}\r\n              x1={ln.x1}\r\n              y1={ln.y1}\r\n              x2={ln.x2}\r\n              y2={ln.y2}\r\n              stroke=\"#0f0\"\r\n              strokeWidth={3}\r\n              onClick={(e) => onBridgeClick(key, e)}\r\n              onContextMenu={(e) => onBridgeClick(key, e)}\r\n            />\r\n          ));\r\n        })}\r\n\r\n        {/* Cursor (must not be a circle) */}\r\n        {cursorIslandId != null ? (() => {\r\n          const isl = findIslandById(islands, cursorIslandId);\r\n          if (!isl) return null;\r\n          const px = isl.x * GRID;\r\n          const py = isl.y * GRID;\r\n          const size = 34;\r\n "]
[88.906183, "o", "         const isSelected = selectedIslandId === isl.id;\r\n          return (\r\n            <rect\r\n              x={px - size / 2}\r\n              y={py - size / 2}\r\n              width={size}\r\n              height={size}\r\n              fill=\"none\"\r\n              stroke={isSelected ? '#fff' : '#0f0'}\r\n              strokeWidth={2}\r\n              strokeDasharray={isSelected ? '0' : '4 3'}\r\n            />\r\n          );\r\n        })() : null}\r\n\r\n        {/* Islands */}\r\n        {islands.map((isl) => {\r\n          const px = isl.x * GRID;\r\n          const py = isl.y * GRID;\r\n          const current = counts.get(isl.id) ?? 0;\r\n          const over = current > isl.value;\r\n          return (\r\n            <g key={isl.id} onClick={(e) => onIslandClick(isl, e)} style={{ cursor: 'pointer' }}>\r\n              <circle\r\n                cx={px}\r\n                cy={py}\r\n                r={16}\r\n                fill=\"black\"\r\n                stroke={over ? 'red' : '#0f0'}\r\n                strokeWidth={2}\r\n              />\r\n         "]
[88.906214, "o", "     <text\r\n                x={px}\r\n                y={py + 5}\r\n                textAnchor=\"middle\"\r\n                fontFamily=\"monospace\"\r\n                fontSize={16}\r\n                fill=\"#0f0\"\r\n              >\r\n                {isl.value}\r\n              </text>\r\n            </g>\r\n          );\r\n        })}\r\n      </svg>\r\n    </div>\r\n  );\r\n}\r\n"]
