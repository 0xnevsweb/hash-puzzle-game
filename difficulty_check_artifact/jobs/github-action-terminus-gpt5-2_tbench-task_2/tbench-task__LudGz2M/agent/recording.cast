[74.075735, "o", "import React, { useEffect, useMemo, useRef, useState } from 'react';\r\nimport { puzzles } from './data/puzzles';\r\nimport {\r\n  canAddBridge,\r\n  canonicalBridgeKey,\r\n  computeCurrentCounts,\r\n  isVictory,\r\n} from './utils/hashiLogic';\r\n"]
[74.075951, "o", "\r\nconst GRID = 40;\r\nconst SVG_W = 800;\r\nconst SVG_H = 600;\r\n\r\nfunction findIslandById(islands, id) {\r\n  return islands.find((i) => i.id === id);\r\n}\r\n\r\nfunction getDirectionalNeighbor(islands, from, dir) {\r\n  // dir: 'left'|'right'|'up'|'down'\r\n"]
[74.075979, "o", "  let best = null;\r\n  for (const isl of islands) {\r\n    if (isl.id === from.id) continue;\r\n    if (dir === 'left' && isl.y === from.y && isl.x < from.x) {\r\n      if (!best || isl.x > best.x) best = isl;\r\n    }\r\n    if (dir === 'right' && isl.y === from.y && isl.x > from.x) {\r\n      if (!best || isl.x < best.x) best = isl;\r\n    }\r\n    if (dir === 'up' && isl.x === from.x && isl.y < from.y) {\r\n      if (!best || isl.y > best.y) best = isl;\r\n    }\r\n    if (dir === 'down' && isl.x === from.x && isl.y > from.y) {\r\n      if (!best || isl.y < best.y) best = isl;\r\n    }\r\n  }\r\n  return best;\r\n}\r\n\r\nfunction bridgeLinesForKey(key, count) {\r\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\r\n  const px1 = x1 * GRID;\r\n  const py1 = y1 * GRID;\r\n  const px2 = x2 * GRID;\r\n  const py2 = y2 * GRID;\r\n\r\n  const vertical = px1 === px2;\r\n"]
[74.076039, "o", "  const offset = 4;\r\n\r\n  if (count === 1) {\r\n    return [\r\n      {\r\n        x1: px1,\r\n        y1: py1,\r\n        x2: px2,\r\n        y2: py2,\r\n      },\r\n    ];\r\n"]
[74.076938, "o", "  }\r\n\r\n  if (vertical) {\r\n    return [\r\n      { x1: px1 - offset, y1: py1, x2: px2 - offset, y2: py2 },\r\n      { x1: px1 + offset, y1: py1, x2: px2 + offset, y2: py2 },\r\n    ];\r\n  }\r\n\r\n  return [\r\n    { x1: px1, y1: py1 - offset, x2: px2, y2: py2 - offset },\r\n    { x1: px1, y1: py1 + offset, x2: px2, y2: py2 + offset },\r\n  ];\r\n}\r\n"]
[74.076983, "o", "\r\nexport default function App() {\r\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\r\n  const puzzle = puzzles[puzzleIndex];\r\n  const islands = puzzle.islands;\r\n\r\n  const [bridges, setBridges] = useState(() => new Map());\r\n  const [selectedIslandId, setSelectedIslandId] = useState(null);\r\n  const [cursorIslandId, setCursorIslandId] = useState(() => islands[0]?.id ?? null);\r\n  const [error, setError] = useState(null);\r\n\r\n  const svgRef = useRef(null);\r\n\r\n  // Reset when puzzle changes\r\n  useEffect(() => {\r\n    setBridges(new Map());\r\n    setSelectedIslandId(null);\r\n    setError(null);\r\n    setCursorIslandId(puzzles[puzzleIndex].islands[0]?.id ?? null);\r\n  }, [puzzleIndex]);\r\n\r\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\r\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\r\n\r\n  function clearErrorOnValid(valid) {\r\n    if (valid) setError(null);\r\n  }\r\n\r\n  function applyToggle(from, to) {\r\n    const key = canonicalBridgeKey(from, to);"]
[74.07701, "o", "\r\n    const existing = bridges.get(key) ?? 0;\r\n    const next = existing === 0 ? 1 : existing === 1 ? 2 : 0;\r\n\r\n    if (next === 0) {\r\n      const nb = new Map(bridges);\r\n      nb.delete(key);\r\n      setBridges(nb);\r\n      setError(null);\r\n      return;\r\n    }\r\n\r\n    const delta = next - existing;\r\n    const check = canAddBridge(islands, bridges, from, to, delta);\r\n    if (!check.valid) {\r\n      setError(check.error);\r\n      return;\r\n    }\r\n\r\n    const nb = new Map(bridges);\r\n    nb.set(key, next);\r\n    setBridges(nb);\r\n    clearErrorOnValid(true);\r\n  }\r\n\r\n  function onIslandClick(isl, e) {\r\n    e.preventDefault();\r\n    setCursorIslandId(isl.id);\r\n\r\n    if (selectedIslandId == null) {\r\n      setSelectedIslandId(isl.id);\r\n      return;\r\n    }\r\n\r\n    if (selectedIslandId === isl.id) {\r\n      // Clicking same island keeps selection.\r\n      return;\r\n    }\r\n\r\n    const from = findIslandById(islands, selectedIslandId);\r\n    const to = isl;\r\n    applyToggle(from, to);\r\n    setSelectedIslandId(null);\r\n  }\r\n\r\n  functi"]
[74.077025, "o", "on onBridgeClick(key, e) {\r\n    // Right click or Ctrl+click removes entirely\r\n    if (e.type === 'contextmenu' || e.ctrlKey) {\r\n      e.preventDefault();\r\n      const nb = new Map(bridges);\r\n      nb.delete(key);\r\n      setBridges(nb);\r\n      setSelectedIslandId(null);\r\n      setError(null);\r\n    }\r\n  }\r\n\r\n  function reset() {\r\n    setBridges(new Map());\r\n    setSelectedIslandId(null);\r\n    setError(null);\r\n  }\r\n\r\n  useEffect(() => {\r\n    const el = svgRef.current;\r\n    if (el) el.focus();\r\n  }, []);\r\n\r\n  function onKeyDown(e) {\r\n    if (!cursorIslandId && islands.length) setCursorIslandId(islands[0].id);\r\n    const cur = findIslandById(islands, cursorIslandId);\r\n    if (!cur) return;\r\n\r\n    if (e.key === 'Escape') {\r\n      setSelectedIslandId(null);\r\n      setError(null);\r\n      return;\r\n    }\r\n\r\n    const dirByKey = {\r\n      ArrowLeft: 'left',\r\n      ArrowRight: 'right',\r\n      ArrowUp: 'up',\r\n      ArrowDown: 'down',\r\n    };\r\n\r\n    if (dirByKey[e.key]) {\r\n      e.preventDefault();\r\n      const nb = getDir"]
[74.077037, "o", "ectionalNeighbor(islands, cur, dirByKey[e.key]);\r\n      if (nb) setCursorIslandId(nb.id);\r\n      return;\r\n    }\r\n\r\n    if (e.key === 'Enter') {\r\n      e.preventDefault();\r\n      if (selectedIslandId == null) {\r\n        setSelectedIslandId(cur.id);\r\n        return;\r\n      }\r\n      if (selectedIslandId === cur.id) return;\r\n\r\n      const from = findIslandById(islands, selectedIslandId);\r\n      const to = cur;\r\n      applyToggle(from, to);\r\n      setSelectedIslandId(null);\r\n    }\r\n  }\r\n\r\n  const bridgeEntries = Array.from(bridges.entries()).filter(([, n]) => n > 0);\r\n\r\n  return (\r\n    <div style={{ position: 'absolute', left: 0, top: 0 }}>\r\n      <div\r\n        style={{\r\n          padding: '8px',\r\n          display: 'flex',\r\n          gap: '12px',\r\n          alignItems: 'center',\r\n        }}\r\n      >\r\n        <label>\r\n          Puzzle:{' '}\r\n          <select\r\n            value={puzzleIndex}\r\n            onChange={(e) => setPuzzleIndex(Number(e.target.value))}\r\n          >\r\n            {puzzles.map((p, idx) => (\r\n"]
[74.077118, "o", "              <option key={p.id} value={idx}>\r\n                {p.name}\r\n              </option>\r\n            ))}\r\n          </select>\r\n        </label>\r\n        <button onClick={reset}>Reset</button>\r\n        {error ? <div className=\"error-message\">{error}</div> : null}\r\n        {solved ? <div className=\"victory-banner\">SOLVED!</div> : null}\r\n      </div>\r\n\r\n      <svg\r\n        ref={svgRef}\r\n        tabIndex={0}\r\n        width={SVG_W}\r\n        height={SVG_H}\r\n        style={{ display: 'block', outline: 'none' }}\r\n        onKeyDown={onKeyDown}\r\n      >\r\n        {/* Bridges */}\r\n        {bridgeEntries.flatMap(([key, n]) => {\r\n          const lines = bridgeLinesForKey(key, n);\r\n          return lines.map((ln, idx) => (\r\n            <line\r\n              key={`${key}-${idx}`}\r\n              x1={ln.x1}\r\n              y1={ln.y1}\r\n              x2={ln.x2}\r\n              y2={ln.y2}\r\n              stroke=\"#0f0\"\r\n              strokeWidth={3}\r\n              onClick={(e) => onBridgeClick(key, e)}\r\n              onContex"]
