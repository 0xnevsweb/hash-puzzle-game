          const size = 34;
          const isSelected = selectedIslandId === isl.id;
          return (
            <rect
              x={px - size / 2}
              y={py - size / 2}
              width={size}
              height={size}
              fill="none"
              stroke={isSelected ? '#fff' : '#0f0'}
              strokeWidth={2}
              strokeDasharray={isSelected ? '0' : '4 3'}
            />
          );
        })() : null}

        {/* Islands */}
        {islands.map((isl) => {
          const px = isl.x * GRID;
          const py = isl.y * GRID;
          const current = counts.get(isl.id) ?? 0;
          const over = current > isl.value;
          return (
            <g key={isl.id} onClick={(e) => onIslandClick(isl, e)} style={{ cursor: 'pointer' }}>
              <circle
                cx={px}
                cy={py}
                r={16}
                fill="black"
                stroke={over ? 'red' : '#0f0'}
                strokeWidth={2}
              />
              <text
                x={px}
                y={py + 5}
                textAnchor="middle"
                fontFamily="monospace"
                fontSize={16}
                fill="#0f0"
              >
                {isl.value}
              </text>
            </g>
          );
        })}
      </svg>
    </div>
