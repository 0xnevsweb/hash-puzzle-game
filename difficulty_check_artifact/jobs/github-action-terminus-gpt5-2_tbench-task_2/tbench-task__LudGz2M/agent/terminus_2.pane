[?2004l[?2004h>   const next = existing + delta;
[?2004l[?2004h> 
[?2004l[?2004h>   if (next < 0) return { valid: false, error: ERROR_MAX_PAIR };
[?2004l[?2004h>   if (next > 2) return { valid: false, error: ERROR_MAX_PAIR };
[?2004l[?2004h> 
[?2004l[?2004h>   const counts = computeCurrentCounts(islands, bridges);
[?2004l[?2004h>   const fromCount = counts.get(from.id) ?? 0;
[?2004l[?2004h>   const toCount = counts.get(to.id) ?? 0;
[?2004l[?2004h> 
[?2004l[?2004h>   if (fromCount + delta > from.value) return { valid: false, error: ERROR_EXCEED };
[?2004l[?2004h>   if (toCount + delta > to.value) return { valid: false, error: ERROR_EXCEED };
[?2004l[?2004h> 
[?2004l[?2004h>   if (delta > 0 && existing === 0) {
[?2004l[?2004h>     const seg = parseBridgeKey(key);
[?2004l[?2004h>     if (wouldCrossExisting(bridges, seg)) return { valid: false, error: ERROR_CROSS };
[?2004l[?2004h>   }
[?2004l[?2004h> 
[?2004l[?2004h>   return { valid: true, error: null };
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> export function checkConnectivity(islands, bridges) {
[?2004l[?2004h>   if (islands.length === 0) return true;
[?2004l[?2004h>   const byCoord = new Map();
