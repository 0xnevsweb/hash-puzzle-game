[?2004l[?2004h>   // Intersection point (v.x, h.y)
[?2004l[?2004h>   const ix = v.x1;
[?2004l[?2004h>   const iy = h.y1;
[?2004l[?2004h> 
[?2004l[?2004h>   // Must be strictly inside both segments (not at endpoints)
[?2004l[?2004h>   if (!isBetweenExclusive(ix, h.x1, h.x2)) return false;
[?2004l[?2004h>   if (!isBetweenExclusive(iy, v.y1, v.y2)) return false;
