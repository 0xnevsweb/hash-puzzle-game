[?2004l[?2004h>     const { x1, y1, x2, y2 } = parseBridgeKey(key);
[?2004l[?2004h>     const a = islands.find((i) => i.x === x1 && i.y === y1);
[?2004l[?2004h>     const b = islands.find((i) => i.x === x2 && i.y === y2);
[?2004l[?2004h>     if (!a || !b) continue;
[?2004l[?2004h>     counts.set(a.id, (counts.get(a.id) ?? 0) + n);
[?2004l[?2004h>     counts.set(b.id, (counts.get(b.id) ?? 0) + n);
[?2004l[?2004h>   }
[?2004l[?2004h>   return counts;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function isAdjacent(islands, from, to) {
[?2004l[?2004h>   if (from.id === to.id) return false;
[?2004l[?2004h>   const sameRow = from.y === to.y;
[?2004l[?2004h>   const sameCol = from.x === to.x;
[?2004l[?2004h>   if (!sameRow && !sameCol) return false;
[?2004l[?2004h> 
[?2004l[?2004h>   // Ensure no island blocks between them.
[?2004l[?2004h>   if (sameRow) {
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.y === from.y && isBetweenExclusive(isl.x, from.x, to.x)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   } else {
[?2004l[?2004h>     for (const isl of islands) {
[?2004l[?2004h>       if (isl.id === from.id || isl.id === to.id) continue;
[?2004l[?2004h>       if (isl.x === from.x && isBetweenExclusive(isl.y, from.y, to.y)) return false;
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h>   return true;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> function segmentsCross(segA, segB) {
[?2004l[?2004h>   // Only consider perpendicular crossing (Hashi rule). Shared endpoints are allowed.
[?2004l[?2004h>   const aVert = segA.x1 === segA.x2;
