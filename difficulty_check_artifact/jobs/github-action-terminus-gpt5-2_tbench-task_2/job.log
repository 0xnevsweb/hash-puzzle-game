Sending keys: ["cat > src/utils/hashiLogic.js <<'EOF'\nexport const ERROR_NON_ADJACENT = 'Cannot connect non-adjacent islands';\nexport const ERROR_MAX_PAIR = 'Max 2 bridges per pair';\nexport const ERROR_EXCEED = 'Island would exceed its number';\nexport const ERROR_CROSS = 'Bridges would cross';\n\nconst isBetweenExclusive = (v, a, b) => {\n  const min = Math.min(a, b);\n  const max = Math.max(a, b);\n  return v > min && v < max;\n};\n\nexport function canonicalBridgeKey(from, to) {\n  const a = { x: from.x, y: from.y };\n  const b = { x: to.x, y: to.y };\n  const first = a.x < b.x || (a.x === b.x && a.y <= b.y) ? a : b;\n  const second = first === a ? b : a;\n  return `${first.x},${first.y},${second.x},${second.y}`;\n}\n\nexport function parseBridgeKey(key) {\n  const [x1, y1, x2, y2] = key.split(',').map(Number);\n  return { x1, y1, x2, y2 };\n}\n\nexport function computeCurrentCounts(islands, bridges) {\n  const counts = new Map();\n  for (const isl of islands) counts.set(isl.id, 0);\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = islands.find((i) => i.x === x1 && i.y === y1);\n    const b = islands.find((i) => i.x === x2 && i.y === y2);\n    if (!a || !b) continue;\n    counts.set(a.id, (counts.get(a.id) ?? 0) + n);\n    counts.set(b.id, (counts.get(b.id) ?? 0) + n);\n  }\n  return counts;\n}\n\nfunction isAdjacent(islands, from, to) {\n  if (from.id === to.id) return false;\n  const sameRow = from.y === to.y;\n  const sameCol = from.x === to.x;\n  if (!sameRow && !sameCol) return false;\n\n  // Ensure no island blocks between them.\n  if (sameRow) {\n    for (const isl of islands) {\n      if (isl.id === from.id || isl.id === to.id) continue;\n      if (isl.y === from.y && isBetweenExclusive(isl.x, from.x, to.x)) return false;\n    }\n  } else {\n    for (const isl of islands) {\n      if (isl.id === from.id || isl.id === to.id) continue;\n      if (isl.x === from.x && isBetweenExclusive(isl.y, from.y, to.y)) return false;\n    }\n  }\n  return true;\n}\n\nfunction segmentsCross(segA, segB) {\n  // Only consider perpendicular crossing (Hashi rule). Shared endpoints are allowed.\n  const aVert = segA.x1 === segA.x2;\n  const bVert = segB.x1 === segB.x2;\n  if (aVert === bVert) return false;\n\n  const v = aVert ? segA : segB;\n  const h = aVert ? segB : segA;\n\n  // Intersection point (v.x, h.y)\n  const ix = v.x1;\n  const iy = h.y1;\n\n  // Must be strictly inside both segments (not at endpoints)\n  if (!isBetweenExclusive(ix, h.x1, h.x2)) return false;\n  if (!isBetweenExclusive(iy, v.y1, v.y2)) return false;\n  return true;\n}\n\nfunction wouldCrossExisting(bridges, newSeg) {\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const seg = parseBridgeKey(key);\n    // Sharing endpoints is fine.\n    const sharesEndpoint =\n      (seg.x1 === newSeg.x1 && seg.y1 === newSeg.y1) ||\n      (seg.x2 === newSeg.x1 && seg.y2 === newSeg.y1) ||\n      (seg.x1 === newSeg.x2 && seg.y1 === newSeg.y2) ||\n      (seg.x2 === newSeg.x2 && seg.y2 === newSeg.y2);\n    if (sharesEndpoint) continue;\n\n    if (segmentsCross(seg, newSeg)) return true;\n  }\n  return false;\n}\n\nexport function canAddBridge(islands, bridges, from, to, delta) {\n  if (!isAdjacent(islands, from, to)) return { valid: false, error: ERROR_NON_ADJACENT };\n\n  const key = canonicalBridgeKey(from, to);\n  const existing = bridges.get(key) ?? 0;\n  const next = existing + delta;\n\n  if (next < 0) return { valid: false, error: ERROR_MAX_PAIR };\n  if (next > 2) return { valid: false, error: ERROR_MAX_PAIR };\n\n  const counts = computeCurrentCounts(islands, bridges);\n  const fromCount = counts.get(from.id) ?? 0;\n  const toCount = counts.get(to.id) ?? 0;\n\n  if (fromCount + delta > from.value) return { valid: false, error: ERROR_EXCEED };\n  if (toCount + delta > to.value) return { valid: false, error: ERROR_EXCEED };\n\n  if (delta > 0 && existing === 0) {\n    const seg = parseBridgeKey(key);\n    if (wouldCrossExisting(bridges, seg)) return { valid: false, error: ERROR_CROSS };\n  }\n\n  return { valid: true, error: null };\n}\n\nexport function checkConnectivity(islands, bridges) {\n  if (islands.length === 0) return true;\n  const byCoord = new Map();\n  for (const isl of islands) byCoord.set(`${isl.x},${isl.y}`, isl);\n\n  const adj = new Map();\n  for (const isl of islands) adj.set(isl.id, []);\n\n  for (const [key, n] of bridges.entries()) {\n    if (!n) continue;\n    const { x1, y1, x2, y2 } = parseBridgeKey(key);\n    const a = byCoord.get(`${x1},${y1}`);\n    const b = byCoord.get(`${x2},${y2}`);\n    if (!a || !b) continue;\n    adj.get(a.id).push(b.id);\n    adj.get(b.id).push(a.id);\n  }\n\n  const startId = islands[0].id;\n  const seen = new Set([startId]);\n  const stack = [startId];\n  while (stack.length) {\n    const cur = stack.pop();\n    for (const nxt of adj.get(cur) || []) {\n      if (seen.has(nxt)) continue;\n      seen.add(nxt);\n      stack.push(nxt);\n    }\n  }\n  return seen.size === islands.length;\n}\n\nexport function isVictory(islands, bridges) {\n  // Ensure no crossings\n  for (const [k1, n1] of bridges.entries()) {\n    if (!n1) continue;\n    const s1 = parseBridgeKey(k1);\n    for (const [k2, n2] of bridges.entries()) {\n      if (!n2) continue;\n      if (k1 === k2) continue;\n      const s2 = parseBridgeKey(k2);\n      const sharesEndpoint =\n        (s1.x1 === s2.x1 && s1.y1 === s2.y1) ||\n        (s1.x1 === s2.x2 && s1.y1 === s2.y2) ||\n        (s1.x2 === s2.x1 && s1.y2 === s2.y1) ||\n        (s1.x2 === s2.x2 && s1.y2 === s2.y2);\n      if (sharesEndpoint) continue;\n      if (segmentsCross(s1, s2)) return false;\n    }\n  }\n\n  const counts = computeCurrentCounts(islands, bridges);\n  for (const isl of islands) {\n    if ((counts.get(isl.id) ?? 0) !== isl.value) return false;\n  }\n\n  return checkConnectivity(islands, bridges);\n}\nEOF\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
Sending keys: ['cat > src/App.jsx <<\'EOF\'\nimport React, { useEffect, useMemo, useRef, useState } from \'react\';\nimport { puzzles } from \'./data/puzzles\';\nimport {\n  canAddBridge,\n  canonicalBridgeKey,\n  computeCurrentCounts,\n  isVictory,\n} from \'./utils/hashiLogic\';\n\nconst GRID = 40;\nconst SVG_W = 800;\nconst SVG_H = 600;\n\nfunction findIslandById(islands, id) {\n  return islands.find((i) => i.id === id);\n}\n\nfunction getDirectionalNeighbor(islands, from, dir) {\n  // dir: \'left\'|\'right\'|\'up\'|\'down\'\n  let best = null;\n  for (const isl of islands) {\n    if (isl.id === from.id) continue;\n    if (dir === \'left\' && isl.y === from.y && isl.x < from.x) {\n      if (!best || isl.x > best.x) best = isl;\n    }\n    if (dir === \'right\' && isl.y === from.y && isl.x > from.x) {\n      if (!best || isl.x < best.x) best = isl;\n    }\n    if (dir === \'up\' && isl.x === from.x && isl.y < from.y) {\n      if (!best || isl.y > best.y) best = isl;\n    }\n    if (dir === \'down\' && isl.x === from.x && isl.y > from.y) {\n      if (!best || isl.y < best.y) best = isl;\n    }\n  }\n  return best;\n}\n\nfunction bridgeLinesForKey(key, count) {\n  const [x1, y1, x2, y2] = key.split(\',\').map(Number);\n  const px1 = x1 * GRID;\n  const py1 = y1 * GRID;\n  const px2 = x2 * GRID;\n  const py2 = y2 * GRID;\n\n  const vertical = px1 === px2;\n  const offset = 4;\n\n  if (count === 1) {\n    return [\n      {\n        x1: px1,\n        y1: py1,\n        x2: px2,\n        y2: py2,\n      },\n    ];\n  }\n\n  if (vertical) {\n    return [\n      { x1: px1 - offset, y1: py1, x2: px2 - offset, y2: py2 },\n      { x1: px1 + offset, y1: py1, x2: px2 + offset, y2: py2 },\n    ];\n  }\n\n  return [\n    { x1: px1, y1: py1 - offset, x2: px2, y2: py2 - offset },\n    { x1: px1, y1: py1 + offset, x2: px2, y2: py2 + offset },\n  ];\n}\n\nexport default function App() {\n  const [puzzleIndex, setPuzzleIndex] = useState(0);\n  const puzzle = puzzles[puzzleIndex];\n  const islands = puzzle.islands;\n\n  const [bridges, setBridges] = useState(() => new Map());\n  const [selectedIslandId, setSelectedIslandId] = useState(null);\n  const [cursorIslandId, setCursorIslandId] = useState(() => islands[0]?.id ?? null);\n  const [error, setError] = useState(null);\n\n  const svgRef = useRef(null);\n\n  // Reset when puzzle changes\n  useEffect(() => {\n    setBridges(new Map());\n    setSelectedIslandId(null);\n    setError(null);\n    setCursorIslandId(puzzles[puzzleIndex].islands[0]?.id ?? null);\n  }, [puzzleIndex]);\n\n  const counts = useMemo(() => computeCurrentCounts(islands, bridges), [islands, bridges]);\n  const solved = useMemo(() => isVictory(islands, bridges), [islands, bridges]);\n\n  function clearErrorOnValid(valid) {\n    if (valid) setError(null);\n  }\n\n  function applyToggle(from, to) {\n    const key = canonicalBridgeKey(from, to);\n    const existing = bridges.get(key) ?? 0;\n    const next = existing === 0 ? 1 : existing === 1 ? 2 : 0;\n\n    if (next === 0) {\n      const nb = new Map(bridges);\n      nb.delete(key);\n      setBridges(nb);\n      setError(null);\n      return;\n    }\n\n    const delta = next - existing;\n    const check = canAddBridge(islands, bridges, from, to, delta);\n    if (!check.valid) {\n      setError(check.error);\n      return;\n    }\n\n    const nb = new Map(bridges);\n    nb.set(key, next);\n    setBridges(nb);\n    clearErrorOnValid(true);\n  }\n\n  function onIslandClick(isl, e) {\n    e.preventDefault();\n    setCursorIslandId(isl.id);\n\n    if (selectedIslandId == null) {\n      setSelectedIslandId(isl.id);\n      return;\n    }\n\n    if (selectedIslandId === isl.id) {\n      // Clicking same island keeps selection.\n      return;\n    }\n\n    const from = findIslandById(islands, selectedIslandId);\n    const to = isl;\n    applyToggle(from, to);\n    setSelectedIslandId(null);\n  }\n\n  function onBridgeClick(key, e) {\n    // Right click or Ctrl+click removes entirely\n    if (e.type === \'contextmenu\' || e.ctrlKey) {\n      e.preventDefault();\n      const nb = new Map(bridges);\n      nb.delete(key);\n      setBridges(nb);\n      setSelectedIslandId(null);\n      setError(null);\n    }\n  }\n\n  function reset() {\n    setBridges(new Map());\n    setSelectedIslandId(null);\n    setError(null);\n  }\n\n  useEffect(() => {\n    const el = svgRef.current;\n    if (el) el.focus();\n  }, []);\n\n  function onKeyDown(e) {\n    if (!cursorIslandId && islands.length) setCursorIslandId(islands[0].id);\n    const cur = findIslandById(islands, cursorIslandId);\n    if (!cur) return;\n\n    if (e.key === \'Escape\') {\n      setSelectedIslandId(null);\n      setError(null);\n      return;\n    }\n\n    const dirByKey = {\n      ArrowLeft: \'left\',\n      ArrowRight: \'right\',\n      ArrowUp: \'up\',\n      ArrowDown: \'down\',\n    };\n\n    if (dirByKey[e.key]) {\n      e.preventDefault();\n      const nb = getDirectionalNeighbor(islands, cur, dirByKey[e.key]);\n      if (nb) setCursorIslandId(nb.id);\n      return;\n    }\n\n    if (e.key === \'Enter\') {\n      e.preventDefault();\n      if (selectedIslandId == null) {\n        setSelectedIslandId(cur.id);\n        return;\n      }\n      if (selectedIslandId === cur.id) return;\n\n      const from = findIslandById(islands, selectedIslandId);\n      const to = cur;\n      applyToggle(from, to);\n      setSelectedIslandId(null);\n    }\n  }\n\n  const bridgeEntries = Array.from(bridges.entries()).filter(([, n]) => n > 0);\n\n  return (\n    <div style={{ position: \'absolute\', left: 0, top: 0 }}>\n      <div\n        style={{\n          padding: \'8px\',\n          display: \'flex\',\n          gap: \'12px\',\n          alignItems: \'center\',\n        }}\n      >\n        <label>\n          Puzzle:{\' \'}\n          <select\n            value={puzzleIndex}\n            onChange={(e) => setPuzzleIndex(Number(e.target.value))}\n          >\n            {puzzles.map((p, idx) => (\n              <option key={p.id} value={idx}>\n                {p.name}\n              </option>\n            ))}\n          </select>\n        </label>\n        <button onClick={reset}>Reset</button>\n        {error ? <div className="error-message">{error}</div> : null}\n        {solved ? <div className="victory-banner">SOLVED!</div> : null}\n      </div>\n\n      <svg\n        ref={svgRef}\n        tabIndex={0}\n        width={SVG_W}\n        height={SVG_H}\n        style={{ display: \'block\', outline: \'none\' }}\n        onKeyDown={onKeyDown}\n      >\n        {/* Bridges */}\n        {bridgeEntries.flatMap(([key, n]) => {\n          const lines = bridgeLinesForKey(key, n);\n          return lines.map((ln, idx) => (\n            <line\n              key={`${key}-${idx}`}\n              x1={ln.x1}\n              y1={ln.y1}\n              x2={ln.x2}\n              y2={ln.y2}\n              stroke="#0f0"\n              strokeWidth={3}\n              onClick={(e) => onBridgeClick(key, e)}\n              onContextMenu={(e) => onBridgeClick(key, e)}\n            />\n          ));\n        })}\n\n        {/* Cursor (must not be a circle) */}\n        {cursorIslandId != null ? (() => {\n          const isl = findIslandById(islands, cursorIslandId);\n          if (!isl) return null;\n          const px = isl.x * GRID;\n          const py = isl.y * GRID;\n          const size = 34;\n          const isSelected = selectedIslandId === isl.id;\n          return (\n            <rect\n              x={px - size / 2}\n              y={py - size / 2}\n              width={size}\n              height={size}\n              fill="none"\n              stroke={isSelected ? \'#fff\' : \'#0f0\'}\n              strokeWidth={2}\n              strokeDasharray={isSelected ? \'0\' : \'4 3\'}\n            />\n          );\n        })() : null}\n\n        {/* Islands */}\n        {islands.map((isl) => {\n          const px = isl.x * GRID;\n          const py = isl.y * GRID;\n          const current = counts.get(isl.id) ?? 0;\n          const over = current > isl.value;\n          return (\n            <g key={isl.id} onClick={(e) => onIslandClick(isl, e)} style={{ cursor: \'pointer\' }}>\n              <circle\n                cx={px}\n                cy={py}\n                r={16}\n                fill="black"\n                stroke={over ? \'red\' : \'#0f0\'}\n                strokeWidth={2}\n              />\n              <text\n                x={px}\n                y={py + 5}\n                textAnchor="middle"\n                fontFamily="monospace"\n                fontSize={16}\n                fill="#0f0"\n              >\n                {isl.value}\n              </text>\n            </g>\n          );\n        })}\n      </svg>\n    </div>\n  );\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
